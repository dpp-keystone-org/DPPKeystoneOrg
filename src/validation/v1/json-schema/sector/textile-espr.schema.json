{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dpp-keystone.org/spec/validation/v1/json-schema/sector/textile-espr.schema.json",
    "title": "DPP for Textiles (ESPR Update Draft)",
    "description": "A conditional schema that applies if the DPP is for the textile sector following the new ESPR specification.",
    "if": {
        "type": "object",
        "properties": {
            "contentSpecificationIds": {
                "type": "array",
                "contains": {
                    "const": "draft_textile_espr_specification_id"
                }
            }
        },
        "required": [
            "contentSpecificationIds"
        ]
    },
    "then": {
        "type": "object",
        "properties": {
            "components": {
                "type": "array",
                "items": {
                    "$ref": "../shared/component.schema.json"
                }
            },
            "substancesOfConcern": {
                "type": "array",
                "items": {
                    "$ref": "../shared/component.schema.json"
                }
            },
            "fibreComposition": {
                "type": "array",
                "items": {
                    "$ref": "../shared/component.schema.json"
                }
            },
            "organicMaterialComposition": {
                "type": "array",
                "items": {
                    "$ref": "../shared/component.schema.json"
                }
            },
            "recycledMaterialComposition": {
                "type": "array",
                "items": {
                    "$ref": "../shared/component.schema.json"
                }
            },
            "textileCertifications": {
                "type": "array",
                "items": {
                    "oneOf": [
                        {
                            "$ref": "../shared/certification.schema.json"
                        },
                        {
                            "$ref": "../shared/related-resource.schema.json"
                        }
                    ]
                }
            },
            "safeUseInstructions": {
                "type": "array",
                "items": {
                    "$ref": "../shared/related-resource.schema.json"
                }
            },
            "endOfLifeInstructions": {
                "type": "array",
                "items": {
                    "$ref": "../shared/related-resource.schema.json"
                }
            }
        },
        "required": []
    }
}
