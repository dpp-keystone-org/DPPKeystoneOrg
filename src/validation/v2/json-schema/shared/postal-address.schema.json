{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dpp-keystone.org/spec/validation/{{VERSION}}/json-schema/shared/postal-address.schema.json",
    "title": "Postal Address",
    "description": "The physical mailing address of an organization or location.",
    "type": "object",
    "properties": {
        "streetAddress": {
            "type": "string"
        },
        "postalCode": {
            "type": "string"
        },
        "addressLocality": {
            "type": "string"
        },
        "addressCountry": {
            "type": "string"
        }
    },
    "required": [
        "streetAddress",
        "postalCode",
        "addressLocality",
        "addressCountry"
    ]
}
