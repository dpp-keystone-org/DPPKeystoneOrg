{
    "@context": {
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "dppk": "https://dpp-keystone.org/spec/v1/terms#",
        "dcterms": "http://purl.org/dc/terms/",
        "schema": "http://schema.org/"
    },
    "@id": "https://dpp-keystone.org/spec/ontology/v1/core/Visibility",
    "@type": "owl:Ontology",
    "dcterms:title": "DPP Visibility Ontology",
    "dcterms:description": "Defines the allowable visibility tiers (enum) for data properties within a Digital Product Passport to dictate privacy serialization.",
    "rdfs:label": [
        {
            "@language": "en",
            "@value": "DPP Visibility Ontology"
        }
    ],
    "@graph": [
        {
            "@id": "dppk:VisibilityValue",
            "@type": "rdfs:Class",
            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "Visibility Value"
                }
            ],
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "An enumeration of the allowed visibility and access levels for specific DPP data."
                }
            ],
            "rdfs:subClassOf": {
                "@id": "rdfs:Resource"
            },
            "owl:oneOf": [
                {
                    "@id": "dppk:Public"
                },
                {
                    "@id": "dppk:LegitimateInterest"
                },
                {
                    "@id": "dppk:LegitimateInterestOrAuthority"
                },
                {
                    "@id": "dppk:AuthorityOnly"
                }
            ]
        },
        {
            "@id": "dppk:Public",
            "@type": "dppk:VisibilityValue",
            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "Public"
                }
            ],
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "Data is publicly accessible without restriction."
                }
            ]
        },
        {
            "@id": "dppk:LegitimateInterest",
            "@type": "dppk:VisibilityValue",
            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "Legitimate Interest"
                }
            ],
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "Data access is restricted or relies on proven legitimate interest."
                }
            ]
        },
        {
            "@id": "dppk:LegitimateInterestOrAuthority",
            "@type": "dppk:VisibilityValue",
            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "Legitimate Interest / Authority Only"
                }
            ],
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "Data access is tightly restricted to authorities or highly specialized legitimate interests."
                }
            ]
        },
        {
            "@id": "dppk:AuthorityOnly",
            "@type": "dppk:VisibilityValue",
            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "Authority"
                }
            ],
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "Data access is heavily restricted explicitly to authoritative bodies."
                }
            ]
        },
        {
            "@id": "dppk:visibility",
            "@type": "owl:AnnotationProperty",
            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "Visibility"
                }
            ],
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "Indicates the explicit visibility class of a given property."
                }
            ],
            "rdfs:range": {
                "@id": "dppk:VisibilityValue"
            }
        }
    ]
}