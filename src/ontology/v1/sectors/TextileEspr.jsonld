{
    "@context": {
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "schema": "https://schema.org/",
        "gs1": "https://ref.gs1.org/voc/",
        "dppk": "https://dpp-keystone.org/spec/v1/terms#",
        "dcterms": "http://purl.org/dc/terms/",
        "@base": "https://dpp-keystone.org/spec/v1/terms"
    },
    "@id": "https://dpp-keystone.org/spec/ontology/v1/sectors/TextileEspr",
    "@type": "owl:Ontology",
    "dcterms:title": { "@language": "en", "@value": "DPP Sector Ontology - Textile ESPR Draft (v2 Overlay)" },
    "dcterms:description": { "@language": "en", "@value": "Defines draft sector-specific concepts required for the upcoming ESPR Delegated Act for Textiles. Acts as a V2 overlay on the base Textile ontology." },
    "owl:versionInfo": "Draft",
    "owl:imports": [
        { "@id": "https://dpp-keystone.org/spec/ontology/v1/sectors/Textile.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/v1/core/Compliance.jsonld" }
    ],
    "@graph": [
        {
            "@id": "dppk:pefcrCategory",
            "@type": "owl:ObjectProperty",
            "rdfs:label": { "@language": "en", "@value": "PEFCR Category" },
            "rdfs:comment": { "@language": "en", "@value": "The Product Environmental Footprint Category Rules (PEFCR) category to which the product belongs." },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "dppk:PefcrCategoryValue" }
        },
        {
            "@id": "dppk:PefcrCategoryValue",
            "@type": "rdfs:Class",
            "rdfs:label": { "@language": "en", "@value": "PEFCR Category Value" },
            "rdfs:comment": { "@language": "en", "@value": "An enumeration of the allowed PEFCR categories for apparel and footwear." },
            "rdfs:subClassOf": { "@id": "rdfs:Resource" },
            "owl:oneOf": [
                { "@id": "dppk:PefcrTShirts" },
                { "@id": "dppk:PefcrShirtsAndBlouses" },
                { "@id": "dppk:PefcrSweatersAndMidlayers" },
                { "@id": "dppk:PefcrJacketsAndCoats" },
                { "@id": "dppk:PefcrPantsAndShorts" },
                { "@id": "dppk:PefcrDressesSkirtsAndJumpsuits" },
                { "@id": "dppk:PefcrLeggingsStockingsTightsAndSocks" },
                { "@id": "dppk:PefcrUnderwear" },
                { "@id": "dppk:PefcrSwimwear" },
                { "@id": "dppk:PefcrApparelAccessories" },
                { "@id": "dppk:PefcrOpenToedShoes" },
                { "@id": "dppk:PefcrClosedToedShoes" },
                { "@id": "dppk:PefcrBoots" }
            ]
        },
        {
            "@id": "dppk:PefcrTShirts",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "T-shirts" }
        },
        {
            "@id": "dppk:PefcrShirtsAndBlouses",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Shirts and blouses" }
        },
        {
            "@id": "dppk:PefcrSweatersAndMidlayers",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Sweaters and midlayers" }
        },
        {
            "@id": "dppk:PefcrJacketsAndCoats",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Jackets and coats" }
        },
        {
            "@id": "dppk:PefcrPantsAndShorts",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Pants and shorts" }
        },
        {
            "@id": "dppk:PefcrDressesSkirtsAndJumpsuits",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Dresses, skirts and jumpsuits" }
        },
        {
            "@id": "dppk:PefcrLeggingsStockingsTightsAndSocks",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Leggings, stockings, tights and socks" }
        },
        {
            "@id": "dppk:PefcrUnderwear",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Underwear" }
        },
        {
            "@id": "dppk:PefcrSwimwear",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Swimwear" }
        },
        {
            "@id": "dppk:PefcrApparelAccessories",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Apparel Accessories" }
        },
        {
            "@id": "dppk:PefcrOpenToedShoes",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Open-toed shoes" }
        },
        {
            "@id": "dppk:PefcrClosedToedShoes",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Closed-toed shoes" }
        },
        {
            "@id": "dppk:PefcrBoots",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": { "@language": "en", "@value": "Boots" }
        },
        {
            "@id": "dppk:textileCertifications",
            "@type": "owl:ObjectProperty",
            "rdfs:label": { "@language": "en", "@value": "Textile ESPR Conformity Certifications" },
            "rdfs:comment": { "@language": "en", "@value": "Certifications specifically verifying ESPR textile claims (e.g. recycled content, recyclability, mechanical properties)." },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "dppk:Certification" },
            "rdfs:subPropertyOf": { "@id": "schema:hasCertification" }
        },
        {
            "@id": "dppk:carbonFootprint",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Carbon Footprint" },
            "rdfs:comment": { "@language": "en", "@value": "The carbon footprint of the product." },
            "dppk:unit": "kg CO2 eq",
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
        {
            "@id": "dppk:carbonFootprintBenchmarkPercentage",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Carbon Footprint Benchmark Percentage" },
            "rdfs:comment": { "@language": "en", "@value": "The product's carbon footprint performance compared to the established benchmark, expressed as a percentage." },
            "dppk:unit": "%",
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
        {
            "@id": "dppk:robustnessScore",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Robustness Score" },
            "rdfs:comment": { "@language": "en", "@value": "A numeric score representing the product's robustness (typically 0-10 scale)." },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
        {
            "@id": "dppk:recyclabilityScore",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Recyclability Score" },
            "rdfs:comment": { "@language": "en", "@value": "A numeric score representing the product's recyclability (typically 0-10 scale)." },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
        {
            "@id": "dppk:spirality",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Spirality" },
            "rdfs:comment": { "@language": "en", "@value": "The measured spirality of the textile product." },
            "dppk:unit": "%",
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
        {
            "@id": "dppk:dimensionalChange",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Dimensional Change" },
            "rdfs:comment": { "@language": "en", "@value": "The dimensional change (shrinkage or expansion) after testing." },
            "dppk:unit": "%",
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
        {
            "@id": "dppk:visualInspection",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Visual Inspection Result" },
            "rdfs:comment": { "@language": "en", "@value": "The result of the visual inspection (e.g. Pass/Fail or notes)." },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "dppk:apparelSize",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": "Apparel Size",
            "rdfs:comment": "The size of the textile product (e.g., 'M', 'L', '42').",
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:string" },
            "owl:equivalentProperty": { "@id": "gs1:sizeCode" },
            "skos:closeMatch": { "@id": "schema:size" }
        },
        {
            "@id": "dppk:animalOriginNonTextile",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": { "@language": "en", "@value": "Contains Non-Textile Parts of Animal Origin" },
            "rdfs:comment": { "@language": "en", "@value": "Indicates whether the product contains non-textile parts of animal origin, as required by the EU Textile Labelling Regulation." },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:boolean" }
        }
    ]
}
