{
    "@context": {
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "dppk": "https://dpp-keystone.org/spec/v1/terms#",
        "dcterms": "http://purl.org/dc/terms/",
        "schema": "http://schema.org/"
    },
    "@id": "https://dpp-keystone.org/spec/ontology/v1/sectors/IronSteel",
    "@type": "owl:Ontology",
    "dcterms:title": "DPP Iron & Steel Sector Ontology",
    "dcterms:description": "Defines the specific data model for the Iron and Steel Passport, covering ESPR and MTC attributes.",
    "rdfs:label": [
        { "@language": "en", "@value": "DPP Iron & Steel Sector Ontology" }
    ],
    "rdfs:comment": [
        { "@language": "en", "@value": "Defines the specific data model for the Iron and Steel Passport, covering ESPR and Mill Test Certificate (MTC) attributes." }
    ],
    "owl:imports": [
        { "@id": "https://dpp-keystone.org/spec/ontology/v1/core/Product.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/v1/core/EPD.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/v1/core/DoPC.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/v1/core/Visibility.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/v1/core/MTC.jsonld" }
    ],
    "@graph": [
        {
            "@id": "dppk:IronSteelProduct",
            "@type": "rdfs:Class",
            "rdfs:subClassOf": { "@id": "dppk:Product" },
            "rdfs:label": [
                { "@language": "en", "@value": "Iron and Steel Product" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Data model for the Iron and Steel Passport according to EU ESPR." }
            ],
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:heatNumber",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Heat Number" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The heat number for iron and steel to serve as a lot-level identifier." }
            ],
            "dppk:governedBy": "EN 10168",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "owl:equivalentProperty": [
                { "@id": "gs1:batchLot" },
                { "@id": "schema:sku" }
            ],
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:productNumber",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Product Number" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "An internal identifier at the article level." }
            ],
            "dppk:governedBy": "EN 10168",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "owl:equivalentProperty": [
                { "@id": "schema:productID" },
                { "@id": "schema:model" },
                { "@id": "gs1:globalModelNumber" }
            ],
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:manufacturingDate",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Manufacturing Date" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The date on which the product was manufactured." }
            ],
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:date",
            "dppk:visibility": { "@id": "dppk:Public" },
            "owl:equivalentProperty": { "@id": "schema:productionDate" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:castNumber",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Cast Number" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Optional batch-level identifier representing the specific cast." }
            ],
            "dppk:governedBy": "EN 10168",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "owl:equivalentProperty": { "@id": "gs1:batchLot" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:lotNumber",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Lot Number" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Optional batch-level identifier representing the specific manufacturing lot." }
            ],
            "dppk:governedBy": "EN 10168",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "owl:equivalentProperty": { "@id": "gs1:batchLot" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:purchaserOrder",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Purchaser Order" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Associated purchase order identifier." }
            ],
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:LegitimateInterest" },
            "owl:equivalentProperty": { "@id": "schema:orderNumber" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:steelGradeClassification",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Steel Grade Classification" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The classification of the steel grade." }
            ],
            "dppk:governedBy": "EN 10020",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:steelDesignation",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Steel Designation" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The specific designation or name of the steel." }
            ],
            "dppk:governedBy": "EN 10027",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:technologyRoute",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Technology Route" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The primary manufacturing route (e.g. EAF, BF-BOF)." }
            ],
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:meltAndPourCountry",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Melt and Pour Country" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The country where the steel was originally melted and poured." }
            ],
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "owl:equivalentProperty": { "@id": "schema:countryOfOrigin" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:recycledContentPercentage",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Recycled Content Percentage" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Total recycled content percentage in the steel." }
            ],
            "dppk:unit": "%",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:double",
            "dppk:visibility": { "@id": "dppk:Public" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:preConsumerRecycledContent",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Pre-Consumer Recycled Content" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Percentage of pre-consumer recycled material." }
            ],
            "dppk:unit": "%",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:double",
            "dppk:visibility": { "@id": "dppk:LegitimateInterest" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:postConsumerRecycledContent",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Post-Consumer Recycled Content" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Percentage of post-consumer recycled material." }
            ],
            "dppk:unit": "%",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:double",
            "dppk:visibility": { "@id": "dppk:LegitimateInterest" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:recycledContentConformity",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Recycled Content Conformity" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Reference or URI to the conformity declaration of the recycled content calculation." }
            ],
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "dppk:visibility": { "@id": "dppk:AuthorityOnly" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:cbamReportId",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "CBAM Report ID" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Identifier for the Carbon Border Adjustment Mechanism (CBAM) report." }
            ],
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:LegitimateInterest" },
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:reachDocumentation",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "REACH Documentation" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "URI link to the REACH regulatory documentation if applicable." }
            ],
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": { "@id": "dppk:RelatedResource" },
            "dppk:visibility": { "@id": "dppk:LegitimateInterest" },
            "rdfs:term_status": "unstable"
        }
    ]
}