  "dcterms:title": [
    { "@language": "en", "@value": "DPP Core Ontology - EPD Indicators" },
    { "@language": "bg", "@value": "Основна онтология на DPP - Показатели за EPD" },
    { "@language": "cs", "@value": "Základní ontologie DPP - Indikátory EPD" },
    { "@language": "da", "@value": "DPP-kerneontologi - EPD-indikatorer" },
