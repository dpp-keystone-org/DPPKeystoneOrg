    { "@language": "el", "@value": "Βασική Οντολογία DPP - Δείκτες EPD" },
    { "@language": "es", "@value": "Ontología principal de DPP - Indicadores de EPD" },
    { "@language": "et", "@value": "DPP põhi-ontoloogia - EPD indikaatorid" },
    { "@language": "fi", "@value": "DPP-ydinontologia - EPD-indikaattorit" },
    { "@language": "fr", "@value": "Ontologie de base DPP - Indicateurs EPD" },
    { "@language": "ga", "@value": "Croí-Ointeolaíocht DPP - Táscairí EPD" },
    { "@language": "hr", "@value": "Osnovna ontologija DPP-a - EPD pokazatelji" },
    { "@language": "hu", "@value": "DPP alapontológia - EPD mutatók" },
    { "@language": "it", "@value": "Ontologia di base DPP - Indicatori EPD" },
    { "@language": "lt", "@value": "DPP pagrindinė ontologija - EPD rodikliai" },
    { "@language": "lv", "@value": "DPP pamatontoloģija - EPD rādītāji" },
    { "@language": "mt", "@value": "Ontoloġija Ewlenija tad-DPP - Indikaturi EPD" },
    { "@language": "nl", "@value": "DPP-kernontologie - EPD-indicatoren" },
    { "@language": "pl", "@value": "Podstawowa ontologia DPP - Wskaźniki EPD" },
    { "@language": "pt", "@value": "Ontologia principal do DPP - Indicadores de EPD" },
    { "@language": "ro", "@value": "Ontologia de bază DPP - Indicatori EPD" },
    { "@language": "sk", "@value": "Základná ontológia DPP - Indikátory EPD" },
    { "@language": "sl", "@value": "Osnovna ontologija DPP - Kazalniki EPD" },
    { "@language": "sv", "@value": "DPP-kärnontologi - EPD-indikatorer" }
  ],
  "dcterms:description": [
    { "@language": "en", "@value": "Defines the specific environmental impact indicators used in Environmental Product Declarations." },
    { "@language": "bg", "@value": "Дефинира специфичните показатели за въздействие върху околната среда, използвани в Екологичните продуктови декларации." },
    { "@language": "cs", "@value": "Definuje specifické indikátory dopadu na životní prostředí používané v Environmentálních prohlášeních o produktu." },
    { "@language": "da", "@value": "Definerer de specifikke miljøpåvirkningsindikatorer, der anvendes i miljøvaredeklarationer." },
    { "@language": "de", "@value": "Definiert die spezifischen Umweltwirkungsindikatoren, die in Umweltproduktdeklarationen verwendet werden." },
    { "@language": "el", "@value": "Ορίζει τους ειδικούς δείκτες περιβαλλοντικών επιπτώσεων που χρησιμοποιούνται στις Περιβαλλοντικές Δηλώσεις Προϊόντων." },
    { "@language": "es", "@value": "Define los indicadores específicos de impacto ambiental utilizados en las Declaraciones Ambientales de Producto." },
    { "@language": "et", "@value": "Määratleb konkreetsed keskkonnamõju indikaatorid, mida kasutatakse keskkonnadeklaratsioonides." },
    { "@language": "fi", "@value": "Määrittää erityiset ympäristövaikutusindikaattorit, joita käytetään ympäristöselosteissa." },
    { "@language": "fr", "@value": "Définit les indicateurs spécifiques d'impact environnemental utilisés dans les déclarations environnementales de produit." },
    { "@language": "ga", "@value": "Sainmhíníonn sé na táscairí sainráite don tionchar ar an gcomhshaol a úsáidtear i nDearbhuithe Comhshaoil Táirge." },
    { "@language": "hr", "@value": "Definira specifične pokazatelje utjecaja na okoliš koji se koriste u Izjavama o ekološkim svojstvima proizvoda." },
    { "@language": "hu", "@value": "Meghatározza a környezetvédelmi terméknyilatkozatokban használt konkrét környezeti hatásmutatókat." },
    { "@language": "it", "@value": "Definisce gli specifici indicatori di impatto ambientale utilizzati nelle Dichiarazioni ambientali di prodotto." },
    { "@language": "lt", "@value": "Apibrėžia specifinius poveikio aplinkai rodiklius, naudojamus poveikio aplinkai deklaracijose." },
    { "@language": "lv", "@value": "Definē konkrētus ietekmes uz vidi rādītājus, ko izmanto produkta vides deklarācijās." },
    { "@language": "mt", "@value": "Jiddefinixxi l-indikaturi speċifiċi tal-impatt ambjentali użati fid-Dikjarazzjonijiet Ambjentali tal-Prodott." },
    { "@language": "nl", "@value": "Definieert de specifieke milieueffectindicatoren die worden gebruikt in milieuproductverklaringen." },
    { "@language": "pl", "@value": "Definiuje specyficzne wskaźniki wpływu na środowisko stosowane w deklaracjach środowiskowych produktu." },
    { "@language": "pt", "@value": "Define os indicadores específicos de impacto ambiental utilizados nas Declarações Ambientais do Produto." },
    { "@language": "ro", "@value": "Definește indicatorii specifici de impact asupra mediului utilizați în Declarațiile de mediu ale produsului." },
    { "@language": "sk", "@value": "Definuje špecifické indikátory vplyvu na životné prostredie používané v environmentálnych vyhláseniach o produkte." },
    { "@language": "sl", "@value": "Določa posebne kazalnike vpliva na okolje, ki se uporabljajo v okoljskih deklaracijah proizvoda." },
    { "@language": "sv", "@value": "Definierar de specifika miljöpåverkansindikatorer som används i miljövarudeklarationer." }
  ],
