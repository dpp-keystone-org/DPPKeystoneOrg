      "rdfs:comment": [
        { "@language": "en", "@value": "A generic property representing an environmental impact indicator." },
        { "@language": "bg", "@value": "Общо свойство, представляващо показател за въздействие върху околната среда." },
        { "@language": "cs", "@value": "Obecná vlastnost představující ukazatel dopadu na životní prostředí." },
        { "@language": "da", "@value": "En generisk egenskab, der repræsenterer en miljøpåvirkningsindikator." },
        { "@language": "de", "@value": "Eine generische Eigenschaft, die einen Umweltwirkungsindikator darstellt." },
        { "@language": "el", "@value": "Μια γενική ιδιότητα που αντιπροσωπεύει έναν δείκτη περιβαλλοντικών επιπτώσεων." },
        { "@language": "es", "@value": "Una propiedad genérica que representa un indicador de impacto ambiental." },
        { "@language": "et", "@value": "Üldine omadus, mis esindab keskkonnamõju indikaatorit." },
        { "@language": "fi", "@value": "Yleinen ominaisuus, joka edustaa ympäristövaikutusindikaattoria." },
        { "@language": "fr", "@value": "Une propriété générique représentant un indicateur d'impact environnemental." },
        { "@language": "ga", "@value": "Airí ginearálta a léiríonn táscaire tionchair comhshaoil." },
        { "@language": "hr", "@value": "Generičko svojstvo koje predstavlja pokazatelj utjecaja na okoliš." },
        { "@language": "hu", "@value": "Egy általános tulajdonság, amely egy környezeti hatásmutatót képvisel." },
        { "@language": "it", "@value": "Una proprietà generica che rappresenta un indicatore di impatto ambientale." },
        { "@language": "lt", "@value": "Bendroji savybė, reiškianti poveikio aplinkai rodiklį." },
        { "@language": "lv", "@value": "Vispārīga īpašība, kas atspoguļo ietekmes uz vidi rādītāju." },
        { "@language": "mt", "@value": "Proprjetà ġenerika li tirrappreżenta indikatur tal-impatt ambjentali." },
        { "@language": "nl", "@value": "Een generieke eigenschap die een milieueffectindicator vertegenwoordigt." },
        { "@language": "pl", "@value": "Właściwość ogólna reprezentująca wskaźnik wpływu na środowisko." },
        { "@language": "pt", "@value": "Uma propriedade genérica que representa um indicador de impacto ambiental." },
        { "@language": "ro", "@value": "O proprietate generică reprezentând un indicator de impact asupra mediului." },
        { "@language": "sk", "@value": "Všeobecná vlastnosť predstavujúca ukazovateľ vplyvu na životné prostredie." },
        { "@language": "sl", "@value": "Splošna lastnost, ki predstavlja kazalnik vpliva na okolje." },
        { "@language": "sv", "@value": "En generisk egenskap som representerar en miljöpåverkansindikator." }
      ],
      "rdfs:domain": { "@id": "dppk:EPDBlock" }
    },
