    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Organization.jsonld",
  "@type": "owl:Ontology",
  "dcterms:title": [
    { "@language": "en", "@value": "DPP Core Ontology - Organization and Roles Definitions ({{VERSION}})" },
    { "@language": "bg", "@value": "Основна онтология на DPP - Определения на организации и роли ({{VERSION}})" },
    { "@language": "cs", "@value": "Základní ontologie DPP - Definice organizací a rolí ({{VERSION}})" },
    { "@language": "da", "@value": "DPP Kerneontologi - Organisation og rolledefinitioner ({{VERSION}})" },
    { "@language": "de", "@value": "DPP-Kernontologie - Definitionen von Organisationen und Rollen ({{VERSION}})" },
    { "@language": "el", "@value": "Βασική οντολογία DPP - Ορισμοί οργανισμών και ρόλων ({{VERSION}})" },
    { "@language": "es", "@value": "Ontología central de DPP - Definiciones de organización y roles ({{VERSION}})" },
    { "@language": "et", "@value": "DPP tuumontoloogia - Organisatsiooni ja rollide definitsioonid ({{VERSION}})" },
    { "@language": "fi", "@value": "DPP-ydinontologia - Organisaation ja roolien määritykset ({{VERSION}})" },
    { "@language": "fr", "@value": "Ontologie de base DPP - Définitions d'organisation et de rôles ({{VERSION}})" },
    { "@language": "ga", "@value": "Príomhointeolaíocht DPP - Sainmhínithe Eagraíochta agus Rólanna ({{VERSION}})" },
    { "@language": "hr", "@value": "Osnovna ontologija DPP - Definicije organizacija i uloga ({{VERSION}})" },
    { "@language": "hu", "@value": "DPP alapontológia - Szervezet és szerepkörök definíciói ({{VERSION}})" },
    { "@language": "it", "@value": "Ontologia di base DPP - Definizioni di organizzazione e ruoli ({{VERSION}})" },
    { "@language": "lt", "@value": "DPP pagrindinė ontologija - Organizacijų ir vaidmenų apibrėžimai ({{VERSION}})" },
    { "@language": "lv", "@value": "DPP pamata ontoloģija - Organizācijas un lomu definīcijas ({{VERSION}})" },
    { "@language": "mt", "@value": "Ontoloġija Ewlenija ta' DPP - Definizzjonijiet ta' Organizzazzjoni u Rwoli ({{VERSION}})" },
    { "@language": "nl", "@value": "DPP Kernontologie - Definities van organisatie en rollen ({{VERSION}})" },
    { "@language": "pl", "@value": "Główna ontologia DPP - Definicje organizacji i ról ({{VERSION}})" },
    { "@language": "pt", "@value": "Ontologia Central do DPP - Definições de Organização e Papéis ({{VERSION}})" },
    { "@language": "ro", "@value": "Ontologia de bază DPP - Definiții pentru organizații și roluri ({{VERSION}})" },
    { "@language": "sk", "@value": "Základná ontológia DPP - Definície organizácií a úloh ({{VERSION}})" },
    { "@language": "sl", "@value": "Osnovna ontologija DPP - Definicije organizacij in vlog ({{VERSION}})" },
    { "@language": "sv", "@value": "DPP-kärnontologi - Organisation och rolldefinitioner ({{VERSION}})" }
  ],
  "dcterms:description": [
    { "@language": "en", "@value": "Defines concepts related to organizations, roles (Economic Operator, Manufacturer, Facility), identifiers, and contact information within the DPP ecosystem." },
    { "@language": "bg", "@value": "Определя понятия, свързани с организации, роли (Икономически оператор, Производител, Съоръжение), идентификатори и информация за контакт в екосистемата на DPP." },
    { "@language": "cs", "@value": "Definuje pojmy související s organizacemi, rolemi (Hospodářský subjekt, Výrobce, Zařízení), identifikátory a kontaktními informacemi v rámci ekosystému DPP." },
    { "@language": "da", "@value": "Definerer begreber relateret til organisationer, roller (Økonomisk operatør, Producent, Facilitet), identifikatorer og kontaktoplysninger inden for DPP-økosystemet." },
    { "@language": "de", "@value": "Definiert Konzepte in Bezug auf Organisationen, Rollen (Wirtschaftsakteur, Hersteller, Einrichtung), Kennungen und Kontaktinformationen innerhalb des DPP-Ökosystems." },
    { "@language": "el", "@value": "Καθορίζει έννοιες που σχετίζονται με οργανισμούς, ρόλους (Οικονομικός φορέας, Κατασκευαστής, Εγκατάσταση), αναγνωριστικά και στοιχεία επικοινωνίας στο οικοσύστημα DPP." },
    { "@language": "es", "@value": "Define conceptos relacionados con organizaciones, roles (Operador Económico, Fabricante, Instalación), identificadores e información de contacto dentro del ecosistema DPP." },
    { "@language": "et", "@value": "Määratleb mõisted, mis on seotud organisatsioonide, rollide (Majandustegevuses osaleja, Tootja, Rajatis), identifikaatorite ja kontaktteabega DPP ökosüsteemis." },
    { "@language": "fi", "@value": "Määrittää organisaatioihin, rooleihin (Talouden toimija, Valmistaja, Laitos), tunnisteisiin ja yhteystietoihin liittyviä käsitteitä DPP-ekosysteemissä." },
    { "@language": "fr", "@value": "Définit les concepts liés aux organisations, aux rôles (Opérateur économique, Fabricant, Installation), aux identifiants et aux coordonnées dans l'écosystème DPP." },
    { "@language": "ga", "@value": "Sainmhíníonn sé coincheapa a bhaineann le heagraíochtaí, rólanna (Oibreoir Eacnamaíoch, Déantúsóir, Saoráid), aitheantóirí, agus faisnéis teagmhála laistigh d'éiceachóras DPP." },
    { "@language": "hr", "@value": "Definira koncepte povezane s organizacijama, ulogama (Gospodarski subjekt, Proizvođač, Postrojenje), identifikatorima i podacima za kontakt unutar DPP ekosustava." },
    { "@language": "hu", "@value": "Meghatározza a szervezetekhez, szerepkörökhöz (Gazdasági szereplő, Gyártó, Létesítmény), azonosítókhoz és kapcsolattartási adatokhoz kapcsolódó fogalmakat a DPP ökoszisztémában." },
    { "@language": "it", "@value": "Definisce concetti relativi a organizzazioni, ruoli (Operatore economico, Fabbricante, Impianto), identificatori e informazioni di contatto all'interno dell'ecosistema DPP." },
    { "@language": "lt", "@value": "Apibrėžia sąvokas, susijusias su organizacijomis, vaidmenimis (Ekonominės veiklos vykdytojas, Gamintojas, Objektas), identifikatoriais ir kontaktine informacija DPP ekosistemoje." },
    { "@language": "lv", "@value": "Nosaka jēdzienus, kas saistīti ar organizācijām, lomām (Ekonomikas dalībnieks, Ražotājs, Iekārta), identifikatoriem un kontaktinformāciju DPP ekosistēmā." },
    { "@language": "mt", "@value": "Jiddefinixxi kunċetti relatati ma' organizzazzjonijiet, rwoli (Operatur Ekonomiku, Manifattur, Faċilità), identifikaturi, u informazzjoni ta' kuntatt fl-ekosistema ta' DPP." },
    { "@language": "nl", "@value": "Definieert concepten met betrekking tot organisaties, rollen (Marktdeelnemer, Fabrikant, Faciliteit), identificaties en contactgegevens binnen het DPP-ecosysteem." },
    { "@language": "pl", "@value": "Określa pojęcia związane z organizacjami, rolami (Podmiot gospodarczy, Producent, Obiekt), identyfikatorami i danymi kontaktowymi w ekosystemie DPP." },
    { "@language": "pt", "@value": "Define conceitos relacionados com organizações, papéis (Operador Económico, Fabricante, Instalação), identificadores e informações de contacto dentro do ecossistema DPP." },
    { "@language": "ro", "@value": "Definește concepte referitoare la organizații, roluri (Operator economic, Producător, Instalație), identificatori și informații de contact în cadrul ecosistemului DPP." },
    { "@language": "sk", "@value": "Definuje pojmy súvisiace s organizáciami, úlohami (Hospodársky subjekt, Výrobca, Zariadenie), identifikátormi a kontaktnými informáciami v rámci ekosystému DPP." },
    { "@language": "sl", "@value": "Določa koncepte, povezane z organizacijami, vlogami (Gospodarski subjekt, Proizvajalec, Obrat), identifikatorji in kontaktnimi podatki v ekosistemu DPP." },
    { "@language": "sv", "@value": "Definierar begrepp relaterade till organisationer, roller (Ekonomisk aktör, Tillverkare, Anläggning), identifierare och kontaktinformation inom DPP-ekosystemet." }
  ],
  "owl:versionInfo": "{{VERSION}}",
  // Import the Header ontology as it defines the DPP class used in the domain of properties here.
  "owl:imports": { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Header.jsonld" },

  "@graph": [
    // ==================================================================
    // Classes
    // ==================================================================
    {
      "@id": "dppk:Organization",
      "@type": "rdfs:Class",
      "rdfs:label": [
        { "@language": "en", "@value": "Organization" },
        { "@language": "bg", "@value": "Организация" },
        { "@language": "cs", "@value": "Organizace" },
        { "@language": "da", "@value": "Organisation" },
        { "@language": "de", "@value": "Organisation" },
        { "@language": "el", "@value": "Οργανισμός" },
        { "@language": "es", "@value": "Organización" },
        { "@language": "et", "@value": "Organisatsioon" },
        { "@language": "fi", "@value": "Organisaatio" },
        { "@language": "fr", "@value": "Organisation" },
        { "@language": "ga", "@value": "Eagraíocht" },
        { "@language": "hr", "@value": "Organizacija" },
        { "@language": "hu", "@value": "Szervezet" },
        { "@language": "it", "@value": "Organizzazione" },
        { "@language": "lt", "@value": "Organizacija" },
        { "@language": "lv", "@value": "Organizācija" },
        { "@language": "mt", "@value": "Organizzazzjoni" },
        { "@language": "nl", "@value": "Organisatie" },
        { "@language": "pl", "@value": "Organizacja" },
        { "@language": "pt", "@value": "Organização" },
        { "@language": "ro", "@value": "Organizație" },
        { "@language": "sk", "@value": "Organizácia" },
        { "@language": "sl", "@value": "Organizacija" },
        { "@language": "sv", "@value": "Organisation" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "A general concept for any organization or legal entity involved in the product lifecycle." },
        { "@language": "bg", "@value": "Общо понятие за всяка организация или юридическо лице, участващо в жизнения цикъл на продукта." },
        { "@language": "cs", "@value": "Obecný koncept pro jakoukoli organizaci nebo právnickou osobu zapojenou do životního cyklu produktu." },
        { "@language": "da", "@value": "Et generelt begreb for enhver organisation eller juridisk enhed involveret i produktets livscyklus." },
        { "@language": "de", "@value": "Ein allgemeines Konzept für jede Organisation oder juristische Person, die am Produktlebenszyklus beteiligt ist." },
        { "@language": "el", "@value": "Μια γενική έννοια για κάθε οργανισμό ή νομικό πρόσωπο που συμμετέχει στον κύκλο ζωής του προϊόντος." },
        { "@language": "es", "@value": "Un concepto general para cualquier organización o entidad legal involucrada en el ciclo de vida del producto." },
        { "@language": "et", "@value": "Üldine mõiste mis tahes toote olelusringis osaleva organisatsiooni või juriidilise isiku kohta." },
        { "@language": "fi", "@value": "Yleinen käsite mille tahansa organisaatiolle tai oikeushenkilölle, joka on mukana tuotteen elinkaaressa." },
        { "@language": "fr", "@value": "Un concept général pour toute organisation ou entité légale impliquée dans le cycle de vie du produit." },
        { "@language": "ga", "@value": "Coincheap ginearálta d’aon eagraíocht nó d’aon eintiteas dlíthiúil a bhfuil baint acu le saolré an táirge." },
        { "@language": "hr", "@value": "Opći koncept za svaku organizaciju ili pravnu osobu uključenu u životni ciklus proizvoda." },
        { "@language": "hu", "@value": "Általános fogalom a termék életciklusában részt vevő bármely szervezetre vagy jogi személyre." },
        { "@language": "it", "@value": "Un concetto generale per qualsiasi organizzazione o entità legale coinvolta nel ciclo di vita del prodotto." },
        { "@language": "lt", "@value": "Bendra sąvoka, apibūdinanti bet kurią organizaciją ar juridinį asmenį, dalyvaujantį produkto gyvavimo cikle." },
        { "@language": "lv", "@value": "Vispārīgs jēdziens jebkurai organizācijai vai juridiskai personai, kas iesaistīta produkta aprites ciklā." },
        { "@language": "mt", "@value": "Kunċett ġenerali għal kwalunkwe organizzazzjoni jew entità legali involuta fiċ-ċiklu tal-ħajja tal-prodott." },
        { "@language": "nl", "@value": "Een algemeen concept voor elke organisatie of juridische entiteit die betrokken is bij de levenscyclus van een product." },
        { "@language": "pl", "@value": "Ogólne pojęcie określające dowolną organizację lub osobę prawną zaangażowaną w cykl życia produktu." },
        { "@language": "pt", "@value": "Um conceito geral para qualquer organização ou entidade legal envolvida no ciclo de vida do produto." },
        { "@language": "ro", "@value": "Un concept general pentru orice organizație sau entitate legală implicată în ciclul de viață al produsului." },
        { "@language": "sk", "@value": "Všeobecný pojem pre akúkoľvek organizáciu alebo právnickú osobu zapojenú do životného cyklu produktu." },
        { "@language": "sl", "@value": "Splošen koncept za katero koli organizacijo ali pravno osebo, vključeno v življenjski cikel izdelka." },
        { "@language": "sv", "@value": "Ett allmänt begrepp för alla organisationer eller juridiska personer som är involverade i produktens livscykel." }
      ],
      "skos:exactMatch": [
        {
          "@id": "schema:Organization"
        },
        {
          "@id": "gs1:Organization"
        },
        {
          "@id": "unece:TradeParty"
        }
      ]
    },
    {
      "@id": "dppk:PostalAddress",
      "@type": "rdfs:Class",
      "rdfs:label": [
        { "@language": "en", "@value": "Postal Address" },
