        { "@language": "cs", "@value": "Poštovní adresa" },
        { "@language": "da", "@value": "Postadresse" },
        { "@language": "de", "@value": "Postanschrift" },
        { "@language": "el", "@value": "Ταχυδρομική Διεύθυνση" },
        { "@language": "es", "@value": "Dirección postal" },
        { "@language": "et", "@value": "Postiaadress" },
        { "@language": "fi", "@value": "Postiosoite" },
        { "@language": "fr", "@value": "Adresse postale" },
        { "@language": "ga", "@value": "Seoladh Poist" },
        { "@language": "hr", "@value": "Poštanska adresa" },
        { "@language": "hu", "@value": "Postacím" },
        { "@language": "it", "@value": "Indirizzo postale" },
        { "@language": "lt", "@value": "Pašto adresas" },
        { "@language": "lv", "@value": "Pasta adrese" },
        { "@language": "mt", "@value": "Indirizz Postali" },
        { "@language": "nl", "@value": "Postadres" },
        { "@language": "pl", "@value": "Adres pocztowy" },
        { "@language": "pt", "@value": "Endereço postal" },
        { "@language": "ro", "@value": "Adresă poștală" },
        { "@language": "sk", "@value": "Poštová adresa" },
        { "@language": "sl", "@value": "Poštni naslov" },
        { "@language": "sv", "@value": "Postadress" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "The physical mailing address of an organization or location." },
        { "@language": "bg", "@value": "Физическият пощенски адрес на организация или местоположение." },
        { "@language": "cs", "@value": "Fyzická poštovní adresa organizace nebo místa." },
        { "@language": "da", "@value": "Den fysiske postadresse for en organisation eller placering." },
        { "@language": "de", "@value": "Die physische Postanschrift einer Organisation oder eines Standorts." },
        { "@language": "el", "@value": "Η φυσική ταχυδρομική διεύθυνση ενός οργανισμού ή τοποθεσίας." },
        { "@language": "es", "@value": "La dirección postal física de una organización o ubicación." },
        { "@language": "et", "@value": "Organisatsiooni või asukoha füüsiline postiaadress." },
        { "@language": "fi", "@value": "Organisaation tai sijainnin fyysinen postiosoite." },
        { "@language": "fr", "@value": "L'adresse postale physique d'une organisation ou d'un lieu." },
        { "@language": "ga", "@value": "Seoladh poist fisiciúil eagraíochta nó láithreach." },
        { "@language": "hr", "@value": "Fizička poštanska adresa organizacije ili lokacije." },
        { "@language": "hu", "@value": "Szervezet vagy helyszín fizikai levelezési címe." },
        { "@language": "it", "@value": "L'indirizzo postale fisico di un'organizzazione o luogo." },
        { "@language": "lt", "@value": "Fizinis organizacijos ar vietos pašto adresas." },
        { "@language": "lv", "@value": "Organizācijas vai atrašanās vietas fiziskā pasta adrese." },
        { "@language": "mt", "@value": "L-indirizz postali fiżiku ta’ organizzazzjoni jew post." },
        { "@language": "nl", "@value": "Het fysieke postadres van een organisatie of locatie." },
        { "@language": "pl", "@value": "Fizyczny adres pocztowy organizacji lub lokalizacji." },
        { "@language": "pt", "@value": "O endereço postal físico de uma organização ou local." },
        { "@language": "ro", "@value": "Adresa poștală fizică a unei organizații sau locații." },
        { "@language": "sk", "@value": "Fyzická poštová adresa organizácie alebo miesta." },
        { "@language": "sl", "@value": "Fizični poštni naslov organizacije ali lokacije." },
        { "@language": "sv", "@value": "Den fysiska postadressen till en organisation eller plats." }
      ],
      "skos:exactMatch": [
        {
          "@id": "schema:PostalAddress"
        },
        {
          "@id": "gs1:Address"
        },
        {
          "@id": "unece:TradeAddress"
        }
      ]
    },

    // ==================================================================
    // Properties (Relationships between DPP and Organizations)
    // ==================================================================

    // --- economicOperator (The Relationship Property) ---
    {
      "@id": "dppk:economicOperator",
      "@type": "owl:ObjectProperty",
      "rdfs:label": [
        { "@language": "en", "@value": "Economic Operator" },
        { "@language": "bg", "@value": "Икономически оператор" },
        { "@language": "cs", "@value": "Hospodářský subjekt" },
        { "@language": "da", "@value": "Økonomisk operatør" },
        { "@language": "de", "@value": "Wirtschaftsakteur" },
        { "@language": "el", "@value": "Οικονομικός Φορέας" },
        { "@language": "es", "@value": "Operador Económico" },
        { "@language": "et", "@value": "Majandustegevuses osaleja" },
        { "@language": "fi", "@value": "Talouden toimija" },
        { "@language": "fr", "@value": "Opérateur économique" },
        { "@language": "ga", "@value": "Oibreoir Eacnamaíoch" },
        { "@language": "hr", "@value": "Gospodarski subjekt" },
        { "@language": "hu", "@value": "Gazdasági szereplő" },
        { "@language": "it", "@value": "Operatore economico" },
        { "@language": "lt", "@value": "Ekonominės veiklos vykdytojas" },
        { "@language": "lv", "@value": "Ekonomikas dalībnieks" },
        { "@language": "mt", "@value": "Operatur Ekonomiku" },
        { "@language": "nl", "@value": "Marktdeelnemer" },
        { "@language": "pl", "@value": "Podmiot gospodarczy" },
        { "@language": "pt", "@value": "Operador Económico" },
        { "@language": "ro", "@value": "Operator economic" },
        { "@language": "sk", "@value": "Hospodársky subjekt" },
        { "@language": "sl", "@value": "Gospodarski subjekt" },
        { "@language": "sv", "@value": "Ekonomisk aktör" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "Relates the DPP to the Economic Operator responsible for it." },
        { "@language": "bg", "@value": "Свързва DPP с отговорния за него икономически оператор." },
        { "@language": "cs", "@value": "Spojuje DPP s hospodářským subjektem za něj odpovědným." },
        { "@language": "da", "@value": "Relaterer DPP til den økonomiske operatør, der er ansvarlig for det." },
        { "@language": "de", "@value": "Bezieht den DPP auf den dafür verantwortlichen Wirtschaftsakteur." },
        { "@language": "el", "@value": "Συνδέει το DPP με τον υπεύθυνο Οικονομικό Φορέα για αυτό." },
        { "@language": "es", "@value": "Relaciona el DPP con el Operador Económico responsable de él." },
        { "@language": "et", "@value": "Seob DPP-i selle eest vastutava majandustegevuses osalejaga." },
        { "@language": "fi", "@value": "Yhdistää DPP:n siitä vastaavaan talouden toimijaan." },
        { "@language": "fr", "@value": "Relie le DPP à l'opérateur économique qui en est responsable." },
        { "@language": "ga", "@value": "Nascann sé an DPP leis an Oibreoir Eacnamaíoch atá freagrach as." },
        { "@language": "hr", "@value": "Povezuje DPP s gospodarskim subjektom odgovornim za njega." },
        { "@language": "hu", "@value": "A DPP-t a termékért felelős gazdasági szereplőhöz kapcsolja." },
        { "@language": "it", "@value": "Mette in relazione il DPP con l'operatore economico che ne è responsabile." },
        { "@language": "lt", "@value": "Susieja DPP su už jį atsakingu ekonominės veiklos vykdytoju." },
        { "@language": "lv", "@value": "Saista DPP ar par to atbildīgo ekonomikas dalībnieku." },
        { "@language": "mt", "@value": "Jirrelata DPP mal-Operatur Ekonomiku responsabbli għalih." },
        { "@language": "nl", "@value": "Koppelt het DPP aan de marktdeelnemer die er verantwoordelijk voor is." },
        { "@language": "pl", "@value": "Powiązuje DPP z odpowiedzialnym za niego podmiotem gospodarczym." },
        { "@language": "pt", "@value": "Relaciona o DPP com o Operador Económico responsável por ele." },
        { "@language": "ro", "@value": "Relaționează DPP-ul cu operatorul economic responsabil pentru acesta." },
        { "@language": "sk", "@value": "Spája DPP s hospodárskym subjektom zaň zodpovedným." },
