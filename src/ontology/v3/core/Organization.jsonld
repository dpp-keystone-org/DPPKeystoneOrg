          { "@language": "sl", "@value": "Proizvodni obrat" },
          { "@language": "sv", "@value": "Tillverkningsanläggning" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Relates the DPP to the specific facility where the product (or a step) was manufactured." },
          { "@language": "bg", "@value": "Свързва DPP със специфичното съоръжение, където е произведен продуктът (или стъпка от него)." },
          { "@language": "cs", "@value": "Spojuje DPP s konkrétním zařízením, kde byl produkt (nebo jeho část) vyroben." },
          { "@language": "da", "@value": "Relaterer DPP til det specifikke anlæg, hvor produktet (eller et trin) blev fremstillet." },
          { "@language": "de", "@value": "Bezieht den DPP auf die spezifische Einrichtung, in der das Produkt (oder ein Schritt) hergestellt wurde." },
          { "@language": "el", "@value": "Συνδέει το DPP με τη συγκεκριμένη εγκατάσταση όπου κατασκευάστηκε το προϊόν (ή ένα στάδιο)." },
          { "@language": "es", "@value": "Relaciona el DPP con la instalación específica donde se fabricó el producto (o un paso)." },
          { "@language": "et", "@value": "Seob DPP-i konkreetse rajatisega, kus toode (või selle etapp) valmistati." },
          { "@language": "fi", "@value": "Yhdistää DPP:n tiettyyn laitokseen, jossa tuote (tai sen vaihe) valmistettiin." },
          { "@language": "fr", "@value": "Relie le DPP à l'installation spécifique où le produit (ou une étape) a été fabriqué." },
          { "@language": "ga", "@value": "Nascann sé an DPP leis an tsaoráid shainiúil ina ndearnadh an táirge (nó céim de)." },
          { "@language": "hr", "@value": "Povezuje DPP sa specifičnim postrojenjem gdje je proizvod (ili jedan korak) proizveden." },
          { "@language": "hu", "@value": "A DPP-t ahhoz az adott létesítményhez kapcsolja, ahol a terméket (vagy egy lépését) gyártották." },
          { "@language": "it", "@value": "Mette in relazione il DPP con lo specifico impianto in cui il prodotto (o una fase) è stato fabbricato." },
          { "@language": "lt", "@value": "Susieja DPP su konkrečiu objektu, kuriame buvo pagamintas produktas (arba atliktas etapas)." },
          { "@language": "lv", "@value": "Saista DPP ar konkrēto iekārtu, kurā produkts (vai tā posms) tika ražots." },
          { "@language": "mt", "@value": "Jirrelata DPP mal-faċilità speċifika fejn il-prodott (jew pass) ġie mmanifatturat." },
          { "@language": "nl", "@value": "Koppelt het DPP aan de specifieke faciliteit waar het product (of een stap) is vervaardigd." },
          { "@language": "pl", "@value": "Powiązuje DPP z konkretnym obiektem, w którym wyprodukowano produkt (lub jego etap)." },
          { "@language": "pt", "@value": "Relaciona o DPP com a instalação específica onde o produto (ou uma etapa) foi fabricado." },
          { "@language": "ro", "@value": "Relaționează DPP-ul cu instalația specifică în care a fost fabricat produsul (sau o etapă)." },
          { "@language": "sk", "@value": "Spája DPP s konkrétnym zariadením, kde bol produkt (alebo jeho krok) vyrobený." },
          { "@language": "sl", "@value": "Povezuje DPP s specifičnim obratom, kjer je bil izdelek (ali korak) proizveden." },
          { "@language": "sv", "@value": "Relaterar DPP till den specifika anläggning där produkten (eller ett steg) tillverkades." }
        ],
        "rdfs:domain": { "@id": "dppk:DigitalProductPassport" },
        "rdfs:range": {
          "@id": "dppk:Organization"
        },
        "skos:relatedMatch": [
          {
            "@id": "schema:Place"
          },
          {
            "@id": "gs1:Place"
          }
        ]
    },
