          { "@language": "hr", "@value": "Proizvodno postrojenje" },
          { "@language": "hu", "@value": "Gyártólétesítmény" },
          { "@language": "it", "@value": "Impianto di produzione" },
          { "@language": "lt", "@value": "Gamybos objektas" },
          { "@language": "lv", "@value": "Ražošanas iekārta" },
