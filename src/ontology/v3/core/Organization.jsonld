        "rdfs:comment": [
          { "@language": "en", "@value": "An identifier for the organization other than GLN or LEI (e.g., EORI, VAT ID). Must be used in conjunction with additionalOrganizationIdType." },
          { "@language": "bg", "@value": "Идентификатор на организацията, различен от GLN или LEI (напр. EORI, ДДС номер). Трябва да се използва заедно с additionalOrganizationIdType." },
          { "@language": "cs", "@value": "Identifikátor organizace jiný než GLN nebo LEI (např. EORI, DIČ). Musí být použit ve spojení s additionalOrganizationIdType." },
          { "@language": "da", "@value": "En identifikator for organisationen ud over GLN eller LEI (f.eks. EORI, momsnummer). Skal bruges sammen med additionalOrganizationIdType." },
          { "@language": "de", "@value": "Eine andere Kennung für die Organisation als GLN oder LEI (z. B. EORI, USt-IdNr.). Muss in Verbindung mit additionalOrganizationIdType verwendet werden." },
          { "@language": "el", "@value": "Ένα αναγνωριστικό για τον οργανισμό εκτός από το GLN ή το LEI (π.χ. EORI, ΑΦΜ). Πρέπει να χρησιμοποιείται σε συνδυασμό με το additionalOrganizationIdType." },
          { "@language": "es", "@value": "Un identificador para la organización que no sea GLN o LEI (p. ej., EORI, NIF). Debe utilizarse junto con additionalOrganizationIdType." },
          { "@language": "et", "@value": "Organisatsiooni identifikaator peale GLN-i või LEI (nt EORI, käibemaksukohustuslase number). Tuleb kasutada koos atribuudiga additionalOrganizationIdType." },
          { "@language": "fi", "@value": "Organisaation tunniste, joka ei ole GLN tai LEI (esim. EORI, ALV-numero). On käytettävä yhdessä additionalOrganizationIdType-määritteen kanssa." },
          { "@language": "fr", "@value": "Un identifiant pour l'organisation autre que GLN ou LEI (par ex., EORI, numéro de TVA). Doit être utilisé conjointement avec additionalOrganizationIdType." },
          { "@language": "ga", "@value": "Aitheantóir don eagraíocht seachas GLN nó LEI (m.sh., EORI, Uimhir CBL). Ní mór é a úsáid i gcomhar le additionalOrganizationIdType." },
          { "@language": "hr", "@value": "Identifikator za organizaciju koji nije GLN ili LEI (npr. EORI, PDV ID). Mora se koristiti zajedno s additionalOrganizationIdType." },
          { "@language": "hu", "@value": "A szervezet azonosítója a GLN-en vagy LEI-n kívül (pl. EORI, adószám). Az additionalOrganizationIdType attribútummal együtt kell használni." },
          { "@language": "it", "@value": "Un identificatore per l'organizzazione diverso da GLN o LEI (es. EORI, partita IVA). Deve essere utilizzato insieme a additionalOrganizationIdType." },
          { "@language": "lt", "@value": "Organizacijos identifikatorius, kuris nėra GLN arba LEI (pvz., EORI, PVM mokėtojo kodas). Turi būti naudojamas kartu su additionalOrganizationIdType." },
          { "@language": "lv", "@value": "Organizācijas identifikators, kas nav GLN vai LEI (piemēram, EORI, PVN maksātāja numurs). Jāizmanto kopā ar additionalOrganizationIdType." },
          { "@language": "mt", "@value": "Identifikatur għall-organizzazzjoni għajr GLN jew LEI (eż., EORI, numru tal-VAT). Għandu jintuża flimkien ma' additionalOrganizationIdType." },
          { "@language": "nl", "@value": "Een identificatie voor de organisatie anders dan GLN of LEI (bijv. EORI, btw-nummer). Moet worden gebruikt in combinatie met additionalOrganizationIdType." },
          { "@language": "pl", "@value": "Identyfikator organizacji inny niż GLN lub LEI (np. EORI, NIP). Musi być używany w połączeniu z additionalOrganizationIdType." },
          { "@language": "pt", "@value": "Um identificador para a organização que não seja GLN ou LEI (por exemplo, EORI, NIF). Deve ser utilizado em conjunto com additionalOrganizationIdType." },
          { "@language": "ro", "@value": "Un identificator pentru organizație, altul decât GLN sau LEI (de ex. EORI, cod de TVA). Trebuie utilizat împreună cu additionalOrganizationIdType." },
          { "@language": "sk", "@value": "Identifikátor organizácie iný ako GLN alebo LEI (napr. EORI, IČ DPH). Musí sa použiť v spojení s additionalOrganizationIdType." },
          { "@language": "sl", "@value": "Identifikator za organizacijo, ki ni GLN ali LEI (npr. EORI, davčna številka). Uporabljati se mora skupaj z additionalOrganizationIdType." },
          { "@language": "sv", "@value": "En identifierare för organisationen annan än GLN eller LEI (t.ex. EORI, momsregistreringsnummer). Måste användas i kombination med additionalOrganizationIdType." }
        ],
