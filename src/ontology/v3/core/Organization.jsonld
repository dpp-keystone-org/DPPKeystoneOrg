          { "@language": "ga", "@value": "Aitheantóir caighdeánach GS1 d'eintitis dhlíthiúla, ranna feidhmiúla, nó láithreacha fisiciúla." },
          { "@language": "hr", "@value": "Standardni GS1 identifikator za pravne osobe, funkcionalne odjele ili fizičke lokacije." },
          { "@language": "hu", "@value": "Egy GS1 szabványos azonosító jogi személyek, funkcionális részlegek vagy fizikai helyszínek számára." },
          { "@language": "it", "@value": "Un identificatore standard GS1 per entità legali, dipartimenti funzionali o luoghi fisici." },
          { "@language": "lt", "@value": "GS1 standarto identifikatorius juridiniams asmenims, funkciniams skyriams ar fizinėms vietoms." },
          { "@language": "lv", "@value": "GS1 standarta identifikators juridiskām personām, funkcionālām nodaļām vai fiziskām atrašanās vietām." },
          { "@language": "mt", "@value": "Identifikatur standard GS1 għal entitajiet legali, dipartimenti funzjonali, jew postijiet fiżiċi." },
          { "@language": "nl", "@value": "Een GS1-standaardidentificatie voor juridische entiteiten, functionele afdelingen of fysieke locaties." },
          { "@language": "pl", "@value": "Standardowy identyfikator GS1 dla podmiotów prawnych, działów funkcjonalnych lub lokalizacji fizycznych." },
          { "@language": "pt", "@value": "Um identificador padrão GS1 para entidades legais, departamentos funcionais ou locais físicos." },
          { "@language": "ro", "@value": "Un identificator standard GS1 pentru entități legale, departamente funcționale sau locații fizice." },
          { "@language": "sk", "@value": "Štandardný identifikátor GS1 pre právnické osoby, funkčné oddelenia alebo fyzické miesta." },
          { "@language": "sl", "@value": "Standardni identifikator GS1 za pravne osebe, funkcionalne oddelke ali fizične lokacije." },
          { "@language": "sv", "@value": "En GS1-standardidentifierare för juridiska personer, funktionella avdelningar eller fysiska platser." }
