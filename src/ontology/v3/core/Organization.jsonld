          { "@language": "pl", "@value": "Wspólnotowy System Rejestracji i Identyfikacji Podmiotów Gospodarczych (EORI)" },
          { "@language": "pt", "@value": "Registo e Identificação de Operadores Económicos (EORI)" },
          { "@language": "ro", "@value": "Înregistrarea și identificarea operatorilor economici (EORI)" },
          { "@language": "sk", "@value": "Registrácia a identifikácia hospodárskych subjektov (EORI)" },
          { "@language": "sl", "@value": "Registracija in identifikacija gospodarskih subjektov (EORI)" },
          { "@language": "sv", "@value": "Registrering och identifiering av ekonomiska aktörer (EORI)" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "A unique identifier assigned by a customs authority in the EU to economic operators." },
          { "@language": "bg", "@value": "Уникален идентификатор, определен от митнически орган в ЕС на икономически оператори." },
          { "@language": "cs", "@value": "Jedinečný identifikátor přidělený celním orgánem v EU hospodářským subjektům." },
          { "@language": "da", "@value": "En unik identifikator tildelt af en toldmyndighed i EU til økonomiske operatører." },
          { "@language": "de", "@value": "Ein eindeutiger Identifikator, der von einer Zollbehörde in der EU an Wirtschaftsakteure vergeben wird." },
          { "@language": "el", "@value": "Ένα μοναδικό αναγνωριστικό που εκχωρείται από μια τελωνειακή αρχή στην ΕΕ σε οικονομικούς φορείς." },
          { "@language": "es", "@value": "Un identificador único asignado por una autoridad aduanera en la UE a los operadores económicos." },
          { "@language": "et", "@value": "Ainulaadne identifikaator, mille ELi tolliasutus on majandustegevuses osalejatele määranud." },
          { "@language": "fi", "@value": "Yksilöllinen tunniste, jonka EU:n tulliviranomainen antaa talouden toimijoille." },
          { "@language": "fr", "@value": "Un identifiant unique attribué par une autorité douanière de l'UE aux opérateurs économiques." },
          { "@language": "ga", "@value": "Aitheantóir uathúil arna shannadh ag údarás custaim san AE d'oibreoirí eacnamaíocha." },
          { "@language": "hr", "@value": "Jedinstveni identifikator koji carinsko tijelo u EU-u dodjeljuje gospodarskim subjektima." },
          { "@language": "hu", "@value": "Egy egyedi azonosító, amelyet egy uniós vámhatóság rendel a gazdasági szereplőkhöz." },
          { "@language": "it", "@value": "Un identificatore unico assegnato da un'autorità doganale nell'UE agli operatori economici." },
          { "@language": "lt", "@value": "Unikalus identifikatorius, kurį ES muitinė suteikia ekonominės veiklos vykdytojams." },
          { "@language": "lv", "@value": "Unikāls identifikators, ko ES muitas iestāde piešķir ekonomikas dalībniekiem." },
          { "@language": "mt", "@value": "Identifikatur uniku assenjat minn awtorità doganali fl-UE lill-operaturi ekonomiċi." },
          { "@language": "nl", "@value": "Een unieke identificatie toegekend door een douaneautoriteit in de EU aan marktdeelnemers." },
          { "@language": "pl", "@value": "Unikalny identyfikator nadawany przez organy celne w UE podmiotom gospodarczym." },
          { "@language": "pt", "@value": "Um identificador único atribuído por uma autoridade aduaneira na UE aos operadores económicos." },
          { "@language": "ro", "@value": "Un identificator unic atribuit de o autoritate vamală din UE operatorilor economici." },
          { "@language": "sk", "@value": "Jedinečný identifikátor pridelený colným orgánom v EÚ hospodárskym subjektom." },
          { "@language": "sl", "@value": "Edinstven identifikator, ki ga carinski organ v EU dodeli gospodarskim subjektom." },
          { "@language": "sv", "@value": "En unik identifierare tilldelad av en tullmyndighet i EU till ekonomiska aktörer." }
        ],
        "dppk:visibility": { "@id": "dppk:Public" },
        "rdfs:domain": { "@id": "dppk:Organization" },
        "rdfs:range": {
          "@id": "xsd:string"
        },
        "skos:relatedMatch": [
          {
            "@id": "schema:identifier"
          },
          {
            "@id": "gs1:additionalOrganizationIdentification"
          }
        ]
    },

    // --- Additional Identifiers (EORI, VAT, etc.) ---
    // These utilize the GS1 pattern for extensible identification.
    {
        "@id": "dppk:additionalOrganizationId",
        "@type": "owl:DatatypeProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Additional Organization ID" },
          { "@language": "bg", "@value": "Допълнителен идентификатор на организация" },
