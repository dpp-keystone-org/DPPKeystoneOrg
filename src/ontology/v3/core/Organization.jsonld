          { "@language": "sv", "@value": "Handelsnamn" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "The name under which the organization conducts business, if different from the legal name." },
          { "@language": "bg", "@value": "Името, под което организацията извършва дейност, ако е различно от юридическото име." },
          { "@language": "cs", "@value": "Název, pod kterým organizace podniká, pokud se liší od právního názvu." },
          { "@language": "da", "@value": "Det navn, hvorunder organisationen driver virksomhed, hvis det adskiller sig fra det juridiske navn." },
          { "@language": "de", "@value": "Der Name, unter dem die Organisation geschäftlich tätig ist, falls abweichend vom rechtlichen Namen." },
          { "@language": "el", "@value": "Η ονομασία με την οποία ο οργανισμός διεξάγει τις εργασίες του, εάν διαφέρει από το νομικό όνομα." },
          { "@language": "es", "@value": "El nombre bajo el cual la organización hace negocios, si difiere del nombre legal." },
          { "@language": "et", "@value": "Nimi, mille all organisatsioon tegutseb, kui see erineb juriidilisest nimest." },
          { "@language": "fi", "@value": "Nimi, jolla organisaatio harjoittaa liiketoimintaa, jos se eroaa oikeudellisesta nimestä." },
          { "@language": "fr", "@value": "Le nom sous lequel l'organisation exerce ses activités, s'il est différent du nom légal." },
          { "@language": "ga", "@value": "An t-ainm faoina ndéanann an eagraíocht gnó, más difriúil ón ainm dlíthiúil é." },
          { "@language": "hr", "@value": "Naziv pod kojim organizacija posluje, ako se razlikuje od pravnog naziva." },
          { "@language": "hu", "@value": "A név, amely alatt a szervezet üzleti tevékenységet folytat, ha eltér a jogi névtől." },
          { "@language": "it", "@value": "Il nome con cui l'organizzazione svolge le proprie attività, se diverso dal nome legale." },
          { "@language": "lt", "@value": "Pavadinimas, kuriuo organizacija vykdo veiklą, jei skiriasi nuo juridinio pavadinimo." },
          { "@language": "lv", "@value": "Nosaukums, ar kuru organizācija veic uzņēmējdarbību, ja tas atšķiras no juridiskā nosaukuma." },
          { "@language": "mt", "@value": "L-isem li taħtu l-organizzazzjoni twettaq in-negozju, jekk differenti mill-isem legali." },
          { "@language": "nl", "@value": "De naam waaronder de organisatie zaken doet, indien verschillend van de wettelijke naam." },
          { "@language": "pl", "@value": "Nazwa, pod którą organizacja prowadzi działalność, jeśli inna niż nazwa prawna." },
          { "@language": "pt", "@value": "O nome sob o qual a organização realiza negócios, se diferente do nome legal." },
          { "@language": "ro", "@value": "Numele sub care organizația desfășoară afaceri, dacă este diferit de numele legal." },
          { "@language": "sk", "@value": "Názov, pod ktorým organizácia podniká, ak sa líši od právneho názvu." },
          { "@language": "sl", "@value": "Ime, pod katerim organizacija posluje, če se razlikuje od pravnega imena." },
          { "@language": "sv", "@value": "Det namn under vilket organisationen bedriver verksamhet, om det skiljer sig från det juridiska namnet." }
        ],
        "dppk:visibility": { "@id": "dppk:Public" },
        "rdfs:domain": { "@id": "dppk:Organization" },
        "rdfs:range": {
          "@id": "xsd:string"
        },
        "skos:exactMatch": [
          {
            "@id": "gs1:organizationTradingName"
          },
          {
            "@id": "unece:tradingBusinessName"
          }
        ]
    },
    
