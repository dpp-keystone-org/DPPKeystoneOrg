        "rdfs:comment": [
          { "@language": "en", "@value": "A GS1 standard identifier for legal entities, functional departments, or physical locations." },
          { "@language": "bg", "@value": "Стандартен идентификатор на GS1 за юридически лица, функционални отдели или физически местоположения." },
