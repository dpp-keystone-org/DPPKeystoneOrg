        { "@language": "sk", "@value": "AVS: 2+; Poznámky: relevantné len ak je zahrnuté, pre špeciálne aplikácie; zmes obsahuje 75% primárneho cementu." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: pomembno le, če je vključeno, za posebne aplikacije; mešanica vsebuje 75 % primarnega cementa." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: endast relevant om det ingår, för speciella tillämpningar; blandningen innehåller 75% primärcement." }
