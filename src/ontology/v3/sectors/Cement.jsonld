        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση (≥ 66.6% δηλωθέν) για κλίνκερ τσιμέντου Portland." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria (≥ 66.6% declarado) para clinker de cemento Portland." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon (≥ 66.6% deklareeritud) Portlandtsemendi klinkri puhul." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus (≥ 66.6% ilmoitettu) Portlandsementtiklinkkerille." },
