        { "@language": "ga", "@value": "AVS: 1+; FPC: min mhinicíocht 1/seachtain; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% ci; Nótaí: d'fheidhmchláir speisialta, ach amháin má theastaíonn (Tástáil cineáil)." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: min. učestalost 1/tjedan; Revizija: 6/godina; Uzorci za ispitivanje tipa: 1; Stat. vrijednost: 10% fraktil 95% ci; Napomene: za posebne primjene, samo ako se zahtijeva (Ispitivanje tipa)." },
        { "@language": "hu", "@value": "AVS: 1+; ÜGY: min. gyakoriság 1/hét; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 10% fraktilis 95% ci; Megjegyzések: speciális alkalmazásokhoz, csak ha szükséges (Típusvizsgálat)." },
        { "@language": "it", "@value": "VVCP: 1+; CPF: freq. min. 1/settimana; Audit: 6/anno; Campioni di prova di tipo: 1; Valore stat.: frattile 10% 95% ci; Note: per applicazioni speciali, solo se richiesto (Prova di tipo)." },
        { "@language": "lt", "@value": "AVS: 1+; VKS: min. dažnis 1/savaitė; Auditas: 6/metai; Tipo bandymo mėginiai: 1; Stat. vertė: 10 % fraktilis 95 % ci; Pastabos: specialioms reikmėms, tik jei reikalaujama (Tipo bandymas)." },
