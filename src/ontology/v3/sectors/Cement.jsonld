    {
      "@id": "dppk-cement:maximumStandardCompressiveStrength28Days",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Maximum Standard Compressive Strength 28 Days" },
