        { "@language": "bg", "@value": "AVS: 2+; Забележки: уместно само ако е включено." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze pokud je zahrnuto." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant, hvis inkluderet." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant, falls enthalten." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εάν περιλαμβάνεται." },
        { "@language": "es", "@value": "AVS: 2+; Notas: relevante solo si se incluye." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui see on lisatud." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: merkityksellinen vain, jos sisältyy." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: pertinent seulement si inclus." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha amháin má chuirtear san áireamh." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: relevantno samo ako je uključeno." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha tartalmazza." },
        { "@language": "it", "@value": "AVS: 2+; Note: rilevante solo se incluso." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: aktualu tik tuo atveju, jei įtraukta." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: attiecas tikai tad, ja tas ir iekļauts." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: rilevanti biss jekk inkluż." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: alleen relevant indien inbegrepen." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: istotne tylko wtedy, gdy jest uwzględniony." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: relevante apenas se incluído." },
        { "@language": "ro", "@value": "AVS: 2+; Note: relevant numai dacă este inclus." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: relevantné len ak je zahrnuté." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: pomembno le, če je vključeno." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: endast relevant om det ingår." }
      ]
