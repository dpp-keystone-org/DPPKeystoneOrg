        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължително деклариране (≥ 66.6% декларирано) за портландциментов клинкер." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace (≥ 66.6% deklarováno) pro portlandský slínek." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration (≥ 66.6% deklareret) for Portlandcementklinker." },
