      "dppk:governedBy": "EN 196-1:2026",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 85% declared); ratio of compressive strength of standard mortar bars with 75/25 mix." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включен (≥ 85% декларирано); съотношение на якостта на натиск на стандартни строителни разтвори със смес 75/25." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuta (deklarováno ≥ 85 %); poměr pevnosti v tlaku standardních maltových trámečků se směsí 75/25." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≥ 85% deklareret); forholdet mellem trykstyrke for standard mørtelprisme med 75/25 blanding." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, falls enthalten (≥ 85% deklariert); Verhältnis der Druckfestigkeit von Standardmörtelprismen mit 75/25-Mischung." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εφόσον περιλαμβάνεται (≥ 85% δηλωμένο)· λόγος θλιπτικής αντοχής πρότυπων δοκιμίων κονιάματος με μείγμα 75/25." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 85% declarado); relación de resistencia a la compresión de probetas de mortero estándar con mezcla 75/25." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklareerimine, kui see on lisatud (≥ 85% deklareeritud); standardsete mördiprismade survetugevuse suhe 75/25 seguga." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautuksia: pakollinen ilmoitus, jos sisällytetty (≥ 85 % ilmoitettu); standardilaastiprismojen puristuslujuuden suhde 75/25-seoksella." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 85% déclaré); rapport de résistance à la compression d'éprouvettes de mortier standard avec un mélange 75/25." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh é (≥ 85% dearbhaithe); cóimheas neart comhbhrúite de bharraí moirtéal caighdeánacha le meascán 75/25." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 85% deklarirano); omjer tlačne čvrstoće standardnih prizmi morta s mješavinom 75/25." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha szerepel (≥ 85% deklarált); szabványos habarcsprízmák nyomószilárdsági aránya 75/25-ös keverékkel." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 85% dichiarato); rapporto di resistenza alla compressione di prismi di malta standard con miscela 75/25." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privalomas deklaravimas, jei įtraukta (≥ 85% deklaruota); standartinių skiedinio prizmių gniuždymo stiprio santykis su 75/25 mišiniu." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja ir iekļauts (≥ 85% deklarēts); standarta javas prizmu spiedes stiprības attiecība ar 75/25 maisījumu." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≥ 85% iddikjarat); proporzjon tas-saħħa kompressiva ta' priżmi ta' mehrież standard b'taħlita ta' 75/25." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien opgenomen (≥ 85% aangegeven); verhouding van de druksterkte van standaard mortelprisma's met 75/25 mengsel." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja w przypadku włączenia (≥ 85% deklarowane); stosunek wytrzymałości na ściskanie standardowych beleczek zaprawy z mieszanką 75/25." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 85% declarado); relação da resistência à compressão de provetes de argamassa padrão com mistura 75/25." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 85% declarat); raportul rezistenței la compresiune al prismelor de mortar standard cu amestec 75/25." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 85% deklarované); pomer pevnosti v tlaku štandardných maltových hranolov so zmesou 75/25." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 85% deklarirano); razmerje tlačne trdnosti standardnih maltnih prizem z mešanico 75/25." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om inkluderad (≥ 85 % deklarerad); förhållande av tryckhållfasthet för standardmurbruksprovkroppar med 75/25-blandning." }
      ]
    },
    {
      "@id": "dppk-cement:compressiveStrengthBurntShale28Days",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Compressive Strength Burnt Shale 28 days" },
        { "@language": "bg", "@value": "Якост на натиск на изпечен шист след 28 дни" },
        { "@language": "cs", "@value": "Pevnost v tlaku pálené břidlice 28 dní" },
        { "@language": "da", "@value": "Trykstyrke brændt skifer 28 dage" },
        { "@language": "de", "@value": "Druckfestigkeit von gebranntem Schiefer 28 Tage" },
        { "@language": "el", "@value": "Θλιπτική αντοχή ψημένου σχιστόλιθου 28 ημερών" },
        { "@language": "es", "@value": "Resistencia a la compresión del esquisto calcinado a 28 días" },
        { "@language": "et", "@value": "Põletatud põlevkivi survetugevus 28 päeva" },
        { "@language": "fi", "@value": "Poltetun liuskeen puristuslujuus 28 päivää" },
        { "@language": "fr", "@value": "Résistance à la compression du schiste calciné à 28 jours" },
        { "@language": "ga", "@value": "Neart comhbhrúite scealla dóite 28 lá" },
        { "@language": "hr", "@value": "Tlačna čvrstoća pečenog škriljevca 28 dana" },
        { "@language": "hu", "@value": "Égetett pala nyomószilárdsága 28 nap" },
        { "@language": "it", "@value": "Resistenza alla compressione dello scisto calcinato a 28 giorni" },
        { "@language": "lt", "@value": "Degto skalūno gniuždymo stipris 28 dienų" },
        { "@language": "lv", "@value": "Dedzināta slānekļa spiedes stiprība 28 dienas" },
        { "@language": "mt", "@value": "Saħħa Kompressiva tax-Shale Maħruq 28 jum" },
        { "@language": "nl", "@value": "Druksterkte gebrande schalie 28 dagen" },
        { "@language": "pl", "@value": "Wytrzymałość na ściskanie łupka palonego 28 dni" },
        { "@language": "pt", "@value": "Resistência à compressão de xisto calcinado aos 28 dias" },
        { "@language": "ro", "@value": "Rezistența la compresiune a șistului calcinat la 28 de zile" },
        { "@language": "sk", "@value": "Pevnosť v tlaku pálenej bridlice 28 dní" },
        { "@language": "sl", "@value": "Tlačna trdnost žganega skrilavca 28 dni" },
        { "@language": "sv", "@value": "Tryckhållfasthet bränd skiffer 28 dagar" }
      ],
      "dppk:governedBy": "EN 196-1:2026",
      "dppk:unit": { "@id": "dppk-unit:Megapascal" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 25.0 MPa declared); test mortar prepared with finely ground burnt shale only." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≥ 25,0 MPa декларирано); изпитателен разтвор, приготвен само с фино смлян изпечен шист." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (deklarováno ≥ 25,0 MPa); zkušební malta připravená pouze s jemně mletou pálenou břidlicí." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≥ 25,0 MPa deklareret); prøvemørtel fremstillet kun med fintmalet brændt skifer." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, falls enthalten (≥ 25,0 MPa deklariert); Prüfmörtel nur mit fein gemahlenem gebranntem Schiefer hergestellt." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εφόσον περιλαμβάνεται (≥ 25,0 MPa δηλωμένο)· δοκιμαστικό κονίαμα παρασκευασμένο μόνο με λεπτά αλεσμένο ψημένο σχιστόλιθο." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 25,0 MPa declarado); mortero de prueba preparado solo con esquisto calcinado finamente molido." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklareerimine, kui see on lisatud (≥ 25,0 MPa deklareeritud); katsemört on valmistatud ainult peeneks jahvatatud põletatud põlevkiviga." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautuksia: pakollinen ilmoitus, jos sisällytetty (≥ 25,0 MPa ilmoitettu); koelaasti valmistettu ainoastaan hienoksi jauhetusta poltetusta liuskeesta." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 25,0 MPa déclaré); mortier d'essai préparé uniquement avec du schiste calciné finement broyé." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh é (≥ 25.0 MPa dearbhaithe); moirtéal tástála ullmhaithe le scealla dóite atá meilte go mín amháin." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 25,0 MPa deklarirano); ispitni mort pripremljen samo od fino mljevenog pečenog škriljevca." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha szerepel (≥ 25,0 MPa deklarált); a vizsgálati habarcs csak finomra őrölt égetett palával készül." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 25,0 MPa dichiarato); malta di prova preparata solo con scisto calcinato finemente macinato." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privalomas deklaravimas, jei įtraukta (≥ 25,0 MPa deklaruota); bandomasis skiedinys, paruoštas tik su smulkiai sumaltu degtu skalūnu." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja ir iekļauts (≥ 25,0 MPa deklarēts); testa java sagatavota tikai ar smalki samaltu dedzinātu slānekli." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≥ 25.0 MPa iddikjarat); mehrież tat-test ippreparat biss bi shale maħruq mitħun fin." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien opgenomen (≥ 25,0 MPa aangegeven); testmortel uitsluitend bereid met fijngemalen gebrande schalie." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja w przypadku włączenia (≥ 25,0 MPa deklarowane); zaprawa testowa przygotowana wyłącznie z drobno zmielonym łupkiem palonym." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 25,0 MPa declarado); argamassa de ensaio preparada apenas com xisto calcinado finamente moído." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 25,0 MPa declarat); mortar de testare preparat numai cu șist calcinat măcinat fin." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 25,0 MPa deklarované); skúšobná malta pripravená len s jemne mletou pálenou bridlicou." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 25,0 MPa deklarirano); testna malta, pripravljena samo s fino mletim žganim skrilavcem." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om inkluderad (≥ 25,0 MPa deklarerad); provmurbruk berett endast med finmald bränd skiffer." }
      ]
    },
    {
      "@id": "dppk-cement:totalOrganicCarbonContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Total Organic Carbon Content" },
        { "@language": "bg", "@value": "Общо съдържание на органичен въглерод" },
        { "@language": "cs", "@value": "Celkový obsah organického uhlíku" },
        { "@language": "da", "@value": "Totalt organisk kulstofindhold" },
        { "@language": "de", "@value": "Gesamter organischer Kohlenstoffgehalt" },
        { "@language": "el", "@value": "Συνολική περιεκτικότητα σε οργανικό άνθρακα" },
        { "@language": "es", "@value": "Contenido de carbono orgánico total" },
        { "@language": "et", "@value": "Orgaanilise süsiniku kogusisaldus" },
        { "@language": "fi", "@value": "Kokonaisorgaanisen hiilen pitoisuus" },
        { "@language": "fr", "@value": "Teneur totale en carbone organique" },
        { "@language": "ga", "@value": "Ábhar carbóin orgánaigh iomlán" },
        { "@language": "hr", "@value": "Ukupni udio organskog ugljika" },
        { "@language": "hu", "@value": "Teljes szerves széntartalom" },
        { "@language": "it", "@value": "Contenuto di carbonio organico totale" },
        { "@language": "lt", "@value": "Bendras organinės anglies kiekis" },
        { "@language": "lv", "@value": "Kopējais organiskā oglekļa saturs" },
        { "@language": "mt", "@value": "Kontenut ta' karbonju organiku totali" },
        { "@language": "nl", "@value": "Totaal organisch koolstofgehalte" },
        { "@language": "pl", "@value": "Całkowita zawartość węgla organicznego" },
        { "@language": "pt", "@value": "Teor de carbono orgânico total" },
        { "@language": "ro", "@value": "Conținut total de carbon organic" },
        { "@language": "sk", "@value": "Celkový obsah organického uhlíka" },
        { "@language": "sl", "@value": "Skupna vsebnost organskega ogljika" },
        { "@language": "sv", "@value": "Totalt organiskt kolinnehåll" }
      ],
      "dppk:governedBy": "EN 13639:2017",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≤ 0.8% declared for recycled fines; LL ≤ 0.20%, L ≤ 0.50% for limestone)." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≤ 0,8% декларирано за рециклирани фини частици; LL ≤ 0,20%, L ≤ 0,50% за варовик)." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≤ 0,8 % deklarováno pro recyklované jemné podíly; LL ≤ 0,20 %, L ≤ 0,50 % pro vápenec)." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≤ 0,8% deklareret for genanvendt finstof; LL ≤ 0,20%, L ≤ 0,50% for kalksten)." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, falls enthalten (≤ 0,8% deklariert für rezyklierten Brechsand; LL ≤ 0,20%, L ≤ 0,50% für Kalkstein)." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εφόσον περιλαμβάνεται (≤ 0,8% δηλωμένο για λεπτόκοκκα ανακυκλωμένου· LL ≤ 0,20%, L ≤ 0,50% για ασβεστόλιθο)." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≤ 0,8% declarado para finos reciclados; LL ≤ 0,20%, L ≤ 0,50% para caliza)." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklareerimine, kui see on lisatud (≤ 0,8% deklareeritud ringlussevõetud peenmaterjali puhul; LL ≤ 0,20%, L ≤ 0,50% lubjakivi puhul)." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautuksia: pakollinen ilmoitus, jos sisällytetty (≤ 0,8 % ilmoitettu kierrätetylle hienoainekselle; LL ≤ 0,20 %, L ≤ 0,50 % kalkkikivelle)." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≤ 0,8% déclaré pour les fines recyclées ; LL ≤ 0,20%, L ≤ 0,50% pour le calcaire)." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh é (≤ 0.8% dearbhaithe d'fhíneálacha athchúrsáilte; LL ≤ 0.20%, L ≤ 0.50% le haghaidh aolchloiche)." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≤ 0,8% deklarirano za reciklirane sitne čestice; LL ≤ 0,20%, L ≤ 0,50% za vapnenac)." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha szerepel (≤ 0,8% deklarált újrahasznosított finomanyagokra; LL ≤ 0,20%, L ≤ 0,50% mészkőre)." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≤ 0,8% dichiarato per fini riciclati; LL ≤ 0,20%, L ≤ 0,50% per calcare)." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privalomas deklaravimas, jei įtraukta (≤ 0,8% deklaruota perdirbtoms smulkioms dalelėms; LL ≤ 0,20%, L ≤ 0,50% klinčiai)." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja ir iekļauts (≤ 0,8% deklarēts pārstrādātiem smalkumiem; LL ≤ 0,20%, L ≤ 0,50% kaļķakmenim)." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≤ 0.8% iddikjarat għal trab riċiklat; LL ≤ 0.20%, L ≤ 0.50% għal ġebla tal-ġir)." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien opgenomen (≤ 0,8% aangegeven voor gerecyclede fijne stoffen; LL ≤ 0,20%, L ≤ 0,50% voor kalksteen)." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja w przypadku włączenia (≤ 0,8% deklarowane dla frakcji drobnej z recyklingu; LL ≤ 0,20%, L ≤ 0,50% dla wapienia)." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≤ 0,8% declarado para finos reciclados; LL ≤ 0,20%, L ≤ 0,50% para calcário)." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≤ 0,8% declarat pentru particule fine reciclate; LL ≤ 0,20%, L ≤ 0,50% pentru calcar)." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≤ 0,8 % deklarované pre recyklované jemné podiely; LL ≤ 0,20 %, L ≤ 0,50 % pre vápenec)." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≤ 0,8 % deklarirano za reciklirane fine delce; LL ≤ 0,20 %, L ≤ 0,50 % za apnenec)." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om inkluderad (≤ 0,8 % deklarerad för återvunnet finsten; LL ≤ 0,20 %, L ≤ 0,50 % för kalksten)." }
      ]
    },
    {
      "@id": "dppk-cement:clayContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Clay Content" },
        { "@language": "bg", "@value": "Съдържание на глина" },
        { "@language": "cs", "@value": "Obsah jílu" },
        { "@language": "da", "@value": "Lerindhold" },
        { "@language": "de", "@value": "Tongehalt" },
        { "@language": "el", "@value": "Περιεκτικότητα σε άργιλο" },
        { "@language": "es", "@value": "Contenido de arcilla" },
        { "@language": "et", "@value": "Savisisaldus" },
        { "@language": "fi", "@value": "Savipitoisuus" },
        { "@language": "fr", "@value": "Teneur en argile" },
        { "@language": "ga", "@value": "Ábhar cré" },
        { "@language": "hr", "@value": "Udio gline" },
        { "@language": "hu", "@value": "Agyagtartalom" },
        { "@language": "it", "@value": "Contenuto di argilla" },
        { "@language": "lt", "@value": "Molio kiekis" },
        { "@language": "lv", "@value": "Māla saturs" },
        { "@language": "mt", "@value": "Kontenut ta' tafal" },
        { "@language": "nl", "@value": "Kleigehalte" },
        { "@language": "pl", "@value": "Zawartość gliny" },
        { "@language": "pt", "@value": "Teor de argila" },
        { "@language": "ro", "@value": "Conținut de argilă" },
        { "@language": "sk", "@value": "Obsah ílu" },
        { "@language": "sl", "@value": "Vsebnost gline" },
        { "@language": "sv", "@value": "Lerhalt" }
      ],
      "dppk:governedBy": "EN 933-9:2022",
      "dppk:unit": { "@id": "dppk-unit:GramPer100Gram" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≤ 1.20 g/100 g declared); measured on powder ground to a fineness of approximately 5000 cm²/g in accordance with EN 196-6." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (декларирано ≤ 1,20 g/100 g); измерва се върху прах, смлян до финост от приблизително 5000 cm²/g в съответствие с EN 196-6." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (deklarováno ≤ 1,20 g/100 g); měřeno na prášku mletém na jemnost přibližně 5000 cm²/g v souladu s EN 196-6." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≤ 1,20 g/100 g deklareret); målt på pulver malet til en finhed på ca. 5000 cm²/g i henhold til EN 196-6." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, falls enthalten (≤ 1,20 g/100 g deklariert); gemessen an Pulver, das auf eine Feinheit von ca. 5000 cm²/g nach EN 196-6 gemahlen wurde." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εφόσον περιλαμβάνεται (≤ 1,20 g/100 g δηλωμένο)· μετράται σε σκόνη αλεσμένη σε λεπτότητα περίπου 5000 cm²/g σύμφωνα με το EN 196-6." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≤ 1,20 g/100 g declarado); medido en polvo molido a una finura de aproximadamente 5000 cm²/g de acuerdo con EN 196-6." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklareerimine, kui see on lisatud (≤ 1,20 g/100 g deklareeritud); mõõdetud pulbril, mis on jahvatatud peensuseni umbes 5000 cm²/g vastavalt standardile EN 196-6." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautuksia: pakollinen ilmoitus, jos sisällytetty (≤ 1,20 g/100 g ilmoitettu); mitattu jauheesta, joka on jauhettu noin 5000 cm²/g hienouteen standardin EN 196-6 mukaisesti." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≤ 1,20 g/100 g déclaré); mesuré sur une poudre broyée à une finesse d'environ 5000 cm²/g conformément à la norme EN 196-6." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh é (≤ 1.20 g/100 g dearbhaithe); tomhaiste ar phúdar a meileadh go míne de thart ar 5000 cm²/g i gcomhréir le EN 196-6." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≤ 1,20 g/100 g deklarirano); mjereno na prahu mljevenom na finoću od približno 5000 cm²/g u skladu s EN 196-6." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha szerepel (≤ 1,20 g/100 g deklarált); poron mérve, amelyet körülbelül 5000 cm²/g finomságúra őröltek az EN 196-6 szabvány szerint." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≤ 1,20 g/100 g dichiarato); misurato su polvere macinata a una finezza di circa 5000 cm²/g in conformità con la norma EN 196-6." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privalomas deklaravimas, jei įtraukta (≤ 1,20 g/100 g deklaruota); matuojama ant miltelių, sumaltų iki maždaug 5000 cm²/g smulkumo pagal EN 196-6." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja ir iekļauts (≤ 1,20 g/100 g deklarēts); mērīts pulverim, kas samalts līdz apmēram 5000 cm²/g smalkumam saskaņā ar EN 196-6." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≤ 1.20 g/100 g iddikjarat); imkejjel fuq trab mitħun sa finezza ta' bejn wieħed u ieħor 5000 cm²/g skont EN 196-6." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien opgenomen (≤ 1,20 g/100 g aangegeven); gemeten op poeder gemalen tot een fijnheid van ongeveer 5000 cm²/g overeenkomstig EN 196-6." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja w przypadku włączenia (≤ 1,20 g/100 g deklarowane); mierzone na proszku zmielonym do miałkości około 5000 cm²/g zgodnie z EN 196-6." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≤ 1,20 g/100 g declarado); medido em pó moído até uma finura de aproximadamente 5000 cm²/g de acordo com a norma EN 196-6." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≤ 1,20 g/100 g declarat); măsurat pe pulbere măcinată la o finețe de aproximativ 5000 cm²/g în conformitate cu EN 196-6." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≤ 1,20 g/100 g deklarované); merané na prášku mletom na jemnosť približne 5000 cm²/g v súlade s EN 196-6." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≤ 1,20 g/100 g deklarirano); merjeno na prahu, zmletem na finost približno 5000 cm²/g v skladu z EN 196-6." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om inkluderad (≤ 1,20 g/100 g deklarerad); uppmätt på pulver malt till en finlek av ca 5000 cm²/g i enlighet med EN 196-6." }
      ]
    },
