      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: freq 1/year; Audit: 1/year; Type Test Samples: 1; Notes: for special applications, only if required." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: честота 1/година; Одит: 1/година; Проби за изпитване на типа: 1; Забележки: за специални приложения, само ако се изисква." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: frekvence 1/rok; Audit: 1/rok; Vzorky pro zkoušky typu: 1; Poznámky: pro speciální použití, pouze pokud je to požadováno." },
        { "@language": "da", "@value": "AVS: 1+; FPC: frekvens 1/år; Audit: 1/år; Typeprøvningsemner: 1; Bemærkninger: til specielle anvendelser, kun hvis krævet." },
        { "@language": "de", "@value": "AVS: 1+; FPC: Häufigkeit 1/Jahr; Audit: 1/Jahr; Typprüfkörper: 1; Anmerkungen: für besondere Anwendungen, nur wenn gefordert." },
        { "@language": "el", "@value": "AVS: 1+; FPC: συχνότητα 1/έτος; Έλεγχος: 1/έτος; Δείγματα δοκιμής τύπου: 1; Σημειώσεις: για ειδικές εφαρμογές, μόνο εάν απαιτείται." },
        { "@language": "es", "@value": "AVS: 1+; FPC: frec 1/año; Auditoría: 1/año; Muestras de ensayo de tipo: 1; Notas: para aplicaciones especiales, solo si se requiere." },
        { "@language": "et", "@value": "AVS: 1+; FPC: sagedus 1/aasta; Audit: 1/aasta; Tüübikatse proovid: 1; Märkused: erirakendusteks, ainult nõudmisel." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: taajuus 1/vuosi; Auditointi: 1/vuosi; Tyyppikoenäytteet: 1; Huomautukset: erityiskäyttöön, vain vaadittaessa." },
        { "@language": "fr", "@value": "AVS : 1+ ; FPC : fréq 1/an ; Audit : 1/an ; Échantillons d'essai de type : 1 ; Notes : pour applications spéciales, uniquement si requis." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: minicíocht 1/bliain; Iniúchadh: 1/bliain; Samplaí Tástála Cineáil: 1; Nótaí: d'fheidhmeanna speisialta, más gá amháin." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: učestalost 1/god.; Revizija: 1/god.; Uzorci za ispitivanje tipa: 1; Napomene: za posebne primjene, samo ako se zahtijeva." },
        { "@language": "hu", "@value": "AVS: 1+; FPC: gyakoriság 1/év; Audit: 1/év; Típusvizsgálati minták: 1; Megjegyzések: speciális alkalmazásokhoz, csak ha szükséges." },
        { "@language": "it", "@value": "AVS: 1+; FPC: freq 1/anno; Audit: 1/anno; Campioni di prova di tipo: 1; Note: per applicazioni speciali, solo se richiesto." },
        { "@language": "lt", "@value": "AVS: 1+; FPC: dažnis 1/metus; Auditas: 1/metus; Tipo bandymo mėginiai: 1; Pastabos: specialioms reikmėms, tik jei reikalaujama." },
        { "@language": "lv", "@value": "AVS: 1+; FPC: biežums 1/gadā; Audits: 1/gadā; Tipa testa paraugi: 1; Piezīmes: īpašiem pielietojumiem, tikai ja nepieciešams." },
        { "@language": "mt", "@value": "AVS: 1+; FPC: frekwenza 1/sena; Verifika: 1/sena; Kampjuni tat-Test tat-Tip: 1; Noti: għal applikazzjonijiet speċjali, biss jekk meħtieġ." },
        { "@language": "nl", "@value": "AVS: 1+; FPC: freq 1/jaar; Audit: 1/jaar; Typetestmonsters: 1; Opmerkingen: voor speciale toepassingen, alleen indien vereist." },
        { "@language": "pl", "@value": "AVS: 1+; FPC: częstotliwość 1/rok; Audyt: 1/rok; Próbki do badań typu: 1; Uwagi: do zastosowań specjalnych, tylko gdy jest to wymagane." },
        { "@language": "pt", "@value": "AVS: 1+; FPC: freq 1/ano; Auditoria: 1/ano; Amostras de ensaio de tipo: 1; Notas: para aplicações especiais, apenas se exigido." },
        { "@language": "ro", "@value": "AVS: 1+; FPC: frecv 1/an; Audit: 1/an; Eșantioane de încercare de tip: 1; Note: pentru aplicații speciale, numai dacă se solicită." },
        { "@language": "sk", "@value": "AVS: 1+; FPC: frekvencia 1/rok; Audit: 1/rok; Vzorky na skúšky typu: 1; Poznámky: pre špeciálne použitie, len ak sa to požaduje." },
        { "@language": "sl", "@value": "AVS: 1+; FPC: pogostost 1/leto; Presoja: 1/leto; Vzorci za preskus tipa: 1; Opombe: za posebne uporabe, samo če je zahtevano." },
        { "@language": "sv", "@value": "AVS: 1+; FPC: frekvens 1/år; Audit: 1/år; Typprovningsprover: 1; Anmärkningar: för speciella tillämpningar, endast om det krävs." }
      ]
    },
