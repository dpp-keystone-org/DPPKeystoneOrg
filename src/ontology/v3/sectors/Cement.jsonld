        { "@language": "da", "@value": "Prøvning af sulfatbestandighed med flade prismer" },
        { "@language": "de", "@value": "Prüfung des Sulfatwiderstands an flachen Prismen" },
        { "@language": "el", "@value": "Δοκιμή αντοχής σε θειικά άλατα με επίπεδα πρίσματα" },
