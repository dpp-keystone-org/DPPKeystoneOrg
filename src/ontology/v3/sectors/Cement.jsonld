    {
      "@id": "dppk-cement:calciumCarbonateContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Calcium Carbonate Content" },
        { "@language": "bg", "@value": "Съдържание на калциев карбонат" },
        { "@language": "cs", "@value": "Obsah uhličitanu vápenatého" },
        { "@language": "da", "@value": "Calciumkarbonatindhold" },
        { "@language": "de", "@value": "Calciumcarbonatgehalt" },
        { "@language": "el", "@value": "Περιεκτικότητα σε ανθρακικό ασβέστιο" },
        { "@language": "es", "@value": "Contenido de carbonato de calcio" },
        { "@language": "et", "@value": "Kaltsiumkarbonaadi sisaldus" },
        { "@language": "fi", "@value": "Kalsiumkarbonaattipitoisuus" },
        { "@language": "fr", "@value": "Teneur en carbonate de calcium" },
        { "@language": "ga", "@value": "Ábhar Carbónáit Chailciam" },
        { "@language": "hr", "@value": "Udio kalcijevog karbonata" },
        { "@language": "hu", "@value": "Kalcium-karbonát tartalom" },
        { "@language": "it", "@value": "Contenuto di carbonato di calcio" },
        { "@language": "lt", "@value": "Kalcio karbonato kiekis" },
        { "@language": "lv", "@value": "Kalcija karbonāta saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Karbonat tal-Kalċju" },
        { "@language": "nl", "@value": "Calciumcarbonaatgehalte" },
        { "@language": "pl", "@value": "Zawartość węglanu wapnia" },
        { "@language": "pt", "@value": "Teor de carbonato de cálcio" },
        { "@language": "ro", "@value": "Conținut de carbonat de calciu" },
        { "@language": "sk", "@value": "Obsah uhličitanu vápenatého" },
        { "@language": "sl", "@value": "Vsebnost kalcijevega karbonata" },
        { "@language": "sv", "@value": "Kalciumkarbonathalt" }
      ],
      "dppk:governedBy": "EN 196-2:2026",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 40.0% declared); determine total CO2 (EN 196-2) and subtract fraction from MgCO3." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≥ 40.0% декларирано); определете общия CO2 (EN 196-2) и извадете фракцията от MgCO3." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 40.0% deklarováno); stanovte celkový CO2 (EN 196-2) a odečtěte frakci z MgCO3." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≥ 40.0% deklareret); bestem total CO2 (EN 196-2) og fratræk fraktion fra MgCO3." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Erklärung, falls enthalten (≥ 40.0% deklariert); Gesamt-CO2 bestimmen (EN 196-2) und Anteil aus MgCO3 abziehen." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 40.0% δηλωμένο)· προσδιορίστε το συνολικό CO2 (EN 196-2) και αφαιρέστε το κλάσμα από το MgCO3." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 40.0% declarado); determinar el CO2 total (EN 196-2) y restar la fracción del MgCO3." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui on lisatud (≥ 40.0% deklareeritud); määrake kogu CO2 (EN 196-2) ja lahutage MgCO3 fraktsioon." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≥ 40.0 % ilmoitettu); määritä kokonais-CO2 (EN 196-2) ja vähennä MgCO3-osuus." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 40.0% déclaré); déterminer le CO2 total (EN 196-2) et soustraire la fraction de MgCO3." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 40.0% dearbhaithe); cinntigh iomlán CO2 (EN 196-2) agus dealaigh an codán ó MgCO3." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 40.0% deklarirano); odredite ukupni CO2 (EN 196-2) i oduzmite udio iz MgCO3." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 40.0% deklarált); határozza meg a teljes CO2-t (EN 196-2) és vonja le az MgCO3 hányadát." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 40.0% dichiarato); determinare la CO2 totale (EN 196-2) e sottrarre la frazione da MgCO3." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 40.0% deklaruota); nustatyti bendrą CO2 (EN 196-2) ir atimti dalį iš MgCO3." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 40.0% deklarēts); nosaka kopējo CO2 (EN 196-2) un atņem frakciju no MgCO3." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluża (≥ 40.0% iddikjarat); iddetermina s-CO2 totali (EN 196-2) u naqqas il-frazzjoni minn MgCO3." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≥ 40.0% gedeclareerd); bepaal totale CO2 (EN 196-2) en trek fractie van MgCO3 af." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: deklaracja obowiązkowa, jeśli uwzględniono (≥ 40.0% deklarowane); oznaczyć całkowity CO2 (EN 196-2) i odjąć frakcję z MgCO3." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 40.0% declarado); determinar o CO2 total (EN 196-2) e subtrair a fração do MgCO3." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 40.0% declarat); determinați CO2 total (EN 196-2) și scădeți fracția din MgCO3." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 40.0% deklarované); stanovte celkový CO2 (EN 196-2) a odčítajte frakciu z MgCO3." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 40.0 % deklarirano); določite celotni CO2 (EN 196-2) in odštejte frakcijo iz MgCO3." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 40.0% deklarerat); bestäm total CO2 (EN 196-2) och subtrahera fraktionen från MgCO3." }
      ]
    },
