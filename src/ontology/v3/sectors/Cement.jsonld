      "dppk:governedBy": "EN 196-1:2026",
      "dppk:unit": { "@id": "dppk-unit:Megapascal" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: min freq 1/week; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: for special applications, only if required (Type test)." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: мин. честота 1/седмица; Одит: 6/година; Типово изпитване проби: 1; Стат. стойност: 10% квантил 95% ci; Бележки: за специални приложения, само при изискване (Типово изпитване)." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: min. frekvence 1/týden; Audit: 6/rok; Vzorky pro zkoušku typu: 1; Stat. hodnota: 10% kvantil 95% ci; Poznámky: pro speciální aplikace, pouze pokud je požadováno (Zkouška typu)." },
        { "@language": "da", "@value": "AVS: 1+; FPC: min. frekvens 1/uge; Audit: 6/år; Typeprøvning prøver: 1; Stat. værdi: 10% fraktil 95% ci; Bemærkninger: til særlige anvendelser, kun hvis krævet (Typeprøvning)." },
        { "@language": "de", "@value": "AVS: 1+; WPK: min. Häufigkeit 1/Woche; Audit: 6/Jahr; Typprüfung Proben: 1; Stat. Wert: 10% Fraktil 95% CI; Anmerkungen: für spezielle Anwendungen, nur wenn erforderlich (Typprüfung)." },
        { "@language": "el", "@value": "AVS: 1+; FPC: ελάχ. συχνότητα 1/εβδομάδα; Έλεγχος: 6/έτος; Δείγματα δοκιμής τύπου: 1; Στατ. τιμή: 10% ποσοστημόριο 95% ci; Σημειώσεις: για ειδικές εφαρμογές, μόνο εάν απαιτείται (Δοκιμή τύπου)." },
        { "@language": "es", "@value": "AVS: 1+; CPF: frec. mín. 1/semana; Auditoría: 6/año; Muestras de ensayo de tipo: 1; Valor est.: cuantil 10% 95% ci; Notas: para aplicaciones especiales, solo si se requiere (Ensayo de tipo)." },
        { "@language": "et", "@value": "AVS: 1+; FPC: min sagedus 1/nädal; Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 10% fraktiil 95% ci; Märkused: erirakenduste puhul, ainult nõudmisel (Tüübikatse)." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: vähimmäistiheys 1/viikko; Auditointi: 6/vuosi; Tyyppikokeen näytteet: 1; Tilastollinen arvo: 10 % fraktiili 95 % ci; Huomautukset: erityiskäyttöön, vain vaadittaessa (Tyyppikoe)." },
        { "@language": "fr", "@value": "EVCP: 1+; CPU: fréq. min. 1/semaine; Audit: 6/an; Échantillons d'essai de type: 1; Valeur stat.: quantile 10% 95% ci; Remarques: pour applications spéciales, seulement si requis (Essai de type)." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: min mhinicíocht 1/seachtain; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% ci; Nótaí: d'fheidhmchláir speisialta, ach amháin má theastaíonn (Tástáil cineáil)." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: min. učestalost 1/tjedan; Revizija: 6/godina; Uzorci za ispitivanje tipa: 1; Stat. vrijednost: 10% fraktil 95% ci; Napomene: za posebne primjene, samo ako se zahtijeva (Ispitivanje tipa)." },
