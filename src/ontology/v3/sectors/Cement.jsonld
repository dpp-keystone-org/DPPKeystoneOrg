        { "@language": "et", "@value": "Leelisesisaldus" },
        { "@language": "fi", "@value": "Alkalipitoisuus" },
        { "@language": "fr", "@value": "Teneur en alcalis" },
        { "@language": "ga", "@value": "Cion Alcaile" },
        { "@language": "hr", "@value": "Sadržaj alkalija" },
        { "@language": "hu", "@value": "Alkalitartalom" },
        { "@language": "it", "@value": "Contenuto di alcali" },
        { "@language": "lt", "@value": "Šarmų kiekis" },
        { "@language": "lv", "@value": "Sārmu saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Alkali" },
        { "@language": "nl", "@value": "Alkaligehalte" },
        { "@language": "pl", "@value": "Zawartość alkaliów" },
        { "@language": "pt", "@value": "Teor de álcalis" },
        { "@language": "ro", "@value": "Conținut de alcalii" },
        { "@language": "sk", "@value": "Obsah alkálií" },
        { "@language": "sl", "@value": "Vsebnost alkalij" },
        { "@language": "sv", "@value": "Alkaliinnehåll" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.5",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: relevant only if included (for burnt shale)." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: приложимо само ако е включено (за изпечен шист)." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze tehdy, je-li zahrnuto (pro pálenou břidlici)." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant, hvis inkluderet (for brændt skifer)." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant, wenn eingeschlossen (für gebrannten Schiefer)." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εάν συμπεριλαμβάνεται (για ψημένο σχιστόλιθο)." },
        { "@language": "es", "@value": "AVS: 2+; Notas: relevante solo si se incluye (para esquisto calcinado)." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui see on hõlmatud (põletatud kiltkivi puhul)." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: oleellinen vain, jos sisällytetty (poltetulle liuskekivelle)." },
        { "@language": "fr", "@value": "AVS : 2+; Remarques : pertinent uniquement si inclus (pour le schiste calciné)." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha ach amháin má tá sé san áireamh (do scealla dóite)." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: relevantno samo ako je uključeno (za pečeni škriljevac)." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha szerepel (égetett pala esetében)." },
        { "@language": "it", "@value": "AVS: 2+; Note: rilevante solo se incluso (per scisto calcinato)." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: aktualu tik tuo atveju, jei įtraukta (degtam skalūnui)." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: attiecas tikai tad, ja tas ir iekļauts (apdedzinātam slāneklim)." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: rilevanti biss jekk inkluż (għal shale maħruq)." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: alleen relevant indien inbegrepen (voor gebrande schalie)." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: istotne tylko wtedy, gdy jest to uwzględnione (dla łupka palonego)." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: relevante apenas se incluído (para xisto calcinado)." },
        { "@language": "ro", "@value": "AVS: 2+; Note: relevant numai dacă este inclus (pentru șist calcinat)." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: relevantné, len ak je zahrnuté (pre pálenú bridlicu)." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: pomembno samo, če je vključeno (za žgani skrilavec)." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: relevant endast om det ingår (för bränd skiffer)." }
      ]
    },
    {
      "@id": "dppk-cement:tricalciumAluminateContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Tricalcium Aluminate Content" },
        { "@language": "bg", "@value": "Съдържание на трикалциев алуминат" },
        { "@language": "cs", "@value": "Obsah trikalciumaluminátu" },
        { "@language": "da", "@value": "Tricalciumaluminatindhold" },
        { "@language": "de", "@value": "Tricalciumaluminatgehalt" },
        { "@language": "el", "@value": "Περιεκτικότητα σε αργιλικό τριασβέστιο" },
        { "@language": "es", "@value": "Contenido de aluminato tricálcico" },
        { "@language": "et", "@value": "Trikaltsiumaluminaadisisaldus" },
        { "@language": "fi", "@value": "Trikalsiumaluminaattipitoisuus" },
        { "@language": "fr", "@value": "Teneur en aluminate tricalcique" },
        { "@language": "ga", "@value": "Cion Alúmanáit Trí-chailciam" },
        { "@language": "hr", "@value": "Sadržaj trikalcijeva aluminata" },
        { "@language": "hu", "@value": "Trikalcium-aluminát tartalom" },
        { "@language": "it", "@value": "Contenuto di alluminato tricalcico" },
        { "@language": "lt", "@value": "Trikalcio aliuminato kiekis" },
        { "@language": "lv", "@value": "Trikalcija alumināta saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Aluminat Trikalċju" },
        { "@language": "nl", "@value": "Tricalciumaluminaatgehalte" },
        { "@language": "pl", "@value": "Zawartość glinianu trójwapniowego" },
        { "@language": "pt", "@value": "Teor de aluminato tricálcico" },
        { "@language": "ro", "@value": "Conținut de aluminat tricalcic" },
        { "@language": "sk", "@value": "Obsah trikalciumaluminátu" },
        { "@language": "sl", "@value": "Vsebnost trikalcijevega aluminata" },
        { "@language": "sv", "@value": "Trikalciumaluminatinnehåll" }
      ],
      "dppk:governedBy": "EN 196-14:2027",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+ or 2+; FPC (AVS 1+): freq 2/month; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: for special applications. For CEM I permissible to calculate from chemical analysis (C3A = 2.65 A - 1.69 F)." },
        { "@language": "bg", "@value": "AVS: 1+ или 2+; FPC (AVS 1+): честота 2/месец; Одит: 6/година; Проби за изпитване на типа: 1; Стат. стойност: 10% фрактил 95% ci; Забележки: за специални приложения. За CEM I е допустимо да се изчисли от химически анализ (C3A = 2.65 A - 1.69 F)." },
        { "@language": "cs", "@value": "AVS: 1+ nebo 2+; FPC (AVS 1+): frekvence 2/měsíc; Audit: 6/rok; Vzorky pro zkoušku typu: 1; Stat. hodnota: 10% kvantil 95% is; Poznámky: pro speciální aplikace. Pro CEM I lze vypočítat z chemické analýzy (C3A = 2,65 A - 1,69 F)." },
        { "@language": "da", "@value": "AVS: 1+ eller 2+; FPC (AVS 1+): frekvens 2/måned; Audit: 6/år; Typeprøvningsprøver: 1; Stat. værdi: 10% fraktil 95% ki; Bemærkninger: til særlige anvendelser. For CEM I tilladt at beregne ud fra kemisk analyse (C3A = 2,65 A - 1,69 F)." },
        { "@language": "de", "@value": "AVS: 1+ oder 2+; WPK (AVS 1+): Häufigkeit 2/Monat; Audit: 6/Jahr; Typprüfproben: 1; Stat. Wert: 10 %-Fraktil 95 %-VI; Anmerkungen: für besondere Anwendungen. Für CEM I zulässig zur Berechnung aus der chemischen Analyse (C3A = 2,65 A - 1,69 F)." },
        { "@language": "el", "@value": "AVS: 1+ ή 2+; FPC (AVS 1+): συχνότητα 2/μήνα; Έλεγχος: 6/έτος; Δείγματα δοκιμής τύπου: 1; Στατ. τιμή: ποσοστημόριο 10% 95% ci; Σημειώσεις: για ειδικές εφαρμογές. Για το CEM I επιτρέπεται ο υπολογισμός από χημική ανάλυση (C3A = 2.65 A - 1.69 F)." },
        { "@language": "es", "@value": "AVS: 1+ o 2+; FPC (AVS 1+): frecuencia 2/mes; Auditoría: 6/año; Muestras de ensayo de tipo: 1; Valor est.: cuantil 10 % 95 % ic; Notas: para aplicaciones especiales. Para CEM I es permisible calcular a partir del análisis químico (C3A = 2,65 A - 1,69 F)." },
        { "@language": "et", "@value": "AVS: 1+ või 2+; FPC (AVS 1+): sagedus 2/kuus; Audit: 6/aastas; Tüübikatsetuse proovid: 1; Stat. väärtus: 10% fraktiil 95% uv; Märkused: erirakenduste puhul. CEM I puhul on lubatud arvutada keemilisest analüüsist (C3A = 2,65 A - 1,69 F)." },
        { "@language": "fi", "@value": "AVS: 1+ tai 2+; FPC (AVS 1+): tiheys 2/kk; Auditointi: 6/vuosi; Tyyppikoenäytteet: 1; Tilastollinen arvo: 10 % fraktiili 95 % lv; Huomautukset: erityiskäyttöön. Sementille CEM I sallittua laskea kemiallisesta analyysistä (C3A = 2,65 A - 1,69 F)." },
        { "@language": "fr", "@value": "AVS : 1+ ou 2+; FPC (AVS 1+) : fréq 2/mois; Audit : 6/an; Échantillons d'essai de type : 1; Valeur stat. : fractile 10 % ic 95 %; Remarques : pour les applications spéciales. Pour le CEM I, il est permis de calculer à partir de l'analyse chimique (C3A = 2,65 A - 1,69 F)." },
        { "@language": "ga", "@value": "AVS: 1+ nó 2+; FPC (AVS 1+): minicíocht 2/mí; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% cm; Nótaí: le haghaidh feidhmchlár speisialta. Do CEM I tá sé incheadaithe é a ríomh ó anailís cheimiceach (C3A = 2.65 A - 1.69 F)." },
        { "@language": "hr", "@value": "AVS: 1+ ili 2+; FPC (AVS 1+): učestalost 2/mjesečno; Revizija: 6/godišnje; Uzorci za ispitivanje tipa: 1; Stat. vrijednost: 10% fraktila 95% pi; Napomene: za posebne primjene. Za CEM I dopušteno je izračunati iz kemijske analize (C3A = 2,65 A - 1,69 F)." },
        { "@language": "hu", "@value": "AVS: 1+ vagy 2+; FPC (AVS 1+): gyakoriság 2/hó; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 10% fraktilis 95% mk; Megjegyzések: speciális alkalmazásokhoz. A CEM I esetében megengedett a kémiai elemzésből történő kiszámítás (C3A = 2,65 A - 1,69 F)." },
        { "@language": "it", "@value": "AVS: 1+ o 2+; FPC (AVS 1+): freq 2/mese; Audit: 6/anno; Campioni di prova di tipo: 1; Valore stat.: frattile 10% ic 95%; Note: per applicazioni speciali. Per CEM I è consentito calcolare dall'analisi chimica (C3A = 2,65 A - 1,69 F)." },
        { "@language": "lt", "@value": "AVS: 1+ arba 2+; FPC (AVS 1+): dažnumas 2/mėn.; Auditas: 6/metus; Tipo bandymo mėginiai: 1; Stat. vertė: 10% fraktilis 95% pi; Pastabos: specialiam naudojimui. CEM I leidžiama apskaičiuoti iš cheminės analizės (C3A = 2,65 A - 1,69 F)." },
        { "@language": "lv", "@value": "AVS: 1+ vai 2+; FPC (AVS 1+): biežums 2/mēnesī; Audits: 6/gadā; Tipa testa paraugi: 1; Stat. vērtība: 10% fraktīle 95% ti; Piezīmes: īpašiem pielietojumiem. CEM I pieļaujams aprēķināt no ķīmiskās analīzes (C3A = 2,65 A - 1,69 F)." },
        { "@language": "mt", "@value": "AVS: 1+ jew 2+; FPC (AVS 1+): frekwenza 2/xahar; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil 95% ci; Noti: għal applikazzjonijiet speċjali. Għal CEM I permissibbli li jiġi kkalkulat minn analiżi kimika (C3A = 2.65 A - 1.69 F)." },
        { "@language": "nl", "@value": "AVS: 1+ of 2+; FPC (AVS 1+): freq 2/maand; Audit: 6/jaar; Typebeproevingsmonsters: 1; Stat. waarde: 10% fractiel 95% bi; Opmerkingen: voor speciale toepassingen. Voor CEM I is het toegestaan te berekenen uit chemische analyse (C3A = 2,65 A - 1,69 F)." },
        { "@language": "pl", "@value": "AVS: 1+ lub 2+; FPC (AVS 1+): częst. 2/miesiąc; Audyt: 6/rok; Próbki do badania typu: 1; Wartość stat.: 10% fraktyl 95% pu; Uwagi: do zastosowań specjalnych. W przypadku CEM I dopuszczalne jest obliczenie na podstawie analizy chemicznej (C3A = 2,65 A - 1,69 F)." },
        { "@language": "pt", "@value": "AVS: 1+ ou 2+; FPC (AVS 1+): freq 2/mês; Auditoria: 6/ano; Amostras de Ensaio de Tipo: 1; Valor Est.: quantil 10% 95% ic; Notas: para aplicações especiais. Para CEM I, é permitido calcular a partir da análise química (C3A = 2,65 A - 1,69 F)." },
        { "@language": "ro", "@value": "AVS: 1+ sau 2+; FPC (AVS 1+): frecvență 2/lună; Audit: 6/an; Eșantioane de încercare de tip: 1; Valoare stat.: 10% fractil 95% ic; Note: pentru aplicații speciale. Pentru CEM I se permite calcularea din analiza chimică (C3A = 2,65 A - 1,69 F)." },
        { "@language": "sk", "@value": "AVS: 1+ alebo 2+; FPC (AVS 1+): frekvencia 2/mesiac; Audit: 6/rok; Vzorky na skúšku typu: 1; Štat. hodnota: 10% kvantil 95% is; Poznámky: na špeciálne aplikácie. Pre CEM I je prípustné vypočítať z chemickej analýzy (C3A = 2,65 A - 1,69 F)." },
        { "@language": "sl", "@value": "AVS: 1+ ali 2+; FPC (AVS 1+): pogostost 2/mesec; Presoja: 6/leto; Vzorci za preskus tipa: 1; Stat. vrednost: 10 % fraktil 95 % iz; Opombe: za posebne aplikacije. Za CEM I je dovoljeno izračunati iz kemične analize (C3A = 2,65 A - 1,69 F)." },
