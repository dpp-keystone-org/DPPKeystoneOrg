        { "@language": "mt", "@value": "Kontenut ta' Ossidu tal-Kalċju Ħieles" },
        { "@language": "nl", "@value": "Gehalte aan vrij calciumoxide" },
        { "@language": "pl", "@value": "Zawartość wolnego tlenku wapnia" },
        { "@language": "pt", "@value": "Teor de óxido de cálcio livre" },
        { "@language": "ro", "@value": "Conținut de oxid de calciu liber" },
        { "@language": "sk", "@value": "Obsah voľného oxidu vápenatého" },
        { "@language": "sl", "@value": "Vsebnost prostega kalcijevega oksida" },
        { "@language": "sv", "@value": "Halt av fritt kalciumoxid" }
      ],
      "dppk:governedBy": "EN 451-1:2017",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≤ 2.5% declared) for fly ash and bottom ash." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≤ 2.5% декларирано) за летлива пепел и дънна пепел." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinné prohlášení, pokud je zahrnuto (≤ 2.5% deklarováno) pro popílek a strusku." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≤ 2.5% deklareret) for flyveaske og bundaske." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Angabe, falls enthalten (≤ 2.5% deklariert) für Flugasche und Kesselasche." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν συμπεριλαμβάνεται (≤ 2.5% δηλωμένο) για ιπτάμενη τέφρα και τέφρα πυθμένα." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≤ 2.5% declarado) para cenizas volantes y cenizas de fondo." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklareerimine, kui see on lisatud (≤ 2.5% deklareeritud) lendtuha ja koldetuha puhul." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≤ 2.5% ilmoitettu) lentotuhkalle ja pohjatuhkalle." },
        { "@language": "fr", "@value": "AVS: 2+; Remarques : déclaration obligatoire si inclus (≤ 2.5% déclaré) pour les cendres volantes et les cendres de foyer." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh é (≤ 2.5% dearbhaithe) d'luaithreach eitilte agus luaithreach grinnill." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≤ 2.5% deklarirano) za leteći pepeo i pepeo iz ložišta." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≤ 2.5% deklarált) pernye és fenékhamu esetén." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≤ 2.5% dichiarato) per ceneri volanti e ceneri pesanti." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≤ 2.5% deklaruota) lakiesiems pelenams ir dugno pelenams." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≤ 2.5% deklarēts) lidojošajiem pelniem un grunts pelniem." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≤ 2.5% iddikjarat) għall-irmied li jtir u l-irmied tal-qiegħ." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≤ 2.5% gedeclareerd) voor vliegas en bodemas." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja, jeśli jest zawarty (≤ 2.5% deklarowane) dla popiołu lotnego i żużla paleniskowego." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≤ 2.5% declarado) para cinzas volantes e cinzas de fundo." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≤ 2.5% declarat) pentru cenușa zburătoare și cenușa de vatră." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinné vyhlásenie, ak je zahrnuté (≤ 2.5% deklarované) pre popolček a spodný popol." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≤ 2.5% deklarirano) za leteči pepel in pepel iz kurišča." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≤ 2.5% deklarerat) för flygaska och bottenaska." }
      ]
    },
    {
      "@id": "dppk-cement:reactiveCalciumOxideContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Reactive Calcium Oxide Content" },
        { "@language": "bg", "@value": "Съдържание на реактивен калциев оксид" },
        { "@language": "cs", "@value": "Obsah reaktivního oxidu vápenatého" },
        { "@language": "da", "@value": "Indhold af reaktivt calciumoxid" },
        { "@language": "de", "@value": "Gehalt an reaktivem Calciumoxid" },
        { "@language": "el", "@value": "Περιεκτικότητα σε αντιδραστικό οξείδιο του ασβεστίου" },
        { "@language": "es", "@value": "Contenido de óxido de calcio reactivo" },
        { "@language": "et", "@value": "Reaktiivse kaltsiumoksiidi sisaldus" },
        { "@language": "fi", "@value": "Reaktiivisen kalsiumoksidin pitoisuus" },
        { "@language": "fr", "@value": "Teneur en oxyde de calcium réactif" },
        { "@language": "ga", "@value": "Ábhar Ocsaíd Chailciam Imoibríoch" },
        { "@language": "hr", "@value": "Sadržaj reaktivnog kalcijeva oksida" },
        { "@language": "hu", "@value": "Reaktív kalcium-oxid tartalom" },
        { "@language": "it", "@value": "Contenuto di ossido di calcio reattivo" },
        { "@language": "lt", "@value": "Reaktyvaus kalcio oksido kiekis" },
        { "@language": "lv", "@value": "Reaktīvā kalcija oksīda saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Ossidu tal-Kalċju Reattiv" },
        { "@language": "nl", "@value": "Gehalte aan reactief calciumoxide" },
        { "@language": "pl", "@value": "Zawartość reaktywnego tlenku wapnia" },
        { "@language": "pt", "@value": "Teor de óxido de cálcio reativo" },
        { "@language": "ro", "@value": "Conținut de oxid de calciu reactiv" },
        { "@language": "sk", "@value": "Obsah reaktívneho oxidu vápenatého" },
        { "@language": "sl", "@value": "Vsebnost reaktivnega kalcijevega oksida" },
        { "@language": "sv", "@value": "Halt av reaktivt kalciumoxid" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.5",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≤ 10.0% declared for siliceous fly/bottom ash, ≥ 10.0% declared for calcareous fly ash)." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≤ 10.0% декларирано за силикатна летлива/дънна пепел, ≥ 10.0% декларирано за варовита летлива пепел)." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinné prohlášení, pokud je zahrnuto (≤ 10.0% deklarováno pro křemičitý popílek/strusku, ≥ 10.0% deklarováno pro vápenatý popílek)." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≤ 10.0% deklareret for kiselholdig flyve/bundaske, ≥ 10.0% deklareret for kalkholdig flyveaske)." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Angabe, falls enthalten (≤ 10.0% deklariert für kieselsäurereiche Flugasche/Kesselasche, ≥ 10.0% deklariert für kalkreiche Flugasche)." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν συμπεριλαμβάνεται (≤ 10.0% δηλωμένο για πυριτική ιπτάμενη/τέφρα πυθμένα, ≥ 10.0% δηλωμένο για ασβεστούχα ιπτάμενη τέφρα)." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≤ 10.0% declarado para cenizas volantes/de fondo silíceas, ≥ 10.0% declarado para cenizas volantes calcáreas)." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklareerimine, kui see on lisatud (≤ 10.0% deklareeritud ränihappe lendtuha/koldetuha puhul, ≥ 10.0% deklareeritud lubjarikka lendtuha puhul)." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≤ 10.0% ilmoitettu piipitoiselle lentotuhkalle/pohjatuhkalle, ≥ 10.0% ilmoitettu kalkkipitoiselle lentotuhkalle)." },
        { "@language": "fr", "@value": "AVS: 2+; Remarques : déclaration obligatoire si inclus (≤ 10.0% déclaré pour les cendres volantes/de foyer siliceuses, ≥ 10.0% déclaré pour les cendres volantes calciques)." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh é (≤ 10.0% dearbhaithe d'luaithreach eitilte/luaithreach grinnill shiliceach, ≥ 10.0% dearbhaithe d'luaithreach eitilte cailcreach)." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≤ 10.0% deklarirano za silicijski leteći/pepeo iz ložišta, ≥ 10.0% deklarirano za vapnenasti leteći pepeo)." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≤ 10.0% deklarált szilikátos pernye/fenékhamu esetén, ≥ 10.0% deklarált meszes pernye esetén)." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≤ 10.0% dichiarato per ceneri volanti/pesanti silicee, ≥ 10.0% dichiarato per ceneri volanti calcaree)." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≤ 10.0% deklaruota silikatiniams lakiesiems/dugno pelenams, ≥ 10.0% deklaruota kalkiniams lakiesiems pelenams)." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≤ 10.0% deklarēts silīcija lidojošajiem/grunts pelniem, ≥ 10.0% deklarēts kaļķainajiem lidojošajiem pelniem)." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≤ 10.0% iddikjarat għall-irmied li jtir/irmied tal-qiegħ siliċiku, ≥ 10.0% iddikjarat għall-irmied li jtir kalkarju)." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≤ 10.0% gedeclareerd voor siliciumhoudende vlieg/bodemas, ≥ 10.0% gedeclareerd voor kalkhoudende vliegas)." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja, jeśli jest zawarty (≤ 10.0% deklarowane dla krzemionkowego popiołu lotnego/żużla paleniskowego, ≥ 10.0% deklarowane dla wapiennego popiołu lotnego)." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≤ 10.0% declarado para cinzas volantes/de fundo siliciosas, ≥ 10.0% declarado para cinzas volantes calcárias)." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≤ 10.0% declarat pentru cenușă zburătoare/de vatră silicioasă, ≥ 10.0% declarat pentru cenușă zburătoare calcaroasă)." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinné vyhlásenie, ak je zahrnuté (≤ 10.0% deklarované pre kremičitý popolček/spodný popol, ≥ 10.0% deklarované pre vápenatý popolček)." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≤ 10.0% deklarirano za silikatni leteči pepel/pepel iz kurišča, ≥ 10.0% deklarirano za apnenčasti leteči pepel)." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≤ 10.0% deklarerat för kiselhaltig flyg/bottenaska, ≥ 10.0% deklarerat för kalkhaltig flygaska)." }
      ]
    },
