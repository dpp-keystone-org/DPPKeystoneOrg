      "dppk:governedBy": "EN 196-3:2016, Clause 6",
      "dppk:unit": { "@id": "dppk-unit:Minute" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: val ≥ 45 min, min freq 2/week; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: mandatory declaration; Table 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: стойност ≥ 45 мин, мин честота 2/седмица; Одит: 6/година; Типово изпитване проби: 1; Стат стойност: 10% квантил 95% ci; Бележки: задължителна декларация; Таблица 230: ≥ 75 мин (32,5), ≥ 60 мин (42,5), ≥ 45 мин (52,5)." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: hodnota ≥ 45 min, min frekvence 2/týden; Audit: 6/rok; Vzorky typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarace; Tabulka 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "da", "@value": "AVS: 1+; FPC: værdi ≥ 45 min, min frekvens 2/uge; Audit: 6/år; Typeprøvning prøver: 1; Stat værdi: 10% fraktil 95% ci; Bemærkninger: obligatorisk deklaration; Tabel 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "de", "@value": "AVS: 1+; WPK: Wert ≥ 45 min, min Häufigkeit 2/Woche; Audit: 6/Jahr; Typprüfung Proben: 1; Stat Wert: 10% Fraktil 95% ci; Anmerkungen: obligatorische Erklärung; Tabelle 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "el", "@value": "AVS: 1+; FPC: τιμή ≥ 45 min, ελάχιστη συχνότητα 2/εβδομάδα; Έλεγχος: 6/έτος; Δείγματα τύπου: 1; Στατ τιμή: 10% ποσοστημόριο 95% ci; Σημειώσεις: υποχρεωτική δήλωση; Πίνακας 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "es", "@value": "AVS: 1+; CPF: valor ≥ 45 min, frec min 2/semana; Auditoría: 6/año; Muestras de tipo: 1; Valor est: cuantil 10% 95% ci; Notas: declaración obligatoria; Tabla 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "et", "@value": "AVS: 1+; FPC: väärtus ≥ 45 min, min sagedus 2/nädal; Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 10% fraktiil 95% ci; Märkused: kohustuslik deklareerimine; Tabel 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: arvo ≥ 45 min, min tiheys 2/viikko; Auditointi: 6/vuosi; Tyyppikokeen näytteet: 1; Stat arvo: 10% fraktiili 95% ci; Huomautukset: pakollinen ilmoitus; Taulukko 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "fr", "@value": "EVCP: 1+; CPU: valeur ≥ 45 min, fréq min 2/semaine; Audit: 6/an; Échantillons de type: 1; Valeur stat: quantile 10% 95% ci; Remarques: déclaration obligatoire; Tableau 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: luach ≥ 45 min, min mhinicíocht 2/seachtain; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% ci; Nótaí: dearbhú éigeantach; Tábla 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: vrijednost ≥ 45 min, min učestalost 2/tjedan; Revizija: 6/godina; Uzorci za tip: 1; Stat vrijednost: 10% fraktil 95% ci; Napomene: obvezna deklaracija; Tablica 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "hu", "@value": "AVS: 1+; ÜGY: érték ≥ 45 min, min gyakoriság 2/hét; Audit: 6/év; Típusvizsgálati minták: 1; Stat érték: 10% fraktilis 95% ci; Megjegyzések: kötelező nyilatkozat; Táblázat 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "it", "@value": "VVCP: 1+; CPF: valore ≥ 45 min, freq min 2/settimana; Audit: 6/anno; Campioni di tipo: 1; Valore stat: frattile 10% 95% ci; Note: dichiarazione obbligatoria; Tabella 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "lt", "@value": "AVS: 1+; VKS: vertė ≥ 45 min, min dažnis 2/savaitė; Auditas: 6/metai; Tipo bandymo mėginiai: 1; Stat vertė: 10 % fraktilis 95 % ci; Pastabos: privaloma deklaracija; Lentelė 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "lv", "@value": "AVS: 1+; RKS: vērtība ≥ 45 min, min biežums 2/nedēļa; Audits: 6/gads; Tipa pārbaudes paraugi: 1; Stat vērtība: 10% fraktile 95% ci; Piezīmes: obligāta deklarācija; Tabula 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "mt", "@value": "AVS: 1+; FPC: val ≥ 45 min, min frekwenza 2/ġimgħa; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil 95% ci; Noti: dikjarazzjoni mandatorja; Tabella 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "nl", "@value": "AVS: 1+; FPC: waarde ≥ 45 min, min frequentie 2/week; Audit: 6/jaar; Typetest monsters: 1; Stat waarde: 10% fractiel 95% ci; Opmerkingen: verplichte verklaring; Tabel 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "pl", "@value": "AVS: 1+; ZKP: wartość ≥ 45 min, min częstotliwość 2/tydzień; Audit: 6/rok; Próbki typu: 1; Wartość stat: 10% kwantyl 95% ci; Uwagi: deklaracja obowiązkowa; Tabela 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "pt", "@value": "AVS: 1+; CPF: valor ≥ 45 min, freq mín 2/semana; Auditoria: 6/ano; Amostras de tipo: 1; Valor est: quantil 10% 95% ci; Notas: declaração obrigatória; Tabela 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "ro", "@value": "AVS: 1+; CPF: valoare ≥ 45 min, frecv min 2/săptămână; Audit: 6/an; Eșantioane de tip: 1; Valoare stat: 10% fractil 95% ci; Note: declarație obligatorie; Tabel 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "sk", "@value": "AVS: 1+; FPC: hodnota ≥ 45 min, min frekvencia 2/týždeň; Audit: 6/rok; Vzorky na skúšku typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarácia; Tabuľka 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "sl", "@value": "AVS: 1+; NPK: vrednost ≥ 45 min, min pogostost 2/teden; Presoja: 6/leto; Vzorci za preizkus tipa: 1; Stat vrednost: 10% fraktil 95% ci; Opombe: obvezna deklaracija; Tabela 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." },
        { "@language": "sv", "@value": "AVS: 1+; FPC: värde ≥ 45 min, min frekvens 2/vecka; Revision: 6/år; Typprovningsprover: 1; Stat värde: 10% fraktil 95% ci; Anmärkningar: obligatorisk deklaration; Tabell 230: ≥ 75 min (32,5), ≥ 60 min (42,5), ≥ 45 min (52,5)." }
      ]
    },
    {
      "@id": "dppk-cement:lossOnIgnition",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Loss On Ignition" },
        { "@language": "bg", "@value": "Загуба при накаляване" },
        { "@language": "cs", "@value": "Ztráta žíháním" },
        { "@language": "da", "@value": "Glødetab" },
        { "@language": "de", "@value": "Glühverlust" },
        { "@language": "el", "@value": "Απώλεια κατά την πύρωση" },
        { "@language": "es", "@value": "Pérdida por calcinación" },
        { "@language": "et", "@value": "Kuumutuskadu" },
        { "@language": "fi", "@value": "Hehkutushäviö" },
        { "@language": "fr", "@value": "Perte au feu" },
        { "@language": "ga", "@value": "Caillteanas ar Adhaint" },
        { "@language": "hr", "@value": "Gubitak žarenjem" },
        { "@language": "hu", "@value": "Izzítási veszteség" },
        { "@language": "it", "@value": "Perdita al fuoco" },
        { "@language": "lt", "@value": "Kaitinimo nuostoliai" },
        { "@language": "lv", "@value": "Zudumi karsējot" },
        { "@language": "mt", "@value": "Telf mill-Ignizzjoni" },
        { "@language": "nl", "@value": "Gloeiverlies" },
        { "@language": "pl", "@value": "Strata prażenia" },
        { "@language": "pt", "@value": "Perda ao fogo" },
        { "@language": "ro", "@value": "Pierdere la calcinare" },
        { "@language": "sk", "@value": "Strata žíhaním" },
        { "@language": "sl", "@value": "Izguba pri žarenju" },
        { "@language": "sv", "@value": "Glödförlust" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.4.1",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+ (CEM I/III) or 2+ (Pozzolana); FPC: val ≤ 5.0%, freq 2/month (can reduce to 1/month if max 50% char value over 12mo); Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: mandatory declaration for CEM I/III, relevant only if included for natural/activated pozzolana." },
        { "@language": "bg", "@value": "AVS: 1+ (CEM I/III) или 2+ (Пуцолан); FPC: стойност ≤ 5.0%, честота 2/месец (може да се намали до 1/месец, ако макс 50% от характ. стойност за 12м); Одит: 6/година; Типово изпитване проби: 1; Стат стойност: 10% квантил 95% ci; Бележки: задължителна декларация за CEM I/III, приложимо само ако е включено за естествен/активиран пуцолан." },
        { "@language": "cs", "@value": "AVS: 1+ (CEM I/III) nebo 2+ (Pucolán); FPC: hodnota ≤ 5.0%, frekvence 2/měsíc (lze snížit na 1/měsíc, pokud je max 50% char. hodnoty za 12m); Audit: 6/rok; Vzorky typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarace pro CEM I/III, relevantní pouze pokud je zahrnuto pro přírodní/aktivovaný pucolán." },
        { "@language": "da", "@value": "AVS: 1+ (CEM I/III) eller 2+ (Pozzolan); FPC: værdi ≤ 5.0%, frekvens 2/måned (kan reduceres til 1/måned, hvis max 50% karakt. værdi over 12 mdr); Audit: 6/år; Typeprøvning prøver: 1; Stat værdi: 10% fraktil 95% ci; Bemærkninger: obligatorisk deklaration for CEM I/III, kun relevant hvis inkluderet for naturlig/aktiveret pozzolan." },
        { "@language": "de", "@value": "AVS: 1+ (CEM I/III) oder 2+ (Puzzolan); WPK: Wert ≤ 5.0%, Häufigkeit 2/Monat (kann auf 1/Monat reduziert werden, wenn max. 50% des char. Wertes über 12 Mon.); Audit: 6/Jahr; Typprüfung Proben: 1; Stat Wert: 10% Fraktil 95% ci; Anmerkungen: obligatorische Erklärung für CEM I/III, nur relevant falls für natürliches/aktiviertes Puzzolan enthalten." },
        { "@language": "el", "@value": "AVS: 1+ (CEM I/III) ή 2+ (Ποζολάνη); FPC: τιμή ≤ 5.0%, συχνότητα 2/μήνα (μπορεί να μειωθεί σε 1/μήνα εάν μέγιστο 50% της χαρακτ. τιμής για 12μήνες); Έλεγχος: 6/έτος; Δείγματα τύπου: 1; Στατ τιμή: 10% ποσοστημόριο 95% ci; Σημειώσεις: υποχρεωτική δήλωση για CEM I/III, σχετικό μόνο εάν περιλαμβάνεται για φυσική/ενεργοποιημένη ποζολάνη." },
        { "@language": "es", "@value": "AVS: 1+ (CEM I/III) o 2+ (Puzolana); CPF: valor ≤ 5.0%, frec 2/mes (puede reducirse a 1/mes si máx 50% del valor carac. en 12m); Auditoría: 6/año; Muestras de tipo: 1; Valor est: cuantil 10% 95% ci; Notas: declaración obligatoria para CEM I/III, relevante solo si se incluye para puzolana natural/activada." },
        { "@language": "et", "@value": "AVS: 1+ (CEM I/III) või 2+ (Putsolaan); FPC: väärtus ≤ 5.0%, sagedus 2/kuu (võib vähendada 1/kuu, kui max 50% karakt. väärtusest 12k jooksul); Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 10% fraktiil 95% ci; Märkused: kohustuslik deklareerimine CEM I/III puhul, asjakohane ainult siis, kui on lisatud loodusliku/aktiveeritud putsolaani puhul." },
        { "@language": "fi", "@value": "AVS: 1+ (CEM I/III) tai 2+ (Puzzolaani); FPC: arvo ≤ 5.0%, tiheys 2/kuukausi (voidaan vähentää 1/kk, jos max 50% ominaisarvosta 12kk:n aikana); Auditointi: 6/vuosi; Tyyppikokeen näytteet: 1; Stat arvo: 10% fraktiili 95% ci; Huomautukset: pakollinen ilmoitus CEM I/III:lle, merkityksellinen vain jos mukana luonnolliselle/aktivoidulle puzzolaanille." },
        { "@language": "fr", "@value": "EVCP: 1+ (CEM I/III) ou 2+ (Pouzzolane); CPU: valeur ≤ 5.0%, fréq 2/mois (peut être réduite à 1/mois si max 50% de la valeur caract. sur 12m); Audit: 6/an; Échantillons de type: 1; Valeur stat: quantile 10% 95% ci; Remarques: déclaration obligatoire pour CEM I/III, pertinent uniquement si inclus pour pouzzolane naturelle/activée." },
        { "@language": "ga", "@value": "AVS: 1+ (CEM I/III) nó 2+ (Puaslán); FPC: luach ≤ 5.0%, minicíocht 2/mí (is féidir a laghdú go 1/mí más uasmhéid 50% luach sain. thar 12mh); Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% ci; Nótaí: dearbhú éigeantach do CEM I/III, ábhartha ach amháin má chuirtear san áireamh é do phuaslán nádúrtha/gníomhachtaithe." },
        { "@language": "hr", "@value": "AVS: 1+ (CEM I/III) ili 2+ (Pucolan); FPC: vrijednost ≤ 5.0%, učestalost 2/mjesec (može se smanjiti na 1/mjesec ako je maks. 50% karakt. vrijednosti u 12mj); Revizija: 6/godina; Uzorci za tip: 1; Stat vrijednost: 10% fraktil 95% ci; Napomene: obvezna deklaracija za CEM I/III, važno samo ako je uključeno za prirodni/aktivirani pucolan." },
        { "@language": "hu", "@value": "AVS: 1+ (CEM I/III) vagy 2+ (Pucolán); ÜGY: érték ≤ 5.0%, gyakoriság 2/hónap (csökkenthető 1/hó-ra, ha max 50% a karakt. érték 12hónap alatt); Audit: 6/év; Típusvizsgálati minták: 1; Stat érték: 10% fraktilis 95% ci; Megjegyzések: kötelező nyilatkozat CEM I/III esetén, csak akkor releváns, ha természetes/aktivált pucolánra vonatkozik." },
        { "@language": "it", "@value": "VVCP: 1+ (CEM I/III) o 2+ (Pozzolana); CPF: valore ≤ 5.0%, freq 2/mese (può essere ridotta a 1/mese se max 50% del valore caratt. in 12m); Audit: 6/anno; Campioni di tipo: 1; Valore stat: frattile 10% 95% ci; Note: dichiarazione obbligatoria per CEM I/III, rilevante solo se incluso per pozzolana naturale/attivata." },
        { "@language": "lt", "@value": "AVS: 1+ (CEM I/III) arba 2+ (Pucolanas); VKS: vertė ≤ 5.0%, dažnis 2/mėn. (gali būti sumažintas iki 1/mėn., jei maks. 50% charakt. vertės per 12 mėn.); Auditas: 6/metai; Tipo bandymo mėginiai: 1; Stat vertė: 10 % fraktilis 95 % ci; Pastabos: privaloma deklaracija CEM I/III, aktualu tik jei įtraukta natūraliam/aktyvuotam pucolanui." },
        { "@language": "lv", "@value": "AVS: 1+ (CEM I/III) vai 2+ (Pucolāns); RKS: vērtība ≤ 5.0%, biežums 2/mēnesī (var samazināt līdz 1/mēn., ja maks. 50% no rakst. vērtības 12 mēn.); Audits: 6/gads; Tipa pārbaudes paraugi: 1; Stat vērtība: 10% fraktile 95% ci; Piezīmes: obligāta deklarācija CEM I/III, attiecas tikai tad, ja iekļauts dabīgajam/aktivizētajam pucolānam." },
        { "@language": "mt", "@value": "AVS: 1+ (CEM I/III) jew 2+ (Pozzolana); FPC: val ≤ 5.0%, frekwenza 2/xahar (jista' jitnaqqas għal 1/xahar jekk max 50% tal-valur karatt. f'12-il xahar); Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil 95% ci; Noti: dikjarazzjoni mandatorja għal CEM I/III, rilevanti biss jekk inkluż għal pozzolana naturali/attivata." },
        { "@language": "nl", "@value": "AVS: 1+ (CEM I/III) of 2+ (Puzzolaan); FPC: waarde ≤ 5.0%, frequentie 2/maand (kan worden verlaagd naar 1/maand indien max 50% karakt. waarde gedurende 12m); Audit: 6/jaar; Typetest monsters: 1; Stat waarde: 10% fractiel 95% ci; Opmerkingen: verplichte verklaring voor CEM I/III, alleen relevant indien opgenomen voor natuurlijke/geactiveerde puzzolaan." },
        { "@language": "pl", "@value": "AVS: 1+ (CEM I/III) lub 2+ (Pucolana); ZKP: wartość ≤ 5.0%, częstotliwość 2/miesiąc (można zmniejszyć do 1/miesiąc jeśli maks. 50% wart. charakt. w ciągu 12m); Audit: 6/rok; Próbki typu: 1; Wartość stat: 10% kwantyl 95% ci; Uwagi: deklaracja obowiązkowa dla CEM I/III, dotyczy tylko jeśli dodano do naturalnej/aktywowanej pucolany." },
        { "@language": "pt", "@value": "AVS: 1+ (CEM I/III) ou 2+ (Pozolana); CPF: valor ≤ 5.0%, freq 2/mês (pode ser reduzido para 1/mês se máx. 50% do valor carater. em 12m); Auditoria: 6/ano; Amostras de tipo: 1; Valor est: quantil 10% 95% ci; Notas: declaração obrigatória para CEM I/III, relevante apenas se incluído para pozolana natural/ativada." },
        { "@language": "ro", "@value": "AVS: 1+ (CEM I/III) sau 2+ (Pozolană); CPF: valoare ≤ 5.0%, frecv 2/lună (se poate reduce la 1/lună dacă max 50% din valoarea caract. pe 12luni); Audit: 6/an; Eșantioane de tip: 1; Valoare stat: 10% fractil 95% ci; Note: declarație obligatorie pentru CEM I/III, relevant doar dacă este inclus pentru pozolana naturală/activată." },
        { "@language": "sk", "@value": "AVS: 1+ (CEM I/III) alebo 2+ (Pucolán); FPC: hodnota ≤ 5.0%, frekvencia 2/mesiac (možno znížiť na 1/mesiac, ak max 50% char. hodnoty za 12m); Audit: 6/rok; Vzorky na skúšku typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarácia pre CEM I/III, relevantné iba ak je zahrnuté pre prírodný/aktivovaný pucolán." },
        { "@language": "sl", "@value": "AVS: 1+ (CEM I/III) ali 2+ (Pucolan); NPK: vrednost ≤ 5.0%, pogostost 2/mesec (lahko se zmanjša na 1/mesec, če je maks. 50% karakt. vrednosti v 12m); Presoja: 6/leto; Vzorci za preizkus tipa: 1; Stat vrednost: 10% fraktil 95% ci; Opombe: obvezna deklaracija za CEM I/III, relevantno samo, če je vključeno za naravni/aktivirani pucolan." },
        { "@language": "sv", "@value": "AVS: 1+ (CEM I/III) eller 2+ (Puzzolan); FPC: värde ≤ 5.0%, frekvens 2/månad (kan minskas till 1/månad om max 50% karakt. värde under 12m); Revision: 6/år; Typprovningsprover: 1; Stat värde: 10% fraktil 95% ci; Anmärkningar: obligatorisk deklaration för CEM I/III, endast relevant om det ingår för naturlig/aktiverad puzzolan." }
      ]
    },
    {
      "@id": "dppk-cement:lossOnIgnition1h",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Loss On Ignition 1h" },
        { "@language": "bg", "@value": "Загуба при накаляване 1ч" },
        { "@language": "cs", "@value": "Ztráta žíháním 1h" },
        { "@language": "da", "@value": "Glødetab 1t" },
        { "@language": "de", "@value": "Glühverlust 1h" },
        { "@language": "el", "@value": "Απώλεια κατά την πύρωση 1ω" },
        { "@language": "es", "@value": "Pérdida por calcinación 1h" },
        { "@language": "et", "@value": "Kuumutuskadu 1h" },
        { "@language": "fi", "@value": "Hehkutushäviö 1h" },
        { "@language": "fr", "@value": "Perte au feu 1h" },
        { "@language": "ga", "@value": "Caillteanas ar Adhaint 1u" },
        { "@language": "hr", "@value": "Gubitak žarenjem 1h" },
        { "@language": "hu", "@value": "Izzítási veszteség 1ó" },
        { "@language": "it", "@value": "Perdita al fuoco 1h" },
        { "@language": "lt", "@value": "Kaitinimo nuostoliai 1h" },
        { "@language": "lv", "@value": "Zudumi karsējot 1h" },
        { "@language": "mt", "@value": "Telf mill-Ignizzjoni 1s" },
        { "@language": "nl", "@value": "Gloeiverlies 1u" },
        { "@language": "pl", "@value": "Strata prażenia 1h" },
        { "@language": "pt", "@value": "Perda ao fogo 1h" },
        { "@language": "ro", "@value": "Pierdere la calcinare 1h" },
        { "@language": "sk", "@value": "Strata žíhaním 1h" },
        { "@language": "sl", "@value": "Izguba pri žarenju 1h" },
        { "@language": "sv", "@value": "Glödförlust 1h" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.4.1",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included, ≤ 9.0% declared (fly ash, bottom ash) or ≤ 4.0% declared (silica fume), 1h ignition time." },
        { "@language": "bg", "@value": "AVS: 2+; Бележки: задължителна декларация ако е включено, ≤ 9.0% декларирано (летяща пепел, дънна пепел) или ≤ 4.0% декларирано (силициев прах), 1ч време на накаляване." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace pokud je zahrnuto, ≤ 9.0% deklarováno (popílek, struska) nebo ≤ 4.0% deklarováno (křemičitý úlet), 1h doba žíhání." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration hvis inkluderet, ≤ 9.0% deklareret (flyveaske, bundaske) eller ≤ 4.0% deklareret (silica fume), 1t glødetid." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Erklärung falls enthalten, ≤ 9.0% deklariert (Flugasche, Bodenasche) oder ≤ 4.0% deklariert (Silikastaub), 1h Glühzeit." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται, ≤ 9.0% δηλωμένο (ιπτάμενη τέφρα, τέφρα πυθμένα) ή ≤ 4.0% δηλωμένο (πυριτική παιπάλη), 1ω χρόνος πύρωσης." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye, ≤ 9.0% declarado (cenizas volantes, cenizas de fondo) o ≤ 4.0% declarado (humo de sílice), 1h tiempo de calcinación." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklareerimine kui on lisatud, ≤ 9.0% deklareeritud (lendtuhk, koldetuhk) või ≤ 4.0% deklareeritud (ränituhk), 1h kuumutusaeg." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus jos mukana, ≤ 9.0% ilmoitettu (lentotuhka, pohjatuhka) tai ≤ 4.0% ilmoitettu (silikajauhe), 1h hehkutusaika." },
        { "@language": "fr", "@value": "EVCP: 2+; Remarques: déclaration obligatoire si inclus, ≤ 9.0% déclaré (cendres volantes, cendres de foyer) ou ≤ 4.0% déclaré (fumée de silice), 1h temps de calcination." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh é, ≤ 9.0% dearbhaithe (luath eitilte, luath thóin) nó ≤ 4.0% dearbhaithe (múch shilice), 1u am adhainte." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno, ≤ 9.0% deklarirano (leteći pepeo, donji pepeo) ili ≤ 4.0% deklarirano (silikatna prašina), 1h vrijeme žarenja." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat ha szerepel, ≤ 9.0% bejelentett (pernye, fenékhamu) vagy ≤ 4.0% bejelentett (szilikapor), 1ó izzítási idő." },
        { "@language": "it", "@value": "VVCP: 2+; Note: dichiarazione obbligatoria se incluso, ≤ 9.0% dichiarato (ceneri volanti, ceneri pesanti) o ≤ 4.0% dichiarato (fumi di silice), 1h tempo di calcinazione." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija jei įtraukta, ≤ 9.0% deklaruota (lakieji pelenai, dugno pelenai) arba ≤ 4.0% deklaruota (silicio dioksido dulkės), 1h kaitinimo laikas." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija ja iekļauts, ≤ 9.0% deklarēts (lidojošie pelni, izdedži) vai ≤ 4.0% deklarēts (silīcija mikropulveris), 1h karsēšanas laiks." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni mandatorja jekk inkluż, ≤ 9.0% iddikjarat (irmied li jtir, irmied tal-qiegħ) jew ≤ 4.0% iddikjarat (dħaħen tas-silika), 1s ħin ta' ignizzjoni." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien opgenomen, ≤ 9.0% aangegeven (vliegas, bodemas) of ≤ 4.0% aangegeven (silica fume), 1u gloeitijd." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: deklaracja obowiązkowa jeśli dodano, ≤ 9.0% deklarowane (popiół lotny, żużel) lub ≤ 4.0% deklarowane (pył krzemionkowy), 1h czas prażenia." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído, ≤ 9.0% declarado (cinzas volantes, cinzas de fundo) ou ≤ 4.0% declarado (fumo de sílica), 1h tempo de calcinação." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus, ≤ 9.0% declarat (cenușă zburătoare, cenușă de vatră) sau ≤ 4.0% declarat (silice ultrafină), 1h timp de calcinare." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia ak je zahrnuté, ≤ 9.0% deklarované (popolček, struska) alebo ≤ 4.0% deklarované (kremičitý úlet), 1h čas žíhania." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija če je vključeno, ≤ 9.0% deklarirano (leteči pepel, talni pepel) ali ≤ 4.0% deklarirano (silikatni prah), 1h čas žarenja." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår, ≤ 9.0% deklarerat (flygaska, bottenaska) eller ≤ 4.0% deklarerat (silikastoft), 1h glödtid." }
      ]
    },
    {
      "@id": "dppk-cement:soundness",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Soundness" },
        { "@language": "bg", "@value": "Постоянство на обема" },
        { "@language": "cs", "@value": "Stálost objemu" },
        { "@language": "da", "@value": "Volumenbestandighed" },
        { "@language": "de", "@value": "Raumbeständigkeit" },
        { "@language": "el", "@value": "Σταθερότητα όγκου" },
        { "@language": "es", "@value": "Estabilidad de volumen" },
        { "@language": "et", "@value": "Mahupüsivus" },
        { "@language": "fi", "@value": "Tilavuudenpysyvyys" },
        { "@language": "fr", "@value": "Stabilité de volume" },
        { "@language": "ga", "@value": "Sláine" },
        { "@language": "hr", "@value": "Stalnost volumena" },
        { "@language": "hu", "@value": "Térfogatállandóság" },
        { "@language": "it", "@value": "Stabilità di volume" },
        { "@language": "lt", "@value": "Tūrio pastovumas" },
        { "@language": "lv", "@value": "Apjoma stabilitāte" },
        { "@language": "mt", "@value": "Sodezza" },
        { "@language": "nl", "@value": "Volumebestendigheid" },
        { "@language": "pl", "@value": "Stałość objętości" },
        { "@language": "pt", "@value": "Estabilidade de volume" },
        { "@language": "ro", "@value": "Stabilitatea volumului" },
        { "@language": "sk", "@value": "Stálosť objemu" },
        { "@language": "sl", "@value": "Stalnost prostornine" },
        { "@language": "sv", "@value": "Volymbeständighet" }
      ],
      "dppk:governedBy": "EN 196-3:2016, Clause 7",
      "dppk:unit": { "@id": "dppk-unit:Millimeter" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+ (Primary) or 2+ (Fly ash, Bottom ash, Burnt shale); FPC (Primary): val ≤ 10 mm, freq 1/week; Audit: 6/year; Type Test Samples: 1; Notes: mandatory declaration; Fly/bottom ash tested with 30% ash / 70% CEM I; Burnt shale used instead of cement." },
        { "@language": "bg", "@value": "AVS: 1+ (Първичен) или 2+ (Летяща пепел, Дънна пепел, Изгорял шист); FPC (Първичен): стойност ≤ 10 мм, честота 1/седмица; Одит: 6/година; Типово изпитване проби: 1; Бележки: задължителна декларация; Летяща/дънна пепел тествана с 30% пепел / 70% CEM I; Изгорял шист използван вместо цимент." },
        { "@language": "cs", "@value": "AVS: 1+ (Primární) nebo 2+ (Popílek, Struska, Pálená břidlice); FPC (Primární): hodnota ≤ 10 mm, frekvence 1/týden; Audit: 6/rok; Vzorky typu: 1; Poznámky: povinná deklarace; Popílek/struska testována s 30% popela / 70% CEM I; Pálená břidlice použita místo cementu." },
        { "@language": "da", "@value": "AVS: 1+ (Primær) eller 2+ (Flyveaske, Bundaske, Brændt skifer); FPC (Primær): værdi ≤ 10 mm, frekvens 1/uge; Audit: 6/år; Typeprøvning prøver: 1; Bemærkninger: obligatorisk deklaration; Flyve/bundaske testet med 30% aske / 70% CEM I; Brændt skifer brugt i stedet for cement." },
        { "@language": "de", "@value": "AVS: 1+ (Primär) oder 2+ (Flugasche, Bodenasche, Gebrannter Schiefer); WPK (Primär): Wert ≤ 10 mm, Häufigkeit 1/Woche; Audit: 6/Jahr; Typprüfung Proben: 1; Anmerkungen: obligatorische Erklärung; Flug-/Bodenasche getestet mit 30% Asche / 70% CEM I; Gebrannter Schiefer anstelle von Zement verwendet." },
        { "@language": "el", "@value": "AVS: 1+ (Πρωτεύον) ή 2+ (Ιπτάμενη τέφρα, Τέφρα πυθμένα, ψημένος σχιστόλιθος); FPC (Πρωτεύον): τιμή ≤ 10 mm, συχνότητα 1/εβδομάδα; Έλεγχος: 6/έτος; Δείγματα τύπου: 1; Σημειώσεις: υποχρεωτική δήλωση; Ιπτάμενη/τέφρα πυθμένα ελεγμένη με 30% τέφρα / 70% CEM I; Ψημένος σχιστόλιθος χρησιμοποιείται αντί για τσιμέντο." },
        { "@language": "es", "@value": "AVS: 1+ (Primario) o 2+ (Cenizas volantes, Cenizas de fondo, Esquisto calcinado); CPF (Primario): valor ≤ 10 mm, frec 1/semana; Auditoría: 6/año; Muestras de tipo: 1; Notas: declaración obligatoria; Cenizas volantes/de fondo probadas con 30% ceniza / 70% CEM I; Esquisto calcinado usado en lugar de cemento." },
        { "@language": "et", "@value": "AVS: 1+ (Primaarne) või 2+ (Lendtuhk, Koldetuhk, Põlevkivituhk); FPC (Primaarne): väärtus ≤ 10 mm, sagedus 1/nädal; Audit: 6/aasta; Tüübikatse proovid: 1; Märkused: kohustuslik deklareerimine; Lend-/koldetuhk testitud 30% tuhka / 70% CEM I; Põlevkivituhka kasutatud tsemendi asemel." },
        { "@language": "fi", "@value": "AVS: 1+ (Ensisijainen) tai 2+ (Lentotuhka, Pohjatuhka, Poltettu liuske); FPC (Ensisijainen): arvo ≤ 10 mm, tiheys 1/viikko; Auditointi: 6/vuosi; Tyyppikokeen näytteet: 1; Huomautukset: pakollinen ilmoitus; Lento-/pohjatuhka testattu 30% tuhkaa / 70% CEM I; Poltettua liusketa käytetty sementin sijaan." },
        { "@language": "fr", "@value": "EVCP: 1+ (Primaire) ou 2+ (Cendres volantes, Cendres de foyer, Schiste calciné); CPU (Primaire): valeur ≤ 10 mm, fréq 1/semaine; Audit: 6/an; Échantillons de type: 1; Remarques: déclaration obligatoire; Cendres volantes/foyer testées avec 30% cendres / 70% CEM I; Schiste calciné utilisé au lieu du ciment." },
        { "@language": "ga", "@value": "AVS: 1+ (Príomhúil) nó 2+ (Luath eitilte, Luath thóin, Scealla dóite); FPC (Príomhúil): luach ≤ 10 mm, minicíocht 1/seachtain; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Nótaí: dearbhú éigeantach; Luath eitilte/thóin tástálta le 30% luath / 70% CEM I; Scealla dóite in úsáid in ionad stroighne." },
        { "@language": "hr", "@value": "AVS: 1+ (Primarni) ili 2+ (Leteći pepeo, Donji pepeo, Spaljeni škriljevac); FPC (Primarni): vrijednost ≤ 10 mm, učestalost 1/tjedan; Revizija: 6/godina; Uzorci za tip: 1; Napomene: obvezna deklaracija; Leteći/donji pepeo ispitan s 30% pepela / 70% CEM I; Spaljeni škriljevac korišten umjesto cementa." },
        { "@language": "hu", "@value": "AVS: 1+ (Elsődleges) vagy 2+ (Pernye, Fenékhamu, Égetett pala); ÜGY (Elsődleges): érték ≤ 10 mm, gyakoriság 1/hét; Audit: 6/év; Típusvizsgálati minták: 1; Megjegyzések: kötelező nyilatkozat; Pernye/fenékhamu 30% hamu / 70% CEM I-gyel tesztelve; Égetett pala cement helyett használva." },
        { "@language": "it", "@value": "VVCP: 1+ (Primario) o 2+ (Ceneri volanti, Ceneri pesanti, Scisto calcinato); CPF (Primario): valore ≤ 10 mm, freq 1/settimana; Audit: 6/anno; Campioni di tipo: 1; Note: dichiarazione obbligatoria; Ceneri volanti/pesanti testate con 30% ceneri / 70% CEM I; Scisto calcinato usato al posto del cemento." },
        { "@language": "lt", "@value": "AVS: 1+ (Pirminis) arba 2+ (Lakieji pelenai, Dugno pelenai, Degtas skalūnas); VKS (Pirminis): vertė ≤ 10 mm, dažnis 1/savaitė; Auditas: 6/metai; Tipo bandymo mėginiai: 1; Pastabos: privaloma deklaracija; Lakieji/dugno pelenai išbandyti su 30% pelenų / 70% CEM I; Degtas skalūnas naudotas vietoje cemento." },
        { "@language": "lv", "@value": "AVS: 1+ (Primārais) vai 2+ (Lidojošie pelni, Izdedži, Dedzināts slāneklis); RKS (Primārais): vērtība ≤ 10 mm, biežums 1/nedēļa; Audits: 6/gads; Tipa pārbaudes paraugi: 1; Piezīmes: obligāta deklarācija; Lidojošie/izdedžu pelni testēti ar 30% pelnu / 70% CEM I; Dedzināts slāneklis izmantots cementa vietā." },
        { "@language": "mt", "@value": "AVS: 1+ (Primarju) jew 2+ (Irmied li jtir, Irmied tal-qiegħ, Shale maħruq); FPC (Primarju): val ≤ 10 mm, frekwenza 1/ġimgħa; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Noti: dikjarazzjoni mandatorja; Irmied li jtir/qiegħ ittestjat b'30% irmied / 70% CEM I; Shale maħruq użat minflok siment." },
        { "@language": "nl", "@value": "AVS: 1+ (Primair) of 2+ (Vliegas, Bodemas, Gebrande schalie); FPC (Primair): waarde ≤ 10 mm, frequentie 1/week; Audit: 6/jaar; Typetest monsters: 1; Opmerkingen: verplichte verklaring; Vlieg-/bodemas getest met 30% as / 70% CEM I; Gebrande schalie gebruikt in plaats van cement." },
        { "@language": "pl", "@value": "AVS: 1+ (Podstawowy) lub 2+ (Popiół lotny, Żużel, Łupek palony); ZKP (Podstawowy): wartość ≤ 10 mm, częstotliwość 1/tydzień; Audit: 6/rok; Próbki typu: 1; Uwagi: deklaracja obowiązkowa; Popiół lotny/żużel badany z 30% popiołu / 70% CEM I; Łupek palony użyty zamiast cementu." },
        { "@language": "pt", "@value": "AVS: 1+ (Primário) ou 2+ (Cinzas volantes, Cinzas de fundo, Xisto calcinado); CPF (Primário): valor ≤ 10 mm, freq 1/semana; Auditoria: 6/ano; Amostras de tipo: 1; Notas: declaração obrigatória; Cinzas volantes/fundo testadas com 30% cinza / 70% CEM I; Xisto calcinado usado em vez de cimento." },
        { "@language": "ro", "@value": "AVS: 1+ (Primar) sau 2+ (Cenușă zburătoare, Cenușă de vatră, Șist calcinat); CPF (Primar): valoare ≤ 10 mm, frecv 1/săptămână; Audit: 6/an; Eșantioane de tip: 1; Note: declarație obligatorie; Cenușă zburătoare/vatră testată cu 30% cenușă / 70% CEM I; Șist calcinat utilizat în loc de ciment." },
        { "@language": "sk", "@value": "AVS: 1+ (Primárny) alebo 2+ (Popolček, Struska, Pálená bridlica); FPC (Primárny): hodnota ≤ 10 mm, frekvencia 1/týždeň; Audit: 6/rok; Vzorky na skúšku typu: 1; Poznámky: povinná deklarácia; Popolček/struska testovaná s 30% popola / 70% CEM I; Pálená bridlica použitá namiesto cementu." },
        { "@language": "sl", "@value": "AVS: 1+ (Primarni) ali 2+ (Leteči pepel, Talni pepel, Žgani skrilavec); NPK (Primarni): vrednost ≤ 10 mm, pogostost 1/teden; Presoja: 6/leto; Vzorci za preizkus tipa: 1; Opombe: obvezna deklaracija; Leteči/talni pepel preizkušen s 30% pepela / 70% CEM I; Žgani skrilavec uporabljen namesto cementa." },
        { "@language": "sv", "@value": "AVS: 1+ (Primär) eller 2+ (Flygaska, Bottenaska, Bränd skiffer); FPC (Primär): värde ≤ 10 mm, frekvens 1/vecka; Revision: 6/år; Typprovningsprover: 1; Anmärkningar: obligatorisk deklaration; Flyg-/bottenaska testad med 30% aska / 70% CEM I; Bränd skiffer använd i stället för cement." }
      ]
    },
    {
      "@id": "dppk-cement:heatOfHydration",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Heat Of Hydration" },
        { "@language": "bg", "@value": "Топлина на хидратация" },
        { "@language": "cs", "@value": "Hydratační teplo" },
        { "@language": "da", "@value": "Hydratiseringsvarme" },
        { "@language": "de", "@value": "Hydratationswärme" },
        { "@language": "el", "@value": "Θερμότητα υδάτωσης" },
        { "@language": "es", "@value": "Calor de hidratación" },
        { "@language": "et", "@value": "Hüdratsioonisoojus" },
        { "@language": "fi", "@value": "Hydrataatiolämpö" },
        { "@language": "fr", "@value": "Chaleur d'hydratation" },
        { "@language": "ga", "@value": "Teas Hiodráitithe" },
        { "@language": "hr", "@value": "Toplina hidratacije" },
        { "@language": "hu", "@value": "Hidratációs hő" },
        { "@language": "it", "@value": "Calore di idratazione" },
        { "@language": "lt", "@value": "Hidratacijos šiluma" },
        { "@language": "lv", "@value": "Hidratācijas siltums" },
        { "@language": "mt", "@value": "Sħana tal-Idratazzjoni" },
        { "@language": "nl", "@value": "Hydratatiewarmte" },
        { "@language": "pl", "@value": "Ciepło hydratacji" },
        { "@language": "pt", "@value": "Calor de hidratação" },
        { "@language": "ro", "@value": "Căldură de hidratare" },
        { "@language": "sk", "@value": "Hydratačné teplo" },
        { "@language": "sl", "@value": "Toplota hidratacije" },
        { "@language": "sv", "@value": "Hydratationsvärme" }
      ],
      "dppk:governedBy": "EN 196-9:2010",
      "dppk:unit": { "@id": "dppk-unit:JoulePerGram" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+ (Low heat cement) or 2+ (Activated pozzolana); FPC (Low heat): freq 1/month; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: mandatory declaration (≥ 90 J/g) for pozzolana, or only if required (Type test) for low heat." },
        { "@language": "bg", "@value": "AVS: 1+ (Нискотермичен цимент) или 2+ (Активиран пуцолан); FPC (Нискотермичен): честота 1/месец; Одит: 6/година; Типово изпитване проби: 1; Стат стойност: 10% квантил 95% ci; Бележки: задължителна декларация (≥ 90 J/g) за пуцолан, или само ако се изисква (Типово изпитване) за нискотермичен." },
        { "@language": "cs", "@value": "AVS: 1+ (Cement s nízkým tepelem) nebo 2+ (Aktivovaný pucolán); FPC (Nízké teplo): frekvence 1/měsíc; Audit: 6/rok; Vzorky typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarace (≥ 90 J/g) pro pucolán, nebo pouze pokud je požadováno (Test typu) pro nízké teplo." },
        { "@language": "da", "@value": "AVS: 1+ (Lavvarmecement) eller 2+ (Aktiveret pozzolan); FPC (Lavvarme): frekvens 1/måned; Audit: 6/år; Typeprøvning prøver: 1; Stat værdi: 10% fraktil 95% ci; Bemærkninger: obligatorisk deklaration (≥ 90 J/g) for pozzolan, eller kun hvis påkrævet (Type test) for lavvarme." },
        { "@language": "de", "@value": "AVS: 1+ (Zement mit niedriger Wärmeentwicklung) oder 2+ (Aktiviertes Puzzolan); WPK (Niedrige Wärme): Häufigkeit 1/Monat; Audit: 6/Jahr; Typprüfung Proben: 1; Stat Wert: 10% Fraktil 95% ci; Anmerkungen: obligatorische Erklärung (≥ 90 J/g) für Puzzolan, oder nur falls erforderlich (Typprüfung) für niedrige Wärme." },
        { "@language": "el", "@value": "AVS: 1+ (Τσιμέντο χαμηλής θερμότητας) ή 2+ (Ενεργοποιημένη ποζολάνη); FPC (Χαμηλή θερμότητα): συχνότητα 1/μήνα; Έλεγχος: 6/έτος; Δείγματα τύπου: 1; Στατ τιμή: 10% ποσοστημόριο 95% ci; Σημειώσεις: υποχρεωτική δήλωση (≥ 90 J/g) για ποζολάνη, ή μόνο εάν απαιτείται (Δοκιμή τύπου) για χαμηλή θερμότητα." },
        { "@language": "es", "@value": "AVS: 1+ (Cemento de bajo calor) o 2+ (Puzolana activada); CPF (Bajo calor): frec 1/mes; Auditoría: 6/año; Muestras de tipo: 1; Valor est: cuantil 10% 95% ci; Notas: declaración obligatoria (≥ 90 J/g) para puzolana, o solo si se requiere (Prueba de tipo) para bajo calor." },
        { "@language": "et", "@value": "AVS: 1+ (Madala soojuseraldusega tsement) või 2+ (Aktiveeritud putsolaan); FPC (Madal soojus): sagedus 1/kuu; Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 10% fraktiil 95% ci; Märkused: kohustuslik deklareerimine (≥ 90 J/g) putsolaani puhul või ainult siis, kui on nõutud (Tüübikatse) madala soojuse puhul." },
        { "@language": "fi", "@value": "AVS: 1+ (Matalalämpösementti) tai 2+ (Aktivoitu puzzolaani); FPC (Matalalämpö): tiheys 1/kuukausi; Auditointi: 6/vuosi; Tyyppikokeen näytteet: 1; Stat arvo: 10% fraktiili 95% ci; Huomautukset: pakollinen ilmoitus (≥ 90 J/g) puzzolaanille, tai vain jos vaaditaan (Tyyppikoe) matalalämmölle." },
        { "@language": "fr", "@value": "EVCP: 1+ (Ciment à faible chaleur) ou 2+ (Pouzzolane activée); CPU (Faible chaleur): fréq 1/mois; Audit: 6/an; Échantillons de type: 1; Valeur stat: quantile 10% 95% ci; Remarques: déclaration obligatoire (≥ 90 J/g) pour pouzzolane, ou uniquement si requis (Essai de type) pour faible chaleur." },
        { "@language": "ga", "@value": "AVS: 1+ (Stroighin teas íseal) nó 2+ (Puaslán gníomhachtaithe); FPC (Teas íseal): minicíocht 1/mí; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% ci; Nótaí: dearbhú éigeantach (≥ 90 J/g) do phuaslán, nó ach amháin más gá (Tástáil cineáil) do theas íseal." },
        { "@language": "hr", "@value": "AVS: 1+ (Cement niske topline) ili 2+ (Aktivirani pucolan); FPC (Niska toplina): učestalost 1/mjesec; Revizija: 6/godina; Uzorci za tip: 1; Stat vrijednost: 10% fraktil 95% ci; Napomene: obvezna deklaracija (≥ 90 J/g) za pucolan, ili samo ako je potrebno (Ispitivanje tipa) za nisku toplinu." },
        { "@language": "hu", "@value": "AVS: 1+ (Alacsony hőfejlesztésű cement) vagy 2+ (Aktivált pucolán); ÜGY (Alacsony hő): gyakoriság 1/hónap; Audit: 6/év; Típusvizsgálati minták: 1; Stat érték: 10% fraktilis 95% ci; Megjegyzések: kötelező nyilatkozat (≥ 90 J/g) pucolánhoz, vagy csak ha szükséges (Típusvizsgálat) alacsony hőhöz." },
        { "@language": "it", "@value": "VVCP: 1+ (Cemento a basso calore) o 2+ (Pozzolana attivata); CPF (Basso calore): freq 1/mese; Audit: 6/anno; Campioni di tipo: 1; Valore stat: frattile 10% 95% ci; Note: dichiarazione obbligatoria (≥ 90 J/g) per pozzolana, o solo se richiesto (Prova di tipo) per basso calore." },
        { "@language": "lt", "@value": "AVS: 1+ (Mažos hidratacijos šilumos cementas) arba 2+ (Aktyvuotas pucolanas); VKS (Maža šiluma): dažnis 1/mėn.; Auditas: 6/metai; Tipo bandymo mėginiai: 1; Stat vertė: 10 % fraktilis 95 % ci; Pastabos: privaloma deklaracija (≥ 90 J/g) pucolanui, arba tik jei reikalaujama (Tipo bandymas) mažai šilumai." },
        { "@language": "lv", "@value": "AVS: 1+ (Zema siltuma cements) vai 2+ (Aktivizēts pucolāns); RKS (Zems siltums): biežums 1/mēnesī; Audits: 6/gads; Tipa pārbaudes paraugi: 1; Stat vērtība: 10% fraktile 95% ci; Piezīmes: obligāta deklarācija (≥ 90 J/g) pucolānam, vai tikai tad, ja prasīts (Tipa tests) zemam siltumam." },
        { "@language": "mt", "@value": "AVS: 1+ (Siment ta' sħana baxxa) jew 2+ (Pozzolana attivata); FPC (Sħana baxxa): frekwenza 1/xahar; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil 95% ci; Noti: dikjarazzjoni mandatorja (≥ 90 J/g) għal pozzolana, jew biss jekk meħtieġ (Test tat-tip) għal sħana baxxa." },
        { "@language": "nl", "@value": "AVS: 1+ (Laag warmte cement) of 2+ (Geactiveerde puzzolaan); FPC (Laag warmte): frequentie 1/maand; Audit: 6/jaar; Typetest monsters: 1; Stat waarde: 10% fractiel 95% ci; Opmerkingen: verplichte verklaring (≥ 90 J/g) voor puzzolaan, of alleen indien vereist (Typetest) voor laag warmte." },
        { "@language": "pl", "@value": "AVS: 1+ (Cement o niskim cieple hydratacji) lub 2+ (Aktywowana pucolana); ZKP (Niskie ciepło): częstotliwość 1/miesiąc; Audit: 6/rok; Próbki typu: 1; Wartość stat: 10% kwantyl 95% ci; Uwagi: deklaracja obowiązkowa (≥ 90 J/g) dla pucolany, lub tylko jeśli wymagana (Badanie typu) dla niskiego ciepła." },
        { "@language": "pt", "@value": "AVS: 1+ (Cimento de baixo calor) ou 2+ (Pozolana ativada); CPF (Baixo calor): freq 1/mês; Auditoria: 6/ano; Amostras de tipo: 1; Valor est: quantil 10% 95% ci; Notas: declaração obrigatória (≥ 90 J/g) para pozolana, ou apenas se exigido (Teste de tipo) para baixo calor." },
        { "@language": "ro", "@value": "AVS: 1+ (Ciment cu căldură redusă) sau 2+ (Pozolană activată); CPF (Căldură redusă): frecv 1/lună; Audit: 6/an; Eșantioane de tip: 1; Valoare stat: 10% fractil 95% ci; Note: declarație obligatorie (≥ 90 J/g) pentru pozolană, sau doar dacă este necesar (Test de tip) pentru căldură redusă." },
        { "@language": "sk", "@value": "AVS: 1+ (Cement s nízkym teplom) alebo 2+ (Aktivovaný pucolán); FPC (Nízke teplo): frekvencia 1/mesiac; Audit: 6/rok; Vzorky na skúšku typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarácia (≥ 90 J/g) pre pucolán, alebo iba ak je to požadované (Typová skúška) pre nízke teplo." },
        { "@language": "sl", "@value": "AVS: 1+ (Cement z nizko toploto) ali 2+ (Aktivirani pucolan); NPK (Nizka toplota): pogostost 1/mesec; Presoja: 6/leto; Vzorci za preizkus tipa: 1; Stat vrednost: 10% fraktil 95% ci; Opombe: obvezna deklaracija (≥ 90 J/g) za pucolan, ali samo, če se zahteva (Preizkus tipa) za nizko toploto." },
        { "@language": "sv", "@value": "AVS: 1+ (Lågvärmecement) eller 2+ (Aktiverad puzzolan); FPC (Låg värme): frekvens 1/månad; Revision: 6/år; Typprovningsprover: 1; Stat värde: 10% fraktil 95% ci; Anmärkningar: obligatorisk deklaration (≥ 90 J/g) för puzzolan, eller endast om det krävs (Typprovning) för låg värme." }
      ]
    },
    {
      "@id": "dppk-cement:pozzolanicityHydroxylIonConcentration",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Pozzolanicity Hydroxyl Ion Concentration" },
        { "@language": "bg", "@value": "Пуцоланова активност, концентрация на хидроксилни йони" },
        { "@language": "cs", "@value": "Pucolánová aktivita, koncentrace hydroxylových iontů" },
        { "@language": "da", "@value": "Pozzolanitet hydroxidionkoncentration" },
        { "@language": "de", "@value": "Puzzolanität Hydroxylionen-Konzentration" },
        { "@language": "el", "@value": "Ποζολανικότητα, συγκέντρωση ιόντων υδροξυλίου" },
        { "@language": "es", "@value": "Puzolanicidad, concentración de iones hidroxilo" },
        { "@language": "et", "@value": "Putsolaansus hüdroksüülioonide kontsentratsioon" },
        { "@language": "fi", "@value": "Puzzolaanisuus hydroksyyli-ionikonsentraatio" },
        { "@language": "fr", "@value": "Pouzzolanicité, concentration en ions hydroxyles" },
        { "@language": "ga", "@value": "Puaslánacht Tiúchan Ian Hiodrocsaile" },
        { "@language": "hr", "@value": "Pucolanska aktivnost, koncentracija hidroksilnih iona" },
        { "@language": "hu", "@value": "Pucolán aktivitás, hidroxil-ion koncentráció" },
        { "@language": "it", "@value": "Pozzolanicità, concentrazione di ioni idrossile" },
        { "@language": "lt", "@value": "Pucolaniškumas hidroksilo jonų koncentracija" },
        { "@language": "lv", "@value": "Pucolāna aktivitāte, hidroksiljonu koncentrācija" },
        { "@language": "mt", "@value": "Pozzolanità Konċentrazzjoni tal-Joni Idroksili" },
        { "@language": "nl", "@value": "Puzzolaniteit hydroxylionconcentratie" },
        { "@language": "pl", "@value": "Pucolanowość, stężenie jonów wodorotlenowych" },
        { "@language": "pt", "@value": "Pozolanicidade, concentração de iões hidroxilo" },
        { "@language": "ro", "@value": "Pozolanicitate, concentrația ionilor de hidroxil" },
        { "@language": "sk", "@value": "Pucolánová aktivita, koncentrácia hydroxylových iónov" },
        { "@language": "sl", "@value": "Pucolanska aktivnost, koncentracija hidroksilnih ionov" },
        { "@language": "sv", "@value": "Puzzolanitet hydroxyljonkoncentration" }
      ],
      "dppk:governedBy": "EN 196-5:2011",
      "dppk:unit": { "@id": "dppk-unit:MillimolePerLiter" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: freq 2/month; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: only for pozzolanic cements, test at 15 days, pozzolanicity means [CaO] < 350/([OH]-15), not on the individual values for [CaO] nor [OH]; only if required (Type test)." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: честота 2/месец; Одит: 6/година; Типово изпитване проби: 1; Стат стойност: 10% квантил 95% ci; Бележки: само за пуцоланови цименти, тест на 15 дни, пуцоланова активност означава [CaO] < 350/([OH]-15), не за отделните стойности на [CaO] или [OH]; само ако се изисква (Типово изпитване)." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: frekvence 2/měsíc; Audit: 6/rok; Vzorky typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: pouze pro pucolánové cementy, test po 15 dnech, pucolánová aktivita znamená [CaO] < 350/([OH]-15), ne pro jednotlivé hodnoty [CaO] ani [OH]; pouze pokud je požadováno (Test typu)." },
        { "@language": "da", "@value": "AVS: 1+; FPC: frekvens 2/måned; Audit: 6/år; Typeprøvning prøver: 1; Stat værdi: 10% fraktil 95% ci; Bemærkninger: kun for pozzolancementer, test ved 15 dage, pozzolanitet betyder [CaO] < 350/([OH]-15), ikke på de enkelte værdier for [CaO] eller [OH]; kun hvis påkrævet (Type test)." },
        { "@language": "de", "@value": "AVS: 1+; WPK: Häufigkeit 2/Monat; Audit: 6/Jahr; Typprüfung Proben: 1; Stat Wert: 10% Fraktil 95% ci; Anmerkungen: nur für Puzzolanzemente, Prüfung nach 15 Tagen, Puzzolanität bedeutet [CaO] < 350/([OH]-15), nicht auf die Einzelwerte für [CaO] oder [OH]; nur falls erforderlich (Typprüfung)." },
        { "@language": "el", "@value": "AVS: 1+; FPC: συχνότητα 2/μήνα; Έλεγχος: 6/έτος; Δείγματα τύπου: 1; Στατ τιμή: 10% ποσοστημόριο 95% ci; Σημειώσεις: μόνο για ποζολανικά τσιμέντα, δοκιμή στις 15 ημέρες, ποζολανικότητα σημαίνει [CaO] < 350/([OH]-15), όχι στις μεμονωμένες τιμές για [CaO] ούτε [OH]; μόνο εάν απαιτείται (Δοκιμή τύπου)." },
        { "@language": "es", "@value": "AVS: 1+; CPF: frec 2/mes; Auditoría: 6/año; Muestras de tipo: 1; Valor est: cuantil 10% 95% ci; Notas: solo para cementos puzolánicos, prueba a los 15 días, puzolanicidad significa [CaO] < 350/([OH]-15), no en los valores individuales para [CaO] ni [OH]; solo si se requiere (Prueba de tipo)." },
        { "@language": "et", "@value": "AVS: 1+; FPC: sagedus 2/kuu; Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 10% fraktiil 95% ci; Märkused: ainult putsolaantsementide puhul, katse 15 päeva möödudes, putsolaansus tähendab [CaO] < 350/([OH]-15), mitte [CaO] ega [OH] üksikväärtuste põhjal; ainult siis, kui on nõutud (Tüübikatse)." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: tiheys 2/kuukausi; Auditointi: 6/vuosi; Tyyppikokeen näytteet: 1; Stat arvo: 10% fraktiili 95% ci; Huomautukset: vain puzzolaanisementteille, koe 15 päivän iässä, puzzolaanisuus tarkoittaa [CaO] < 350/([OH]-15), ei [CaO]:n eikä [OH]:n yksittäisille arvoille; vain jos vaaditaan (Tyyppikoe)." },
        { "@language": "fr", "@value": "EVCP: 1+; CPU: fréq 2/mois; Audit: 6/an; Échantillons de type: 1; Valeur stat: quantile 10% 95% ci; Remarques: uniquement pour les ciments pouzzolaniques, essai à 15 jours, la pouzzolanicité signifie [CaO] < 350/([OH]-15), pas sur les valeurs individuelles pour [CaO] ni [OH]; uniquement si requis (Essai de type)." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: minicíocht 2/mí; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% ci; Nótaí: do stroighne puaslánacha amháin, tástáil ag 15 lá, is éard is puaslánacht ann ná [CaO] < 350/([OH]-15), ní ar na luachanna aonair do [CaO] ná [OH]; ach amháin más gá (Tástáil cineáil)." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: učestalost 2/mjesec; Revizija: 6/godina; Uzorci za tip: 1; Stat vrijednost: 10% fraktil 95% ci; Napomene: samo za pucolanske cemente, ispitivanje nakon 15 dana, pucolanska aktivnost znači [CaO] < 350/([OH]-15), ne na pojedinačne vrijednosti za [CaO] ni [OH]; samo ako je potrebno (Ispitivanje tipa)." },
        { "@language": "hu", "@value": "AVS: 1+; ÜGY: gyakoriság 2/hónap; Audit: 6/év; Típusvizsgálati minták: 1; Stat érték: 10% fraktilis 95% ci; Megjegyzések: csak pucoláncementekhez, vizsgálat 15 naposan, a pucolán aktivitás [CaO] < 350/([OH]-15) jelent, nem az egyes [CaO] vagy [OH] értékekre; csak ha szükséges (Típusvizsgálat)." },
        { "@language": "it", "@value": "VVCP: 1+; CPF: freq 2/mese; Audit: 6/anno; Campioni di tipo: 1; Valore stat: frattile 10% 95% ci; Note: solo per cementi pozzolanici, prova a 15 giorni, pozzolanicità significa [CaO] < 350/([OH]-15), non sui valori individuali per [CaO] né [OH]; solo se richiesto (Prova di tipo)." },
        { "@language": "lt", "@value": "AVS: 1+; VKS: dažnis 2/mėn.; Auditas: 6/metai; Tipo bandymo mėginiai: 1; Stat vertė: 10 % fraktilis 95 % ci; Pastabos: tik pucolaniniams cementams, bandymas po 15 dienų, pucolaniškumas reiškia [CaO] < 350/([OH]-15), o ne atskiroms [CaO] ir [OH] vertėms; tik jei reikalaujama (Tipo bandymas)." },
        { "@language": "lv", "@value": "AVS: 1+; RKS: biežums 2/mēnesī; Audits: 6/gads; Tipa pārbaudes paraugi: 1; Stat vērtība: 10% fraktile 95% ci; Piezīmes: tikai pucolāna cementiem, tests 15 dienu vecumā, pucolāna aktivitāte nozīmē [CaO] < 350/([OH]-15), ne uz atsevišķām [CaO] vai [OH] vērtībām; tikai tad, ja prasīts (Tipa tests)." },
        { "@language": "mt", "@value": "AVS: 1+; FPC: frekwenza 2/xahar; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil 95% ci; Noti: għal simenti pozzolaniċi biss, test wara 15-il jum, pozzolanità tfisser [CaO] < 350/([OH]-15), mhux fuq il-valuri individwali għal [CaO] jew [OH]; biss jekk meħtieġ (Test tat-tip)." },
        { "@language": "nl", "@value": "AVS: 1+; FPC: frequentie 2/maand; Audit: 6/jaar; Typetest monsters: 1; Stat waarde: 10% fractiel 95% ci; Opmerkingen: alleen voor puzzolaancementen, test na 15 dagen, puzzolaniteit betekent [CaO] < 350/([OH]-15), niet op de individuele waarden voor [CaO] of [OH]; alleen indien vereist (Typetest)." },
        { "@language": "pl", "@value": "AVS: 1+; ZKP: częstotliwość 2/miesiąc; Audit: 6/rok; Próbki typu: 1; Wartość stat: 10% kwantyl 95% ci; Uwagi: tylko dla cementów pucolanowych, badanie po 15 dniach, pucolanowość oznacza [CaO] < 350/([OH]-15), nie dla pojedynczych wartości [CaO] ani [OH]; tylko jeśli wymagana (Badanie typu)." },
        { "@language": "pt", "@value": "AVS: 1+; CPF: freq 2/mês; Auditoria: 6/ano; Amostras de tipo: 1; Valor est: quantil 10% 95% ci; Notas: apenas para cimentos pozolânicos, ensaio aos 15 dias, pozolanicidade significa [CaO] < 350/([OH]-15), não sobre os valores individuais para [CaO] nem [OH]; apenas se exigido (Teste de tipo)." },
        { "@language": "ro", "@value": "AVS: 1+; CPF: frecv 2/lună; Audit: 6/an; Eșantioane de tip: 1; Valoare stat: 10% fractil 95% ci; Note: doar pentru cimenturi pozolanice, testare la 15 zile, pozolanicitatea înseamnă [CaO] < 350/([OH]-15), nu pe valorile individuale pentru [CaO] sau [OH]; doar dacă este necesar (Test de tip)." },
        { "@language": "sk", "@value": "AVS: 1+; FPC: frekvencia 2/mesiac; Audit: 6/rok; Vzorky na skúšku typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: len pre pucolánové cementy, skúška po 15 dňoch, pucolánová aktivita znamená [CaO] < 350/([OH]-15), nie na jednotlivé hodnoty pre [CaO] ani [OH]; iba ak je to požadované (Typová skúška)." },
        { "@language": "sl", "@value": "AVS: 1+; NPK: pogostost 2/mesec; Presoja: 6/leto; Vzorci za preizkus tipa: 1; Stat vrednost: 10% fraktil 95% ci; Opombe: samo za pucolanske cemente, preskus po 15 dneh, pucolanska aktivnost pomeni [CaO] < 350/([OH]-15), ne na posamezne vrednosti za [CaO] ali [OH]; samo, če se zahteva (Preizkus tipa)." },
        { "@language": "sv", "@value": "AVS: 1+; FPC: frekvens 2/månad; Revision: 6/år; Typprovningsprover: 1; Stat värde: 10% fraktil 95% ci; Anmärkningar: endast för puzzolancement, provning vid 15 dygn, puzzolanitet betyder [CaO] < 350/([OH]-15), inte på de enskilda värdena för [CaO] eller [OH]; endast om det krävs (Typprovning)." }
      ]
