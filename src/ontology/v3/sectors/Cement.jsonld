        { "@language": "bg", "@value": "AVS: 1+ или 2+; FPC (AVS 1+): честота 2/месец; Одит: 6/година; Проби за изпитване на типа: 1; Стат. стойност: 10% фрактил 95% ci; Забележки: за специални приложения, само ако се изисква." },
        { "@language": "cs", "@value": "AVS: 1+ nebo 2+; FPC (AVS 1+): frekvence 2/měsíc; Audit: 6/rok; Vzorky pro zkoušku typu: 1; Stat. hodnota: 10% kvantil 95% is; Poznámky: pro speciální aplikace, pouze pokud je to požadováno." },
        { "@language": "da", "@value": "AVS: 1+ eller 2+; FPC (AVS 1+): frekvens 2/måned; Audit: 6/år; Typeprøvningsprøver: 1; Stat. værdi: 10% fraktil 95% ki; Bemærkninger: til særlige anvendelser, kun hvis påkrævet." },
        { "@language": "de", "@value": "AVS: 1+ oder 2+; WPK (AVS 1+): Häufigkeit 2/Monat; Audit: 6/Jahr; Typprüfproben: 1; Stat. Wert: 10 %-Fraktil 95 %-VI; Anmerkungen: für besondere Anwendungen, nur wenn erforderlich." },
        { "@language": "el", "@value": "AVS: 1+ ή 2+; FPC (AVS 1+): συχνότητα 2/μήνα; Έλεγχος: 6/έτος; Δείγματα δοκιμής τύπου: 1; Στατ. τιμή: ποσοστημόριο 10% 95% ci; Σημειώσεις: για ειδικές εφαρμογές, μόνο εάν απαιτείται." },
        { "@language": "es", "@value": "AVS: 1+ o 2+; FPC (AVS 1+): frecuencia 2/mes; Auditoría: 6/año; Muestras de ensayo de tipo: 1; Valor est.: cuantil 10 % 95 % ic; Notas: para aplicaciones especiales, solo si se requiere." },
        { "@language": "et", "@value": "AVS: 1+ või 2+; FPC (AVS 1+): sagedus 2/kuus; Audit: 6/aastas; Tüübikatsetuse proovid: 1; Stat. väärtus: 10% fraktiil 95% uv; Märkused: erirakenduste puhul, ainult nõudmisel." },
        { "@language": "fi", "@value": "AVS: 1+ tai 2+; FPC (AVS 1+): tiheys 2/kk; Auditointi: 6/vuosi; Tyyppikoenäytteet: 1; Tilastollinen arvo: 10 % fraktiili 95 % lv; Huomautukset: erityiskäyttöön, vain jos vaaditaan." },
        { "@language": "fr", "@value": "AVS : 1+ ou 2+; FPC (AVS 1+) : fréq 2/mois; Audit : 6/an; Échantillons d'essai de type : 1; Valeur stat. : fractile 10 % ic 95 %; Remarques : pour les applications spéciales, uniquement si nécessaire." },
        { "@language": "ga", "@value": "AVS: 1+ nó 2+; FPC (AVS 1+): minicíocht 2/mí; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% cm; Nótaí: le haghaidh feidhmchlár speisialta, ach amháin más gá." },
        { "@language": "hr", "@value": "AVS: 1+ ili 2+; FPC (AVS 1+): učestalost 2/mjesečno; Revizija: 6/godišnje; Uzorci za ispitivanje tipa: 1; Stat. vrijednost: 10% fraktila 95% pi; Napomene: za posebne primjene, samo ako se zahtijeva." },
        { "@language": "hu", "@value": "AVS: 1+ vagy 2+; FPC (AVS 1+): gyakoriság 2/hó; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 10% fraktilis 95% mk; Megjegyzések: speciális alkalmazásokhoz, csak ha szükséges." },
        { "@language": "it", "@value": "AVS: 1+ o 2+; FPC (AVS 1+): freq 2/mese; Audit: 6/anno; Campioni di prova di tipo: 1; Valore stat.: frattile 10% ic 95%; Note: per applicazioni speciali, solo se richiesto." },
        { "@language": "lt", "@value": "AVS: 1+ arba 2+; FPC (AVS 1+): dažnumas 2/mėn.; Auditas: 6/metus; Tipo bandymo mėginiai: 1; Stat. vertė: 10% fraktilis 95% pi; Pastabos: specialiam naudojimui, tik jei reikalaujama." },
        { "@language": "lv", "@value": "AVS: 1+ vai 2+; FPC (AVS 1+): biežums 2/mēnesī; Audits: 6/gadā; Tipa testa paraugi: 1; Stat. vērtība: 10% fraktīle 95% ti; Piezīmes: īpašiem pielietojumiem, tikai ja nepieciešams." },
