        { "@language": "en", "@value": "AVS: 2+; Notes: relevant only if included; determine total MgO (EN 196-2) and convert to MgCO3." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: уместно само ако е включено; определете общия MgO (EN 196-2) и конвертирайте в MgCO3." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze pokud je zahrnuto; stanovte celkový MgO (EN 196-2) a přepočítejte na MgCO3." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant, hvis inkluderet; bestem total MgO (EN 196-2) og omdan til MgCO3." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant, falls enthalten; Gesamt-MgO bestimmen (EN 196-2) und in MgCO3 umrechnen." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εάν περιλαμβάνεται· προσδιορίστε το συνολικό MgO (EN 196-2) και μετατρέψτε σε MgCO3." },
        { "@language": "es", "@value": "AVS: 2+; Notas: relevante solo si se incluye; determinar el MgO total (EN 196-2) y convertir a MgCO3." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui on lisatud; määrake kogu MgO (EN 196-2) ja teisendage see MgCO3-ks." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: merkityksellinen vain, jos sisältyy; määritä kokonais-MgO (EN 196-2) ja muunna MgCO3:ksi." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: pertinent seulement si inclus; déterminer le MgO total (EN 196-2) et le convertir en MgCO3." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha amháin má chuirtear san áireamh; cinntigh iomlán MgO (EN 196-2) agus athraigh go MgCO3." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: relevantno samo ako je uključeno; odredite ukupni MgO (EN 196-2) i pretvorite u MgCO3." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha tartalmazza; határozza meg a teljes MgO-t (EN 196-2) és alakítsa át MgCO3-má." },
        { "@language": "it", "@value": "AVS: 2+; Note: rilevante solo se incluso; determinare il MgO totale (EN 196-2) e convertire in MgCO3." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: aktualu tik tuo atveju, jei įtraukta; nustatyti bendrą MgO (EN 196-2) ir paversti į MgCO3." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: attiecas tikai tad, ja tas ir iekļauts; nosaka kopējo MgO (EN 196-2) un pārveido par MgCO3." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: rilevanti biss jekk inkluż; iddetermina l-MgO totali (EN 196-2) u kkonverti f'MgCO3." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: alleen relevant indien inbegrepen; bepaal totale MgO (EN 196-2) en converteer naar MgCO3." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: istotne tylko wtedy, gdy uwzględniono; oznaczyć całkowity MgO (EN 196-2) i przeliczyć na MgCO3." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: relevante apenas se incluído; determinar o MgO total (EN 196-2) e converter para MgCO3." },
        { "@language": "ro", "@value": "AVS: 2+; Note: relevant numai dacă este inclus; determinați MgO total (EN 196-2) și convertiți în MgCO3." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: relevantné len ak je zahrnuté; stanovte celkový MgO (EN 196-2) a prepočítajte na MgCO3." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: pomembno le, če je vključeno; določite celotni MgO (EN 196-2) in pretvorite v MgCO3." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: endast relevant om det ingår; bestäm total MgO (EN 196-2) och omvandla till MgCO3." }
      ]
    },
    {
      "@id": "dppk-cement:sumCalciumCarbonateAndMagnesiumCarbonate",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Sum Calcium Carbonate And Magnesium Carbonate" },
        { "@language": "bg", "@value": "Сума от калциев карбонат и магнезиев карбонат" },
        { "@language": "cs", "@value": "Součet uhličitanu vápenatého a uhličitanu hořečnatého" },
        { "@language": "da", "@value": "Sum calciumkarbonat og magnesiumkarbonat" },
        { "@language": "de", "@value": "Summe Calciumcarbonat und Magnesiumcarbonat" },
        { "@language": "el", "@value": "Άθροισμα ανθρακικού ασβεστίου και ανθρακικού μαγνησίου" },
        { "@language": "es", "@value": "Suma de carbonato de calcio y carbonato de magnesio" },
        { "@language": "et", "@value": "Kaltsiumkarbonaadi ja magneesiumkarbonaadi summa" },
        { "@language": "fi", "@value": "Kalsiumkarbonaatin ja magnesiumkarbonaatin summa" },
        { "@language": "fr", "@value": "Somme de carbonate de calcium et carbonate de magnésium" },
        { "@language": "ga", "@value": "Suim Carbónáit Chailciam agus Carbónáit Mhaignéisiam" },
        { "@language": "hr", "@value": "Zbroj kalcijevog karbonata i magnezijevog karbonata" },
        { "@language": "hu", "@value": "Kalcium-karbonát és magnézium-karbonát összege" },
        { "@language": "it", "@value": "Somma di carbonato di calcio e carbonato di magnesio" },
        { "@language": "lt", "@value": "Kalcio karbonato ir magnio karbonato suma" },
        { "@language": "lv", "@value": "Kalcija karbonāta un magnija karbonāta summa" },
        { "@language": "mt", "@value": "Somma Karbonat tal-Kalċju u Karbonat tal-Magneżju" },
        { "@language": "nl", "@value": "Som calciumcarbonaat en magnesiumcarbonaat" },
        { "@language": "pl", "@value": "Suma węglanu wapnia i węglanu magnezu" },
        { "@language": "pt", "@value": "Soma de carbonato de cálcio e carbonato de magnésio" },
        { "@language": "ro", "@value": "Suma carbonatului de calciu și a carbonatului de magneziu" },
        { "@language": "sk", "@value": "Súčet uhličitanu vápenatého a uhličitanu horečnatého" },
        { "@language": "sl", "@value": "Vsota kalcijevega karbonata in magnezijevega karbonata" },
        { "@language": "sv", "@value": "Summa kalciumkarbonat och magnesiumkarbonat" }
      ],
      "dppk:governedBy": "EN 196-2:2026",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 75.0% declared)." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≥ 75.0% декларирано)." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 75.0% deklarováno)." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≥ 75.0% deklareret)." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Erklärung, falls enthalten (≥ 75.0% deklariert)." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 75.0% δηλωμένο)." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 75.0% declarado)." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui on lisatud (≥ 75.0% deklareeritud)." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≥ 75.0 % ilmoitettu)." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 75.0% déclaré)." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 75.0% dearbhaithe)." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 75.0% deklarirano)." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 75.0% deklarált)." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 75.0% dichiarato)." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 75.0% deklaruota)." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 75.0% deklarēts)." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluża (≥ 75.0% iddikjarat)." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≥ 75.0% gedeclareerd)." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: deklaracja obowiązkowa, jeśli uwzględniono (≥ 75.0% deklarowane)." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 75.0% declarado)." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 75.0% declarat)." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 75.0% deklarované)." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 75.0 % deklarirano)." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 75.0% deklarerat)." }
      ]
    },
    {
      "@id": "dppk-cement:specificSurfaceArea",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Specific Surface Area" },
        { "@language": "bg", "@value": "Специфична повърхнина" },
        { "@language": "cs", "@value": "Měrný povrch" },
        { "@language": "da", "@value": "Specifikt overfladeareal" },
        { "@language": "de", "@value": "Spezifische Oberfläche" },
        { "@language": "el", "@value": "Ειδικό εμβαδόν επιφάνειας" },
        { "@language": "es", "@value": "Superficie específica" },
        { "@language": "et", "@value": "Eripind" },
        { "@language": "fi", "@value": "Ominaispinta-ala" },
        { "@language": "fr", "@value": "Surface spécifique" },
        { "@language": "ga", "@value": "Achar Dromchla Sonrach" },
        { "@language": "hr", "@value": "Specifična površina" },
        { "@language": "hu", "@value": "Fajlagos felület" },
        { "@language": "it", "@value": "Superficie specifica" },
        { "@language": "lt", "@value": "Savitasis paviršiaus plotas" },
        { "@language": "lv", "@value": "Īpatnējais virsmas laukums" },
        { "@language": "mt", "@value": "Erja tal-Wiċċ Speċifika" },
        { "@language": "nl", "@value": "Specifiek oppervlak" },
        { "@language": "pl", "@value": "Powierzchnia właściwa" },
        { "@language": "pt", "@value": "Área de superfície específica" },
        { "@language": "ro", "@value": "Suprafață specifică" },
        { "@language": "sk", "@value": "Merný povrch" },
        { "@language": "sl", "@value": "Specifična površina" },
        { "@language": "sv", "@value": "Specifik yta" }
      ],
      "dppk:governedBy": "ISO 9277:2022",
      "dppk:unit": { "@id": "dppk-unit:SquareMeterPerGram" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 15.0 m²/g declared) for silica fume, or relevant only if included for pozzolana." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≥ 15.0 m²/g декларирано) за силициев прах, или уместно само ако е включено за пуцолан." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 15.0 m²/g deklarováno) pro křemičitý úlet, nebo relevantní pouze pokud je zahrnuto pro pucolán." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≥ 15.0 m²/g deklareret) for mikrosilica, eller kun relevant, hvis inkluderet for puzzolan." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Erklärung, falls enthalten (≥ 15.0 m²/g deklariert) für Silikastaub, oder nur relevant, falls enthalten für Puzzolan." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 15.0 m²/g δηλωμένο) για πυριτική παιπάλη, ή σχετικό μόνο εάν περιλαμβάνεται για ποζολάνη." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 15.0 m²/g declarado) para humo de sílice, o relevante solo si se incluye para puzolana." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui see on lisatud (≥ 15.0 m²/g deklareeritud) ränidioksiiditolmu puhul, või asjakohane ainult siis, kui see on lisatud potsolaani puhul." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≥ 15.0 m²/g ilmoitettu) silikajauheelle, tai merkityksellinen vain, jos sisältyy putsolaanille." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 15.0 m²/g déclaré) pour la fumée de silice, ou pertinent seulement si inclus pour la pouzzolane." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 15.0 m²/g dearbhaithe) do mhúch shilice, nó ábhartha amháin má chuirtear san áireamh do phuisealán." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 15.0 m²/g deklarirano) za silicijsku prašinu, ili relevantno samo ako je uključeno za pucolan." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 15.0 m²/g deklarált) a szilikaporhoz, vagy csak akkor releváns, ha tartalmazza a puccolánhoz." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 15.0 m²/g dichiarato) per fumi di silice, o rilevante solo se incluso per pozzolana." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 15.0 m²/g deklaruota) silicio dioksido dulkėms, arba aktualu tik jei įtraukta pucolanui." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 15.0 m²/g deklarēts) silīcija dioksīda putekļiem, vai attiecas tikai tad, ja tas ir iekļauts pucolānam." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluża (≥ 15.0 m²/g iddikjarat) għal dħaħen tas-silika, jew rilevanti biss jekk inkluża għall-pozzolana." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≥ 15.0 m²/g gedeclareerd) voor silicastof, of alleen relevant indien inbegrepen voor puzzolaan." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: deklaracja obowiązkowa, jeśli jest uwzględniony (≥ 15.0 m²/g deklarowane) dla pyłu krzemionkowego, lub istotne tylko wtedy, gdy uwzględniono dla pucolany." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 15.0 m²/g declarado) para fumo de sílica, ou relevante apenas se incluído para pozolana." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 15.0 m²/g declarat) pentru praful de silice, sau relevant numai dacă este inclus pentru puzzolană." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 15.0 m²/g deklarované) pre kremičitý úlet, alebo relevantné len ak je zahrnuté pre pucolán." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 15.0 m²/g deklarirano) za mikrosiliko, ali pomembno le, če je vključeno za pucolan." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 15.0 m²/g deklarerat) för silikastoft, eller endast relevant om det ingår för puzzolan." }
      ]
    },
    {
      "@id": "dppk-cement:compressiveStrength8020Mix28Days",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Compressive Strength 80/20 Mix 28 Days" },
        { "@language": "bg", "@value": "Якост на натиск 80/20 смес 28 дни" },
        { "@language": "cs", "@value": "Pevnost v tlaku směs 80/20 28 dní" },
        { "@language": "da", "@value": "Trykstyrke 80/20 blanding 28 dage" },
        { "@language": "de", "@value": "Druckfestigkeit 80/20-Mischung 28 Tage" },
        { "@language": "el", "@value": "Αντοχή σε θλίψη μίγμα 80/20 28 ημερών" },
        { "@language": "es", "@value": "Resistencia a compresión mezcla 80/20 28 días" },
        { "@language": "et", "@value": "Survetugevus 80/20 segu 28 päeva" },
        { "@language": "fi", "@value": "Puristuslujuus 80/20-seos 28 vuorokautta" },
        { "@language": "fr", "@value": "Résistance à la compression mélange 80/20 28 jours" },
        { "@language": "ga", "@value": "Neart Comhbhrúite meascán 80/20 28 lá" },
        { "@language": "hr", "@value": "Tlačna čvrstoća 80/20 mješavina 28 dana" },
        { "@language": "hu", "@value": "Nyomószilárdság 80/20 keverék 28 nap" },
        { "@language": "it", "@value": "Resistenza a compressione miscela 80/20 28 giorni" },
        { "@language": "lt", "@value": "Gniuždymo stipris 80/20 mišinys 28 dienos" },
        { "@language": "lv", "@value": "Spiedes stiprība 80/20 maisījums 28 dienas" },
        { "@language": "mt", "@value": "Qawwa kompressiva taħlita 80/20 28 jum" },
        { "@language": "nl", "@value": "Druksterkte 80/20 mengsel 28 dagen" },
        { "@language": "pl", "@value": "Wytrzymałość na ściskanie mieszanka 80/20 28 dni" },
        { "@language": "pt", "@value": "Resistência à compressão mistura 80/20 28 dias" },
        { "@language": "ro", "@value": "Rezistență la compresiune amestec 80/20 28 zile" },
        { "@language": "sk", "@value": "Pevnosť v tlaku zmes 80/20 28 dní" },
        { "@language": "sl", "@value": "Tlačna trdnost 80/20 mešanica 28 dni" },
        { "@language": "sv", "@value": "Tryckhållfasthet 80/20-blandning 28 dagar" }
      ],
      "dppk:governedBy": "EN 196-1:2026",
      "dppk:unit": { "@id": "dppk-unit:Megapascal" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: relevant only if included, for special applications; mix contains 80% natural/activated pozzolana." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: уместно само ако е включено, за специални приложения; сместа съдържа 80% естествен/активиран пуцолан." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze pokud je zahrnuto, pro speciální aplikace; směs obsahuje 80% přírodního/aktivovaného pucolánu." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant, hvis inkluderet, til specielle applikationer; blanding indeholder 80% naturlig/aktiveret puzzolan." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant, falls enthalten, für spezielle Anwendungen; Mischung enthält 80% natürlichen/aktivierten Puzzolan." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εάν περιλαμβάνεται, για ειδικές εφαρμογές· το μίγμα περιέχει 80% φυσική/ενεργοποιημένη ποζολάνη." },
        { "@language": "es", "@value": "AVS: 2+; Notas: relevante solo si se incluye, para aplicaciones especiales; la mezcla contiene 80% puzolana natural/activada." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui on lisatud, erirakenduste puhul; segu sisaldab 80% looduslikku/aktiveeritud potsolaani." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: merkityksellinen vain, jos sisältyy, erityissovelluksiin; seos sisältää 80 % luonnollista/aktivoitua putsolaania." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: pertinent seulement si inclus, pour des applications spéciales; le mélange contient 80% de pouzzolane naturelle/activée." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha amháin má chuirtear san áireamh, d'fheidhmeanna speisialta; tá 80% puisealán nádúrtha/gníomhachtaithe sa mheascán." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: relevantno samo ako je uključeno, za posebne primjene; mješavina sadrži 80% prirodnog/aktiviranog pucolana." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha tartalmazza, speciális alkalmazásokhoz; a keverék 80% természetes/aktivált puccolánt tartalmaz." },
        { "@language": "it", "@value": "AVS: 2+; Note: rilevante solo se incluso, per applicazioni speciali; la miscela contiene 80% pozzolana naturale/attivata." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: aktualu tik tuo atveju, jei įtraukta, specialioms taikymo sritims; mišinyje yra 80% natūralaus / aktyvuoto pucolano." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: attiecas tikai tad, ja tas ir iekļauts, īpašiem lietojumiem; maisījums satur 80% dabīgā/aktivizētā pucolāna." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: rilevanti biss jekk inkluż, għal applikazzjonijiet speċjali; it-taħlita fiha 80% pozzolana naturali/attivata." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: alleen relevant indien inbegrepen, voor speciale toepassingen; mengsel bevat 80% natuurlijk/geactiveerd puzzolaan." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: istotne tylko wtedy, gdy uwzględniono, do specjalnych zastosowań; mieszanka zawiera 80% naturalnej/aktywowanej pucolany." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: relevante apenas se incluído, para aplicações especiais; a mistura contém 80% de pozolana natural/ativada." },
        { "@language": "ro", "@value": "AVS: 2+; Note: relevant numai dacă este inclus, pentru aplicații speciale; amestecul conține 80% puzzolană naturală/activată." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: relevantné len ak je zahrnuté, pre špeciálne aplikácie; zmes obsahuje 80% prírodného/aktivovaného pucolánu." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: pomembno le, če je vključeno, za posebne aplikacije; mešanica vsebuje 80 % naravnega/aktiviranega pucolana." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: endast relevant om det ingår, för speciella tillämpningar; blandningen innehåller 80% naturlig/aktiverad puzzolan." }
      ]
    },
