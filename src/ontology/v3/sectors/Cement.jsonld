        { "@language": "hr", "@value": "AVS: 1+; FPC: min. učestalost 2/tjedan; Revizija: 6/godina; Uzorci za ispitivanje tipa: 1; Stat. vrijednost: 5% fraktil 95% ci; Napomene: samo ako se zahtijeva (Ispitivanje tipa); Tablica 170/230 Razredi: 12,0 (min 12.0 MPa), 16,0 (min 16.0 MPa)." },
        { "@language": "hu", "@value": "AVS: 1+; ÜGY: min. gyakoriság 2/hét; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 5% fraktilis 95% ci; Megjegyzések: csak ha szükséges (Típusvizsgálat); Táblázat 170/230 Osztályok: 12,0 (min 12.0 MPa), 16,0 (min 16.0 MPa)." },
        { "@language": "it", "@value": "VVCP: 1+; CPF: freq. min. 2/settimana; Audit: 6/anno; Campioni di prova di tipo: 1; Valore stat.: frattile 5% 95% ci; Note: solo se richiesto (Prova di tipo); Tabella 170/230 Classi: 12,0 (min 12.0 MPa), 16,0 (min 16.0 MPa)." },
        { "@language": "lt", "@value": "AVS: 1+; VKS: min. dažnis 2/savaitė; Auditas: 6/metai; Tipo bandymo mėginiai: 1; Stat. vertė: 5 % fraktilis 95 % ci; Pastabos: tik jei reikalaujama (Tipo bandymas); Lentelė 170/230 Klasės: 12,0 (min 12.0 MPa), 16,0 (min 16.0 MPa)." },
        { "@language": "lv", "@value": "AVS: 1+; RKS: min. biežums 2/nedēļa; Audits: 6/gads; Tipa pārbaudes paraugi: 1; Stat. vērtība: 5% fraktile 95% ci; Piezīmes: tikai ja nepieciešams (Tipa pārbaude); Tabula 170/230 Klases: 12,0 (min 12.0 MPa), 16,0 (min 16.0 MPa)." },
        { "@language": "mt", "@value": "AVS: 1+; FPC: min frekwenza 2/ġimgħa; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 5% frattil 95% ci; Noti: biss jekk meħtieġ (Test tat-tip); Tabella 170/230 Klassijiet: 12,0 (min 12.0 MPa), 16,0 (min 16.0 MPa)." },
