        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 66.6% declarado) para escoria de alto horno." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui see on lisatud (≥ 66.6% deklareeritud) kõrgahju räbu puhul." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≥ 66.6 % ilmoitettu) masuunikuonalle." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 66.6% déclaré) pour le laitier de haut fourneau." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 66.6% dearbhaithe) do shlaig fhoirnéise soinneáin." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 66.6% deklarirano) za trosku visoke peći." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 66.6% deklarált) a kohósalakhoz." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 66.6% dichiarato) per scoria d'altoforno." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 66.6% deklaruota) aukštakrosnių šlakui." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 66.6% deklarēts) domnas sārņiem." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluża (≥ 66.6% iddikjarat) għal gagazza tal-kalkara tal-funderija." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≥ 66.6% gedeclareerd) voor hoogovenslak." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: deklaracja obowiązkowa, jeśli jest uwzględniony (≥ 66.6% deklarowane) dla żużla wielkopiecowego." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 66.6% declarado) para escória de alto-forno." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 66.6% declarat) pentru zgură de furnal." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 66.6% deklarované) pre vysokopecnú strusku." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 66.6 % deklarirano) za plavžno žlindro." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 66.6% deklarerat) för masugnsslagg." }
      ]
    },
