        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze pokud je zahrnuto." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant, hvis inkluderet." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant, falls enthalten." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εφόσον περιλαμβάνεται." },
