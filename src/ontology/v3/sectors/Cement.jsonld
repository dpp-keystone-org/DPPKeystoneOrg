  "dcterms:description": [
    { "@language": "en", "@value": "Ontology defining terms and concepts specific to the cement sector." },
    { "@language": "bg", "@value": "Онтология, дефинираща термини и концепции, специфични за циментовия сектор." },
    { "@language": "cs", "@value": "Ontologie definující termíny a koncepty specifické pro odvětví cementu." },
    { "@language": "da", "@value": "Ontologi, der definerer termer og begreber, som er specifikke for cementsektoren." },
    { "@language": "de", "@value": "Ontologie zur Definition spezifischer Begriffe und Konzepte für den Zementsektor." },
    { "@language": "el", "@value": "Οντολογία που ορίζει όρους και έννοιες ειδικές για τον τομέα του τσιμέντου." },
    { "@language": "es", "@value": "Ontología que define términos y conceptos específicos del sector del cemento." },
    { "@language": "et", "@value": "Tsemendisektorile spetsiifilisi termineid ja mõisteid määratlev ontoloogia." },
    { "@language": "fi", "@value": "Ontologia, joka määrittelee sementtialalle ominaiset termit ja käsitteet." },
    { "@language": "fr", "@value": "Ontologie définissant les termes et concepts spécifiques au secteur du ciment." },
    { "@language": "ga", "@value": "Ointeolaíocht a shainíonn téarmaí agus coincheapa a bhaineann go sonrach le hearnáil na stroighne." },
    { "@language": "hr", "@value": "Ontologija koja definira pojmove i koncepte specifične za sektor cementa." },
    { "@language": "hu", "@value": "A cementiparra jellemző fogalmakat és koncepciókat meghatározó ontológia." },
    { "@language": "it", "@value": "Ontologia che definisce termini e concetti specifici per il settore del cemento." },
    { "@language": "lt", "@value": "Ontologija, apibrėžianti cemento sektoriui būdingus terminus ir sąvokas." },
    { "@language": "lv", "@value": "Ontoloģija, kas definē cementa nozarei specifiskus terminus un jēdzienus." },
    { "@language": "mt", "@value": "Ontoloġija li tiddefinixxi termini u kunċetti speċifiċi għas-settur tas-siment." },
    { "@language": "nl", "@value": "Ontologie die termen en concepten definieert die specifiek zijn voor de cementsector." },
    { "@language": "pl", "@value": "Ontologia definiująca terminy i pojęcia specyficzne dla sektora cementowego." },
    { "@language": "pt", "@value": "Ontologia que define termos e conceitos específicos do setor de cimento." },
    { "@language": "ro", "@value": "Ontologie care definește termeni și concepte specifice sectorului cimentului." },
    { "@language": "sk", "@value": "Ontológia definujúca termíny a koncepty špecifické pre sektor cementu." },
    { "@language": "sl", "@value": "Ontologija, ki opredeljuje izraze in koncepte, specifične za sektor cementa." },
    { "@language": "sv", "@value": "Ontologi som definierar termer och begrepp specifika för cementsektorn." }
  ],
  "dcterms:conformsTo": "prEN 197",
