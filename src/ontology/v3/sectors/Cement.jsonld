        { "@language": "et", "@value": "Ränidioksiidi sisaldus" },
        { "@language": "fi", "@value": "Piidioksidipitoisuus" },
        { "@language": "fr", "@value": "Teneur en dioxyde de silicium" },
        { "@language": "ga", "@value": "Cion Dé-ocsaíde Sileacain" },
        { "@language": "hr", "@value": "Udio silicijeva dioksida" },
        { "@language": "hu", "@value": "Szilícium-dioxid-tartalom" },
        { "@language": "it", "@value": "Contenuto di biossido di silicio" },
        { "@language": "lt", "@value": "Silicio dioksido kiekis" },
        { "@language": "lv", "@value": "Silīcija dioksīda saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Diossidu tas-Silikon" },
