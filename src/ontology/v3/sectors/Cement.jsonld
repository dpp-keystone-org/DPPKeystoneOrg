        { "@language": "pl", "@value": "Zawartość dwutlenku krzemu" },
        { "@language": "pt", "@value": "Teor de dióxido de silício" },
        { "@language": "ro", "@value": "Conținut de dioxid de siliciu" },
        { "@language": "sk", "@value": "Obsah oxidu kremičitého" },
        { "@language": "sl", "@value": "Vsebnost silicijevega dioksida" },
        { "@language": "sv", "@value": "Halt av kiseldioxid" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.5",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: relevant only if included (pozzolana) or mandatory (clinker)." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: приложимо само ако е включено (пуцолан) или задължително (клинкер)." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze pokud je zahrnuto (pucolán) nebo povinné (slínek)." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant hvis inkluderet (pozzolan) eller obligatorisk (klinker)." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant, wenn enthalten (Puzzolan) oder obligatorisch (Klinker)." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εάν περιλαμβάνεται (ποζολάνη) ή υποχρεωτικό (κλίνκερ)." },
        { "@language": "es", "@value": "AVS: 2+; Notas: relevante solo si se incluye (puzolana) u obligatorio (clinker)." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui on kaasatud (putsolaan) või kohustuslik (klinker)." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: merkityksellinen vain jos sisältyy (putsolani) tai pakollinen (klinkkeri)." },
        { "@language": "fr", "@value": "AVS : 2+ ; Notes : pertinent uniquement si inclus (pouzzolane) ou obligatoire (clinker)." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha ach amháin má chuirtear san áireamh (pozzolana) nó éigeantach (clinker)." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: relevantno samo ako je uključeno (pucolan) ili obvezno (klinker)." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha tartalmazza (puccolán) vagy kötelező (klinker)." },
        { "@language": "it", "@value": "AVS: 2+; Note: rilevante solo se incluso (pozzolana) o obbligatorio (clinker)." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: aktualu tik tuo atveju, jei įtraukta (pucolanas) arba privaloma (klinkeris)." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: attiecas tikai tad, ja iekļauts (pucolāns) vai obligāts (klinkers)." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: rilevanti biss jekk inkluż (pozzolana) jew obbligatorju (klinker)." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: alleen relevant indien inbegrepen (puzzolaan) of verplicht (klinker)." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: dotyczy tylko, jeśli dołączono (pucolana) lub obowiązkowo (klinkier)." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: relevante apenas se incluído (pozolana) ou obrigatório (clínquer)." },
        { "@language": "ro", "@value": "AVS: 2+; Note: relevant numai dacă este inclus (pozolană) sau obligatoriu (clincher)." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: relevantné len ak je zahrnuté (pucolán) alebo povinné (slinok)." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: relevantno samo, če je vključeno (pucolan) ali obvezno (klinker)." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: relevant endast om det ingår (pozzolan) eller obligatoriskt (klinker)." }
      ]
    },
    {
      "@id": "dppk-cement:reactiveSiliconDioxideContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Reactive Silicon Dioxide Content" },
        { "@language": "bg", "@value": "Съдържание на реактивен силициев диоксид" },
        { "@language": "cs", "@value": "Obsah reaktivního oxidu křemičitého" },
        { "@language": "da", "@value": "Indhold af reaktivt siliciumdioxid" },
        { "@language": "de", "@value": "Gehalt an reaktivem Siliciumdioxid" },
        { "@language": "el", "@value": "Περιεκτικότητα σε ενεργό διοξείδιο του πυριτίου" },
        { "@language": "es", "@value": "Contenido de dióxido de silicio reactivo" },
        { "@language": "et", "@value": "Reaktiivse ränidioksiidi sisaldus" },
        { "@language": "fi", "@value": "Reaktiivisen piidioksidin pitoisuus" },
        { "@language": "fr", "@value": "Teneur en dioxyde de silicium réactif" },
        { "@language": "ga", "@value": "Cion Dé-ocsaíde Sileacain Imoibríche" },
        { "@language": "hr", "@value": "Udio reaktivnog silicijeva dioksida" },
        { "@language": "hu", "@value": "Reaktív szilícium-dioxid-tartalom" },
        { "@language": "it", "@value": "Contenuto di biossido di silicio reattivo" },
        { "@language": "lt", "@value": "Reaktyvaus silicio dioksido kiekis" },
        { "@language": "lv", "@value": "Reaktīvā silīcija dioksīda saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Diossidu tas-Silikon Reattiv" },
        { "@language": "nl", "@value": "Gehalte aan reactief siliciumdioxide" },
        { "@language": "pl", "@value": "Zawartość reaktywnego dwutlenku krzemu" },
        { "@language": "pt", "@value": "Teor de dióxido de silício reativo" },
        { "@language": "ro", "@value": "Conținut de dioxid de siliciu reactiv" },
        { "@language": "sk", "@value": "Obsah reaktívneho oxidu kremičitého" },
        { "@language": "sl", "@value": "Vsebnost reaktivnega silicijevega dioksida" },
        { "@language": "sv", "@value": "Halt av reaktiv kiseldioxid" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.5",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 25.0% declared); for calcareous fly ash threshold only applicable if reactive CaO is 10.0-15.0%." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължително деклариране, ако е включено (≥ 25.0% декларирано); за варовита летлива пепел прагът е приложим само ако реактивният CaO е 10.0-15.0%." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 25.0% deklarováno); pro vápenatý popílek je práh použitelný pouze pokud je reaktivní CaO 10.0-15.0%." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration hvis inkluderet (≥ 25.0% deklareret); for kalkholdig flyveaske gælder tærsklen kun hvis reaktivt CaO er 10.0-15.0%." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, wenn enthalten (≥ 25.0% deklariert); für kalkreiche Flugasche gilt der Schwellenwert nur, wenn reaktives CaO 10.0-15.0% beträgt." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 25.0% δηλωθέν); για ασβεστούχο ιπτάμενη τέφρα το όριο ισχύει μόνο εάν το ενεργό CaO είναι 10.0-15.0%." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 25.0% declarado); para cenizas volantes calcáreas el umbral solo es aplicable si el CaO reactivo es 10.0-15.0%." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui on kaasatud (≥ 25.0% deklareeritud); lubjarikka lendtuha puhul kehtib künnis ainult siis, kui reaktiivne CaO on 10.0-15.0%." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus jos sisältyy (≥ 25.0% ilmoitettu); kalkkipitoisen lentotuhkan osalta kynnysarvo soveltuu vain jos reaktiivinen CaO on 10.0-15.0%." },
        { "@language": "fr", "@value": "AVS : 2+ ; Notes : déclaration obligatoire si inclus (≥ 25.0% déclaré) ; pour les cendres volantes calciques le seuil n'est applicable que si le CaO réactif est de 10.0-15.0%." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 25.0% dearbhaithe); do luaithne eitilte chailcreach ní bhaineann an tairseach ach amháin má tá CaO imoibríoch 10.0-15.0%." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 25.0% deklarirano); za vapnenasti leteći pepeo prag je primjenjiv samo ako je reaktivni CaO 10.0-15.0%." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 25.0% deklarálva); meszes pernye esetén a határérték csak akkor alkalmazható, ha a reaktív CaO 10.0-15.0%." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 25.0% dichiarato); per ceneri volanti calcaree la soglia è applicabile solo se il CaO reattivo è 10.0-15.0%." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 25.0% deklaruota); kalkingiems lakiesiems pelenams riba taikoma tik tuo atveju, jei reaktyvusis CaO yra 10.0-15.0%." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 25.0% deklarēts); kaļķainiem lidojošiem pelniem slieksnis piemērojams tikai tad, ja reaktīvais CaO ir 10.0-15.0%." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≥ 25.0% iddikjarat); għal irmied li jtir kalkarju l-limitu huwa applikabbli biss jekk is-CaO reattiv huwa 10.0-15.0%." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien inbegrepen (≥ 25.0% aangegeven); voor kalkrijke vliegas is de drempelwaarde alleen van toepassing als het reactieve CaO 10.0-15.0%." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja, jeśli dołączono (≥ 25.0% deklarowane); dla wapiennego popiołu lotnego próg ma zastosowanie tylko wtedy, gdy reaktywny CaO wynosi 10.0-15.0%." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 25.0% declarado); para cinzas volantes calcárias o limite só é aplicável se o CaO reativo for 10.0-15.0%." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 25.0% declarat); pentru cenușa zburătoare calcaroasă pragul este aplicabil numai dacă CaO reactiv este de 10.0-15.0%." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 25.0% deklarované); pre vápenatý popolček je prah použiteľný len ak je reaktívny CaO 10.0-15.0%." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 25.0% deklarirano); za apnenčasti leteči pepel prag velja samo, če je reaktivni CaO 10.0-15.0%." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 25.0% deklarerat); för kalkhaltig flygaska är tröskelvärdet endast tillämpligt om reaktivt CaO är 10.0-15.0%." }
      ]
    },
    {
      "@id": "dppk-cement:amorphousSiliconDioxideContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Amorphous Silicon Dioxide Content" },
        { "@language": "bg", "@value": "Съдържание на аморфен силициев диоксид" },
        { "@language": "cs", "@value": "Obsah amorfního oxidu křemičitého" },
        { "@language": "da", "@value": "Indhold af amorft siliciumdioxid" },
        { "@language": "de", "@value": "Gehalt an amorphem Siliciumdioxid" },
        { "@language": "el", "@value": "Περιεκτικότητα σε άμορφο διοξείδιο του πυριτίου" },
        { "@language": "es", "@value": "Contenido de dióxido de silicio amorfo" },
        { "@language": "et", "@value": "Amorfse ränidioksiidi sisaldus" },
        { "@language": "fi", "@value": "Amorfisen piidioksidin pitoisuus" },
        { "@language": "fr", "@value": "Teneur en dioxyde de silicium amorphe" },
        { "@language": "ga", "@value": "Cion Dé-ocsaíde Sileacain Éagruthach" },
        { "@language": "hr", "@value": "Udio amorfnog silicijeva dioksida" },
        { "@language": "hu", "@value": "Amorf szilícium-dioxid-tartalom" },
        { "@language": "it", "@value": "Contenuto di biossido di silicio amorfo" },
        { "@language": "lt", "@value": "Amorfinio silicio dioksido kiekis" },
        { "@language": "lv", "@value": "Amorfā silīcija dioksīda saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Diossidu tas-Silikon Amorfu" },
        { "@language": "nl", "@value": "Gehalte aan amorf siliciumdioxide" },
        { "@language": "pl", "@value": "Zawartość amorficznego dwutlenku krzemu" },
        { "@language": "pt", "@value": "Teor de dióxido de silício amorfo" },
        { "@language": "ro", "@value": "Conținut de dioxid de siliciu amorf" },
        { "@language": "sk", "@value": "Obsah amorfného oxidu kremičitého" },
        { "@language": "sl", "@value": "Vsebnost amorfnega silicijevega dioksida" },
        { "@language": "sv", "@value": "Halt av amorf kiseldioxid" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.5",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 85% declared); all SiO2 in silica fume is assumed amorphous." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължително деклариране, ако е включено (≥ 85% декларирано); целият SiO2 в силициевия прах се приема за аморфен." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 85% deklarováno); veškerý SiO2 v křemičitém úletu se považuje za amorfní." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration hvis inkluderet (≥ 85% deklareret); alt SiO2 i mikrosilica antages at være amorft." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, wenn enthalten (≥ 85% deklariert); das gesamte SiO2 in Silikastaub wird als amorph angenommen." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 85% δηλωθέν); όλο το SiO2 στην πυριτική παιπάλη θεωρείται άμορφο." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 85% declarado); se asume que todo el SiO2 en el humo de sílice es amorfo." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui on kaasatud (≥ 85% deklareeritud); eeldatakse, et kogu SiO2 ränidioksiidi tolmus on amorfne." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus jos sisältyy (≥ 85% ilmoitettu); kaiken SiO2:n silikaköylyssä oletetaan olevan amorfista." },
        { "@language": "fr", "@value": "AVS : 2+ ; Notes : déclaration obligatoire si inclus (≥ 85% déclaré) ; tout le SiO2 dans la fumée de silice est supposé amorphe." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 85% dearbhaithe); glactar leis go bhfuil gach SiO2 i múch shilice éagruthach." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 85% deklarirano); pretpostavlja se da je sav SiO2 u silicijskoj prašini amorfan." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 85% deklarálva); a szilikaporban lévő összes SiO2 amorfnak tekintendő." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 85% dichiarato); tutto il SiO2 nel fumo di silice si presume amorfo." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 85% deklaruota); visas SiO2 silicio dioksido dulkėse laikomas amorfiniu." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 85% deklarēts); pieņem, ka viss SiO2 silīcija dioksīda putekļos ir amorfs." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≥ 85% iddikjarat); is-SiO2 kollu fid-dħaħen tas-silika huwa assunt amorfu." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien inbegrepen (≥ 85% aangegeven); alle SiO2 in silicastof wordt als amorf beschouwd." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja, jeśli dołączono (≥ 85% deklarowane); zakłada się, że cały SiO2 w pyle krzemionkowym jest amorficzny." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 85% declarado); assume-se que todo o SiO2 no fumo de sílica é amorfo." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 85% declarat); se presupune că tot SiO2 din praful de silice este amorf." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 85% deklarované); všetok SiO2 v kremičitom úlete sa považuje za amorfný." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 85% deklarirano); predpostavlja se, da je ves SiO2 v silicijevi prašini amorfen." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 85% deklarerat); allt SiO2 i silikastoft antas vara amorft." }
      ]
    },
    {
      "@id": "dppk-cement:elementalSiliconContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Elemental Silicon Content" },
        { "@language": "bg", "@value": "Съдържание на елементарен силиций" },
        { "@language": "cs", "@value": "Obsah elementárního křemíku" },
        { "@language": "da", "@value": "Indhold af elementært silicium" },
        { "@language": "de", "@value": "Gehalt an elementarem Silicium" },
        { "@language": "el", "@value": "Περιεκτικότητα σε στοιχειακό πυρίτιο" },
        { "@language": "es", "@value": "Contenido de silicio elemental" },
        { "@language": "et", "@value": "Elementaarse räni sisaldus" },
        { "@language": "fi", "@value": "Alkuainepiin pitoisuus" },
        { "@language": "fr", "@value": "Teneur en silicium élémentaire" },
        { "@language": "ga", "@value": "Cion Sileacain Eilimintigh" },
        { "@language": "hr", "@value": "Udio elementarnog silicija" },
        { "@language": "hu", "@value": "Elemi szilíciumtartalom" },
        { "@language": "it", "@value": "Contenuto di silicio elementare" },
        { "@language": "lt", "@value": "Elementinio silicio kiekis" },
        { "@language": "lv", "@value": "Elementārā silīcija saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Silikon Elementari" },
        { "@language": "nl", "@value": "Gehalte aan elementair silicium" },
        { "@language": "pl", "@value": "Zawartość krzemu pierwiastkowego" },
        { "@language": "pt", "@value": "Teor de silício elementar" },
        { "@language": "ro", "@value": "Conținut de siliciu elementar" },
        { "@language": "sk", "@value": "Obsah elementárneho kremíka" },
        { "@language": "sl", "@value": "Vsebnost elementarnega silicija" },
        { "@language": "sv", "@value": "Halt av elementärt kisel" }
      ],
      "dppk:governedBy": "ISO 9286:2021",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≤ 0.4% declared) for silica fume." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължително деклариране, ако е включено (≤ 0.4% декларирано) за силициев прах." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≤ 0.4% deklarováno) pro křemičitý úlet." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration hvis inkluderet (≤ 0.4% deklareret) for mikrosilica." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, wenn enthalten (≤ 0.4% deklariert) für Silikastaub." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≤ 0.4% δηλωθέν) για πυριτική παιπάλη." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≤ 0.4% declarado) para humo de sílice." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui on kaasatud (≤ 0.4% deklareeritud) ränidioksiidi tolmu puhul." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus jos sisältyy (≤ 0.4% ilmoitettu) silikaköylylle." },
        { "@language": "fr", "@value": "AVS : 2+ ; Notes : déclaration obligatoire si inclus (≤ 0.4% déclaré) pour la fumée de silice." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≤ 0.4% dearbhaithe) do mhúch shilice." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≤ 0.4% deklarirano) za silicijsku prašinu." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≤ 0.4% deklarálva) szilikapor esetén." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≤ 0.4% dichiarato) per fumo di silice." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≤ 0.4% deklaruota) silicio dioksido dulkėms." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≤ 0.4% deklarēts) silīcija dioksīda putekļiem." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≤ 0.4% iddikjarat) għad-dħaħen tas-silika." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien inbegrepen (≤ 0.4% aangegeven) voor silicastof." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja, jeśli dołączono (≤ 0.4% deklarowane) dla pyłu krzemionkowego." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≤ 0.4% declarado) para fumo de sílica." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≤ 0.4% declarat) pentru praful de silice." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≤ 0.4% deklarované) pre kremičitý úlet." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≤ 0.4% deklarirano) za silicijevo prašino." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≤ 0.4% deklarerat) för silikastoft." }
      ]
    },
    {
      "@id": "dppk-cement:ratioCalciumOxideToSiliconDioxide",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Ratio Calcium Oxide To Silicon Dioxide" },
        { "@language": "bg", "@value": "Съотношение калциев оксид към силициев диоксид" },
        { "@language": "cs", "@value": "Poměr oxid vápenatý k oxidu křemičitému" },
        { "@language": "da", "@value": "Forholdet calciumoxid til siliciumdioxid" },
        { "@language": "de", "@value": "Verhältnis Calciumoxid zu Siliciumdioxid" },
        { "@language": "el", "@value": "Λόγος οξειδίου του ασβεστίου προς διοξείδιο του πυριτίου" },
        { "@language": "es", "@value": "Relación óxido de calcio a dióxido de silicio" },
        { "@language": "et", "@value": "Kaltsiumoksiidi ja ränidioksiidi suhe" },
        { "@language": "fi", "@value": "Kalsiumoksidin ja piidioksidin suhde" },
        { "@language": "fr", "@value": "Rapport oxyde de calcium sur dioxyde de silicium" },
        { "@language": "ga", "@value": "Cóimheas Ocsaíd Chailciam le Dé-ocsaíd Shileacain" },
        { "@language": "hr", "@value": "Omjer kalcijeva oksida i silicijeva dioksida" },
        { "@language": "hu", "@value": "Kalcium-oxid / szilícium-dioxid arány" },
        { "@language": "it", "@value": "Rapporto ossido di calcio su biossido di silicio" },
        { "@language": "lt", "@value": "Kalcio oksido ir silicio dioksido santykis" },
        { "@language": "lv", "@value": "Kalcija oksīda un silīcija dioksīda attiecība" },
        { "@language": "mt", "@value": "Proporzjon ta' Ossidu tal-Kalċju għal Diossidu tas-Silikon" },
        { "@language": "nl", "@value": "Verhouding calciumoxide tot siliciumdioxide" },
        { "@language": "pl", "@value": "Stosunek tlenku wapnia do dwutlenku krzemu" },
        { "@language": "pt", "@value": "Relação óxido de cálcio para dióxido de silício" },
        { "@language": "ro", "@value": "Raport oxid de calciu la dioxid de siliciu" },
        { "@language": "sk", "@value": "Pomer oxid vápenatý k oxidu kremičitému" },
        { "@language": "sl", "@value": "Razmerje kalcijev oksid proti silicijevemu dioksidu" },
        { "@language": "sv", "@value": "Förhållande kalciumoxid till kiseldioxid" }
      ],
      "dppk:governedBy": "EN 196-2:2026",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration (≥ 2.0 declared) for clinker." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължително деклариране (≥ 2.0 декларирано) за клинкер." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace (≥ 2.0 deklarováno) pro slínek." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration (≥ 2.0 deklareret) for klinker." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration (≥ 2.0 deklariert) für Klinker." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση (≥ 2.0 δηλωθέν) για κλίνκερ." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria (≥ 2.0 declarado) para clinker." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon (≥ 2.0 deklareeritud) klinkri puhul." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus (≥ 2.0 ilmoitettu) klinkkerille." },
        { "@language": "fr", "@value": "AVS : 2+ ; Notes : déclaration obligatoire (≥ 2.0 déclaré) pour le clinker." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach (≥ 2.0 dearbhaithe) do chlinker." },
