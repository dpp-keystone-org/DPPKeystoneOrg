        { "@language": "it", "@value": "Contenuto totale di alcali" },
        { "@language": "lt", "@value": "Bendras šarmų kiekis" },
        { "@language": "lv", "@value": "Kopējais sārmu saturs" },
        { "@language": "mt", "@value": "Kontenut Totali ta' Alkali" },
        { "@language": "nl", "@value": "Totaal alkaligehalte" },
        { "@language": "pl", "@value": "Całkowita zawartość alkaliów" },
        { "@language": "pt", "@value": "Teor total de álcalis" },
        { "@language": "ro", "@value": "Conținut total de alcalii" },
        { "@language": "sk", "@value": "Celkový obsah alkálií" },
        { "@language": "sl", "@value": "Skupna vsebnost alkalij" },
