      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "A specific class representing cement construction products, inheriting from the core DPP Product." },
        { "@language": "bg", "@value": "Специфичен клас, представляващ циментови строителни продукти, наследяващ от основния DPP продукт." },
        { "@language": "cs", "@value": "Specifická třída představující cementové stavební výrobky, dědící z jádrového produktu DPP." },
        { "@language": "da", "@value": "En specifik klasse, der repræsenterer cementbyggevarer og nedarver fra DPP-kerneproduktet." },
        { "@language": "de", "@value": "Eine spezifische Klasse, die Zementbauprodukte repräsentiert und vom DPP-Kernprodukt erbt." },
        { "@language": "el", "@value": "Μια ειδική κλάση που αντιπροσωπεύει δομικά προϊόντα τσιμέντου, η οποία κληρονομεί από το βασικό προϊόν DPP." },
        { "@language": "es", "@value": "Una clase específica que representa los productos de construcción de cemento y hereda del producto central DPP." },
        { "@language": "et", "@value": "Spetsiifiline klass, mis esindab tsemendist ehitustooteid ja pärib põhi-DPP tootelt." },
        { "@language": "fi", "@value": "Erityinen luokka, joka edustaa sementtirakennustuotteita ja periytyy ydin-DPP-tuotteesta." },
        { "@language": "fr", "@value": "Classe spécifique représentant les produits de construction en ciment, héritant du produit central DPP." },
        { "@language": "ga", "@value": "Aicme shonrach a léiríonn táirgí foirgníochta stroighne, a fhaigheann oidhreacht ón Táirge DPP lárnach." },
        { "@language": "hr", "@value": "Specifična klasa koja predstavlja cementne građevne proizvode, a nasljeđuje od središnjeg DPP proizvoda." },
        { "@language": "hu", "@value": "A cement építési termékeket képviselő specifikus osztály, amely az alapvető DPP termékből öröklődik." },
        { "@language": "it", "@value": "Una classe specifica che rappresenta i prodotti da costruzione in cemento e che eredita dal prodotto centrale DPP." },
        { "@language": "lt", "@value": "Specifinė klasė, atstovaujanti cemento statybos produktams ir paveldinti iš pagrindinio DPP produkto." },
        { "@language": "lv", "@value": "Īpaša klase, kas apzīmē cementa būvizstrādājumus un manto no pamatnes DPP produkta." },
        { "@language": "mt", "@value": "Klassi speċifika li tirrappreżenta prodotti tal-kostruzzjoni tas-siment, li tiret mill-prodott ċentrali DPP." },
        { "@language": "nl", "@value": "Een specifieke klasse die cementbouwproducten vertegenwoordigt en overerft van het DPP-kernproduct." },
        { "@language": "pl", "@value": "Specyficzna klasa reprezentująca cementowe wyroby budowlane, dziedzicząca z głównego produktu DPP." },
        { "@language": "pt", "@value": "Uma classe específica que representa produtos de construção de cimento, herdando do produto principal DPP." },
        { "@language": "ro", "@value": "O clasă specifică reprezentând produsele de construcții din ciment, care moștenește din Produsul de bază DPP." },
        { "@language": "sk", "@value": "Špecifická trieda reprezentujúca cementové stavebné výrobky, ktorá dedí z hlavného produktu DPP." },
        { "@language": "sl", "@value": "Specifičen razred, ki predstavlja cementne gradbene proizvode in podeduje iz jedrnega izdelka DPP." },
        { "@language": "sv", "@value": "En specifik klass som representerar cementbyggprodukter och ärver från kärn-DPP-produkten." }
      ]
    },
