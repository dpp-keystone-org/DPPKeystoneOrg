      ],
      "dppk:governedBy": "EN 196-1:2026",
      "dppk:unit": { "@id": "dppk-unit:Megapascal" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: min freq 2/week; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: only if required for cement type (Type test); Table 170/230 Classes: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: мин. честота 2/седмично; Одит: 6/година; Проби за типово изпитване: 1; Стат. стойност: 10% квантил 95% дов. инт.; Забележки: само ако се изисква за типа цимент (Типово изпитване); Таблица 170/230 Класове: 32,5 (макс 52.5 MPa), 42,5 (макс 62.5 MPa)." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: min frekvence 2/týden; Audit: 6/rok; Vzorky pro zkoušku typu: 1; Stat. hodnota: 10% kvantil 95% int. spolehlivosti; Poznámky: pouze pokud je to požadováno pro typ cementu (Zkouška typu); Tabulka 170/230 Třídy: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "da", "@value": "AVS: 1+; FPC: min. frekvens 2/uge; Audit: 6/år; Typeprøvningsemner: 1; Stat. værdi: 10% fraktil 95% konfidensinterval; Bemærkninger: kun hvis det kræves for cementtypen (Typeprøvning); Tabel 170/230 Klasser: 32,5 (maks 52.5 MPa), 42,5 (maks 62.5 MPa)." },
        { "@language": "de", "@value": "AVS: 1+; FPC: min. Häufigkeit 2/Woche; Audit: 6/Jahr; Typprüfungsproben: 1; Stat. Wert: 10% Fraktil 95% Konfidenzintervall; Anmerkungen: nur falls für Zementart erforderlich (Typprüfung); Tabelle 170/230 Klassen: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "el", "@value": "AVS: 1+; FPC: ελάχιστη συχνότητα 2/εβδομάδα; Έλεγχος: 6/έτος; Δείγματα δοκιμής τύπου: 1; Στατ. τιμή: 10% ποσοστημόριο 95% διάστημα εμπιστοσύνης; Σημειώσεις: μόνο εάν απαιτείται για τον τύπο τσιμέντου (Δοκιμή τύπου); Πίνακας 170/230 Κλάσεις: 32,5 (μέγ. 52.5 MPa), 42,5 (μέγ. 62.5 MPa)." },
        { "@language": "es", "@value": "AVS: 1+; FPC: frec. mín. 2/semana; Auditoría: 6/año; Muestras ensayo tipo: 1; Valor est.: 10% cuantil 95% int. conf.; Notas: solo si se requiere para el tipo de cemento (Ensayo tipo); Tabla 170/230 Clases: 32,5 (máx 52.5 MPa), 42,5 (máx 62.5 MPa)." },
        { "@language": "et", "@value": "AVS: 1+; FPC: min sagedus 2/nädal; Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 10% kvantiil 95% usaldusintervall; Märkused: ainult siis, kui seda nõutakse tsemenditüübi puhul (Tüübikatse); Tabel 170/230 Klassid: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: min. taajuus 2/viikko; Auditointi: 6/vuosi; Tyyppikoenäytteet: 1; Tilastollinen arvo: 10 % fraktiili 95 % luottamusväli; Huomautukset: vain jos vaaditaan sementtityypille (Tyyppikoe); Taulukko 170/230 Luokat: 32,5 (maks. 52.5 MPa), 42,5 (maks. 62.5 MPa)." },
        { "@language": "fr", "@value": "AVS: 1+; FPC: fréq. min. 2/semaine; Audit: 6/an; Échantillons d'essai de type: 1; Valeur stat.: fractile à 10% IC 95%; Notes: seulement si requis pour le type de ciment (Essai de type); Tableau 170/230 Classes: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: íos-mhinicíocht 2/seachtain; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% muinín; Nótaí: ach amháin más gá don chineál stroighne (Tástáil cineáil); Tábla 170/230 Aicmí: 32,5 (uasmhéid 52.5 MPa), 42,5 (uasmhéid 62.5 MPa)." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: min. učestalost 2/tjedan; Revizija: 6/godina; Uzorci za tipsko ispitivanje: 1; Stat. vrijednost: 10% fraktil 95% int. pouzdanosti; Napomene: samo ako je potrebno za vrstu cementa (Tipsko ispitivanje); Tablica 170/230 Klase: 32,5 (maks 52.5 MPa), 42,5 (maks 62.5 MPa)." },
        { "@language": "hu", "@value": "AVS: 1+; FPC: min. gyakoriság 2/hét; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 10% fraktilis 95% konf. int.; Megjegyzések: csak akkor, ha a cementtípushoz szükséges (Típusvizsgálat); 170/230 Táblázat Osztályok: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "it", "@value": "AVS: 1+; FPC: freq. min. 2/settimana; Audit: 6/anno; Campioni prova tipo: 1; Valore stat.: frattile 10% IC 95%; Note: solo se richiesto per il tipo di cemento (Prova tipo); Tabella 170/230 Classi: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "lt", "@value": "AVS: 1+; FPC: min. dažnumas 2/sav.; Auditas: 6/metus; Tipo bandymo mėginiai: 1; Stat. vertė: 10% fraktilis 95% pasikl. int.; Pastabos: tik jei reikalaujama cemento tipui (Tipo bandymas); Lentelė 170/230 Klasės: 32,5 (maks 52.5 MPa), 42,5 (maks 62.5 MPa)." },
        { "@language": "lv", "@value": "AVS: 1+; FPC: min. biežums 2/nedēļā; Audits: 6/gadā; Tipa testa paraugi: 1; Stat. vērtība: 10% fraktile 95% ticamības intervāls; Piezīmes: tikai tad, ja tas ir nepieciešams cementa tipam (Tipa tests); Tabula 170/230 Klases: 32,5 (maks 52.5 MPa), 42,5 (maks 62.5 MPa)." },
        { "@language": "mt", "@value": "AVS: 1+; FPC: frekwenza min 2/ġimgħa; Awditjar: 6/sena; Kampjuni ta' Test tat-Tip: 1; Valur Stat: 10% frattil 95% int. ta' kunfidenza; Noti: biss jekk meħtieġ għat-tip tas-siment (Test tat-tip); Tabella 170/230 Klassijiet: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "nl", "@value": "AVS: 1+; FPC: min. freq 2/week; Audit: 6/jaar; Typetestmonsters: 1; Stat. waarde: 10% fractiel 95% betr. int.; Opmerkingen: alleen indien vereist voor cementtype (Typetest); Tabel 170/230 Klassen: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "pl", "@value": "AVS: 1+; FPC: min. częstotliwość 2/tydzień; Audyt: 6/rok; Próbki do badania typu: 1; Wartość stat.: 10% fraktyl 95% przedział ufności; Uwagi: tylko jeśli jest to wymagane dla typu cementu (Badanie typu); Tabela 170/230 Klasy: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "pt", "@value": "AVS: 1+; FPC: freq. mín. 2/semana; Auditoria: 6/ano; Amostras de ensaio de tipo: 1; Valor est.: 10% quantil 95% int. de confiança; Notas: apenas se exigido para o tipo de cimento (Ensaio de tipo); Tabela 170/230 Classes: 32,5 (máx 52.5 MPa), 42,5 (máx 62.5 MPa)." },
        { "@language": "ro", "@value": "AVS: 1+; FPC: frecv. min. 2/săptămână; Audit: 6/an; Eșantioane de încercare de tip: 1; Valoare stat.: 10% fractil 95% int. de încredere; Note: doar dacă este necesar pentru tipul de ciment (Încercare de tip); Tabel 170/230 Clase: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "sk", "@value": "AVS: 1+; FPC: min frekvencia 2/týždeň; Audit: 6/rok; Vzorky na skúšku typu: 1; Štat. hodnota: 10% kvantil 95% int. spoľahlivosti; Poznámky: len ak sa to vyžaduje pre typ cementu (Skúška typu); Tabuľka 170/230 Triedy: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "sl", "@value": "AVS: 1+; FPC: min. pogostost 2/teden; Revizija: 6/leto; Vzorci za preskus tipa: 1; Stat. vrednost: 10 % fraktil 95 % int. zaupanja; Opombe: samo če je to zahtevano za vrsto cementa (Preskus tipa); Tabela 170/230 Razredi: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." },
        { "@language": "sv", "@value": "AVS: 1+; FPC: min. frekvens 2/vecka; Revision: 6/år; Typprovningsexemplar: 1; Stat. värde: 10% fraktil 95% konfidensintervall; Anmärkningar: endast om det krävs för cementtypen (Typprovning); Tabell 170/230 Klasser: 32,5 (max 52.5 MPa), 42,5 (max 62.5 MPa)." }
      ]
    },
