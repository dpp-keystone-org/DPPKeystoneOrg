    {
      "@id": "dppk-cement:sulfateResistanceSquarePrismTest",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Sulfate Resistance Square Prism Test" },
        { "@language": "bg", "@value": "Изпитване на сулфатоустойчивост с квадратни призми" },
        { "@language": "cs", "@value": "Zkouška síranové odolnosti na čtvercových hranolech" },
        { "@language": "da", "@value": "Prøvning af sulfatbestandighed med kvadratiske prismer" },
        { "@language": "de", "@value": "Prüfung des Sulfatwiderstands an quadratischen Prismen" },
        { "@language": "el", "@value": "Δοκιμή αντοχής σε θειικά άλατα με τετράγωνα πρίσματα" },
        { "@language": "es", "@value": "Ensayo de resistencia a los sulfatos con prismas cuadrados" },
        { "@language": "et", "@value": "Sulfaadikindluse katse ruudukujuliste prismadega" },
        { "@language": "fi", "@value": "Sulfaattikestävyyskoe neliöprismoilla" },
        { "@language": "fr", "@value": "Essai de résistance aux sulfates sur prismes carrés" },
