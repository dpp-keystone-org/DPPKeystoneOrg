        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui on lisatud." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautuksia: merkityksellinen vain, jos sisällytetty." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: pertinent uniquement si inclus." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha amháin má chuirtear san áireamh é." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: relevantno samo ako je uključeno." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha szerepel." },
        { "@language": "it", "@value": "AVS: 2+; Note: rilevante solo se incluso." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: aktualu tik tuo atveju, jei įtraukta." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: attiecas tikai tad, ja ir iekļauts." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: rilevanti biss jekk inkluż." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: alleen relevant indien opgenomen." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: istotne tylko w przypadku włączenia." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: relevante apenas se incluído." },
        { "@language": "ro", "@value": "AVS: 2+; Note: relevant numai dacă este inclus." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: relevantné len ak je zahrnuté." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: pomembno le, če je vključeno." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: endast relevant om inkluderad." }
      ]
