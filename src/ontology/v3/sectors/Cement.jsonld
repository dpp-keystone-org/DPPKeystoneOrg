      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: freq 1/every 2 months; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: for special applications, only if required (Type test)." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: честота 1/на всеки 2 месеца; Одит: 6/година; Проби за изпитване на типа: 1; Стат. стойност: 10% фрактил 95% ci; Забележки: за специални приложения, само ако се изисква (Изпитване на типа)." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: frekvence 1/každé 2 měsíce; Audit: 6/rok; Vzorky pro zkoušku typu: 1; Stat. hodnota: 10% kvantil 95% is; Poznámky: pro speciální aplikace, pouze pokud je to požadováno (Zkouška typu)." },
        { "@language": "da", "@value": "AVS: 1+; FPC: frekvens 1/hver 2. måned; Audit: 6/år; Typeprøvningsprøver: 1; Stat. værdi: 10% fraktil 95% ki; Bemærkninger: til særlige anvendelser, kun hvis påkrævet (Typeprøvning)." },
        { "@language": "de", "@value": "AVS: 1+; WPK: Häufigkeit 1/alle 2 Monate; Audit: 6/Jahr; Typprüfproben: 1; Stat. Wert: 10 %-Fraktil 95 %-VI; Anmerkungen: für besondere Anwendungen, nur wenn erforderlich (Typprüfung)." },
        { "@language": "el", "@value": "AVS: 1+; FPC: συχνότητα 1/κάθε 2 μήνες; Έλεγχος: 6/έτος; Δείγματα δοκιμής τύπου: 1; Στατ. τιμή: ποσοστημόριο 10% 95% ci; Σημειώσεις: για ειδικές εφαρμογές, μόνο εάν απαιτείται (Δοκιμή τύπου)." },
        { "@language": "es", "@value": "AVS: 1+; FPC: frecuencia 1/cada 2 meses; Auditoría: 6/año; Muestras de ensayo de tipo: 1; Valor est.: cuantil 10 % 95 % ic; Notas: para aplicaciones especiales, solo si se requiere (Ensayo de tipo)." },
        { "@language": "et", "@value": "AVS: 1+; FPC: sagedus 1/iga 2 kuu järel; Audit: 6/aastas; Tüübikatsetuse proovid: 1; Stat. väärtus: 10% fraktiil 95% uv; Märkused: erirakenduste puhul, ainult nõudmisel (Tüübikatsetus)." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: tiheys 1/joka 2. kuukausi; Auditointi: 6/vuosi; Tyyppikoenäytteet: 1; Tilastollinen arvo: 10 % fraktiili 95 % lv; Huomautukset: erityiskäyttöön, vain jos vaaditaan (Tyyppikoe)." },
        { "@language": "fr", "@value": "AVS : 1+; FPC : fréq 1/tous les 2 mois; Audit : 6/an; Échantillons d'essai de type : 1; Valeur stat. : fractile 10 % ic 95 %; Remarques : pour les applications spéciales, uniquement si nécessaire (Essai de type)." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: minicíocht 1/gach 2 mhí; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% cm; Nótaí: le haghaidh feidhmchlár speisialta, ach amháin más gá (Tástáil chineáil)." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: učestalost 1/svaka 2 mjeseca; Revizija: 6/godišnje; Uzorci za ispitivanje tipa: 1; Stat. vrijednost: 10% fraktila 95% pi; Napomene: za posebne primjene, samo ako se zahtijeva (Ispitivanje tipa)." },
        { "@language": "hu", "@value": "AVS: 1+; FPC: gyakoriság 1/minden 2. hónapban; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 10% fraktilis 95% mk; Megjegyzések: speciális alkalmazásokhoz, csak ha szükséges (Típusvizsgálat)." },
        { "@language": "it", "@value": "AVS: 1+; FPC: freq 1/ogni 2 mesi; Audit: 6/anno; Campioni di prova di tipo: 1; Valore stat.: frattile 10% ic 95%; Note: per applicazioni speciali, solo se richiesto (Prova di tipo)." },
        { "@language": "lt", "@value": "AVS: 1+; FPC: dažnumas 1/kas 2 mėnesius; Auditas: 6/metus; Tipo bandymo mėginiai: 1; Stat. vertė: 10% fraktilis 95% pi; Pastabos: specialiam naudojimui, tik jei reikalaujama (Tipo bandymas)." },
        { "@language": "lv", "@value": "AVS: 1+; FPC: biežums 1/reizi 2 mēnešos; Audits: 6/gadā; Tipa testa paraugi: 1; Stat. vērtība: 10% fraktīle 95% ti; Piezīmes: īpašiem pielietojumiem, tikai ja nepieciešams (Tipa tests)." },
        { "@language": "mt", "@value": "AVS: 1+; FPC: frekwenza 1/kull 2 xhur; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil 95% ci; Noti: għal applikazzjonijiet speċjali, biss jekk meħtieġ (Test tat-Tip)." },
        { "@language": "nl", "@value": "AVS: 1+; FPC: freq 1/elke 2 maanden; Audit: 6/jaar; Typebeproevingsmonsters: 1; Stat. waarde: 10% fractiel 95% bi; Opmerkingen: voor speciale toepassingen, alleen indien vereist (Typebeproeving)." },
        { "@language": "pl", "@value": "AVS: 1+; FPC: częst. 1/co 2 miesiące; Audyt: 6/rok; Próbki do badania typu: 1; Wartość stat.: 10% fraktyl 95% pu; Uwagi: do zastosowań specjalnych, tylko jeśli jest to wymagane (Badanie typu)." },
        { "@language": "pt", "@value": "AVS: 1+; FPC: freq 1/a cada 2 meses; Auditoria: 6/ano; Amostras de Ensaio de Tipo: 1; Valor Est.: quantil 10% 95% ic; Notas: para aplicações especiais, apenas se exigido (Ensaio de tipo)." },
        { "@language": "ro", "@value": "AVS: 1+; FPC: frecvență 1/la fiecare 2 luni; Audit: 6/an; Eșantioane de încercare de tip: 1; Valoare stat.: 10% fractil 95% ic; Note: pentru aplicații speciale, numai dacă se cere (Încercare de tip)." },
        { "@language": "sk", "@value": "AVS: 1+; FPC: frekvencia 1/každé 2 mesiace; Audit: 6/rok; Vzorky na skúšku typu: 1; Štat. hodnota: 10% kvantil 95% is; Poznámky: na špeciálne aplikácie, len ak sa to vyžaduje (Skúška typu)." },
        { "@language": "sl", "@value": "AVS: 1+; FPC: pogostost 1/vsaka 2 meseca; Presoja: 6/leto; Vzorci za preskus tipa: 1; Stat. vrednost: 10 % fraktil 95 % iz; Opombe: za posebne aplikacije, samo če se zahteva (Preskus tipa)." },
        { "@language": "sv", "@value": "AVS: 1+; FPC: frekvens 1/varannan månad; Revision: 6/år; Typprovningsprov: 1; Stat. värde: 10% fraktil 95% ki; Anmärkningar: för speciella tillämpningar, endast om så krävs (Typprovning)." }
      ]
    },
    {
      "@id": "dppk-cement:alkaliContent",
