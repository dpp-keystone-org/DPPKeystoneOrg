        { "@language": "pl", "@value": "Maksymalna znormalizowana wytrzymałość na ściskanie 28 dni" },
        { "@language": "pt", "@value": "Resistência à compressão padrão máxima 28 dias" },
        { "@language": "ro", "@value": "Rezistență standard maximă la compresiune 28 zile" },
