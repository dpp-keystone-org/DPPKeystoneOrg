      "dppk:governedBy": "EN 196-1:2026",
      "dppk:unit": { "@id": "dppk-unit:Megapascal" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: val ≥ 32.5 MPa, min freq 2/week; Audit: 6/year; Type Test Samples: 1; Stat Value: 5% fractile 95% ci; Notes: mandatory declaration; Table 170/230 Classes: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: стойност ≥ 32.5 MPa, мин. честота 2/седмично; Одит: 6/година; Проби за типово изпитване: 1; Стат. стойност: 5% квантил 95% дов. инт.; Забележки: задължителна декларация; Таблица 170/230 Класове: 32,5 (мин 32.5 MPa), 42,5 (мин 42.5 MPa), 52,5 (мин 52.5 MPa)." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: hodnota ≥ 32.5 MPa, min frekvence 2/týden; Audit: 6/rok; Vzorky pro zkoušku typu: 1; Stat. hodnota: 5% kvantil 95% int. spolehlivosti; Poznámky: povinná deklarace; Tabulka 170/230 Třídy: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "da", "@value": "AVS: 1+; FPC: værdi ≥ 32.5 MPa, min. frekvens 2/uge; Audit: 6/år; Typeprøvningsemner: 1; Stat. værdi: 5% fraktil 95% konfidensinterval; Bemærkninger: obligatorisk deklaration; Tabel 170/230 Klasser: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "de", "@value": "AVS: 1+; FPC: Wert ≥ 32.5 MPa, min. Häufigkeit 2/Woche; Audit: 6/Jahr; Typprüfungsproben: 1; Stat. Wert: 5% Fraktil 95% Konfidenzintervall; Anmerkungen: obligatorische Erklärung; Tabelle 170/230 Klassen: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "el", "@value": "AVS: 1+; FPC: τιμή ≥ 32.5 MPa, ελάχιστη συχνότητα 2/εβδομάδα; Έλεγχος: 6/έτος; Δείγματα δοκιμής τύπου: 1; Στατ. τιμή: 5% ποσοστημόριο 95% διάστημα εμπιστοσύνης; Σημειώσεις: υποχρεωτική δήλωση; Πίνακας 170/230 Κλάσεις: 32,5 (ελάχ. 32.5 MPa), 42,5 (ελάχ. 42.5 MPa), 52,5 (ελάχ. 52.5 MPa)." },
        { "@language": "es", "@value": "AVS: 1+; FPC: valor ≥ 32.5 MPa, frec. mín. 2/semana; Auditoría: 6/año; Muestras ensayo tipo: 1; Valor est.: 5% cuantil 95% int. conf.; Notas: declaración obligatoria; Tabla 170/230 Clases: 32,5 (mín 32.5 MPa), 42,5 (mín 42.5 MPa), 52,5 (mín 52.5 MPa)." },
        { "@language": "et", "@value": "AVS: 1+; FPC: väärtus ≥ 32.5 MPa, min sagedus 2/nädal; Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 5% kvantiil 95% usaldusintervall; Märkused: kohustuslik deklaratsioon; Tabel 170/230 Klassid: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: arvo ≥ 32.5 MPa, min. taajuus 2/viikko; Auditointi: 6/vuosi; Tyyppikoenäytteet: 1; Tilastollinen arvo: 5 % fraktiili 95 % luottamusväli; Huomautukset: pakollinen ilmoitus; Taulukko 170/230 Luokat: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "fr", "@value": "AVS: 1+; FPC: valeur ≥ 32.5 MPa, fréq. min. 2/semaine; Audit: 6/an; Échantillons d'essai de type: 1; Valeur stat.: fractile à 5% IC 95%; Notes: déclaration obligatoire; Tableau 170/230 Classes: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: luach ≥ 32.5 MPa, íos-mhinicíocht 2/seachtain; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 5% codán 95% muinín; Nótaí: dearbhú éigeantach; Tábla 170/230 Aicmí: 32,5 (íosmhéid 32.5 MPa), 42,5 (íosmhéid 42.5 MPa), 52,5 (íosmhéid 52.5 MPa)." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: vrijednost ≥ 32.5 MPa, min. učestalost 2/tjedan; Revizija: 6/godina; Uzorci za tipsko ispitivanje: 1; Stat. vrijednost: 5% fraktil 95% int. pouzdanosti; Napomene: obvezna deklaracija; Tablica 170/230 Klase: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
        { "@language": "hu", "@value": "AVS: 1+; FPC: érték ≥ 32.5 MPa, min. gyakoriság 2/hét; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 5% fraktilis 95% konf. int.; Megjegyzések: kötelező nyilatkozat; 170/230 Táblázat Osztályok: 32,5 (min 32.5 MPa), 42,5 (min 42.5 MPa), 52,5 (min 52.5 MPa)." },
