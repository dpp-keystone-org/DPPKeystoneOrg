        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze pokud je zahrnuto; pro speciální aplikace; směs obsahuje 75% primárního cementu." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant hvis inkluderet; til specielle anvendelser; blandingen indeholder 75% primær cement." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant falls enthalten; für spezielle Anwendungen; Mischung enthält 75% Primärzement." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εάν περιλαμβάνεται; για ειδικές εφαρμογές; το μίγμα περιέχει 75% πρωτεύον τσιμέντο." },
        { "@language": "es", "@value": "AVS: 2+; Notas: relevante solo si se incluye; para aplicaciones especiales; la mezcla contiene 75% de cemento primario." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui on lisatud; erirakenduste jaoks; segu sisaldab 75% primaarset tsementi." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: merkityksellinen vain jos mukana; erityissovelluksiin; seos sisältää 75% ensisijaista sementtiä." },
        { "@language": "fr", "@value": "EVCP: 2+; Remarques: pertinent uniquement si inclus; pour des applications spéciales; le mélange contient 75% de ciment primaire." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha ach amháin má chuirtear san áireamh é; le haghaidh feidhmeanna speisialta; tá 75% stroighne príomhúil sa mheascán." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: važno samo ako je uključeno; za posebne primjene; mješavina sadrži 75% primarnog cementa." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha szerepel; speciális alkalmazásokhoz; a keverék 75% elsődleges cementet tartalmaz." },
        { "@language": "it", "@value": "VVCP: 2+; Note: rilevante solo se incluso; per applicazioni speciali; la miscela contiene il 75% di cemento primario." },
