        { "@language": "it", "@value": "Prova di resistenza ai solfati su prismi piatti" },
        { "@language": "lt", "@value": "Atsparumo sulfatams bandymas su plokščiomis prizmėmis" },
        { "@language": "lv", "@value": "Sulfātizturības tests ar plakanām prizmām" },
        { "@language": "mt", "@value": "Test ta' Reżistenza għas-Sulfati bi Priżmi Ċatti" },
        { "@language": "nl", "@value": "Bepaling van de sulfaatbestandheid met platte prisma's" },
        { "@language": "pl", "@value": "Badanie odporności na siarczany na płaskich beleczkach" },
        { "@language": "pt", "@value": "Ensaio de resistência aos sulfatos com prismas planos" },
        { "@language": "ro", "@value": "Încercare de rezistență la sulfați pe prisme plate" },
        { "@language": "sk", "@value": "Skúška síranovej odolnosti na plochých hranoloch" },
        { "@language": "sl", "@value": "Preskus odpornosti proti sulfatom s ploščatimi prizmami" },
        { "@language": "sv", "@value": "Provning av sulfatresistens med flata prismor" }
