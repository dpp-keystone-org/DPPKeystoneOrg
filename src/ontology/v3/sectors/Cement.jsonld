    {
      "@id": "dppk-cement:combinedCalciumOxideMagnesiumOxideSiliconDioxideContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Combined Calcium Oxide Magnesium Oxide Silicon Dioxide Content" },
        { "@language": "bg", "@value": "Съдържание на комбиниран калциев оксид магнезиев оксид силициев диоксид" },
        { "@language": "cs", "@value": "Obsah kombinovaného oxidu vápenatého oxidu hořečnatého oxidu křemičitého" },
        { "@language": "da", "@value": "Kombineret indhold af calciumoxid magnesiumoxid siliciumdioxid" },
        { "@language": "de", "@value": "Kombinierter Gehalt an Calciumoxid Magnesiumoxid Siliciumdioxid" },
        { "@language": "el", "@value": "Συνδυασμένη περιεκτικότητα σε οξείδιο του ασβεστίου οξείδιο του μαγνησίου διοξείδιο του πυριτίου" },
        { "@language": "es", "@value": "Contenido combinado de óxido de calcio óxido de magnesio dióxido de silicio" },
        { "@language": "et", "@value": "Kombineeritud kaltsiumoksiidi magneesiumoksiidi ränidioksiidi sisaldus" },
        { "@language": "fi", "@value": "Yhdistetty kalsiumoksidin magnesiumoksidin piidioksidin pitoisuus" },
        { "@language": "fr", "@value": "Teneur combinée en oxyde de calcium oxyde de magnésium dioxyde de silicium" },
        { "@language": "ga", "@value": "Ábhar Comhcheangailte Ocsaíd Chailciam Ocsaíd Mhaignéisiam Dé-ocsaíd Sileacain" },
        { "@language": "hr", "@value": "Kombinirani udio kalcijevog oksida magnezijevog oksida silicijevog dioksida" },
        { "@language": "hu", "@value": "Kombinált kalcium-oxid magnézium-oxid szilícium-dioxid tartalom" },
        { "@language": "it", "@value": "Contenuto combinato di ossido di calcio ossido di magnesio biossido di silicio" },
        { "@language": "lt", "@value": "Bendras kalcio oksido magnio oksido silicio dioksido kiekis" },
        { "@language": "lv", "@value": "Kombinētais kalcija oksīda magnija oksīda silīcija dioksīda saturs" },
        { "@language": "mt", "@value": "Kontenut Magħqud ta' Ossidu tal-Kalċju Ossidu tal-Magneżju Diossidu tas-Silikon" },
        { "@language": "nl", "@value": "Gecombineerd gehalte calciumoxide magnesiumoxide siliciumdioxide" },
        { "@language": "pl", "@value": "Łączna zawartość tlenku wapnia tlenku magnezu dwutlenku krzemu" },
        { "@language": "pt", "@value": "Teor combinado de óxido de cálcio óxido de magnésio dióxido de silício" },
        { "@language": "ro", "@value": "Conținut combinat de oxid de calciu oxid de magneziu dioxid de siliciu" },
        { "@language": "sk", "@value": "Obsah kombinovaného oxidu vápenatého oxidu horečnatého oxidu kremičitého" },
        { "@language": "sl", "@value": "Kombinirana vsebnost kalcijevega oksida magnezijevega oksida silicijevega dioksida" },
        { "@language": "sv", "@value": "Kombinerad halt av kalciumoxid magnesiumoxid kiseldioxid" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.5",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 66.6% declared) for blast furnace slag; means the sum CaO + MgO + SiO2." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≥ 66.6% декларирано) за гранулирана доменна шлака; означава сумата CaO + MgO + SiO2." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 66.6% deklarováno) pro vysokopecní strusku; znamená součet CaO + MgO + SiO2." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≥ 66.6% deklareret) for højovnsslagge; betyder summen CaO + MgO + SiO2." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Erklärung, falls enthalten (≥ 66.6% deklariert) für Hüttensand; bedeutet die Summe CaO + MgO + SiO2." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 66.6% δηλωμένο) για σκωρία υψικαμίνου· σημαίνει το άθροισμα CaO + MgO + SiO2." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 66.6% declarado) para escoria de alto horno; significa la suma CaO + MgO + SiO2." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui see on lisatud (≥ 66.6% deklareeritud) kõrgahju räbu puhul; tähendab summat CaO + MgO + SiO2." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≥ 66.6 % ilmoitettu) masuunikuonalle; tarkoittaa summaa CaO + MgO + SiO2." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 66.6% déclaré) pour le laitier de haut fourneau; signifie la somme CaO + MgO + SiO2." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 66.6% dearbhaithe) do shlaig fhoirnéise soinneáin; ciallaíonn sé an tsuim CaO + MgO + SiO2." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 66.6% deklarirano) za trosku visoke peći; znači zbroj CaO + MgO + SiO2." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 66.6% deklarált) a kohósalakhoz; a CaO + MgO + SiO2 összegét jelenti." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 66.6% dichiarato) per scoria d'altoforno; significa la somma CaO + MgO + SiO2." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 66.6% deklaruota) aukštakrosnių šlakui; reiškia sumą CaO + MgO + SiO2." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 66.6% deklarēts) domnas sārņiem; nozīmē summu CaO + MgO + SiO2." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluża (≥ 66.6% iddikjarat) għal gagazza tal-kalkara tal-funderija; tfisser is-somma CaO + MgO + SiO2." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≥ 66.6% gedeclareerd) voor hoogovenslak; betekent de som CaO + MgO + SiO2." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: deklaracja obowiązkowa, jeśli jest uwzględniony (≥ 66.6% deklarowane) dla żużla wielkopiecowego; oznacza sumę CaO + MgO + SiO2." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 66.6% declarado) para escória de alto-forno; significa a soma CaO + MgO + SiO2." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 66.6% declarat) pentru zgură de furnal; înseamnă suma CaO + MgO + SiO2." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 66.6% deklarované) pre vysokopecnú strusku; znamená súčet CaO + MgO + SiO2." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 66.6 % deklarirano) za plavžno žlindro; pomeni vsoto CaO + MgO + SiO2." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 66.6% deklarerat) för masugnsslagg; betyder summan CaO + MgO + SiO2." }
      ]
    },
