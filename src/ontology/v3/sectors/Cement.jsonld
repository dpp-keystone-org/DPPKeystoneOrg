    {
      "@id": "dppk-cement:activityIndex28Days",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Activity Index 28 Days" },
        { "@language": "bg", "@value": "Индекс на активност 28 дни" },
        { "@language": "cs", "@value": "Index aktivity 28 dní" },
        { "@language": "da", "@value": "Aktivitetsindeks 28 dage" },
        { "@language": "de", "@value": "Aktivitätsindex 28 Tage" },
        { "@language": "el", "@value": "Δείκτης δραστικότητας 28 ημερών" },
        { "@language": "es", "@value": "Índice de actividad 28 días" },
        { "@language": "et", "@value": "Aktiivsusindeks 28 päeva" },
        { "@language": "fi", "@value": "Aktiivisuusindeksi 28 vuorokautta" },
        { "@language": "fr", "@value": "Indice d'activité 28 jours" },
        { "@language": "ga", "@value": "Innéacs Gníomhaíochta 28 lá" },
        { "@language": "hr", "@value": "Indeks aktivnosti 28 dana" },
        { "@language": "hu", "@value": "Aktivitási index 28 nap" },
        { "@language": "it", "@value": "Indice di attività 28 giorni" },
        { "@language": "lt", "@value": "Aktyvumo indeksas 28 dienos" },
        { "@language": "lv", "@value": "Aktivitātes indekss 28 dienas" },
        { "@language": "mt", "@value": "Indiċi ta' Attività 28 jum" },
        { "@language": "nl", "@value": "Activiteitsindex 28 dagen" },
        { "@language": "pl", "@value": "Wskaźnik aktywności 28 dni" },
        { "@language": "pt", "@value": "Índice de atividade 28 dias" },
        { "@language": "ro", "@value": "Indice de activitate 28 zile" },
        { "@language": "sk", "@value": "Index aktivity 28 dní" },
        { "@language": "sl", "@value": "Indeks aktivnosti 28 dni" },
        { "@language": "sv", "@value": "Aktivitetsindex 28 dagar" }
      ],
      "dppk:governedBy": "EN 196-1:2026",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 75% declared); ratio of compressive strength of standard mortar bars with 75/25 mix." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължителна декларация, ако е включено (≥ 75% декларирано); съотношение на якостта на натиск на стандартни строителни разтвори със 75/25 смес." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 75% deklarováno); poměr pevnosti v tlaku standardních maltových trámečků se směsí 75/25." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration, hvis inkluderet (≥ 75% deklareret); forhold af trykstyrke for standard mørtelprismer med 75/25 blanding." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Erklärung, falls enthalten (≥ 75% deklariert); Verhältnis der Druckfestigkeit von Standardmörtelprismen mit 75/25-Mischung." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 75% δηλωμένο)· αναλογία αντοχής σε θλίψη τυπικών δοκιμίων κονιάματος με μίγμα 75/25." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 75% declarado); relación de resistencia a compresión de prismas de mortero normal con mezcla 75/25." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui on lisatud (≥ 75% deklareeritud); standardsete mördiproovide survetugevuse suhe 75/25 seguga." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus, jos sisältyy (≥ 75 % ilmoitettu); standardilaastikappaleiden puristuslujuuden suhde 75/25-seoksella." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: déclaration obligatoire si inclus (≥ 75% déclaré); rapport de résistance à la compression d'éprouvettes de mortier normal avec mélange 75/25." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 75% dearbhaithe); cóimheas neart comhbhrúite de bharraí moirtéal caighdeánach le meascán 75/25." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 75% deklarirano); omjer tlačne čvrstoće standardnih prizmi morta sa 75/25 mješavinom." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 75% deklarált); standard habarcs prizmák nyomószilárdságának aránya 75/25 keverékkel." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 75% dichiarato); rapporto di resistenza a compressione di prismi di malta standard con miscela 75/25." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 75% deklaruota); standartinių skiedinio prizmių su 75/25 mišiniu gniuždymo stiprio santykis." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 75% deklarēts); standarta javas prizmu spiedes stiprības attiecība ar 75/25 maisījumu." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluża (≥ 75% iddikjarat); proporzjon ta' qawwa kompressiva ta' priżmi tat-tikħil standard b'taħlita 75/25." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte declaratie indien inbegrepen (≥ 75% gedeclareerd); verhouding van druksterkte van standaard mortelprisma's met 75/25 mengsel." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: deklaracja obowiązkowa, jeśli uwzględniono (≥ 75% deklarowane); stosunek wytrzymałości na ściskanie standardowych beleczek z zaprawy z mieszanką 75/25." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 75% declarado); relação de resistência à compressão de prismas de argamassa padrão com mistura 75/25." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 75% declarat); raportul rezistenței la compresiune al prismelor de mortar standard cu amestec 75/25." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 75% deklarované); pomer pevnosti v tlaku štandardných maltových trámečkov so zmesou 75/25." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 75 % deklarirano); razmerje tlačne trdnosti standardnih prizem malte s 75/25 mešanico." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 75% deklarerat); förhållande av tryckhållfasthet för standardmurbruksprismor med 75/25-blandning." }
      ]
    },
