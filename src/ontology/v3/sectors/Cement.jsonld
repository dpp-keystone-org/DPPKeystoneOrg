      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: relevant only if included, for special applications; mix contains 75% primary cement." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: уместно само ако е включено, за специални приложения; сместа съдържа 75% първичен цимент." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: relevantní pouze pokud je zahrnuto, pro speciální aplikace; směs obsahuje 75% primárního cementu." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: kun relevant, hvis inkluderet, til specielle applikationer; blanding indeholder 75% primær cement." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: nur relevant, falls enthalten, für spezielle Anwendungen; Mischung enthält 75% Primärzement." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: σχετικό μόνο εάν περιλαμβάνεται, για ειδικές εφαρμογές· το μίγμα περιέχει 75% πρωτογενές τσιμέντο." },
        { "@language": "es", "@value": "AVS: 2+; Notas: relevante solo si se incluye, para aplicaciones especiales; la mezcla contiene 75% cemento primario." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: asjakohane ainult siis, kui on lisatud, erirakenduste puhul; segu sisaldab 75% primaartsementi." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: merkityksellinen vain, jos sisältyy, erityissovelluksiin; seos sisältää 75 % primäärisementtiä." },
        { "@language": "fr", "@value": "AVS: 2+; Notes: pertinent seulement si inclus, pour des applications spéciales; le mélange contient 75% de ciment primaire." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: ábhartha amháin má chuirtear san áireamh, d'fheidhmeanna speisialta; tá 75% stroighin phríomhúil sa mheascán." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: relevantno samo ako je uključeno, za posebne primjene; mješavina sadrži 75% primarnog cementa." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: csak akkor releváns, ha tartalmazza, speciális alkalmazásokhoz; a keverék 75% primer cementet tartalmaz." },
        { "@language": "it", "@value": "AVS: 2+; Note: rilevante solo se incluso, per applicazioni speciali; la miscela contiene 75% cemento primario." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: aktualu tik tuo atveju, jei įtraukta, specialioms taikymo sritims; mišinyje yra 75% pirminio cemento." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: attiecas tikai tad, ja tas ir iekļauts, īpašiem lietojumiem; maisījums satur 75% primārā cementa." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: rilevanti biss jekk inkluż, għal applikazzjonijiet speċjali; it-taħlita fiha 75% siment primarju." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: alleen relevant indien inbegrepen, voor speciale toepassingen; mengsel bevat 75% primair cement." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: istotne tylko wtedy, gdy uwzględniono, do specjalnych zastosowań; mieszanka zawiera 75% cementu podstawowego." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: relevante apenas se incluído, para aplicações especiais; a mistura contém 75% de cimento primário." },
