        { "@language": "pt", "@value": "AVS: 1+; CPF: freq. mín. 1/semana; Auditoria: 6/ano; Amostras de ensaio de tipo: 1; Valor est.: quantil 10% 95% ci; Notas: para aplicações especiais, apenas se exigido (Ensaio de tipo)." },
        { "@language": "ro", "@value": "AVS: 1+; CPF: frecv. min. 1/săptămână; Audit: 6/an; Eșantioane încercare de tip: 1; Valoare stat.: 10% fractil 95% ci; Note: pentru aplicații speciale, numai dacă se solicită (Încercare de tip)." },
        { "@language": "sk", "@value": "AVS: 1+; FPC: min. frekvencia 1/týždeň; Audit: 6/rok; Vzorky na skúšku typu: 1; Stat. hodnota: 10% kvantil 95% ci; Poznámky: pre špeciálne aplikácie, len ak sa požaduje (Skúška typu)." },
        { "@language": "sl", "@value": "AVS: 1+; NPK: min. pogostost 1/teden; Presoja: 6/leto; Vzorci za preizkus tipa: 1; Stat. vrednost: 10% fraktil 95% ci; Opombe: za posebne aplikacije, samo če se zahteva (Preizkus tipa)." },
        { "@language": "sv", "@value": "AVS: 1+; FPC: min. frekvens 1/vecka; Revision: 6/år; Typprovningsprover: 1; Stat. värde: 10% fraktil 95% ci; Anmärkningar: för speciella tillämpningar, endast om så krävs (Typprovning)." }
      ]
    },
