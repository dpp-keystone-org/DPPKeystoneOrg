    {
      "@id": "dppk-cement:insolubleResidueContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Insoluble Residue Content" },
        { "@language": "bg", "@value": "Съдържание на неразтворим остатък" },
        { "@language": "cs", "@value": "Obsah nerozpustného zbytku" },
        { "@language": "da", "@value": "Uopløselig restindhold" },
        { "@language": "de", "@value": "Gehalt an unlöslichem Rückstand" },
        { "@language": "el", "@value": "Περιεκτικότητα σε αδιάλυτο υπόλειμμα" },
        { "@language": "es", "@value": "Contenido de residuo insoluble" },
        { "@language": "et", "@value": "Lahustumatu jäägi sisaldus" },
        { "@language": "fi", "@value": "Liukenemattoman jäännöksen pitoisuus" },
        { "@language": "fr", "@value": "Teneur en résidu insoluble" },
        { "@language": "ga", "@value": "Ábhar Iarmhar Dothuaslagtha" },
        { "@language": "hr", "@value": "Sadržaj netopivog ostatka" },
        { "@language": "hu", "@value": "Oldhatatlan maradék tartalom" },
        { "@language": "it", "@value": "Contenuto di residuo insolubile" },
        { "@language": "lt", "@value": "Netirpių liekanų kiekis" },
        { "@language": "lv", "@value": "Nešķīstošo atlikumu saturs" },
        { "@language": "mt", "@value": "Kontenut ta' Residwu Insolubbli" },
        { "@language": "nl", "@value": "Gehalte onoplosbaar residu" },
        { "@language": "pl", "@value": "Zawartość pozostałości nierozpuszczalnej" },
        { "@language": "pt", "@value": "Teor de resíduo insolúvel" },
        { "@language": "ro", "@value": "Conținut de reziduu insolubil" },
        { "@language": "sk", "@value": "Obsah nerozpustného zvyšku" },
        { "@language": "sl", "@value": "Vsebnost netopnega ostanka" },
        { "@language": "sv", "@value": "Olöslig resthalt" }
      ],
      "dppk:governedBy": "EN 196-2:2026, Clause 4.4",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+; FPC: val ≤ 5.0%, freq 2/month (reduce to 1/month if max 50% char value over 12mo); Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile 95% ci; Notes: mandatory declaration; only for CEM I and CEM III, only if required." },
        { "@language": "bg", "@value": "AVS: 1+; FPC: стойност ≤ 5.0%, честота 2/месец (намаляване до 1/месец, ако макс 50% от характ. стойност за 12м); Одит: 6/година; Типово изпитване проби: 1; Стат стойност: 10% квантил 95% ci; Бележки: задължителна декларация; само за CEM I и CEM III, само ако се изисква." },
        { "@language": "cs", "@value": "AVS: 1+; FPC: hodnota ≤ 5.0%, frekvence 2/měsíc (snížit na 1/měsíc, pokud je max 50% char. hodnoty za 12m); Audit: 6/rok; Vzorky typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarace; pouze pro CEM I a CEM III, pouze pokud je požadováno." },
        { "@language": "da", "@value": "AVS: 1+; FPC: værdi ≤ 5.0%, frekvens 2/måned (reduceres til 1/måned, hvis max 50% karakt. værdi over 12 mdr); Audit: 6/år; Typeprøvning prøver: 1; Stat værdi: 10% fraktil 95% ci; Bemærkninger: obligatorisk deklaration; kun for CEM I og CEM III, kun hvis påkrævet." },
        { "@language": "de", "@value": "AVS: 1+; WPK: Wert ≤ 5.0%, Häufigkeit 2/Monat (reduzieren auf 1/Monat, wenn max. 50% des char. Wertes über 12 Mon.); Audit: 6/Jahr; Typprüfung Proben: 1; Stat Wert: 10% Fraktil 95% ci; Anmerkungen: obligatorische Erklärung; nur für CEM I und CEM III, nur falls erforderlich." },
        { "@language": "el", "@value": "AVS: 1+; FPC: τιμή ≤ 5.0%, συχνότητα 2/μήνα (μείωση σε 1/μήνα εάν μέγιστο 50% της χαρακτ. τιμής για 12μήνες); Έλεγχος: 6/έτος; Δείγματα τύπου: 1; Στατ τιμή: 10% ποσοστημόριο 95% ci; Σημειώσεις: υποχρεωτική δήλωση; μόνο για CEM I και CEM III, μόνο εάν απαιτείται." },
        { "@language": "es", "@value": "AVS: 1+; CPF: valor ≤ 5.0%, frec 2/mes (reducir a 1/mes si máx 50% del valor carac. en 12m); Auditoría: 6/año; Muestras de tipo: 1; Valor est: cuantil 10% 95% ci; Notas: declaración obligatoria; solo para CEM I y CEM III, solo si se requiere." },
        { "@language": "et", "@value": "AVS: 1+; FPC: väärtus ≤ 5.0%, sagedus 2/kuu (vähendada 1/kuu, kui max 50% karakt. väärtusest 12k jooksul); Audit: 6/aasta; Tüübikatse proovid: 1; Stat väärtus: 10% fraktiil 95% ci; Märkused: kohustuslik deklareerimine; ainult CEM I ja CEM III puhul, ainult siis, kui on nõutud." },
        { "@language": "fi", "@value": "AVS: 1+; FPC: arvo ≤ 5.0%, tiheys 2/kuukausi (vähennys 1/kk, jos max 50% ominaisarvosta 12kk:n aikana); Auditointi: 6/vuosi; Tyyppikokeen näytteet: 1; Stat arvo: 10% fraktiili 95% ci; Huomautukset: pakollinen ilmoitus; vain CEM I ja CEM III, vain jos vaaditaan." },
        { "@language": "fr", "@value": "EVCP: 1+; CPU: valeur ≤ 5.0%, fréq 2/mois (réduire à 1/mois si max 50% de la valeur caract. sur 12m); Audit: 6/an; Échantillons de type: 1; Valeur stat: quantile 10% 95% ci; Remarques: déclaration obligatoire; uniquement pour CEM I et CEM III, uniquement si requis." },
        { "@language": "ga", "@value": "AVS: 1+; FPC: luach ≤ 5.0%, minicíocht 2/mí (laghdú go 1/mí más uasmhéid 50% luach sain. thar 12mh); Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán 95% ci; Nótaí: dearbhú éigeantach; do CEM I agus CEM III amháin, ach amháin más gá." },
        { "@language": "hr", "@value": "AVS: 1+; FPC: vrijednost ≤ 5.0%, učestalost 2/mjesec (smanjiti na 1/mjesec ako je maks. 50% karakt. vrijednosti u 12mj); Revizija: 6/godina; Uzorci za tip: 1; Stat vrijednost: 10% fraktil 95% ci; Napomene: obvezna deklaracija; samo za CEM I i CEM III, samo ako je potrebno." },
        { "@language": "hu", "@value": "AVS: 1+; ÜGY: érték ≤ 5.0%, gyakoriság 2/hónap (csökkentés 1/hó-ra, ha max 50% a karakt. érték 12hónap alatt); Audit: 6/év; Típusvizsgálati minták: 1; Stat érték: 10% fraktilis 95% ci; Megjegyzések: kötelező nyilatkozat; csak CEM I és CEM III esetén, csak ha szükséges." },
        { "@language": "it", "@value": "VVCP: 1+; CPF: valore ≤ 5.0%, freq 2/mese (ridurre a 1/mese se max 50% del valore caratt. in 12m); Audit: 6/anno; Campioni di tipo: 1; Valore stat: frattile 10% 95% ci; Note: dichiarazione obbligatoria; solo per CEM I e CEM III, solo se richiesto." },
        { "@language": "lt", "@value": "AVS: 1+; VKS: vertė ≤ 5.0%, dažnis 2/mėn. (sumažinti iki 1/mėn., jei maks. 50% charakt. vertės per 12 mėn.); Auditas: 6/metai; Tipo bandymo mėginiai: 1; Stat vertė: 10 % fraktilis 95 % ci; Pastabos: privaloma deklaracija; tik CEM I ir CEM III, tik jei reikalaujama." },
        { "@language": "lv", "@value": "AVS: 1+; RKS: vērtība ≤ 5.0%, biežums 2/mēnesī (samazināt līdz 1/mēn., ja maks. 50% no rakst. vērtības 12 mēn.); Audits: 6/gads; Tipa pārbaudes paraugi: 1; Stat vērtība: 10% fraktile 95% ci; Piezīmes: obligāta deklarācija; tikai CEM I un CEM III, tikai tad, ja prasīts." },
        { "@language": "mt", "@value": "AVS: 1+; FPC: val ≤ 5.0%, frekwenza 2/xahar (tnaqqas għal 1/xahar jekk max 50% tal-valur karatt. f'12-il xahar); Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil 95% ci; Noti: dikjarazzjoni mandatorja; għal CEM I u CEM III biss, biss jekk meħtieġ." },
        { "@language": "nl", "@value": "AVS: 1+; FPC: waarde ≤ 5.0%, frequentie 2/maand (verlagen naar 1/maand indien max 50% karakt. waarde gedurende 12m); Audit: 6/jaar; Typetest monsters: 1; Stat waarde: 10% fractiel 95% ci; Opmerkingen: verplichte verklaring; alleen voor CEM I en CEM III, alleen indien vereist." },
        { "@language": "pl", "@value": "AVS: 1+; ZKP: wartość ≤ 5.0%, częstotliwość 2/miesiąc (zmniejszyć do 1/miesiąc jeśli maks. 50% wart. charakt. w ciągu 12m); Audit: 6/rok; Próbki typu: 1; Wartość stat: 10% kwantyl 95% ci; Uwagi: deklaracja obowiązkowa; tylko dla CEM I i CEM III, tylko jeśli wymagana." },
        { "@language": "pt", "@value": "AVS: 1+; CPF: valor ≤ 5.0%, freq 2/mês (reduzir para 1/mês se máx. 50% do valor carater. em 12m); Auditoria: 6/ano; Amostras de tipo: 1; Valor est: quantil 10% 95% ci; Notas: declaração obrigatória; apenas para CEM I e CEM III, apenas se exigido." },
        { "@language": "ro", "@value": "AVS: 1+; CPF: valoare ≤ 5.0%, frecv 2/lună (se reduce la 1/lună dacă max 50% din valoarea caract. pe 12luni); Audit: 6/an; Eșantioane de tip: 1; Valoare stat: 10% fractil 95% ci; Note: declarație obligatorie; doar pentru CEM I și CEM III, doar dacă este necesar." },
        { "@language": "sk", "@value": "AVS: 1+; FPC: hodnota ≤ 5.0%, frekvencia 2/mesiac (znížiť na 1/mesiac, ak max 50% char. hodnoty za 12m); Audit: 6/rok; Vzorky na skúšku typu: 1; Stat hodnota: 10% kvantil 95% ci; Poznámky: povinná deklarácia; len pre CEM I a CEM III, iba ak je to požadované." },
        { "@language": "sl", "@value": "AVS: 1+; NPK: vrednost ≤ 5.0%, pogostost 2/mesec (zmanjšati na 1/mesec, če je maks. 50% karakt. vrednosti v 12m); Presoja: 6/leto; Vzorci za preizkus tipa: 1; Stat vrednost: 10% fraktil 95% ci; Opombe: obvezna deklaracija; samo za CEM I in CEM III, samo, če se zahteva." },
        { "@language": "sv", "@value": "AVS: 1+; FPC: värde ≤ 5.0%, frekvens 2/månad (minska till 1/månad om max 50% karakt. värde under 12m); Revision: 6/år; Typprovningsprover: 1; Stat värde: 10% fraktil 95% ci; Anmärkningar: obligatorisk deklaration; endast för CEM I och CEM III, endast om det krävs." }
      ]
    },
    {
      "@id": "dppk-cement:sulfateContent",
