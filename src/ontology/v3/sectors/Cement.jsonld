      "dppk:governedBy": "EN 196-2:2026, Clause 4.5",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+ or 2+; FPC (AVS 1+): freq 1/week; Audit: 6/year; Type Test Samples: 1; Stat Value: 10% fractile; Notes: for special applications, only if required; relevant only if included for many additions." },
        { "@language": "bg", "@value": "AVS: 1+ или 2+; FPC (AVS 1+): честота 1/седмица; Одит: 6/година; Проби за изпитване на типа: 1; Стат. стойност: 10% фрактил; Забележки: за специални приложения, само ако се изисква; приложимо само ако е включено за много добавки." },
        { "@language": "cs", "@value": "AVS: 1+ nebo 2+; FPC (AVS 1+): frekvence 1/týden; Audit: 6/rok; Vzorky pro zkoušku typu: 1; Stat. hodnota: 10% kvantil; Poznámky: pro speciální aplikace, pouze pokud je to požadováno; relevantní pouze tehdy, je-li zahrnuto pro mnoho přísad." },
        { "@language": "da", "@value": "AVS: 1+ eller 2+; FPC (AVS 1+): frekvens 1/uge; Audit: 6/år; Typeprøvningsprøver: 1; Stat. værdi: 10% fraktil; Bemærkninger: til særlige anvendelser, kun hvis påkrævet; kun relevant, hvis inkluderet for mange tilsætninger." },
        { "@language": "de", "@value": "AVS: 1+ oder 2+; WPK (AVS 1+): Häufigkeit 1/Woche; Audit: 6/Jahr; Typprüfproben: 1; Stat. Wert: 10 %-Fraktil; Anmerkungen: für besondere Anwendungen, nur wenn erforderlich; nur relevant, wenn für viele Zusätze eingeschlossen." },
        { "@language": "el", "@value": "AVS: 1+ ή 2+; FPC (AVS 1+): συχνότητα 1/εβδομάδα; Έλεγχος: 6/έτος; Δείγματα δοκιμής τύπου: 1; Στατ. τιμή: ποσοστημόριο 10%; Σημειώσεις: για ειδικές εφαρμογές, μόνο εάν απαιτείται. σχετικό μόνο εάν συμπεριλαμβάνεται για πολλές προσθήκες." },
        { "@language": "es", "@value": "AVS: 1+ o 2+; FPC (AVS 1+): frecuencia 1/semana; Auditoría: 6/año; Muestras de ensayo de tipo: 1; Valor est.: cuantil 10 %; Notas: para aplicaciones especiales, solo si se requiere; relevante solo si se incluye para muchas adiciones." },
        { "@language": "et", "@value": "AVS: 1+ või 2+; FPC (AVS 1+): sagedus 1/nädalas; Audit: 6/aastas; Tüübikatsetuse proovid: 1; Stat. väärtus: 10% fraktiil; Märkused: erirakenduste puhul, ainult nõudmisel; asjakohane ainult siis, kui see on hõlmatud paljude lisandite puhul." },
        { "@language": "fi", "@value": "AVS: 1+ tai 2+; FPC (AVS 1+): tiheys 1/viikko; Auditointi: 6/vuosi; Tyyppikoenäytteet: 1; Tilastollinen arvo: 10 % fraktiili; Huomautukset: erityiskäyttöön, vain jos vaaditaan; oleellinen vain, jos sisällytetty monille lisäaineille." },
        { "@language": "fr", "@value": "AVS : 1+ ou 2+; FPC (AVS 1+) : fréq 1/semaine; Audit : 6/an; Échantillons d'essai de type : 1; Valeur stat. : fractile 10 %; Remarques : pour les applications spéciales, uniquement si nécessaire ; pertinent uniquement si inclus pour de nombreux ajouts." },
        { "@language": "ga", "@value": "AVS: 1+ nó 2+; FPC (AVS 1+): minicíocht 1/seachtain; Iniúchadh: 6/bliain; Samplaí Tástála Cineáil: 1; Luach Stat: 10% codán; Nótaí: le haghaidh feidhmchlár speisialta, ach amháin más gá; ábhartha ach amháin má tá sé san áireamh i go leor breiseán." },
        { "@language": "hr", "@value": "AVS: 1+ ili 2+; FPC (AVS 1+): učestalost 1/tjedno; Revizija: 6/godišnje; Uzorci za ispitivanje tipa: 1; Stat. vrijednost: 10% fraktila; Napomene: za posebne primjene, samo ako se zahtijeva; relevantno samo ako je uključeno za mnoge dodatke." },
        { "@language": "hu", "@value": "AVS: 1+ vagy 2+; FPC (AVS 1+): gyakoriság 1/hét; Audit: 6/év; Típusvizsgálati minták: 1; Stat. érték: 10% fraktilis; Megjegyzések: speciális alkalmazásokhoz, csak ha szükséges; csak akkor releváns, ha sok adalékanyaghoz szerepel." },
        { "@language": "it", "@value": "AVS: 1+ o 2+; FPC (AVS 1+): freq 1/settimana; Audit: 6/anno; Campioni di prova di tipo: 1; Valore stat.: frattile 10%; Note: per applicazioni speciali, solo se richiesto; rilevante solo se incluso per molte aggiunte." },
        { "@language": "lt", "@value": "AVS: 1+ arba 2+; FPC (AVS 1+): dažnumas 1/sav.; Auditas: 6/metus; Tipo bandymo mėginiai: 1; Stat. vertė: 10% fraktilis; Pastabos: specialiam naudojimui, tik jei reikalaujama; aktualu tik tuo atveju, jei įtraukta daugeliui priedų." },
        { "@language": "lv", "@value": "AVS: 1+ vai 2+; FPC (AVS 1+): biežums 1/nedēļā; Audits: 6/gadā; Tipa testa paraugi: 1; Stat. vērtība: 10% fraktīle; Piezīmes: īpašiem pielietojumiem, tikai ja nepieciešams; attiecas tikai tad, ja tas ir iekļauts daudzām piedevām." },
        { "@language": "mt", "@value": "AVS: 1+ jew 2+; FPC (AVS 1+): frekwenza 1/ġimgħa; Awditjar: 6/sena; Kampjuni tat-Test tat-Tip: 1; Valur Stat: 10% frattil; Noti: għal applikazzjonijiet speċjali, biss jekk meħtieġ; rilevanti biss jekk inkluż għal ħafna żidiet." },
        { "@language": "nl", "@value": "AVS: 1+ of 2+; FPC (AVS 1+): freq 1/week; Audit: 6/jaar; Typebeproevingsmonsters: 1; Stat. waarde: 10% fractiel; Opmerkingen: voor speciale toepassingen, alleen indien vereist; alleen relevant indien inbegrepen voor veel toevoegingen." },
        { "@language": "pl", "@value": "AVS: 1+ lub 2+; FPC (AVS 1+): częst. 1/tydzień; Audyt: 6/rok; Próbki do badania typu: 1; Wartość stat.: 10% fraktyl; Uwagi: do zastosowań specjalnych, tylko jeśli jest to wymagane; istotne tylko wtedy, gdy jest to uwzględnione w wielu dodatkach." },
        { "@language": "pt", "@value": "AVS: 1+ ou 2+; FPC (AVS 1+): freq 1/semana; Auditoria: 6/ano; Amostras de Ensaio de Tipo: 1; Valor Est.: quantil 10%; Notas: para aplicações especiais, apenas se exigido; relevante apenas se incluído para muitas adições." },
        { "@language": "ro", "@value": "AVS: 1+ sau 2+; FPC (AVS 1+): frecvență 1/săptămână; Audit: 6/an; Eșantioane de încercare de tip: 1; Valoare stat.: 10% fractil; Note: pentru aplicații speciale, numai dacă se cere; relevant numai dacă este inclus pentru multe adaosuri." },
        { "@language": "sk", "@value": "AVS: 1+ alebo 2+; FPC (AVS 1+): frekvencia 1/týždeň; Audit: 6/rok; Vzorky na skúšku typu: 1; Štat. hodnota: 10% kvantil; Poznámky: na špeciálne aplikácie, len ak sa to vyžaduje; relevantné, len ak sú zahrnuté pre mnohé prísady." },
        { "@language": "sl", "@value": "AVS: 1+ ali 2+; FPC (AVS 1+): pogostost 1/teden; Presoja: 6/leto; Vzorci za preskus tipa: 1; Stat. vrednost: 10 % fraktil; Opombe: za posebne aplikacije, samo če se zahteva; pomembno samo, če je vključeno za številne dodatke." },
        { "@language": "sv", "@value": "AVS: 1+ eller 2+; FPC (AVS 1+): frekvens 1/vecka; Revision: 6/år; Typprovningsprov: 1; Stat. värde: 10% fraktil; Anmärkningar: för speciella tillämpningar, endast om så krävs; relevant endast om det ingår för många tillsatser." }
      ]
    },
