      "rdfs:comment": [
        { "@language": "en", "@value": "Notes: Table 220 defines min/max for each designation. Sum of L, LL and F limited to 35%." },
        { "@language": "bg", "@value": "Забележки: Таблица 220 определя мин/макс за всяко обозначение. Сумата от L, LL и F е ограничена до 35%." },
        { "@language": "cs", "@value": "Poznámky: Tabulka 220 definuje min/max pro každé označení. Součet L, LL a F omezen na 35 %." },
        { "@language": "da", "@value": "Bemærkninger: Tabel 220 definerer min/maks for hver betegnelse. Summen af L, LL og F begrænset til 35%." },
        { "@language": "de", "@value": "Anmerkungen: Tabelle 220 definiert Min/Max für jede Bezeichnung. Summe aus L, LL und F begrenzt auf 35%." },
        { "@language": "el", "@value": "Σημειώσεις: Ο πίνακας 220 καθορίζει ελάχιστο/μέγιστο για κάθε ονομασία. Το άθροισμα L, LL και F περιορίζεται σε 35%." },
        { "@language": "es", "@value": "Notas: La tabla 220 define los valores mínimo/máximo para cada designación. La suma de L, LL y F está limitada al 35%." },
        { "@language": "et", "@value": "Märkused: Tabel 220 määrab iga tähistuse min/max. L, LL ja F summa on piiratud 35%-ga." },
        { "@language": "fi", "@value": "Huomautuksia: Taulukko 220 määrittelee min/max jokaiselle merkinnälle. L, LL ja F summa on rajoitettu 35 %:iin." },
        { "@language": "fr", "@value": "Notes: Le tableau 220 définit le min/max pour chaque désignation. Somme de L, LL et F limitée à 35%." },
        { "@language": "ga", "@value": "Nótaí: Sainmhíníonn Tábla 220 íosmhéid/uasmhéid do gach dearadh. Suim L, LL agus F teoranta do 35%." },
        { "@language": "hr", "@value": "Napomene: Tablica 220 definira min/maks za svaku oznaku. Zbroj L, LL i F ograničen na 35%." },
        { "@language": "hu", "@value": "Megjegyzések: A 220. táblázat minden jelöléshez meghatározza a min/max értéket. Az L, LL és F összege 35%-ra van korlátozva." },
        { "@language": "it", "@value": "Note: La tabella 220 definisce il min/max per ciascuna designazione. Somma di L, LL e F limitata al 35%." },
        { "@language": "lt", "@value": "Pastabos: 220 lentelėje nustatomas kiekvieno žymėjimo min/max. L, LL ir F suma ribojama iki 35%." },
        { "@language": "lv", "@value": "Piezīmes: 220. tabula nosaka min/max katram apzīmējumam. L, LL un F summa ierobežota līdz 35%." },
        { "@language": "mt", "@value": "Noti: It-Tabella 220 tiddefinixxi min/max għal kull deżinjazzjoni. Is-somma ta' L, LL u F hija limitata għal 35%." },
        { "@language": "nl", "@value": "Opmerkingen: Tabel 220 definieert min/max voor elke aanduiding. Som van L, LL en F beperkt tot 35%." },
        { "@language": "pl", "@value": "Uwagi: Tabela 220 określa min/max dla każdego oznaczenia. Suma L, LL i F ograniczona do 35%." },
        { "@language": "pt", "@value": "Notas: A tabela 220 define o mínimo/máximo para cada designação. A soma de L, LL e F está limitada a 35%." },
        { "@language": "ro", "@value": "Note: Tabelul 220 definește min/max pentru fiecare desemnare. Suma dintre L, LL și F este limitată la 35%." },
        { "@language": "sk", "@value": "Poznámky: Tabuľka 220 definuje min/max pre každé označenie. Súčet L, LL a F obmedzený na 35 %." },
        { "@language": "sl", "@value": "Opombe: Tabela 220 določa min/maks za vsako oznako. Vsota L, LL in F je omejena na 35 %." },
        { "@language": "sv", "@value": "Anmärkningar: Tabell 220 definierar min/max för varje beteckning. Summan av L, LL och F är begränsad till 35 %." }
      ]
    },
    {
      "@id": "dppk-cement:maximumRecycledConcreteFinesContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Maximum Recycled Concrete Fines Content" },
        { "@language": "bg", "@value": "Максимално съдържание на фини частици от рециклиран бетон" },
        { "@language": "cs", "@value": "Maximální obsah jemných podílů z recyklovaného betonu" },
        { "@language": "da", "@value": "Maksimalt indhold af genanvendt betonfinstof" },
        { "@language": "de", "@value": "Maximaler Gehalt an rezykliertem Betonbrechsand" },
        { "@language": "el", "@value": "Μέγιστη περιεκτικότητα σε λεπτόκοκκα ανακυκλωμένου σκυροδέματος" },
        { "@language": "es", "@value": "Contenido máximo de finos de hormigón reciclado" },
        { "@language": "et", "@value": "Maksimaalne ringlussevõetud betoonipeenmaterjali sisaldus" },
        { "@language": "fi", "@value": "Suurin kierrätysbetonihienoaineksen pitoisuus" },
        { "@language": "fr", "@value": "Teneur maximale en fines de béton recyclé" },
        { "@language": "ga", "@value": "Uasmhéid ábhar fíneálacha coincréite athchúrsáilte" },
        { "@language": "hr", "@value": "Maksimalni udio sitnih čestica recikliranog betona" },
        { "@language": "hu", "@value": "Újrahasznosított beton finomanyagának maximális tartalma" },
        { "@language": "it", "@value": "Contenuto massimo di fini di calcestruzzo riciclato" },
        { "@language": "lt", "@value": "Didžiausias perdirbto betono smulkiųjų dalelių kiekis" },
        { "@language": "lv", "@value": "Maksimālais pārstrādāta betona smalkumu saturs" },
        { "@language": "mt", "@value": "Kontenut massimu ta' trab tal-konkos riċiklat" },
        { "@language": "nl", "@value": "Maximum gehalte aan gerecyclede betonfijne stoffen" },
        { "@language": "pl", "@value": "Maksymalna zawartość mączki z betonu z recyklingu" },
        { "@language": "pt", "@value": "Teor máximo de finos de betão reciclado" },
        { "@language": "ro", "@value": "Conținut maxim de particule fine din beton reciclat" },
        { "@language": "sk", "@value": "Maximálny obsah jemných podielov z recyklovaného betónu" },
        { "@language": "sl", "@value": "Največja vsebnost finih delcev recikliranega betona" },
        { "@language": "sv", "@value": "Högsta halt av återvunnet betongfinsten" }
      ],
      "dppk:governedBy": "EN 197-1",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "Notes: Table 220 defines min/max for each designation. Limited to 29% by mass, sum of L, LL and F limited to 35%." },
        { "@language": "bg", "@value": "Забележки: Таблица 220 определя мин/макс за всяко обозначение. Ограничено до 29% по маса, сумата от L, LL и F е ограничена до 35%." },
        { "@language": "cs", "@value": "Poznámky: Tabulka 220 definuje min/max pro každé označení. Omezeno na 29 % hmotnostních, součet L, LL a F omezen na 35 %." },
        { "@language": "da", "@value": "Bemærkninger: Tabel 220 definerer min/maks for hver betegnelse. Begrænset til 29 masseprocent, summen af L, LL og F begrænset til 35%." },
        { "@language": "de", "@value": "Anmerkungen: Tabelle 220 definiert Min/Max für jede Bezeichnung. Begrenzt auf 29 Massen-%, Summe aus L, LL und F begrenzt auf 35%." },
        { "@language": "el", "@value": "Σημειώσεις: Ο πίνακας 220 καθορίζει ελάχιστο/μέγιστο για κάθε ονομασία. Περιορίζεται σε 29% κατά μάζα, το άθροισμα L, LL και F περιορίζεται σε 35%." },
        { "@language": "es", "@value": "Notas: La tabla 220 define los valores mínimo/máximo para cada designación. Limitado al 29% en masa, la suma de L, LL y F está limitada al 35%." },
        { "@language": "et", "@value": "Märkused: Tabel 220 määrab iga tähistuse min/max. Piiratud 29 massiprotsendiga, L, LL ja F summa on piiratud 35%-ga." },
        { "@language": "fi", "@value": "Huomautuksia: Taulukko 220 määrittelee min/max jokaiselle merkinnälle. Rajoitettu 29 painoprosenttiin, L, LL ja F summa on rajoitettu 35 %:iin." },
        { "@language": "fr", "@value": "Notes: Le tableau 220 définit le min/max pour chaque désignation. Limité à 29% en masse, somme de L, LL et F limitée à 35%." },
        { "@language": "ga", "@value": "Nótaí: Sainmhíníonn Tábla 220 íosmhéid/uasmhéid do gach dearadh. Teoranta do 29% de réir maise, suim L, LL agus F teoranta do 35%." },
        { "@language": "hr", "@value": "Napomene: Tablica 220 definira min/maks za svaku oznaku. Ograničeno na 29% mase, zbroj L, LL i F ograničen na 35%." },
        { "@language": "hu", "@value": "Megjegyzések: A 220. táblázat minden jelöléshez meghatározza a min/max értéket. Tömegszázalékban 29%-ra korlátozva, az L, LL és F összege 35%-ra van korlátozva." },
        { "@language": "it", "@value": "Note: La tabella 220 definisce il min/max per ciascuna designazione. Limitato al 29% in massa, somma di L, LL e F limitata al 35%." },
        { "@language": "lt", "@value": "Pastabos: 220 lentelėje nustatomas kiekvieno žymėjimo min/max. Ribojama iki 29% masės, L, LL ir F suma ribojama iki 35%." },
        { "@language": "lv", "@value": "Piezīmes: 220. tabula nosaka min/max katram apzīmējumam. Ierobežots līdz 29% pēc masas, L, LL un F summa ierobežota līdz 35%." },
        { "@language": "mt", "@value": "Noti: It-Tabella 220 tiddefinixxi min/max għal kull deżinjazzjoni. Limitat għal 29% bil-massa, is-somma ta' L, LL u F hija limitata għal 35%." },
        { "@language": "nl", "@value": "Opmerkingen: Tabel 220 definieert min/max voor elke aanduiding. Beperkt tot 29 massaprocent, som van L, LL en F beperkt tot 35%." },
        { "@language": "pl", "@value": "Uwagi: Tabela 220 określa min/max dla każdego oznaczenia. Ograniczona do 29% masowych, suma L, LL i F ograniczona do 35%." },
        { "@language": "pt", "@value": "Notas: A tabela 220 define o mínimo/máximo para cada designação. Limitado a 29% em massa, a soma de L, LL e F está limitada a 35%." },
        { "@language": "ro", "@value": "Note: Tabelul 220 definește min/max pentru fiecare desemnare. Limitat la 29% din masă, suma dintre L, LL și F este limitată la 35%." },
        { "@language": "sk", "@value": "Poznámky: Tabuľka 220 definuje min/max pre každé označenie. Obmedzené na 29 % hmotnosti, súčet L, LL a F obmedzený na 35 %." },
        { "@language": "sl", "@value": "Opombe: Tabela 220 določa min/maks za vsako oznako. Omejeno na 29 utemnih %, vsota L, LL in F je omejena na 35 %." },
        { "@language": "sv", "@value": "Anmärkningar: Tabell 220 definierar min/max för varje beteckning. Begränsad till 29 viktprocent, summan av L, LL och F är begränsad till 35 %." }
      ]
    },
    {
      "@id": "dppk-cement:maximumChlorideContent",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Maximum Chloride Content" },
        { "@language": "bg", "@value": "Максимално съдържание на хлориди" },
        { "@language": "cs", "@value": "Maximální obsah chloridů" },
        { "@language": "da", "@value": "Maksimalt chloridindhold" },
        { "@language": "de", "@value": "Maximaler Chloridgehalt" },
        { "@language": "el", "@value": "Μέγιστη περιεκτικότητα σε χλωρίδια" },
        { "@language": "es", "@value": "Contenido máximo de cloruros" },
        { "@language": "et", "@value": "Maksimaalne kloriidisisaldus" },
        { "@language": "fi", "@value": "Suurin kloridipitoisuus" },
        { "@language": "fr", "@value": "Teneur maximale en chlorures" },
        { "@language": "ga", "@value": "Uasmhéid ábhar clóiríde" },
        { "@language": "hr", "@value": "Maksimalni udio klorida" },
        { "@language": "hu", "@value": "Maximális kloridtartalom" },
        { "@language": "it", "@value": "Contenuto massimo di cloruri" },
        { "@language": "lt", "@value": "Didžiausias chloridų kiekis" },
        { "@language": "lv", "@value": "Maksimālais hlorīdu saturs" },
        { "@language": "mt", "@value": "Kontenut massimu ta' klorur" },
        { "@language": "nl", "@value": "Maximum chloridegehalte" },
        { "@language": "pl", "@value": "Maksymalna zawartość chlorków" },
        { "@language": "pt", "@value": "Teor máximo de cloretos" },
        { "@language": "ro", "@value": "Conținut maxim de cloruri" },
        { "@language": "sk", "@value": "Maximálny obsah chloridov" },
        { "@language": "sl", "@value": "Največja vsebnost kloridov" },
        { "@language": "sv", "@value": "Högsta kloridhalt" }
      ],
      "dppk:governedBy": "EN 197-1",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 1+ (Primary); Notes: ≤ 0.10% declared unless binary CEM III or composite CEM VI/A, then max must be declared if > 0.10%." },
        { "@language": "bg", "@value": "AVS: 1+ (Първичен); Забележки: ≤ 0.10% декларирано, освен ако не е двоен CEM III или композитен CEM VI/A, тогава трябва да се декларира максимум, ако е > 0.10%." },
        { "@language": "cs", "@value": "AVS: 1+ (Primární); Poznámky: deklarováno ≤ 0,10 %, pokud se nejedná o binární CEM III nebo kompozitní CEM VI/A, pak musí být deklarováno maximum, pokud je > 0,10 %." },
        { "@language": "da", "@value": "AVS: 1+ (Primær); Bemærkninger: ≤ 0,10% deklareret medmindre binær CEM III eller komposit CEM VI/A, så skal maks deklareres, hvis > 0,10%." },
        { "@language": "de", "@value": "AVS: 1+ (Primär); Anmerkungen: ≤ 0,10% deklariert, außer bei binärem CEM III oder Kompositzement CEM VI/A, dann muss das Maximum deklariert werden, wenn > 0,10%." },
        { "@language": "el", "@value": "AVS: 1+ (Πρωτεύον); Σημειώσεις: ≤ 0.10% δηλωμένο εκτός εάν είναι δυαδικό CEM III ή σύνθετο CEM VI/A, τότε το μέγιστο πρέπει να δηλωθεί εάν > 0.10%." },
        { "@language": "es", "@value": "AVS: 1+ (Primario); Notas: ≤ 0.10% declarado a menos que sea CEM III binario o compuesto CEM VI/A, entonces se debe declarar el máximo si es > 0.10%." },
        { "@language": "et", "@value": "AVS: 1+ (Esmane); Märkused: ≤ 0,10% deklareeritud, välja arvatud juhul, kui tegemist on binaarse CEM III või komposiitse CEM VI/A-ga, siis tuleb deklareerida maksimum, kui see on > 0,10%." },
        { "@language": "fi", "@value": "AVS: 1+ (Ensisijainen); Huomautuksia: ≤ 0,10 % ilmoitettu, ellei kyseessä ole binäärinen CEM III tai komposiitti CEM VI/A, jolloin maksimi on ilmoitettava, jos se on > 0,10 %." },
        { "@language": "fr", "@value": "AVS: 1+ (Primaire); Notes: ≤ 0,10% déclaré, sauf s'il s'agit d'un CEM III binaire ou d'un composite CEM VI/A, alors le maximum doit être déclaré si > 0,10%." },
        { "@language": "ga", "@value": "AVS: 1+ (Bunscoile); Nótaí: ≤ 0.10% dearbhaithe mura rud é gur CEM III dénártha nó ilchodach CEM VI/A é, agus caithfear an t-uasmhéid a dhearbhú má tá > 0.10% ann." },
        { "@language": "hr", "@value": "AVS: 1+ (Primarni); Napomene: ≤ 0.10% deklarirano osim za binarni CEM III ili kompozitni CEM VI/A, tada se mora deklarirati maksimum ako je > 0.10%." },
        { "@language": "hu", "@value": "AVS: 1+ (Elsődleges); Megjegyzések: ≤ 0,10% deklarált, kivéve, ha bináris CEM III vagy kompozit CEM VI/A, akkor a maximumot deklarálni kell, ha > 0,10%." },
        { "@language": "it", "@value": "AVS: 1+ (Primario); Note: ≤ 0,10% dichiarato, a meno che non si tratti di CEM III binario o CEM VI/A composito, nel qual caso il valore massimo deve essere dichiarato se > 0,10%." },
        { "@language": "lt", "@value": "AVS: 1+ (Pirminis); Pastabos: ≤ 0,10% deklaruota, nebent dvinaris CEM III arba kompozitinis CEM VI/A, tuomet turi būti deklaruojamas maksimumas, jei > 0,10%." },
        { "@language": "lv", "@value": "AVS: 1+ (Primārais); Piezīmes: ≤ 0,10% deklarēts, ja vien nav binārs CEM III vai kompozīts CEM VI/A, tad jādeklarē maksimums, ja > 0,10%." },
        { "@language": "mt", "@value": "AVS: 1+ (Primarju); Noti: ≤ 0.10% iddikjarat sakemm ma jkunx CEM III binarju jew kompost CEM VI/A, imbagħad il-massimu jrid jiġi ddikjarat jekk > 0.10%." },
        { "@language": "nl", "@value": "AVS: 1+ (Primair); Opmerkingen: ≤ 0,10% gedeclareerd, tenzij binair CEM III of composiet CEM VI/A, dan moet het maximum worden gedeclareerd als het > 0,10% is." },
        { "@language": "pl", "@value": "AVS: 1+ (Pierwszorzędny); Uwagi: ≤ 0,10% deklarowane, chyba że binarny CEM III lub kompozytowy CEM VI/A, wtedy należy zadeklarować maksimum, jeśli > 0,10%." },
        { "@language": "pt", "@value": "AVS: 1+ (Primário); Notas: ≤ 0,10% declarado a menos que seja CEM III binário ou composto CEM VI/A, então o máximo deve ser declarado se > 0,10%." },
        { "@language": "ro", "@value": "AVS: 1+ (Primar); Note: ≤ 0,10% declarat, cu excepția cazului în care este CEM III binar sau CEM VI/A compozit, caz în care maximul trebuie declarat dacă este > 0,10%." },
        { "@language": "sk", "@value": "AVS: 1+ (Primárny); Poznámky: deklarované ≤ 0,10 %, pokiaľ nejde o binárny CEM III alebo kompozitný CEM VI/A, potom musí byť deklarované maximum, ak je > 0,10 %." },
        { "@language": "sl", "@value": "AVS: 1+ (Primarni); Opombe: ≤ 0,10 % deklarirano, razen če gre za binarni CEM III ali kompozitni CEM VI/A, potem se mora deklarirati maksimum, če je > 0,10 %." },
        { "@language": "sv", "@value": "AVS: 1+ (Primär); Anmärkningar: ≤ 0,10 % deklarerat såvida det inte är binär CEM III eller komposit CEM VI/A, då måste maxvärdet deklareras om det är > 0,10 %." }
      ]
    }
  ]
}