      "@id": "dppk-cement:ratioCalciumOxidePlusMagnesiumOxideToSiliconDioxide",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement:CementProduct" },
      "rdfs:range": "xsd:double",
      "rdfs:label": [
        { "@language": "en", "@value": "Ratio Calcium Oxide Plus Magnesium Oxide To Silicon Dioxide" },
        { "@language": "bg", "@value": "Съотношение калциев оксид плюс магнезиев оксид към силициев диоксид" },
        { "@language": "cs", "@value": "Poměr oxid vápenatý plus oxid hořečnatý k oxidu křemičitému" },
        { "@language": "da", "@value": "Forholdet calciumoxid plus magnesiumoxid til siliciumdioxid" },
        { "@language": "de", "@value": "Verhältnis Calciumoxid plus Magnesiumoxid zu Siliciumdioxid" },
        { "@language": "el", "@value": "Λόγος οξειδίου του ασβεστίου συν οξειδίου του μαγνησίου προς διοξείδιο του πυριτίου" },
        { "@language": "es", "@value": "Relación óxido de calcio más óxido de magnesio a dióxido de silicio" },
        { "@language": "et", "@value": "Kaltsiumoksiidi pluss magneesiumoksiidi suhe ränidioksiidiga" },
        { "@language": "fi", "@value": "Kalsiumoksidin ja magnesiumoksidin summa suhteessa piidioksidiin" },
        { "@language": "fr", "@value": "Rapport oxyde de calcium plus oxyde de magnésium sur dioxyde de silicium" },
        { "@language": "ga", "@value": "Cóimheas Ocsaíd Chailciam Móide Ocsaíd Mhaignéisiam le Dé-ocsaíd Shileacain" },
        { "@language": "hr", "@value": "Omjer zbroja kalcijeva oksida i magnezijeva oksida prema silicijevu dioksidu" },
        { "@language": "hu", "@value": "Kalcium-oxid plusz magnézium-oxid / szilícium-dioxid arány" },
        { "@language": "it", "@value": "Rapporto ossido di calcio più ossido di magnesio su biossido di silicio" },
        { "@language": "lt", "@value": "Kalcio oksido plius magnio oksido ir silicio dioksido santykis" },
        { "@language": "lv", "@value": "Kalcija oksīda plus magnija oksīda attiecība pret silīcija dioksīdu" },
        { "@language": "mt", "@value": "Proporzjon ta' Ossidu tal-Kalċju Flimkien ma' Ossidu tal-Manjeżju għal Diossidu tas-Silikon" },
        { "@language": "nl", "@value": "Verhouding calciumoxide plus magnesiumoxide tot siliciumdioxide" },
        { "@language": "pl", "@value": "Stosunek tlenku wapnia plus tlenku magnezu do dwutlenku krzemu" },
        { "@language": "pt", "@value": "Relação óxido de cálcio mais óxido de magnésio para dióxido de silício" },
        { "@language": "ro", "@value": "Raport oxid de calciu plus oxid de magneziu la dioxid de siliciu" },
        { "@language": "sk", "@value": "Pomer oxid vápenatý plus oxid horečnatý k oxidu kremičitému" },
        { "@language": "sl", "@value": "Razmerje kalcijev oksid plus magnezijev oksid proti silicijevemu dioksidu" },
        { "@language": "sv", "@value": "Förhållande kalciumoxid plus magnesiumoxid till kiseldioxid" }
      ],
      "dppk:governedBy": "EN 196-2:2026",
      "dppk:unit": { "@id": "dppk-unit:Unitless" },
      "rdfs:comment": [
        { "@language": "en", "@value": "AVS: 2+; Notes: mandatory declaration if included (≥ 1.0 declared) for blast furnace slag." },
        { "@language": "bg", "@value": "AVS: 2+; Забележки: задължително деклариране, ако е включено (≥ 1.0 декларирано) за гранулирана шлака от доменни пещи." },
        { "@language": "cs", "@value": "AVS: 2+; Poznámky: povinná deklarace, pokud je zahrnuto (≥ 1.0 deklarováno) pro vysokopecní strusku." },
        { "@language": "da", "@value": "AVS: 2+; Bemærkninger: obligatorisk deklaration hvis inkluderet (≥ 1.0 deklareret) for højovnsslagge." },
        { "@language": "de", "@value": "AVS: 2+; Anmerkungen: obligatorische Deklaration, wenn enthalten (≥ 1.0 deklariert) für Hüttensand." },
        { "@language": "el", "@value": "AVS: 2+; Σημειώσεις: υποχρεωτική δήλωση εάν περιλαμβάνεται (≥ 1.0 δηλωθέν) για σκωρία υψικαμίνου." },
        { "@language": "es", "@value": "AVS: 2+; Notas: declaración obligatoria si se incluye (≥ 1.0 declarado) para escoria de horno alto." },
        { "@language": "et", "@value": "AVS: 2+; Märkused: kohustuslik deklaratsioon, kui on kaasatud (≥ 1.0 deklareeritud) kõrgahjuräbu puhul." },
        { "@language": "fi", "@value": "AVS: 2+; Huomautukset: pakollinen ilmoitus jos sisältyy (≥ 1.0 ilmoitettu) masuunikuonalle." },
        { "@language": "fr", "@value": "AVS : 2+ ; Notes : déclaration obligatoire si inclus (≥ 1.0 déclaré) pour le laitier de haut fourneau." },
        { "@language": "ga", "@value": "AVS: 2+; Nótaí: dearbhú éigeantach má chuirtear san áireamh (≥ 1.0 dearbhaithe) do shlaig fhoirnéise soinneáin." },
        { "@language": "hr", "@value": "AVS: 2+; Napomene: obvezna deklaracija ako je uključeno (≥ 1.0 deklarirano) za zguru visoke peći." },
        { "@language": "hu", "@value": "AVS: 2+; Megjegyzések: kötelező nyilatkozat, ha tartalmazza (≥ 1.0 deklarálva) kohósalak esetén." },
        { "@language": "it", "@value": "AVS: 2+; Note: dichiarazione obbligatoria se incluso (≥ 1.0 dichiarato) per loppa di altoforno." },
        { "@language": "lt", "@value": "AVS: 2+; Pastabos: privaloma deklaracija, jei įtraukta (≥ 1.0 deklaruota) aukštakrosnių šlakui." },
        { "@language": "lv", "@value": "AVS: 2+; Piezīmes: obligāta deklarācija, ja iekļauts (≥ 1.0 deklarēts) domnas sārņiem." },
        { "@language": "mt", "@value": "AVS: 2+; Noti: dikjarazzjoni obbligatorja jekk inkluż (≥ 1.0 iddikjarat) għall-gagazza tal-kalkara tal-funderija." },
        { "@language": "nl", "@value": "AVS: 2+; Opmerkingen: verplichte verklaring indien inbegrepen (≥ 1.0 aangegeven) voor hoogovenslak." },
        { "@language": "pl", "@value": "AVS: 2+; Uwagi: obowiązkowa deklaracja, jeśli dołączono (≥ 1.0 deklarowane) dla żużla wielkopiecowego." },
        { "@language": "pt", "@value": "AVS: 2+; Notas: declaração obrigatória se incluído (≥ 1.0 declarado) para escória de alto-forno." },
        { "@language": "ro", "@value": "AVS: 2+; Note: declarație obligatorie dacă este inclus (≥ 1.0 declarat) pentru zgura de furnal." },
        { "@language": "sk", "@value": "AVS: 2+; Poznámky: povinná deklarácia, ak je zahrnuté (≥ 1.0 deklarované) pre vysokopecnú strusku." },
        { "@language": "sl", "@value": "AVS: 2+; Opombe: obvezna deklaracija, če je vključeno (≥ 1.0 deklarirano) za plavžo žlindro." },
        { "@language": "sv", "@value": "AVS: 2+; Anmärkningar: obligatorisk deklaration om det ingår (≥ 1.0 deklarerat) för masugnsslagg." }
      ]
    },
