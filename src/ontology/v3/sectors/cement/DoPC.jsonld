  "dcterms:description": [
    { "@language": "en", "@value": "Ontology defining terms and concepts specific to the Declaration of Performance and Conformity for the cement sector." },
    { "@language": "bg", "@value": "Онтология, дефинираща термини и концепции, специфични за Декларацията за експлоатационни показатели и съответствие за циментовия сектор." },
    { "@language": "cs", "@value": "Ontologie definující termíny a koncepty specifické pro Prohlášení o vlastnostech a shodě pro sektor cementu." },
    { "@language": "da", "@value": "Ontologi, der definerer termer og begreber, der er specifikke for ydeevne- og overensstemmelseserklæringen for cementsektoren." },
    { "@language": "de", "@value": "Ontologie zur Definition von Begriffen und Konzepten speziell für die Leistungs- und Konformitätserklärung im Zementsektor." },
    { "@language": "el", "@value": "Οντολογία που ορίζει όρους και έννοιες ειδικές για τη Δήλωση Επιδόσεων και Συμμόρφωσης για τον τομέα του τσιμέντου." },
    { "@language": "es", "@value": "Ontología que define términos y conceptos específicos de la Declaración de Prestaciones y Conformidad para el sector del cemento." },
    { "@language": "et", "@value": "Ontoloogia, mis määratleb tsemendisektori toimivus- ja vastavusdeklaratsiooni spetsiifilised terminid ja kontseptsioonid." },
    { "@language": "fi", "@value": "Ontologia, joka määrittelee sementtialan suoritustaso- ja vaatimustenmukaisuusvakuutuksen erityiset termit ja käsitteet." },
    { "@language": "fr", "@value": "Ontologie définissant les termes et concepts spécifiques à la Déclaration des Performances et de Conformité pour le secteur du ciment." },
    { "@language": "ga", "@value": "Ointeolaíocht a shainíonn téarmaí agus coincheapa a bhaineann go sonrach le Dearbhú Feidhmíochta agus Comhréireachta d'earnáil na stroighne." },
    { "@language": "hr", "@value": "Ontologija koja definira pojmove i koncepte specifične za Izjavu o svojstvima i sukladnosti za sektor cementa." },
    { "@language": "hu", "@value": "A cementágazat Teljesítmény- és Megfelelőségi Nyilatkozatára jellemző kifejezéseket és fogalmakat meghatározó ontológia." },
    { "@language": "it", "@value": "Ontologia che definisce i termini e i concetti specifici della Dichiarazione di Prestazione e Conformità per il settore del cemento." },
    { "@language": "lt", "@value": "Ontologija, apibrėžianti terminus ir sąvokas, būdingas cemento sektoriaus eksploatacinių savybių ir atitikties deklaracijai." },
    { "@language": "lv", "@value": "Ontoloģija, kas definē terminus un jēdzienus, kas raksturīgi cementa nozares ekspluatācijas īpašību un atbilstības deklarācijai." },
    { "@language": "mt", "@value": "Ontoloġija li tiddefinixxi termini u kunċetti speċifiċi għad-Dikjarazzjoni ta' Prestazzjoni u Konformità għas-settur tas-siment." },
    { "@language": "nl", "@value": "Ontologie die termen en concepten definieert die specifiek zijn voor de Prestatie- en Conformiteitsverklaring voor de cementsector." },
    { "@language": "pl", "@value": "Ontologia definiująca terminy i koncepcje specyficzne dla Deklaracji Właściwości Użytkowych i Zgodności dla sektora cementowego." },
    { "@language": "pt", "@value": "Ontologia que define termos e conceitos específicos da Declaração de Desempenho e Conformidade para o setor do cimento." },
    { "@language": "ro", "@value": "Ontologie care definește termenii și conceptele specifice Declarației de Performanță și Conformitate pentru sectorul cimentului." },
    { "@language": "sk", "@value": "Ontológia definujúca termíny a koncepty špecifické pre Vyhlásenie o parametroch a zhode pre sektor cementu." },
    { "@language": "sl", "@value": "Ontologija, ki določa izraze in koncepte, specifične za Izjavo o lastnostih in skladnosti za sektor cementa." },
    { "@language": "sv", "@value": "Ontologi som definierar termer och begrepp specifika för prestanda- och överensstämmelsedeklarationen för cementsektorn." }
  ],
  "dcterms:conformsTo": "prEN 197",
