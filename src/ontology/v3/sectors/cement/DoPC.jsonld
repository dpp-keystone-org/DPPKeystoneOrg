      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "The postal address of the manufacturer, provided as a flat string to comply with DoPC documentation formats." },
        { "@language": "bg", "@value": "Пощенският адрес на производителя, предоставен като плосък низ, за да съответства на форматите на документацията DoPC." },
        { "@language": "cs", "@value": "Poštovní adresa výrobce, poskytnutá jako plochý řetězec v souladu s formáty dokumentace DoPC." },
        { "@language": "da", "@value": "Producentens postadresse, angivet som en flad streng for at overholde DoPC-dokumentationsformater." },
        { "@language": "de", "@value": "Die Postanschrift des Herstellers, die als flache Zeichenfolge bereitgestellt wird, um den DoPC-Dokumentationsformaten zu entsprechen." },
        { "@language": "el", "@value": "Η ταχυδρομική διεύθυνση του κατασκευαστή, που παρέχεται ως επίπεδη συμβολοσειρά για να συμμορφώνεται με τις μορφές τεκμηρίωσης DoPC." },
        { "@language": "es", "@value": "La dirección postal del fabricante, proporcionada como una cadena plana para cumplir con los formatos de documentación DoPC." },
        { "@language": "et", "@value": "Tootja postiaadress, mis on esitatud lameda stringina, et järgida DoPC dokumentatsioonivorminguid." },
        { "@language": "fi", "@value": "Valmistajan postiosoite litteänä merkkijonona DoPC-dokumentaatiomuotojen noudattamiseksi." },
        { "@language": "fr", "@value": "L'adresse postale du fabricant, fournie sous forme de chaîne plate pour se conformer aux formats de documentation DoPC." },
        { "@language": "ga", "@value": "Seoladh poist an mhonaróra, curtha ar fáil mar theaghrán comhréidh chun cloí le formáidí doiciméadaithe DoPC." },
        { "@language": "hr", "@value": "Poštanska adresa proizvođača, navedena kao ravan niz kako bi bila u skladu s formatima dokumentacije DoPC-a." },
        { "@language": "hu", "@value": "A gyártó postacíme lapos karakterláncként megadva, hogy megfeleljen a DoPC dokumentációs formátumoknak." },
        { "@language": "it", "@value": "L'indirizzo postale del produttore, fornito come stringa piatta per essere conforme ai formati della documentazione DoPC." },
        { "@language": "lt", "@value": "Gamintojo pašto adresas, pateiktas kaip plokščia eilutė, kad atitiktų DoPC dokumentacijos formatus." },
        { "@language": "lv", "@value": "Ražotāja pasta adrese, kas sniegta kā plakana virkne, lai atbilstu DoPC dokumentācijas formātiem." },
        { "@language": "mt", "@value": "L-indirizz postali tal-manifattur, ipprovdut bħala stringa ċatta biex jikkonforma mal-formati tad-dokumentazzjoni DoPC." },
        { "@language": "nl", "@value": "Het postadres van de fabrikant, verstrekt als een platte string om te voldoen aan de DoPC-documentatieformaten." },
        { "@language": "pl", "@value": "Adres pocztowy producenta, podany jako płaski ciąg w celu zachowania zgodności z formatami dokumentacji DoPC." },
        { "@language": "pt", "@value": "O endereço postal do fabricante, fornecido como uma string plana para cumprir com os formatos de documentação DoPC." },
        { "@language": "ro", "@value": "Adresa poștală a producătorului, furnizată ca un șir plat pentru a respecta formatele de documentație DoPC." },
        { "@language": "sk", "@value": "Poštová adresa výrobcu, poskytnutá ako plochý reťazec v súlade s formátmi dokumentácie DoPC." },
        { "@language": "sl", "@value": "Poštni naslov proizvajalca, naveden kot raven niz zaradi skladnosti z formati dokumentacije DoPC." },
        { "@language": "sv", "@value": "Tillverkarens postadress, angiven som en platt sträng för att följa DoPC-dokumentationsformat." }
      ]
    },
