        { "@language": "en", "@value": "Sustainability Data Compliance" },
        { "@language": "bg", "@value": "Съответствие на данните за устойчивост" },
        { "@language": "cs", "@value": "Soulad údajů o udržitelnosti" },
        { "@language": "da", "@value": "Overholdelse af bæredygtighedsdata" },
        { "@language": "de", "@value": "Konformität der Nachhaltigkeitsdaten" },
        { "@language": "el", "@value": "Συμμόρφωση δεδομένων βιωσιμότητας" },
        { "@language": "es", "@value": "Conformidad de los datos de sostenibilidad" },
        { "@language": "et", "@value": "Jätkusuutlikkuse andmete vastavus" },
        { "@language": "fi", "@value": "Kestävyystietojen vaatimustenmukaisuus" },
        { "@language": "fr", "@value": "Conformité des données de durabilité" },
        { "@language": "ga", "@value": "Comhlíonadh sonraí inbhuanaitheachta" },
        { "@language": "hr", "@value": "Sukladnost podataka o održivosti" },
        { "@language": "hu", "@value": "Fenntarthatósági adatok megfelelősége" },
        { "@language": "it", "@value": "Conformità dei dati sulla sostenibilità" },
        { "@language": "lt", "@value": "Tvarumo duomenų atitiktis" },
        { "@language": "lv", "@value": "Ilgtspējas datu atbilstība" },
        { "@language": "mt", "@value": "Konformità tad-dejta dwar is-sostenibbiltà" },
        { "@language": "nl", "@value": "Conformiteit van duurzaamheidsgegevens" },
        { "@language": "pl", "@value": "Zgodność danych dotyczących zrównoważonego rozwoju" },
        { "@language": "pt", "@value": "Conformidade dos dados de sustentabilidade" },
        { "@language": "ro", "@value": "Conformitatea datelor privind durabilitatea" },
        { "@language": "sk", "@value": "Súlad údajov o udržateľnosti" },
        { "@language": "sl", "@value": "Skladnost podatkov o trajnostnosti" },
        { "@language": "sv", "@value": "Överensstämmelse för hållbarhetsdata" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "Indicates whether the sustainability data of the product is compliant, non-compliant, or N/A." },
        { "@language": "bg", "@value": "Посочва дали данните за устойчивост на продукта са в съответствие, не са в съответствие или неприложимо." },
        { "@language": "cs", "@value": "Označuje, zda jsou údaje o udržitelnosti výrobku v souladu, nejsou v souladu nebo se na ně nevztahují (N/A)." },
        { "@language": "da", "@value": "Angiver, om produktets bæredygtighedsdata er i overensstemmelse, ikke i overensstemmelse eller ikke relevant (N/A)." },
        { "@language": "de", "@value": "Gibt an, ob die Nachhaltigkeitsdaten des Produkts konform, nicht konform oder nicht zutreffend (N/A) sind." },
        { "@language": "el", "@value": "Υποδεικνύει εάν τα δεδομένα βιωσιμότητας του προϊόντος είναι συμμορφούμενα, μη συμμορφούμενα ή Δ/Υ." },
        { "@language": "es", "@value": "Indica si los datos de sostenibilidad del producto son conformes, no conformes o no aplicables (N/A)." },
        { "@language": "et", "@value": "Näitab, kas toote jätkusuutlikkuse andmed on vastavad, mittevastavad või ei kohaldata." },
        { "@language": "fi", "@value": "Ilmaisee, ovatko tuotteen kestävyystiedot vaatimustenmukaisia, ei-vaatimustenmukaisia vai ei sovellettavissa." },
        { "@language": "fr", "@value": "Indique si les données de durabilité du produit sont conformes, non conformes ou sans objet (N/A)." },
        { "@language": "ga", "@value": "Léiríonn sé an bhfuil sonraí inbhuanaitheachta an táirge comhlíontach, neamhchomhlíontach nó N/B." },
        { "@language": "hr", "@value": "Pokazuje jesu li podaci o održivosti proizvoda sukladni, nesukladni ili nije primjenjivo (N/A)." },
        { "@language": "hu", "@value": "Azt jelzi, hogy a termék fenntarthatósági adatai megfelelőek, nem megfelelőek vagy nem alkalmazhatók (N/A)." },
        { "@language": "it", "@value": "Indica se i dati sulla sostenibilità del prodotto sono conformi, non conformi o non applicabili (N/A)." },
        { "@language": "lt", "@value": "Nurodo, ar produkto tvarumo duomenys yra atitinkantys, neatitinkantys ar netaikomi." },
        { "@language": "lv", "@value": "Norāda, vai produkta ilgtspējas dati ir atbilstoši, neatbilstoši vai nav piemērojami (N/A)." },
        { "@language": "mt", "@value": "Jindika jekk id-dejta dwar is-sostenibbiltà tal-prodott hijiex konformi, mhux konformi, jew mhux applikabbli (N/A)." },
        { "@language": "nl", "@value": "Geeft aan of de duurzaamheidsgegevens van het product conform, niet conform of niet van toepassing (N/A) zijn." },
        { "@language": "pl", "@value": "Wskazuje, czy dane dotyczące zrównoważonego rozwoju wyrobu są zgodne, niezgodne lub nie dotyczą." },
        { "@language": "pt", "@value": "Indica se os dados de sustentabilidade do produto estão em conformidade, não conformidade ou se não se aplicam (N/A)." },
        { "@language": "ro", "@value": "Indică dacă datele privind durabilitatea produsului sunt conforme, neconforme sau nu se aplică (N/A)." },
        { "@language": "sk", "@value": "Označuje, či sú údaje o udržateľnosti výrobku v súlade, v nesúlade alebo sa neuplatňujú." },
        { "@language": "sl", "@value": "Prikazuje, ali so podatki o trajnostnosti proizvoda skladni, neskladni ali ni primerno (N/A)." },
        { "@language": "sv", "@value": "Anger om produktens hållbarhetsdata är i överensstämmelse, inte i överensstämmelse eller ej tillämpligt (N/A)." }
      ]
    },
    {
      "@id": "dppk-cement-dopc:productConformityDeclaration",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "dppk-cement-dopc:CementDoPC" },
      "rdfs:range": "xsd:string",
      "rdfs:label": [
        { "@language": "en", "@value": "Product Conformity Declaration" },
        { "@language": "bg", "@value": "Декларация за съответствие на продукта" },
        { "@language": "cs", "@value": "Prohlášení o shodě výrobku" },
        { "@language": "da", "@value": "Produktoverensstemmelseserklæring" },
        { "@language": "de", "@value": "Produktkonformitätserklärung" },
        { "@language": "el", "@value": "Δήλωση Συμμόρφωσης Προϊόντος" },
        { "@language": "es", "@value": "Declaración de conformidad del producto" },
        { "@language": "et", "@value": "Toote vastavusdeklaratsioon" },
        { "@language": "fi", "@value": "Tuotteen vaatimustenmukaisuusvakuutus" },
        { "@language": "fr", "@value": "Déclaration de conformité du produit" },
        { "@language": "ga", "@value": "Dearbhú Comhréireachta Táirge" },
        { "@language": "hr", "@value": "Izjava o sukladnosti proizvoda" },
        { "@language": "hu", "@value": "Termékmegfelelőségi nyilatkozat" },
        { "@language": "it", "@value": "Dichiarazione di conformità del prodotto" },
        { "@language": "lt", "@value": "Produkto atitikties deklaracija" },
        { "@language": "lv", "@value": "Produkta atbilstības deklarācija" },
        { "@language": "mt", "@value": "Dikjarazzjoni ta' Konformità tal-Prodott" },
        { "@language": "nl", "@value": "Productconformiteitsverklaring" },
        { "@language": "pl", "@value": "Deklaracja zgodności produktu" },
        { "@language": "pt", "@value": "Declaração de Conformidade do Produto" },
        { "@language": "ro", "@value": "Declarația de conformitate a produsului" },
        { "@language": "sk", "@value": "Vyhlásenie o zhode výrobku" },
        { "@language": "sl", "@value": "Izjava o skladnosti proizvoda" },
        { "@language": "sv", "@value": "Produktförsäkran om överensstämmelse" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "Indicates whether the product identified is in conformity with the applicable requirements (compliant / non-compliant / N/A)." },
        { "@language": "bg", "@value": "Посочва дали идентифицираният продукт е в съответствие с приложимите изисквания (съответстващ / несъответстващ / неприложимо)." },
        { "@language": "cs", "@value": "Označuje, zda je identifikovaný výrobek v souladu s platnými požadavky (v souladu / v nesouladu / N/A)." },
        { "@language": "da", "@value": "Angiver, om det identificerede produkt er i overensstemmelse med de gældende krav (i overensstemmelse / ikke i overensstemmelse / ikke relevant)." },
        { "@language": "de", "@value": "Gibt an, ob das identifizierte Produkt den geltenden Anforderungen entspricht (konform / nicht konform / nicht zutreffend)." },
        { "@language": "el", "@value": "Υποδεικνύει εάν το ταυτοποιημένο προϊόν συμμορφώνεται με τις ισχύουσες απαιτήσεις (συμμορφούμενο / μη συμμορφούμενο / Δ/Υ)." },
        { "@language": "es", "@value": "Indica si el producto identificado es conforme con los requisitos aplicables (conforme / no conforme / N/A)." },
        { "@language": "et", "@value": "Näitab, kas tuvastatud toode vastab kohaldatavatele nõuetele (vastav / mittevastav / ei kohaldata)." },
        { "@language": "fi", "@value": "Ilmaisee, onko tunnistettu tuote sovellettavien vaatimusten mukainen (vaatimustenmukainen / ei-vaatimustenmukainen / ei sovellettavissa)." },
        { "@language": "fr", "@value": "Indique si le produit identifié est conforme aux exigences applicables (conforme / non conforme / S.O.)." },
        { "@language": "ga", "@value": "Léiríonn sé an bhfuil an táirge sainaitheanta i gcomhréir leis na ceanglais is infheidhme (comhlíontach / neamhchomhlíontach / N/B)." },
        { "@language": "hr", "@value": "Pokazuje je li identificirani proizvod u sukladnosti s primjenjivim zahtjevima (sukladan / nesukladan / nije primjenjivo)." },
        { "@language": "hu", "@value": "Azt jelzi, hogy az azonosított termék megfelel-e a vonatkozó követelményeknek (megfelelő / nem megfelelő / nem alkalmazható)." },
        { "@language": "it", "@value": "Indica se il prodotto identificato è conforme ai requisiti applicabili (conforme / non conforme / N/A)." },
        { "@language": "lt", "@value": "Nurodo, ar identifikuotas produktas atitinka taikomus reikalavimus (atitinka / neatitinka / netaikoma)." },
        { "@language": "lv", "@value": "Norāda, vai identificētais produkts atbilst piemērojamajām prasībām (atbilstošs / neatbilstošs / nav piemērojams)." },
        { "@language": "mt", "@value": "Jindika jekk il-prodott identifikat huwiex f'konformità mar-rekwiżiti applikabbli (konformi / mhux konformi / mhux applikabbli)." },
        { "@language": "nl", "@value": "Geeft aan of het geïdentificeerde product in overeenstemming is met de toepasselijke eisen (conform / niet conform / n.v.t.)." },
        { "@language": "pl", "@value": "Wskazuje, czy zidentyfikowany produkt jest zgodny z obowiązującymi wymaganiami (zgodny / niezgodny / nie dotyczy)." },
        { "@language": "pt", "@value": "Indica se o produto identificado está em conformidade com os requisitos aplicáveis (em conformidade / não em conformidade / N/A)." },
        { "@language": "ro", "@value": "Indică dacă produsul identificat este în conformitate cu cerințele aplicabile (conform / neconform / N/A)." },
        { "@language": "sk", "@value": "Označuje, či je identifikovaný výrobok v zhode s uplatniteľnými požiadavkami (v súlade / v nesúlade / neuplatňuje sa)." },
        { "@language": "sl", "@value": "Prikazuje, ali je identificirani proizvod skladen z veljavnimi zahtevami (skladen / neskladen / ni primerno)." },
        { "@language": "sv", "@value": "Anger om den identifierade produkten överensstämmer med de tillämpliga kraven (överensstämmer / överensstämmer inte / ej tillämpligt)." }
      ]
    },
