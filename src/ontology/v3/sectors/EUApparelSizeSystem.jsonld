            "rdfs:comment": [
              { "@language": "en", "@value": "Identification of the clothing size by means of alphanumeric characters." },
              { "@language": "bg", "@value": "Идентификация на размера на облеклото чрез буквено-цифрови знаци." },
              { "@language": "cs", "@value": "Identifikace velikosti oblečení pomocí alfanumerických znaků." },
              { "@language": "da", "@value": "Identifikation af tøjstørrelsen ved hjælp af alfanumeriske tegn." },
              { "@language": "de", "@value": "Identifikation der Konfektionsgröße durch alphanumerische Zeichen." },
              { "@language": "el", "@value": "Αναγνώριση του μεγέθους ενδυμάτων μέσω αλφαριθμητικών χαρακτήρων." },
              { "@language": "es", "@value": "Identificación de la talla de ropa mediante caracteres alfanuméricos." },
              { "@language": "et", "@value": "Riietusesuuruse identifitseerimine tähtnumbriliste märkide abil." },
              { "@language": "fi", "@value": "Vaatekoon tunnistaminen aakkosnumeerisilla merkeillä." },
              { "@language": "fr", "@value": "Identification de la taille des vêtements au moyen de caractères alphanumériques." },
              { "@language": "ga", "@value": "Sainaithint mhéid na n-éadaí trí charachtair alfa-uimhriúla." },
              { "@language": "hr", "@value": "Identifikacija veličine odjeće pomoću alfanumeričkih znakova." },
              { "@language": "hu", "@value": "A ruházati méret azonosítása alfanumerikus karakterekkel." },
              { "@language": "it", "@value": "Identificazione della taglia di abbigliamento mediante caratteri alfanumerici." },
              { "@language": "lt", "@value": "Drabužio dydžio identifikavimas naudojant raidinius-skaitmeninius simbolius." },
              { "@language": "lv", "@value": "Apģērba izmēra identifikācija ar burtciparu rakstzīmēm." },
              { "@language": "mt", "@value": "Identifikazzjoni tad-daqs tal-ilbies permezz ta' karattri alfanumeriċi." },
              { "@language": "nl", "@value": "Identificatie van de kledingmaat door middel van alfanumerieke tekens." },
              { "@language": "pl", "@value": "Identyfikacja rozmiaru odzieży za pomocą znaków alfanumerycznych." },
              { "@language": "pt", "@value": "Identificação do tamanho do vestuário através de caracteres alfanuméricos." },
              { "@language": "ro", "@value": "Identificarea mărimii îmbrăcămintei prin intermediul caracterelor alfanumerice." },
