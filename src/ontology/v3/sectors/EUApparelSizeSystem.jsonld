              { "@language": "bg", "@value": "Структурирано представяне на размер в ЕС според EN 13402." },
              { "@language": "cs", "@value": "Strukturovaná reprezentace velikosti EU podle EN 13402." },
              { "@language": "da", "@value": "En struktureret repræsentation af en EU-størrelse i henhold til EN 13402." },
              { "@language": "de", "@value": "Eine strukturierte Darstellung einer EU-Größe nach EN 13402." },
              { "@language": "el", "@value": "Μια δομημένη αναπαράσταση ενός μεγέθους ΕΕ σύμφωνα με το πρότυπο EN 13402." },
              { "@language": "es", "@value": "Una representación estructurada de una talla de la UE según EN 13402." },
              { "@language": "et", "@value": "ELi suuruse struktureeritud esitus vastavalt standardile EN 13402." },
              { "@language": "fi", "@value": "EU-koon strukturoitu esitys standardin EN 13402 mukaisesti." },
              { "@language": "fr", "@value": "Une représentation structurée d'une taille de l'UE selon EN 13402." },
              { "@language": "ga", "@value": "Léiriú struchtúrtha ar mhéid de chuid an AE de réir EN 13402." },
              { "@language": "hr", "@value": "Strukturirani prikaz veličine u EU-u prema EN 13402." },
              { "@language": "hu", "@value": "Egy EU-méret strukturált megjelenítése az EN 13402 szerint." },
              { "@language": "it", "@value": "Una rappresentazione strutturata di una taglia UE secondo EN 13402." },
              { "@language": "lt", "@value": "Struktūruotas ES dydžio vaizdavimas pagal EN 13402." },
              { "@language": "lv", "@value": "Strukturēts ES izmēra atspoguļojums saskaņā ar EN 13402." },
              { "@language": "mt", "@value": "Rappreżentazzjoni strutturata ta' daqs tal-UE skont EN 13402." },
              { "@language": "nl", "@value": "Een gestructureerde weergave van een EU-maat volgens EN 13402." },
              { "@language": "pl", "@value": "Ustrukturyzowana reprezentacja rozmiaru UE zgodnie z EN 13402." },
              { "@language": "pt", "@value": "Uma representação estruturada de um tamanho da UE de acordo com a norma EN 13402." },
              { "@language": "ro", "@value": "O reprezentare structurată a unei mărimi UE conform EN 13402." },
