    "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/sectors/EUApparelSizeSystem",
    "@type": "owl:Ontology",
    "owl:versionInfo": "{{VERSION}}",
    "dcterms:title": [
      { "@language": "en", "@value": "DPP Ontology - EU Apparel Size System (EN 13402)" },
      { "@language": "bg", "@value": "Онтология на DPP - Система за размери на облекло в ЕС (EN 13402)" },
      { "@language": "cs", "@value": "Ontologie DPP - Systém velikostí oděvů EU (EN 13402)" },
      { "@language": "da", "@value": "DPP-ontologi - EU's system for beklædningsstørrelser (EN 13402)" },
      { "@language": "de", "@value": "DPP-Ontologie - EU-Konfektionsgrößensystem (EN 13402)" },
      { "@language": "el", "@value": "Οντολογία DPP - Σύστημα μεγεθών ενδυμάτων ΕΕ (EN 13402)" },
      { "@language": "es", "@value": "Ontología DPP - Sistema de tallas de ropa de la UE (EN 13402)" },
      { "@language": "et", "@value": "DPP ontoloogia - ELi rõivasuuruste süsteem (EN 13402)" },
      { "@language": "fi", "@value": "DPP-ontologia - EU:n vaatekokojärjestelmä (EN 13402)" },
      { "@language": "fr", "@value": "Ontologie DPP - Système des tailles de vêtements de l'UE (EN 13402)" },
      { "@language": "ga", "@value": "Ointeolaíocht DPP - Córas Méideanna Éadaí an AE (EN 13402)" },
      { "@language": "hr", "@value": "Ontologija DPP - Sustav veličina odjeće u EU-u (EN 13402)" },
      { "@language": "hu", "@value": "DPP ontológia - EU ruházati méretrendszer (EN 13402)" },
      { "@language": "it", "@value": "Ontologia DPP - Sistema di taglie per abbigliamento UE (EN 13402)" },
      { "@language": "lt", "@value": "DPP ontologija - ES drabužių dydžių sistema (EN 13402)" },
      { "@language": "lv", "@value": "DPP ontoloģija - ES apģērbu izmēru sistēma (EN 13402)" },
      { "@language": "mt", "@value": "Ontoloġija DPP - Sistema tad-Daqs tal-Ilbies tal-UE (EN 13402)" },
      { "@language": "nl", "@value": "DPP-ontologie - EU-kledingmatensysteem (EN 13402)" },
      { "@language": "pl", "@value": "Ontologia DPP - Europejski system rozmiarów odzieży (EN 13402)" },
      { "@language": "pt", "@value": "Ontologia DPP - Sistema de tamanhos de vestuário da UE (EN 13402)" },
      { "@language": "ro", "@value": "Ontologie DPP - Sistemul UE de mărimi pentru îmbrăcăminte (EN 13402)" },
      { "@language": "sk", "@value": "Ontológia DPP - Systém veľkostí odevov EÚ (EN 13402)" },
      { "@language": "sl", "@value": "Ontologija DPP - Sistem velikosti oblačil EU (EN 13402)" },
      { "@language": "sv", "@value": "DPP-ontologi - EU:s system för klädstorlekar (EN 13402)" }
    ],
    "dcterms:description": [
      { "@language": "en", "@value": "Defines the structured representation of EU apparel sizing based on body dimensions as specified in EN 13402." },
      { "@language": "bg", "@value": "Дефинира структурираното представяне на размерите на облеклото в ЕС въз основа на телесните размери, както е посочено в EN 13402." },
      { "@language": "cs", "@value": "Definuje strukturovanou reprezentaci velikostí oděvů v EU na základě tělesných rozměrů, jak je specifikováno v EN 13402." },
      { "@language": "da", "@value": "Definerer den strukturerede repræsentation af EU's beklædningsstørrelser baseret på kropsdimensioner som specificeret i EN 13402." },
      { "@language": "de", "@value": "Definiert die strukturierte Darstellung der EU-Bekleidungsgrößen basierend auf Körpermaßen gemäß EN 13402." },
      { "@language": "el", "@value": "Ορίζει τη δομημένη αναπαράσταση των μεγεθών ενδυμάτων της ΕΕ με βάση τις διαστάσεις του σώματος όπως καθορίζεται στο πρότυπο EN 13402." },
      { "@language": "es", "@value": "Define la representación estructurada de las tallas de ropa de la UE basadas en las dimensiones corporales según se especifica en la norma EN 13402." },
      { "@language": "et", "@value": "Määratleb ELi rõivasuuruste struktureeritud esituse kehamõõtmete põhjal vastavalt standardile EN 13402." },
      { "@language": "fi", "@value": "Määrittää EU:n vaatekokojen strukturoidun esityksen vartalon mittojen perusteella standardin EN 13402 mukaisesti." },
      { "@language": "fr", "@value": "Définit la représentation structurée des tailles de vêtements de l'UE en fonction des dimensions corporelles, tel que spécifié dans la norme EN 13402." },
      { "@language": "ga", "@value": "Sainmhíníonn sé léiriú struchtúrtha de mhéideanna éadaí an AE bunaithe ar thoisí an choirp mar a shonraítear in EN 13402." },
      { "@language": "hr", "@value": "Definira strukturirani prikaz veličina odjeće u EU-u na temelju tjelesnih dimenzija kako je navedeno u normi EN 13402." },
      { "@language": "hu", "@value": "Meghatározza az EU ruházati méretezés strukturált megjelenítését a testméretek alapján az EN 13402 szabványnak megfelelően." },
      { "@language": "it", "@value": "Definisce la rappresentazione strutturata delle taglie di abbigliamento dell'UE basate sulle dimensioni del corpo come specificato nella norma EN 13402." },
      { "@language": "lt", "@value": "Apibrėžia struktūrizuotą ES drabužių dydžių vaizdavimą pagal kūno matmenis, kaip nurodyta EN 13402." },
      { "@language": "lv", "@value": "Nosaka ES apģērbu izmēru strukturētu atspoguļojumu, pamatojoties uz ķermeņa izmēriem, kā norādīts EN 13402." },
      { "@language": "mt", "@value": "Tiddefinixxi r-rappreżentazzjoni strutturata tad-daqs tal-ilbies tal-UE bbażata fuq id-dimensjonijiet tal-ġisem kif speċifikat f'EN 13402." },
      { "@language": "nl", "@value": "Definieert de gestructureerde weergave van EU-kledingmaten op basis van lichaamsafmetingen zoals gespecificeerd in EN 13402." },
      { "@language": "pl", "@value": "Definiuje ustrukturyzowaną reprezentację europejskich rozmiarów odzieży na podstawie wymiarów ciała zgodnie z normą EN 13402." },
      { "@language": "pt", "@value": "Define a representação estruturada do tamanho de vestuário da UE com base nas dimensões corporais, conforme especificado na norma EN 13402." },
      { "@language": "ro", "@value": "Definește reprezentarea structurată a mărimilor de îmbrăcăminte din UE pe baza dimensiunilor corporale, așa cum se specifică în EN 13402." },
      { "@language": "sk", "@value": "Definuje štruktúrované vyjadrenie veľkostí odevov v EÚ na základe telesných rozmerov, ako sa uvádza v norme EN 13402." },
      { "@language": "sl", "@value": "Opredeljuje strukturirano predstavitev velikosti oblačil v EU na podlagi telesnih mer, kot določa standard EN 13402." },
      { "@language": "sv", "@value": "Definierar den strukturerade representationen av EU:s klädstorlekar baserat på kroppsmått enligt EN 13402." }
    ],
    "owl:imports": [
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Product.jsonld" }
    ],
