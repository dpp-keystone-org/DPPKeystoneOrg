            "rdfs:comment": [
              { "@language": "en", "@value": "The structured EU specific size of the product based on body dimensions (e.g., EN 13402)." },
              { "@language": "bg", "@value": "Структурираният специфичен за ЕС размер на продукта въз основа на телесните размери (напр. EN 13402)." },
              { "@language": "cs", "@value": "Strukturovaná specifická velikost produktu pro EU na základě tělesných rozměrů (např. EN 13402)." },
              { "@language": "da", "@value": "Den strukturerede EU-specifikke størrelse af produktet baseret på kropsdimensioner (f.eks. EN 13402)." },
              { "@language": "de", "@value": "Die strukturierte EU-spezifische Größe des Produkts basierend auf Körpermaßen (z. B. EN 13402)." },
              { "@language": "el", "@value": "Το δομημένο ειδικό για την ΕΕ μέγεθος του προϊόντος βάσει των διαστάσεων του σώματος (π.χ. EN 13402)." },
              { "@language": "es", "@value": "El tamaño estructurado específico de la UE del producto basado en las dimensiones corporales (por ejemplo, EN 13402)." },
              { "@language": "et", "@value": "Toote struktureeritud ELi-spetsiifiline suurus kehamõõtmete põhjal (nt EN 13402)." },
              { "@language": "fi", "@value": "Tuotteen strukturoitu EU-kohtainen koko vartalon mittojen perusteella (esim. EN 13402)." },
              { "@language": "fr", "@value": "La taille structurée spécifique à l'UE du produit basée sur les dimensions corporelles (par ex. EN 13402)." },
              { "@language": "ga", "@value": "Méid struchtúrtha sainiúil do AE an táirge bunaithe ar thoisí coirp (m.sh., EN 13402)." },
              { "@language": "hr", "@value": "Strukturirana specifična veličina proizvoda u EU-u na temelju tjelesnih dimenzija (npr. EN 13402)." },
              { "@language": "hu", "@value": "A termék strukturált EU-specifikus mérete a testméretek alapján (pl. EN 13402)." },
              { "@language": "it", "@value": "La taglia strutturata specifica dell'UE del prodotto basata sulle dimensioni del corpo (es. EN 13402)." },
              { "@language": "lt", "@value": "Struktūruotas konkretus ES produkto dydis pagal kūno matmenis (pvz., EN 13402)." },
              { "@language": "lv", "@value": "Produkta strukturētais ES specifiskais izmērs, pamatojoties uz ķermeņa izmēriem (piemēram, EN 13402)." },
              { "@language": "mt", "@value": "Id-daqs strutturat speċifiku għall-UE tal-prodott ibbażat fuq id-dimensjonijiet tal-ġisem (eż., EN 13402)." },
              { "@language": "nl", "@value": "De gestructureerde EU-specifieke maat van het product op basis van lichaamsafmetingen (bijv. EN 13402)." },
              { "@language": "pl", "@value": "Ustrukturyzowany rozmiar produktu specyficzny dla UE na podstawie wymiarów ciała (np. EN 13402)." },
              { "@language": "pt", "@value": "O tamanho estruturado do produto específico da UE com base nas dimensões corporais (por exemplo, EN 13402)." },
              { "@language": "ro", "@value": "Mărimea structurată specifică UE a produsului pe baza dimensiunilor corporale (de exemplu, EN 13402)." },
              { "@language": "sk", "@value": "Štruktúrovaná špecifická veľkosť výrobku pre EÚ na základe telesných rozmerov (napr. EN 13402)." },
              { "@language": "sl", "@value": "Strukturirana specifična velikost izdelka v EU na podlagi telesnih mer (npr. EN 13402)." },
              { "@language": "sv", "@value": "Den strukturerade EU-specifika storleken på produkten baserad på kroppsmått (t.ex. EN 13402)." }
            ],
            "rdfs:domain": { "@id": "dppk:Product" },
            "rdfs:range": {
              "@id": "dppk:EuApparelSizeObject"
            },
            "skos:closeMatch": [
