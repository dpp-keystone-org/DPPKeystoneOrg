        { "@language": "et", "@value": "Seotud ressurss" },
        { "@language": "fi", "@value": "Liittyvä resurssi" },
        { "@language": "fr", "@value": "Ressource liée" },
        { "@language": "ga", "@value": "Acmhainn Ghaolmhar" },
        { "@language": "hr", "@value": "Povezani resurs" },
        { "@language": "hu", "@value": "Kapcsolódó erőforrás" },
        { "@language": "it", "@value": "Risorsa correlata" },
        { "@language": "lt", "@value": "Susijęs išteklius" },
        { "@language": "lv", "@value": "Saistītais resurss" },
        { "@language": "mt", "@value": "Riżors Relatat" },
        { "@language": "nl", "@value": "Gerelateerde bron" },
        { "@language": "pl", "@value": "Powiązany zasób" },
        { "@language": "pt", "@value": "Recurso Relacionado" },
        { "@language": "ro", "@value": "Resursă asociată" },
        { "@language": "sk", "@value": "Súvisiaci zdroj" },
        { "@language": "sl", "@value": "Povezan vir" },
        { "@language": "sv", "@value": "Relaterad resurs" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "A resource identified by a URL, with additional metadata such as title, content type, and language." },
        { "@language": "bg", "@value": "Ресурс, идентифициран чрез URL адрес, с допълнителни метаданни като заглавие, тип съдържание и език." },
        { "@language": "cs", "@value": "Zdroj identifikovaný adresou URL s dalšími metadaty, jako je název, typ obsahu a jazyk." },
        { "@language": "da", "@value": "En ressource identificeret af en URL med yderligere metadata såsom titel, indholdstype og sprog." },
        { "@language": "de", "@value": "Eine durch eine URL identifizierte Ressource mit zusätzlichen Metadaten wie Titel, Inhaltstyp und Sprache." },
        { "@language": "el", "@value": "Ένας πόρος που προσδιορίζεται από ένα URL, με πρόσθετα μεταδεδομένα όπως τίτλος, τύπος περιεχομένου και γλώσσα." },
        { "@language": "es", "@value": "Un recurso identificado por una URL, con metadatos adicionales como título, tipo de contenido e idioma." },
        { "@language": "et", "@value": "URL-iga tuvastatud ressurss täiendavate metaandmetega, nagu pealkiri, sisutüüp ja keel." },
        { "@language": "fi", "@value": "URL-osoitteella yksilöity resurssi, jolla on lisämetatietoja, kuten otsikko, sisältötyyppi ja kieli." },
        { "@language": "fr", "@value": "Une ressource identifiée par une URL, avec des métadonnées supplémentaires telles que le titre, le type de contenu et la langue." },
        { "@language": "ga", "@value": "Acmhainn arna sainaithint ag URL, le meiteashonraí breise amhail teideal, cineál ábhair agus teanga." },
        { "@language": "hr", "@value": "Resurs identificiran URL-om, s dodatnim metapodacima kao što su naslov, vrsta sadržaja i jezik." },
        { "@language": "hu", "@value": "URL-lel azonosított erőforrás további metaadatokkal, például címmel, tartalomtípussal és nyelvvel." },
        { "@language": "it", "@value": "Una risorsa identificata da un URL, con metadati aggiuntivi come titolo, tipo di contenuto e lingua." },
        { "@language": "lt", "@value": "Išteklius, identifikuojamas pagal URL, su papildomais metaduomenimis, tokiais kaip pavadinimas, turinio tipas ir kalba." },
        { "@language": "lv", "@value": "Resurss, ko identificē ar URL, ar papildu metadatiem, piemēram, virsrakstu, satura tipu un valodu." },
        { "@language": "mt", "@value": "Riżors identifikat minn URL, b'metadata addizzjonali bħat-titlu, it-tip ta' kontenut u l-lingwa." },
        { "@language": "nl", "@value": "Een bron geïdentificeerd door een URL, met aanvullende metadata zoals titel, inhoudstype en taal." },
        { "@language": "pl", "@value": "Zasób zidentyfikowany za pomocą adresu URL, z dodatkowymi metadanymi, takimi jak tytuł, typ zawartości i język." },
        { "@language": "pt", "@value": "Um recurso identificado por um URL, com metadados adicionais, como título, tipo de conteúdo e idioma." },
        { "@language": "ro", "@value": "O resursă identificată printr-un URL, cu metadate suplimentare, cum ar fi titlul, tipul de conținut și limba." },
        { "@language": "sk", "@value": "Zdroj identifikovaný adresou URL s ďalšími metadátami, ako je názov, typ obsahu a jazyk." },
        { "@language": "sl", "@value": "Vir, ki ga določa URL, z dodatnimi metapodatki, kot so naslov, vrsta vsebine in jezik." },
        { "@language": "sv", "@value": "En resurs identifierad av en URL, med ytterligare metadata som titel, innehållstyp och språk." }
      ],
      "owl:equivalentClass": [
        { "@id": "schema:DigitalDocument" },
        { "@id": "gs1:Document" }
      ]
    },
