        { "@language": "da", "@value": "Instruktioner til korrekt adskillelse, genbrug eller bortskaffelse af produktet ved slutningen af dets levetid." },
        { "@language": "de", "@value": "Anweisungen für die ordnungsgemäße Demontage, das Recycling oder die Entsorgung des Produkts am Ende seiner Lebensdauer." },
        { "@language": "el", "@value": "Οδηγίες για τη σωστή αποσυναρμολόγηση, ανακύκλωση ή απόρριψη του προϊόντος στο τέλος της ζωής του." },
        { "@language": "es", "@value": "Instrucciones para el correcto desmontaje, reciclaje o eliminación del producto al final de su vida útil." },
        { "@language": "et", "@value": "Juhised toote nõuetekohaseks lahtivõtmiseks, ringlussevõtuks või kõrvaldamiseks selle eluea lõpus." },
        { "@language": "fi", "@value": "Ohjeet tuotteen asianmukaiseen purkamiseen, kierrätykseen tai hävittämiseen sen elinkaaren lopussa." },
        { "@language": "fr", "@value": "Instructions pour le démontage, le recyclage ou l'élimination appropriés du produit à la fin de sa vie." },
        { "@language": "ga", "@value": "Treoracha chun an táirge a dhíchóimeáil, a athchúrsáil nó a dhiúscairt i gceart ag deireadh a shaoil." },
        { "@language": "hr", "@value": "Upute za pravilno rastavljanje, recikliranje ili zbrinjavanje proizvoda na kraju njegovog životnog vijeka." },
        { "@language": "hu", "@value": "Utasítások a termék megfelelő szétszereléséhez, újrahasznosításához vagy ártalmatlanításához az élettartama végén." },
        { "@language": "it", "@value": "Istruzioni per il corretto smontaggio, riciclaggio o smaltimento del prodotto alla fine della sua vita." },
        { "@language": "lt", "@value": "Tinkamo gaminio išmontavimo, perdirbimo ar šalinimo instrukcijos pasibaigus jo tarnavimo laikui." },
        { "@language": "lv", "@value": "Norādījumi par produkta pareizu izjaukšanu, pārstrādi vai iznīcināšanu tā kalpošanas laika beigās." },
        { "@language": "mt", "@value": "Struzzjonijiet għaż-żarmar, ir-riċiklaġġ jew ir-rimi xieraq tal-prodott fi tmiem il-ħajja tiegħu." },
        { "@language": "nl", "@value": "Instructies voor de juiste demontage, recycling of verwijdering van het product aan het einde van de levensduur." },
        { "@language": "pl", "@value": "Instrukcje dotyczące właściwego demontażu, recyklingu lub utylizacji produktu pod koniec jego okresu użytkowania." },
        { "@language": "pt", "@value": "Instruções para a correta desmontagem, reciclagem ou descarte do produto no final de sua vida útil." },
        { "@language": "ro", "@value": "Instrucțiuni pentru dezasamblarea, reciclarea sau eliminarea corespunzătoare a produsului la sfârșitul duratei sale de viață." },
        { "@language": "sk", "@value": "Pokyny na správnu demontáž, recykláciu alebo likvidáciu produktu na konci jeho životnosti." },
        { "@language": "sl", "@value": "Navodila za pravilno razstavljanje, recikliranje ali odstranjevanje izdelka ob koncu njegove življenjske dobe." },
        { "@language": "sv", "@value": "Instruktioner för korrekt demontering, återvinning eller kassering av produkten vid slutet av dess livslängd." }
