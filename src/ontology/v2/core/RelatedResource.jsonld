    "gs1": "https://ref.gs1.org/voc/",
    "dppk": "https://dpp-keystone.org/spec/{{VERSION}}/terms#",
    "dcterms": "http://purl.org/dc/terms/"
  },
  "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/RelatedResource",
  "@type": "owl:Ontology",
  "dcterms:title": [
    { "@language": "en", "@value": "DPP Core Ontology - Related Resource" },
    { "@language": "bg", "@value": "Основна онтология на DPP - Свързан ресурс" },
    { "@language": "cs", "@value": "Základní ontologie DPP - Související zdroj" },
    { "@language": "da", "@value": "DPP Kerneontologi - Relateret ressource" },
    { "@language": "de", "@value": "DPP-Kernontologie - Verwandte Ressource" },
    { "@language": "el", "@value": "Βασική οντολογία DPP - Σχετικός πόρος" },
    { "@language": "es", "@value": "Ontología central de DPP - Recurso relacionado" },
    { "@language": "et", "@value": "DPP tuumontoloogia - Seotud ressurss" },
    { "@language": "fi", "@value": "DPP-ydinontologia - Liittyvä resurssi" },
    { "@language": "fr", "@value": "Ontologie de base DPP - Ressource liée" },
    { "@language": "ga", "@value": "Príomhointeolaíocht DPP - Acmhainn Ghaolmhar" },
    { "@language": "hr", "@value": "Osnovna ontologija DPP-a - Povezani resurs" },
    { "@language": "hu", "@value": "DPP alapontológia - Kapcsolódó erőforrás" },
    { "@language": "it", "@value": "Ontologia di base DPP - Risorsa correlata" },
    { "@language": "lt", "@value": "DPP pagrindinė ontologija - Susijęs išteklius" },
    { "@language": "lv", "@value": "DPP pamata ontoloģija - Saistītais resurss" },
    { "@language": "mt", "@value": "Ontoloġija Ewlenija tad-DPP - Riżors Relatat" },
    { "@language": "nl", "@value": "DPP Kernontologie - Gerelateerde bron" },
    { "@language": "pl", "@value": "Główna ontologia DPP - Powiązany zasób" },
    { "@language": "pt", "@value": "Ontologia Central do DPP - Recurso Relacionado" },
    { "@language": "ro", "@value": "Ontologia de bază DPP - Resursă asociată" },
    { "@language": "sk", "@value": "Základná ontológia DPP - Súvisiaci zdroj" },
    { "@language": "sl", "@value": "Osnovna ontologija DPP - Povezan vir" },
    { "@language": "sv", "@value": "DPP-kärnontologi - Relaterad resurs" }
  ],
  "dcterms:description": [
    { "@language": "en", "@value": "Defines a class for linking to external resources, such as documents or websites, with associated metadata." },
    { "@language": "bg", "@value": "Определя клас за свързване към външни ресурси, като документи или уебсайтове, със свързани метаданни." },
    { "@language": "cs", "@value": "Definuje třídu pro odkazování na externí zdroje, jako jsou dokumenty nebo webové stránky, s přidruženými metadaty." },
    { "@language": "da", "@value": "Definerer en klasse til at linke til eksterne ressourcer, såsom dokumenter eller websteder, med tilhørende metadata." },
    { "@language": "de", "@value": "Definiert eine Klasse zur Verknüpfung mit externen Ressourcen wie Dokumenten oder Websites mit zugehörigen Metadaten." },
    { "@language": "el", "@value": "Ορίζει μια κλάση για σύνδεση με εξωτερικούς πόρους, όπως έγγραφα ή ιστότοπους, με σχετικά μεταδεδομένα." },
    { "@language": "es", "@value": "Define una clase para enlazar con recursos externos, como documentos o sitios web, con metadatos asociados." },
    { "@language": "et", "@value": "Määratleb klassi välistele ressurssidele, nagu dokumendid või veebisaidid, viitamiseks koos seotud metaandmetega." },
    { "@language": "fi", "@value": "Määrittää luokan ulkoisiin resursseihin, kuten asiakirjoihin tai verkkosivustoihin, linkittämistä varten niihin liittyvillä metatiedoilla." },
    { "@language": "fr", "@value": "Définit une classe pour lier des ressources externes, telles que des documents ou des sites Web, avec des métadonnées associées." },
    { "@language": "ga", "@value": "Sainmhíníonn sé aicme chun nascadh le hacmhainní seachtracha, amhail cáipéisí nó suíomhanna gréasáin, le meiteashonraí gaolmhara." },
    { "@language": "hr", "@value": "Definira klasu za povezivanje s vanjskim resursima, kao što su dokumenti ili web stranice, s pripadajućim metapodacima." },
    { "@language": "hu", "@value": "Egy osztályt határoz meg külső erőforrásokra, például dokumentumokra vagy weboldalakra való hivatkozáshoz a kapcsolódó metaadatokkal." },
    { "@language": "it", "@value": "Definisce una classe per il collegamento a risorse esterne, come documenti o siti web, con i relativi metadati." },
    { "@language": "lt", "@value": "Apibrėžia klasę susieti su išoriniais ištekliais, tokiais kaip dokumentai ar svetainės, su susijusiais metaduomenimis." },
    { "@language": "lv", "@value": "Definē klasi, lai izveidotu saiti uz ārējiem resursiem, piemēram, dokumentiem vai tīmekļa vietnēm, ar saistītiem metadatiem." },
    { "@language": "mt", "@value": "Jiddefinixxi klassi għall-irbit ma' riżorsi esterni, bħal dokumenti jew websajts, b'metadata assoċjata." },
    { "@language": "nl", "@value": "Definieert een klasse voor het koppelen aan externe bronnen, zoals documenten of websites, met bijbehorende metadata." },
    { "@language": "pl", "@value": "Definiuje klasę służącą do tworzenia łączy do zasobów zewnętrznych, takich jak dokumenty lub witryny internetowe, wraz z powiązanymi metadanymi." },
    { "@language": "pt", "@value": "Define uma classe para ligação a recursos externos, como documentos ou sites, com metadados associados." },
    { "@language": "ro", "@value": "Definește o clasă pentru conectarea la resurse externe, cum ar fi documente sau site-uri web, cu metadate asociate." },
    { "@language": "sk", "@value": "Definuje triedu na prepájanie s externými zdrojmi, ako sú dokumenty alebo webové stránky, s priradenými metadátami." },
    { "@language": "sl", "@value": "Določa razred za povezovanje z zunanjimi viri, kot so dokumenti ali spletna mesta, s povezanimi metapodatki." },
    { "@language": "sv", "@value": "Definierar en klass för att länka till externa resurser, såsom dokument eller webbplatser, med tillhörande metadata." }
  ],
  "owl:imports": { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Product.jsonld" },
