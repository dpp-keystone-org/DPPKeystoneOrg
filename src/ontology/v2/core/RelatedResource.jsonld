      "rdfs:comment": [
        { "@language": "en", "@value": "The media type (MIME type) of the resource (e.g., 'application/pdf', 'image/jpeg')." },
        { "@language": "bg", "@value": "Медийният тип (MIME тип) на ресурса (напр. 'application/pdf', 'image/jpeg')." },
        { "@language": "cs", "@value": "Typ média (typ MIME) zdroje (např. 'application/pdf', 'image/jpeg')." },
        { "@language": "da", "@value": "Medietypen (MIME-type) for ressourcen (f.eks. 'application/pdf', 'image/jpeg')." },
        { "@language": "de", "@value": "Der Medientyp (MIME-Typ) der Ressource (z. B. 'application/pdf', 'image/jpeg')." },
        { "@language": "el", "@value": "Ο τύπος μέσου (τύπος MIME) του πόρου (π.χ. 'application/pdf', 'image/jpeg')." },
        { "@language": "es", "@value": "El tipo de medio (tipo MIME) del recurso (por ejemplo, 'application/pdf', 'image/jpeg')." },
        { "@language": "et", "@value": "Ressursi meediumitüüp (MIME-tüüp) (nt 'application/pdf', 'image/jpeg')." },
        { "@language": "fi", "@value": "Resurssin mediatyyppi (MIME-tyyppi) (esim. 'application/pdf', 'image/jpeg')." },
        { "@language": "fr", "@value": "Le type de média (type MIME) de la ressource (par exemple, 'application/pdf', 'image/jpeg')." },
        { "@language": "ga", "@value": "Cineál meán (cineál MIME) na hacmhainne (e.g., 'application/pdf', 'image/jpeg')." },
        { "@language": "hr", "@value": "Vrsta medija (MIME vrsta) resursa (npr. 'application/pdf', 'image/jpeg')." },
        { "@language": "hu", "@value": "Az erőforrás médiatípusa (MIME-típus) (pl. 'application/pdf', 'image/jpeg')." },
        { "@language": "it", "@value": "Il tipo di supporto (tipo MIME) della risorsa (ad esempio, 'application/pdf', 'image/jpeg')." },
        { "@language": "lt", "@value": "Ištekliaus medijos tipas (MIME tipas) (pvz., 'application/pdf', 'image/jpeg')." },
        { "@language": "lv", "@value": "Resursa multivides tips (MIME tips) (piemēram, 'application/pdf', 'image/jpeg')." },
        { "@language": "mt", "@value": "It-tip tal-midja (tip MIME) tar-riżors (eż., 'application/pdf', 'image/jpeg')." },
        { "@language": "nl", "@value": "Het mediatype (MIME-type) van de bron (bijv. 'application/pdf', 'image/jpeg')." },
        { "@language": "pl", "@value": "Typ nośnika (typ MIME) zasobu (np. 'application/pdf', 'image/jpeg')." },
        { "@language": "pt", "@value": "O tipo de mídia (tipo MIME) do recurso (por exemplo, 'application/pdf', 'image/jpeg')." },
        { "@language": "ro", "@value": "Tipul media (tipul MIME) al resursei (de exemplu, 'application/pdf', 'image/jpeg')." },
        { "@language": "sk", "@value": "Typ média (typ MIME) zdroja (napr. 'application/pdf', 'image/jpeg')." },
        { "@language": "sl", "@value": "Vrsta predstavnosti (vrsta MIME) vira (npr. 'application/pdf', 'image/jpeg')." },
        { "@language": "sv", "@value": "Mediatypen (MIME-typ) för resursen (t.ex. 'application/pdf', 'image/jpeg')." }
      ],
