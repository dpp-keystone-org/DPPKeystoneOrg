    { "@language": "es", "@value": "Ontología central de DPP - Declaración de Prestaciones y Conformidad (DoPC)" },
    { "@language": "et", "@value": "DPP põhiontoloogia - Toimivus- ja vastavusdeklaratsioon (DoPC)" },
    { "@language": "fi", "@value": "DPP:n ydinontologia - Suoritustaso- ja vaatimustenmukaisuusvakuutus (DoPC)" },
    { "@language": "fr", "@value": "Ontologie de base du DPP - Déclaration des performances et de la conformité (DoPC)" },
    { "@language": "ga", "@value": "Croitheointeolaíocht DPP - Dearbhú Feidhmíochta agus Comhréireachta (DoPC)" },
    { "@language": "hr", "@value": "Osnovna ontologija DPP - Izjava o svojstvima i sukladnosti (DoPC)" },
    { "@language": "hu", "@value": "DPP alapontológia - Teljesítmény- és megfelelőségi nyilatkozat (DoPC)" },
    { "@language": "it", "@value": "Ontologia di base DPP - Dichiarazione di Prestazione e Conformità (DoPC)" },
    { "@language": "lt", "@value": "DPP pagrindinė ontologija - Eksploatacinių savybių ir atitikties deklaracija (DoPC)" },
    { "@language": "lv", "@value": "DPP pamatontoloģija - Ekspluatācijas īpašību un atbilstības deklarācija (DoPC)" },
    { "@language": "mt", "@value": "Ontoloġija Ewlenija tad-DPP - Dikjarazzjoni ta' Prestazzjoni u Konformità (DoPC)" },
    { "@language": "nl", "@value": "DPP Core Ontologie - Prestatie- en conformiteitsverklaring (DoPC)" },
    { "@language": "pl", "@value": "Podstawowa ontologia DPP - Deklaracja właściwości użytkowych i zgodności (DoPC)" },
    { "@language": "pt", "@value": "Ontologia Central do DPP - Declaração de Desempenho e Conformidade (DoPC)" },
    { "@language": "ro", "@value": "Ontologia de bază DPP - Declarația de performanță și conformitate (DoPC)" },
    { "@language": "sk", "@value": "Základná ontológia DPP - Vyhlásenie o parametroch a zhode (DoPC)" },
    { "@language": "sl", "@value": "Osnovna ontologija DPP - Izjava o lastnostih in skladnosti (DoPC)" },
    { "@language": "sv", "@value": "DPP Core Ontology - Prestandadeklaration och försäkran om överensstämmelse (DoPC)" }
  ],
  "dcterms:description": [
    { "@language": "en", "@value": "Defines the classes and properties required for representing a Declaration of Performance and Conformity (DoPC)." },
    { "@language": "bg", "@value": "Определя класовете и свойствата, необходими за представяне на Декларация за експлоатационни показатели и съответствие (DoPC)." },
    { "@language": "cs", "@value": "Definuje třídy a vlastnosti požadované pro reprezentaci Prohlášení o vlastnostech a shodě (DoPC)." },
    { "@language": "da", "@value": "Definerer de klasser og egenskaber, der kræves for at repræsentere en ydeevnedeklaration og overensstemmelse (DoPC)." },
    { "@language": "de", "@value": "Definiert die Klassen und Eigenschaften, die zur Darstellung einer Leistungs- und Konformitätserklärung (DoPC) erforderlich sind." },
    { "@language": "el", "@value": "Ορίζει τις κλάσεις και τις ιδιότητες που απαιτούνται για την αναπαράσταση μιας Δήλωσης Επιδόσεων και Συμμόρφωσης (DoPC)." },
    { "@language": "es", "@value": "Define las clases y propiedades requeridas para representar una Declaración de Prestaciones y Conformidad (DoPC)." },
    { "@language": "et", "@value": "Määratleb klassid ja omadused, mis on vajalikud toimivus- ja vastavusdeklaratsiooni (DoPC) esitamiseks." },
    { "@language": "fi", "@value": "Määrittää luokat ja ominaisuudet, joita tarvitaan suoritustaso- ja vaatimustenmukaisuusvakuutuksen (DoPC) esittämiseen." },
    { "@language": "fr", "@value": "Définit les classes et les propriétés requises pour représenter une déclaration des performances et de la conformité (DoPC)." },
    { "@language": "ga", "@value": "Sainmhíníonn sé na haicmí agus na hairíonna is gá chun Dearbhú Feidhmíochta agus Comhréireachta (DoPC) a léiriú." },
    { "@language": "hr", "@value": "Definira klase i svojstva potrebna za predstavljanje Izjave o svojstvima i sukladnosti (DoPC)." },
    { "@language": "hu", "@value": "Meghatározza a teljesítmény- és megfelelőségi nyilatkozat (DoPC) ábrázolásához szükséges osztályokat és tulajdonságokat." },
    { "@language": "it", "@value": "Definisce le classi e le proprietà necessarie per rappresentare una Dichiarazione di Prestazione e Conformità (DoPC)." },
    { "@language": "lt", "@value": "Apibrėžia klases ir savybes, reikalingas eksploatacinių savybių ir atitikties deklaracijai (DoPC) atvaizduoti." },
    { "@language": "lv", "@value": "Definē klases un īpašības, kas nepieciešamas ekspluatācijas īpašību un atbilstības deklarācijas (DoPC) atspoguļošanai." },
    { "@language": "mt", "@value": "Jiddefinixxi l-klassijiet u l-proprjetajiet meħtieġa biex jirrappreżentaw Dikjarazzjoni ta' Prestazzjoni u Konformità (DoPC)." },
    { "@language": "nl", "@value": "Definieert de klassen en eigenschappen die nodig zijn voor het weergeven van een prestatie- en conformiteitsverklaring (DoPC)." },
    { "@language": "pl", "@value": "Definiuje klasy i właściwości wymagane do reprezentowania Deklaracji właściwości użytkowych i zgodności (DoPC)." },
    { "@language": "pt", "@value": "Define as classes e propriedades necessárias para representar uma Declaração de Desempenho e Conformidade (DoPC)." },
    { "@language": "ro", "@value": "Definește clasele și proprietățile necesare pentru reprezentarea unei Declarații de performanță și conformitate (DoPC)." },
    { "@language": "sk", "@value": "Definuje triedy a vlastnosti potrebné na reprezentáciu Vyhlásenia o parametroch a zhode (DoPC)." },
    { "@language": "sl", "@value": "Določa razrede in lastnosti, potrebne za predstavitev Izjave o lastnostih in skladnosti (DoPC)." },
    { "@language": "sv", "@value": "Definierar de klasser och egenskaper som krävs för att representera en prestandadeklaration och försäkran om överensstämmelse (DoPC)." }
  ],
