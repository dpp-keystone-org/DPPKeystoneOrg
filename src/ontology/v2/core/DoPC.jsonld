    { "@language": "en", "@value": "DPP Core Ontology - Declaration of Performance and Conformity (DoPC)" },
    { "@language": "bg", "@value": "Основна онтология на DPP - Декларация за експлоатационни показатели и съответствие (DoPC)" },
    { "@language": "cs", "@value": "Základní ontologie DPP - Prohlášení o vlastnostech a shodě (DoPC)" },
