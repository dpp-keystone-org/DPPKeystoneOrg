      "rdfs:comment": [
        { "@language": "en", "@value": "The quantity of a construction product for use as a reference unit in an EPD for an environmental impact assessment." },
        { "@language": "bg", "@value": "Количеството строителен продукт за използване като референтна единица в ДЕП за оценка на въздействието върху околната среда." },
        { "@language": "cs", "@value": "Množství stavebního výrobku pro použití jako referenční jednotka v EPD pro posouzení vlivu na životní prostředí." },
        { "@language": "da", "@value": "Mængden af en byggevare til brug som referenceenhed i en EPD til en miljøkonsekvensvurdering." },
        { "@language": "de", "@value": "Die Menge eines Bauprodukts zur Verwendung als Bezugseinheit in einer EPD für eine Umweltverträglichkeitsprüfung." },
        { "@language": "el", "@value": "Η ποσότητα ενός δομικού προϊόντος για χρήση ως μονάδα αναφοράς σε EPD για εκτίμηση περιβαλλοντικών επιπτώσεων." },
        { "@language": "es", "@value": "La cantidad de un producto de construcción para su uso como unidad de referencia en una DAP para una evaluación de impacto ambiental." },
        { "@language": "et", "@value": "Ehitustoote kogus, mida kasutatakse EPD-s keskkonnamõju hindamise võrdlusühikuna." },
        { "@language": "fi", "@value": "Rakennustuotteen määrä, jota käytetään vertailuyksikkönä ympäristöselosteessa ympäristövaikutusten arvioinnissa." },
        { "@language": "fr", "@value": "La quantité d'un produit de construction à utiliser comme unité de référence dans une DEP pour une évaluation de l'impact environnemental." },
        { "@language": "ga", "@value": "Cainníocht táirge foirgníochta le húsáid mar aonad tagartha i nDearbhú Comhshaoil Táirge le haghaidh measúnú tionchair timpeallachta." },
        { "@language": "hr", "@value": "Količina građevnog proizvoda za upotrebu kao referentna jedinica u EPD-u za procjenu utjecaja na okoliš." },
        { "@language": "hu", "@value": "Építési termék mennyisége, amelyet referenciaegységként használnak egy környezeti nyilatkozatban (EPD) a környezeti hatásvizsgálathoz." },
        { "@language": "it", "@value": "La quantità di un prodotto da costruzione da utilizzare come unità di riferimento in una EPD per una valutazione dell'impatto ambientale." },
        { "@language": "lt", "@value": "Statybos produkto kiekis, skirtas naudoti kaip atskaitos vienetas EPD vertinant poveikį aplinkai." },
        { "@language": "lv", "@value": "Būvizstrādājuma daudzums, ko izmanto kā atsauces vienību EPD ietekmes uz vidi novērtēšanai." },
        { "@language": "mt", "@value": "Il-kwantità ta' prodott għall-bini għall-użu bħala unità ta' referenza f'EPD għal valutazzjoni tal-impatt ambjentali." },
        { "@language": "nl", "@value": "De hoeveelheid van een bouwproduct voor gebruik als referentie-eenheid in een EPD voor een milieueffectbeoordeling." },
        { "@language": "pl", "@value": "Ilość wyrobu budowlanego do wykorzystania jako jednostka odniesienia w EPD do oceny wpływu na środowisko." },
        { "@language": "pt", "@value": "A quantidade de um produto de construção para uso como unidade de referência numa DAP para uma avaliação de impacto ambiental." },
        { "@language": "ro", "@value": "Cantitatea unui produs pentru construcții destinată utilizării ca unitate de referință într-o DEP pentru o evaluare a impactului asupra mediului." },
        { "@language": "sk", "@value": "Množstvo stavebného výrobku na použitie ako referenčná jednotka v EPD pre posúdenie vplyvu na životné prostredie." },
        { "@language": "sl", "@value": "Količina gradbenega proizvoda za uporabo kot referenčna enota v EPD za presojo vplivov na okolje." },
