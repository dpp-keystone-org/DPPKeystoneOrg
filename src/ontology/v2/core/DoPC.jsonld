      "dppk:governedBy": "ISO 7389:2002",
      "rdfs:comment": [
        { "@language": "en", "@value": "A standardized expansion factor to be recovered from in elastic material testing." },
        { "@language": "bg", "@value": "Стандартизиран коефициент на разширение, от който да се възстанови при изпитване на еластични материали." },
        { "@language": "cs", "@value": "Standardizovaný faktor expanze, ze kterého se má zotavit při testování elastických materiálů." },
        { "@language": "da", "@value": "En standardiseret udvidelsesfaktor til at blive gendannet fra i elastisk materialetestning." },
        { "@language": "de", "@value": "Ein standardisierter Ausdehnungsfaktor, von dem bei der Prüfung elastischer Materialien eine Rückstellung erfolgen soll." },
        { "@language": "el", "@value": "Ένας τυποποιημένος συντελεστής διαστολής από τον οποίο πρέπει να ανακτηθεί στη δοκιμή ελαστικών υλικών." },
        { "@language": "es", "@value": "Un factor de expansión estandarizado del que recuperarse en las pruebas de materiales elásticos." },
        { "@language": "et", "@value": "Standardiseeritud paisumistegur, millest elastsete materjalide testimisel taastuda." },
        { "@language": "fi", "@value": "Standardoitu laajenemiskerroin, josta palaudutaan joustavien materiaalien testauksessa." },
        { "@language": "fr", "@value": "Un facteur d'expansion normalisé à récupérer lors des essais de matériaux élastiques." },
        { "@language": "ga", "@value": "Fachtóir fairsingithe caighdeánaithe le téarnamh uaidh i dtástáil ábhar leaisteach." },
        { "@language": "hr", "@value": "Standardizirani faktor ekspanzije od kojeg se treba oporaviti u ispitivanju elastičnih materijala." },
        { "@language": "hu", "@value": "Szabványosított tágulási tényező, amelyből a rugalmas anyagok vizsgálatánál vissza kell térni." },
        { "@language": "it", "@value": "Un fattore di espansione standardizzato da cui recuperare nei test sui materiali elastici." },
        { "@language": "lt", "@value": "Standartizuotas plėtimosi koeficientas, nuo kurio reikia atsigauti bandant elastines medžiagas." },
        { "@language": "lv", "@value": "Standartizēts izplešanās koeficients, no kura jāatgūstas elastīgo materiālu testēšanā." },
        { "@language": "mt", "@value": "Fattur ta' espansjoni standardizzat li għandu jiġi rkuprat mill-ittestjar tal-materjal elastiku." },
