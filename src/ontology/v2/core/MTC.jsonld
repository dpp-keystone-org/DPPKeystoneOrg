    "dcterms:title": [
      { "@language": "en", "@value": "DPP Core Ontology - Material Test Certificate (MTC)" },
      { "@language": "bg", "@value": "DPP Основна онтология - Сертификат за изпитване на материали (MTC)" },
      { "@language": "cs", "@value": "Základní ontologie DPP - Certifikát o zkoušce materiálu (MTC)" },
      { "@language": "da", "@value": "DPP Kerneontologi - Materialeprøvningscertifikat (MTC)" },
      { "@language": "de", "@value": "DPP-Kernontologie - Werkstoffprüfzeugnis (MTC)" },
