      { "@language": "es", "@value": "Ontología Central DPP - Certificado de Prueba de Material (MTC)" },
      { "@language": "et", "@value": "DPP tuumontoloogia - materjali katsetunnistus (MTC)" },
      { "@language": "fi", "@value": "DPP-ydinontologia - Materiaalitestaustodistus (MTC)" },
      { "@language": "fr", "@value": "Ontologie de base DPP - Certificat d'essai de matériaux (MTC)" },
      { "@language": "ga", "@value": "Ointeolaíocht Chroí DPP - Teastas Tástála Ábhair (MTC)" },
      { "@language": "hr", "@value": "Osnovna ontologija DPP - Potvrda o ispitivanju materijala (MTC)" },
      { "@language": "hu", "@value": "DPP Alap Ontológia - Anyagvizsgálati Tanúsítvány (MTC)" },
      { "@language": "it", "@value": "Ontologia di Base DPP - Certificato di Prova dei Materiali (MTC)" },
      { "@language": "lt", "@value": "DPP pagrindinė ontologija - Medžiagų bandymų sertifikatas (MTC)" },
      { "@language": "lv", "@value": "DPP pamata ontoloģija - Materiālu testēšanas sertifikāts (MTC)" },
      { "@language": "mt", "@value": "Ontoloġija Ewlenija DPP - Ċertifikat tat-Test tal-Materjal (MTC)" },
      { "@language": "nl", "@value": "DPP Kernontologie - Materiaaltestcertificaat (MTC)" },
      { "@language": "pl", "@value": "Podstawowa ontologia DPP - Certyfikat badania materiału (MTC)" },
      { "@language": "pt", "@value": "Ontologia Central DPP - Certificado de Teste de Material (MTC)" },
      { "@language": "ro", "@value": "Ontologie de Bază DPP - Certificat de testare a materialelor (MTC)" },
      { "@language": "sk", "@value": "Základná ontológia DPP - Certifikát o skúške materiálu (MTC)" },
      { "@language": "sl", "@value": "Osnovna ontologija DPP - Potrdilo o preskusu materiala (MTC)" },
      { "@language": "sv", "@value": "DPP Kärnontologi - Materialprovningsintyg (MTC)" }
    ],
    "dcterms:description": [
      { "@language": "en", "@value": "Defines the base class and properties for a Material Test Certificate (e.g., EN 10204)." },
      { "@language": "bg", "@value": "Дефинира базовия клас и свойствата за Сертификат за изпитване на материали (напр. EN 10204)." },
      { "@language": "cs", "@value": "Definuje základní třídu a vlastnosti pro Certifikát o zkoušce materiálu (např. EN 10204)." },
      { "@language": "da", "@value": "Definerer basisklassen og egenskaber for et materialeprøvningscertifikat (f.eks. EN 10204)." },
      { "@language": "de", "@value": "Definiert die Basisklasse und Eigenschaften für ein Werkstoffprüfzeugnis (z. B. EN 10204)." },
      { "@language": "el", "@value": "Ορίζει τη βασική κλάση και τις ιδιότητες για ένα Πιστοποιητικό Δοκιμής Υλικών (π.χ. EN 10204)." },
      { "@language": "es", "@value": "Define la clase base y las propiedades para un Certificado de Prueba de Material (por ejemplo, EN 10204)." },
      { "@language": "et", "@value": "Määrab materjali katsetunnistuse põhiklassi ja omadused (nt EN 10204)." },
      { "@language": "fi", "@value": "Määrittää perusluokan ja ominaisuudet materiaalitestaustodistukselle (esim. EN 10204)." },
      { "@language": "fr", "@value": "Définit la classe de base et les propriétés d'un certificat d'essai de matériaux (par ex. EN 10204)." },
      { "@language": "ga", "@value": "Sainmhíníonn sé an aicme bhunaidh agus airíonna do Theastas Tástála Ábhair (m.sh. EN 10204)." },
      { "@language": "hr", "@value": "Definira osnovnu klasu i svojstva za Potvrdu o ispitivanju materijala (npr. EN 10204)." },
      { "@language": "hu", "@value": "Meghatározza az anyagvizsgálati tanúsítvány alaposztályát és tulajdonságait (pl. EN 10204)." },
      { "@language": "it", "@value": "Definisce la classe di base e le proprietà per un Certificato di Prova dei Materiali (es. EN 10204)." },
      { "@language": "lt", "@value": "Apibrėžia bazinę klasę ir savybes medžiagų bandymų sertifikatui (pvz., EN 10204)." },
      { "@language": "lv", "@value": "Definē pamatklasi un rekvizītus materiālu testēšanas sertifikātam (piemēram, EN 10204)." },
      { "@language": "mt", "@value": "Jiddefinixxi l-klassi bażi u l-proprjetajiet għal Ċertifikat tat-Test tal-Materjal (eż., EN 10204)." },
      { "@language": "nl", "@value": "Definieert de basisklasse en eigenschappen voor een materiaaltestcertificaat (bijv. EN 10204)." },
      { "@language": "pl", "@value": "Definiuje klasę bazową i właściwości Certyfikatu badania materiału (np. EN 10204)." },
      { "@language": "pt", "@value": "Define a classe base e as propriedades para um Certificado de Teste de Material (por exemplo, EN 10204)." },
      { "@language": "ro", "@value": "Definește clasa de bază și proprietățile pentru un Certificat de testare a materialelor (de ex. EN 10204)." },
      { "@language": "sk", "@value": "Definuje základnú triedu a vlastnosti pre Certifikát o skúške materiálu (napr. EN 10204)." },
      { "@language": "sl", "@value": "Določa osnovni razred in lastnosti za Potrdilo o preskusu materiala (npr. EN 10204)." },
      { "@language": "sv", "@value": "Definierar basklassen och egenskaperna för ett materialprovningsintyg (t.ex. EN 10204)." }
    ],
    "owl:imports": { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Product.jsonld" },
    "@graph": [
        {
            "@id": "dppk:MaterialTestCertificate",
            "@type": "rdfs:Class",
            "rdfs:comment": [
              { "@language": "en", "@value": "A certificate detailing the results of tests performed on a material, such as those defined in EN 10204." },
              { "@language": "bg", "@value": "Сертификат, описващ подробно резултатите от тестовете, извършени върху материал, като тези, дефинирани в EN 10204." },
              { "@language": "cs", "@value": "Certifikát podrobně popisující výsledky zkoušek provedených na materiálu, jako jsou zkoušky definované v EN 10204." },
              { "@language": "da", "@value": "Et certifikat, der beskriver resultaterne af test udført på et materiale, såsom dem, der er defineret i EN 10204." },
              { "@language": "de", "@value": "Ein Zeugnis, in dem die Ergebnisse der an einem Material durchgeführten Prüfungen aufgeführt sind, wie sie beispielsweise in der EN 10204 definiert sind." },
              { "@language": "el", "@value": "Πιστοποιητικό που περιγράφει λεπτομερώς τα αποτελέσματα των δοκιμών που πραγματοποιήθηκαν σε ένα υλικό, όπως αυτά που ορίζονται στο EN 10204." },
              { "@language": "es", "@value": "Un certificado que detalla los resultados de las pruebas realizadas en un material, como las definidas en la norma EN 10204." },
              { "@language": "et", "@value": "Sertifikaat, milles on esitatud materjali suhtes tehtud katsete tulemused, näiteks standardis EN 10204 määratletud katsete tulemused." },
              { "@language": "fi", "@value": "Todistus, jossa on yksityiskohtaiset tiedot materiaalille suoritetuista testeistä, kuten standardissa EN 10204 määritellyistä." },
              { "@language": "fr", "@value": "Un certificat détaillant les résultats des essais effectués sur un matériau, tels que ceux définis dans la norme EN 10204." },
              { "@language": "ga", "@value": "Deimhniú ina sonraítear torthaí tástálacha a dhéantar ar ábhar, amhail na cinn a shainítear in EN 10204." },
              { "@language": "hr", "@value": "Potvrda u kojoj se navode rezultati ispitivanja provedenih na materijalu, kao što su oni definirani u EN 10204." },
              { "@language": "hu", "@value": "Olyan tanúsítvány, amely részletezi az anyagon elvégzett vizsgálatok eredményeit, mint például az EN 10204 szabványban meghatározottakat." },
              { "@language": "it", "@value": "Un certificato che descrive i risultati delle prove effettuate su un materiale, come quelle definite nella norma EN 10204." },
              { "@language": "lt", "@value": "Sertifikatas, kuriame išsamiai aprašomi su medžiaga atliktų bandymų rezultatai, pvz., apibrėžti EN 10204." },
              { "@language": "lv", "@value": "Sertifikāts, kurā sīki aprakstīti materiālam veikto testu rezultāti, piemēram, tie, kas noteikti EN 10204." },
              { "@language": "mt", "@value": "Ċertifikat li jagħti dettalji dwar ir-riżultati tat-testijiet imwettqa fuq materjal, bħal dawk definiti f'EN 10204." },
              { "@language": "nl", "@value": "Een certificaat met de resultaten van tests die op een materiaal zijn uitgevoerd, zoals gedefinieerd in EN 10204." },
              { "@language": "pl", "@value": "Certyfikat wyszczególniający wyniki badań przeprowadzonych na materiale, takich jak te zdefiniowane w EN 10204." },
              { "@language": "pt", "@value": "Um certificado que detalha os resultados dos testes realizados num material, como os definidos na norma EN 10204." },
              { "@language": "ro", "@value": "Un certificat care detaliază rezultatele testelor efectuate pe un material, cum ar fi cele definite în EN 10204." },
              { "@language": "sk", "@value": "Certifikát podrobne opisujúci výsledky skúšok vykonaných na materiáli, ako sú skúšky definované v EN 10204." },
              { "@language": "sl", "@value": "Potrdilo, v katerem so podrobno opisani rezultati preskusov, opravljenih na materialu, kot so tisti, opredeljeni v EN 10204." },
              { "@language": "sv", "@value": "Ett intyg som beskriver resultaten av tester som utförts på ett material, såsom de som definieras i EN 10204." }
            ],
            "owl:equivalentClass": { "@id": "schema:Certification" },
            "rdfs:label": [
              { "@language": "en", "@value": "Material Test Certificate (MTC)" },
              { "@language": "bg", "@value": "Сертификат за изпитване на материали (MTC)" },
