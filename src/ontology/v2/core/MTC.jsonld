            ],
            "dppk:governedBy": "EN 10204",
            "rdfs:range": { "@id": "dppk:MaterialTestCertificate" },
            "rdfs:comment": [
              { "@language": "en", "@value": "A link to the Material Test Certificate associated with this product." },
              { "@language": "bg", "@value": "Връзка към Сертификата за изпитване на материали, свързан с този продукт." },
              { "@language": "cs", "@value": "Odkaz na Certifikát o zkoušce materiálu spojený s tímto produktem." },
              { "@language": "da", "@value": "Et link til materialeprøvningscertifikatet tilknyttet dette produkt." },
              { "@language": "de", "@value": "Ein Link zum Werkstoffprüfzeugnis, das mit diesem Produkt verbunden ist." },
              { "@language": "el", "@value": "Σύνδεσμος προς το Πιστοποιητικό Δοκιμής Υλικών που σχετίζεται με αυτό το προϊόν." },
              { "@language": "es", "@value": "Un enlace al Certificado de Prueba de Material asociado con este producto." },
              { "@language": "et", "@value": "Link selle tootega seotud materjali katsetunnistusele." },
              { "@language": "fi", "@value": "Linkki tähän tuotteeseen liittyvään materiaalitestaustodistukseen." },
              { "@language": "fr", "@value": "Un lien vers le certificat d'essai de matériaux associé à ce produit." },
              { "@language": "ga", "@value": "Nasc leis an Teastas Tástála Ábhair a bhaineann leis an táirge seo." },
              { "@language": "hr", "@value": "Poveznica na Potvrdu o ispitivanju materijala povezanu s ovim proizvodom." },
              { "@language": "hu", "@value": "Link a termékhez kapcsolódó anyagvizsgálati tanúsítványhoz." },
              { "@language": "it", "@value": "Un link al Certificato di Prova dei Materiali associato a questo prodotto." },
              { "@language": "lt", "@value": "Nuoroda į su šiuo produktu susijusį medžiagų bandymų sertifikatą." },
              { "@language": "lv", "@value": "Saite uz materiālu testēšanas sertifikātu, kas saistīts ar šo produktu." },
              { "@language": "mt", "@value": "Link għaċ-Ċertifikat tat-Test tal-Materjal assoċjat ma' dan il-prodott." },
              { "@language": "nl", "@value": "Een link naar het materiaaltestcertificaat dat aan dit product is gekoppeld." },
              { "@language": "pl", "@value": "Link do Certyfikatu badania materiału powiązanego z tym produktem." },
              { "@language": "pt", "@value": "Uma ligação para o Certificado de Teste de Material associado a este produto." },
              { "@language": "ro", "@value": "Un link către Certificatul de testare a materialelor asociat cu acest produs." },
              { "@language": "sk", "@value": "Odkaz na Certifikát o skúške materiálu spojený s týmto produktom." },
              { "@language": "sl", "@value": "Povezava do potrdila o preskusu materiala, povezanega s tem izdelkom." },
              { "@language": "sv", "@value": "En länk till materialprovningsintyget som är kopplat till denna produkt." }
            ]
        },
        {
            "@id": "dppk:sourceDocument",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Source Document" },
              { "@language": "bg", "@value": "Изходен документ" },
              { "@language": "cs", "@value": "Zdrojový dokument" },
              { "@language": "da", "@value": "Kildedokument" },
              { "@language": "de", "@value": "Quelldokument" },
              { "@language": "el", "@value": "Έγγραφο προέλευσης" },
              { "@language": "es", "@value": "Documento de origen" },
              { "@language": "et", "@value": "Lähtedokument" },
              { "@language": "fi", "@value": "Lähdeasiakirja" },
              { "@language": "fr", "@value": "Document source" },
              { "@language": "ga", "@value": "Bundoiciméad" },
              { "@language": "hr", "@value": "Izvorni dokument" },
              { "@language": "hu", "@value": "Forrásdokumentum" },
              { "@language": "it", "@value": "Documento sorgente" },
              { "@language": "lt", "@value": "Šaltinio dokumentas" },
              { "@language": "lv", "@value": "Avota dokuments" },
              { "@language": "mt", "@value": "Dokument Sors" },
              { "@language": "nl", "@value": "Brondocument" },
              { "@language": "pl", "@value": "Dokument źródłowy" },
              { "@language": "pt", "@value": "Documento de Origem" },
              { "@language": "ro", "@value": "Document sursă" },
              { "@language": "sk", "@value": "Zdrojový dokument" },
              { "@language": "sl", "@value": "Izvorni dokument" },
              { "@language": "sv", "@value": "Källdokument" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "A reference to the original digital document or file representing this certificate." },
              { "@language": "bg", "@value": "Препратка към оригиналния цифров документ или файл, представляващ този сертификат." },
              { "@language": "cs", "@value": "Odkaz na původní digitální dokument nebo soubor představující tento certifikát." },
              { "@language": "da", "@value": "En henvisning til det originale digitale dokument eller fil, der repræsenterer dette certifikat." },
              { "@language": "de", "@value": "Ein Verweis auf das ursprüngliche digitale Dokument oder die Datei, die dieses Zertifikat darstellt." },
              { "@language": "el", "@value": "Αναφορά στο αρχικό ψηφιακό έγγραφο ή αρχείο που αντιπροσωπεύει αυτό το πιστοποιητικό." },
              { "@language": "es", "@value": "Una referencia al documento digital original o archivo que representa este certificado." },
              { "@language": "et", "@value": "Viide algsele digitaalsele dokumendile või failile, mis esindab seda sertifikaati." },
              { "@language": "fi", "@value": "Viittaus alkuperäiseen digitaaliseen asiakirjaan tai tiedostoon, joka edustaa tätä todistusta." },
              { "@language": "fr", "@value": "Une référence au document numérique ou fichier original représentant ce certificat." },
              { "@language": "ga", "@value": "Tagairt don doiciméad nó don chomhad digiteach bunaidh a sheasann don deimhniú seo." },
              { "@language": "hr", "@value": "Referenca na izvorni digitalni dokument ili datoteku koja predstavlja ovu potvrdu." },
              { "@language": "hu", "@value": "Hivatkozás a tanúsítványt képviselő eredeti digitális dokumentumra vagy fájlra." },
              { "@language": "it", "@value": "Un riferimento al documento digitale originale o al file che rappresenta questo certificato." },
              { "@language": "lt", "@value": "Nuoroda į originalų skaitmeninį dokumentą ar failą, atstovaujantį šiam sertifikatui." },
              { "@language": "lv", "@value": "Atsauce uz oriģinālo digitālo dokumentu vai failu, kas pārstāv šo sertifikātu." },
              { "@language": "mt", "@value": "Referenza għad-dokument diġitali oriġinali jew fajl li jirrappreżenta dan iċ-ċertifikat." },
              { "@language": "nl", "@value": "Een verwijzing naar het originele digitale document of bestand dat dit certificaat vertegenwoordigt." },
              { "@language": "pl", "@value": "Odniesienie do oryginalnego cyfrowego dokumentu lub pliku reprezentującego ten certyfikat." },
              { "@language": "pt", "@value": "Uma referência ao documento digital ou ficheiro original que representa este certificado." },
              { "@language": "ro", "@value": "O referință la documentul digital sau fișierul original care reprezintă acest certificat." },
