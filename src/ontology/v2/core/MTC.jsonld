              { "@language": "fi", "@value": "Materiaalitestaustodistus." },
              { "@language": "fr", "@value": "Le certificat d'essai de matériaux." },
              { "@language": "ga", "@value": "An Teastas Tástála Ábhair." },
              { "@language": "hr", "@value": "Potvrda o ispitivanju materijala." },
              { "@language": "hu", "@value": "Az anyagvizsgálati tanúsítvány." },
              { "@language": "it", "@value": "Il Certificato di Prova dei Materiali." },
              { "@language": "lt", "@value": "Medžiagų bandymų sertifikatas." },
              { "@language": "lv", "@value": "Materiālu testēšanas sertifikāts." },
              { "@language": "mt", "@value": "Iċ-Ċertifikat tat-Test tal-Materjal." },
              { "@language": "nl", "@value": "Het materiaaltestcertificaat." },
              { "@language": "pl", "@value": "Certyfikat badania materiału." },
              { "@language": "pt", "@value": "O Certificado de Teste de Material." },
              { "@language": "ro", "@value": "Certificatul de testare a materialelor." },
              { "@language": "sk", "@value": "Certifikát o skúške materiálu." },
              { "@language": "sl", "@value": "Potrdilo o preskusu materiala." },
