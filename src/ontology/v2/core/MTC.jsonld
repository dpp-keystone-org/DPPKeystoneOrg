              { "@language": "lt", "@value": "Medžiagų bandymų sertifikatas (MTC)" },
              { "@language": "lv", "@value": "Materiālu testēšanas sertifikāts (MTC)" },
              { "@language": "mt", "@value": "Ċertifikat tat-Test tal-Materjal (MTC)" },
              { "@language": "nl", "@value": "Materiaaltestcertificaat (MTC)" },
              { "@language": "pl", "@value": "Certyfikat badania materiału (MTC)" },
              { "@language": "pt", "@value": "Certificado de Teste de Material (MTC)" },
              { "@language": "ro", "@value": "Certificat de testare a materialelor (MTC)" },
              { "@language": "sk", "@value": "Certifikát o skúške materiálu (MTC)" },
              { "@language": "sl", "@value": "Potrdilo o preskusu materiala (MTC)" },
              { "@language": "sv", "@value": "Materialprovningsintyg (MTC)" }
            ]
        },
        {
