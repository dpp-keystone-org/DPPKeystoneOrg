          { "@language": "lv", "@value": "Sertifikācijas iestādes loma" },
          { "@language": "mt", "@value": "Rwol tal-Korp taċ-Ċertifikazzjoni" },
          { "@language": "nl", "@value": "Rol certificerende instantie" },
          { "@language": "pl", "@value": "Rola jednostki certyfikującej" },
          { "@language": "pt", "@value": "Papel do organismo de certificação" },
          { "@language": "ro", "@value": "Rolul organismului de certificare" },
          { "@language": "sk", "@value": "Rola certifikačného orgánu" },
          { "@language": "sl", "@value": "Vloga certifikacijskega organa" },
          { "@language": "sv", "@value": "Certifieringsorganets roll" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "The role or capacity in which the certifying body issued the certification." },
          { "@language": "bg", "@value": "Ролята или качеството, в което сертифициращият орган е издал сертификацията." },
          { "@language": "cs", "@value": "Role nebo postavení, ve kterém certifikační orgán certifikaci vydal." },
          { "@language": "da", "@value": "Den rolle eller egenskab, som certificeringsorganet udstedte certificeringen i." },
          { "@language": "de", "@value": "Die Rolle oder Funktion, in der die Zertifizierungsstelle die Zertifizierung ausgestellt hat." },
          { "@language": "el", "@value": "Ο ρόλος ή η ιδιότητα με την οποία ο οργανισμός πιστοποίησης εξέδωσε την πιστοποίηση." },
          { "@language": "es", "@value": "El rol o la capacidad en la que el organismo certificador emitió la certificación." },
          { "@language": "et", "@value": "Roll või pädevus, milles sertifitseerimisasutus sertifikaadi väljastas." },
          { "@language": "fi", "@value": "Rooli tai ominaisuus, jossa sertifiointielin myönsi sertifioinnin." },
          { "@language": "fr", "@value": "Le rôle ou la qualité en vertu duquel l'organisme certificateur a délivré la certification." },
          { "@language": "ga", "@value": "An ról nó an cháilíocht inar eisigh an comhlacht deimhniúcháin an deimhniú." },
          { "@language": "hr", "@value": "Uloga ili svojstvo u kojem je certifikacijsko tijelo izdalo certifikaciju." },
          { "@language": "hu", "@value": "A szerepkör vagy minőség, amelyben a tanúsító testület a tanúsítványt kiállította." },
          { "@language": "it", "@value": "Il ruolo o la veste in cui l'ente certificatore ha rilasciato la certificazione." },
          { "@language": "lt", "@value": "Vaidmuo ar statusas, kuriuo sertifikavimo įstaiga išdavė sertifikatą." },
          { "@language": "lv", "@value": "Loma vai statusā, kādā sertifikācijas iestāde izdevusi sertifikāciju." },
          { "@language": "mt", "@value": "Ir-rwol jew il-kapaċità li biha l-korp taċ-ċertifikazzjoni ħareġ iċ-ċertifikazzjoni." },
          { "@language": "nl", "@value": "De rol of hoedanigheid waarin de certificerende instantie de certificering heeft afgegeven." },
          { "@language": "pl", "@value": "Rola lub charakter, w jakim jednostka certyfikująca wydała certyfikację." },
          { "@language": "pt", "@value": "O papel ou a capacidade em que o organismo certificador emitiu a certificação." },
          { "@language": "ro", "@value": "Rolul sau calitatea în care organismul de certificare a emis certificarea." },
          { "@language": "sk", "@value": "Rola alebo postavenie, v ktorom certifikačný orgán certifikáciu vydal." },
          { "@language": "sl", "@value": "Vloga ali status, v katerem je certifikacijski organ izdal certifikacijo." },
          { "@language": "sv", "@value": "Den roll eller egenskap i vilken certifieringsorganet utfärdade certifieringen." }
        ],
        "rdfs:domain": { "@id": "dppk:Certification" },
        "rdfs:range": { "@id": "dppk:CertificationBodyRoleType" }
    },

    // --- Enumeration for Certification Body Roles ---
    {
        "@id": "dppk:CertificationBodyRoleType",
        "@type": "rdfs:Class",
        "rdfs:subClassOf": { "@id": "rdfs:Resource" },
        "rdfs:label": "Certification Body Role Type",
        "rdfs:comment": "An enumeration of roles that an organization can assume when issuing a certification.",
        "owl:oneOf": [
            { "@id": "dppk:EconomicOperatorRole" },
            { "@id": "dppk:ManufacturerRole" },
            { "@id": "dppk:ImporterRole" },
            { "@id": "dppk:NotifiedBodyRole" }
        ]
    },
    {
        "@id": "dppk:EconomicOperatorRole",
        "@type": "dppk:CertificationBodyRoleType",
        "rdfs:label": "Economic Operator Role",
        "rdfs:comment": "The role of an entity responsible for placing the product on the market, as defined by ESPR."
    },
    {
        "@id": "dppk:ManufacturerRole",
        "@type": "dppk:CertificationBodyRoleType",
        "rdfs:label": "Manufacturer Role",
        "rdfs:comment": "The role of an entity responsible for the production of the finished goods."
    },
    {
        "@id": "dppk:ImporterRole",
        "@type": "dppk:CertificationBodyRoleType",
        "rdfs:label": "Importer Role",
        "rdfs:comment": "The role of an entity responsible for importing the product into the market."
    },
    {
        "@id": "dppk:NotifiedBodyRole",
        "@type": "dppk:CertificationBodyRoleType",
        "rdfs:label": "Notified Body Role",
        "rdfs:comment": "The role of an entity that performs conformity assessment activities and is officially designated by a notifying authority."
    },


