          { "@language": "da", "@value": "Problematiske stoffer" },
          { "@language": "de", "@value": "Besorgniserregende Stoffe" },
          { "@language": "el", "@value": "Ουσίες που προκαλούν ανησυχία" },
          { "@language": "es", "@value": "Sustancias preocupantes" },
          { "@language": "et", "@value": "Murettekitavad ained" },
          { "@language": "fi", "@value": "Huolta aiheuttavat aineet" },
          { "@language": "fr", "@value": "Substances extrêmement préoccupantes" },
          { "@language": "ga", "@value": "Substaintí is ábhar imní" },
          { "@language": "hr", "@value": "Zabrinjavajuće tvari" },
          { "@language": "hu", "@value": "Különös aggodalomra okot adó anyagok" },
          { "@language": "it", "@value": "Sostanze estremamente problematiche" },
          { "@language": "lt", "@value": "Didelį susirūpinimą keliančios medžiagos" },
          { "@language": "lv", "@value": "Vielas, kas rada bažas" },
          { "@language": "mt", "@value": "Sustanzi ta' tħassib" },
          { "@language": "nl", "@value": "Zeer zorgwekkende stoffen" },
          { "@language": "pl", "@value": "Substancje wzbudzające obawy" },
          { "@language": "pt", "@value": "Substâncias que suscitam preocupação" },
          { "@language": "ro", "@value": "Substanțe care prezintă motive de îngrijorare" },
          { "@language": "sk", "@value": "Látky vzbudzujúce obavy" },
          { "@language": "sl", "@value": "Snovi, ki vzbujajo skrb" },
          { "@language": "sv", "@value": "Särskilt farliga ämnen" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Relates the product to any substances of concern it contains." },
          { "@language": "bg", "@value": "Свързва продукта с всички съдържащи се в него вещества, пораждащи безпокойство." },
          { "@language": "cs", "@value": "Spojuje produkt s jakýmikoli látkami vzbuzujícími obavy, které obsahuje." },
          { "@language": "da", "@value": "Relaterer produktet til eventuelle problematiske stoffer, det indeholder." },
          { "@language": "de", "@value": "Verbindet das Produkt mit allen darin enthaltenen besorgniserregenden Stoffen." },
          { "@language": "el", "@value": "Συνδέει το προϊόν με τυχόν ουσίες που προκαλούν ανησυχία και τις οποίες περιέχει." },
          { "@language": "es", "@value": "Relaciona el producto con cualquier sustancia preocupante que contenga." },
          { "@language": "et", "@value": "Seob toote mis tahes murettekitavate ainetega, mida see sisaldab." },
          { "@language": "fi", "@value": "Yhdistää tuotteen sen sisältämiin huolta aiheuttaviin aineisiin." },
          { "@language": "fr", "@value": "Relie le produit à toute substance extrêmement préoccupante qu'il contient." },
          { "@language": "ga", "@value": "Nascann sé an táirge le haon substaintí is ábhar imní atá ann." },
          { "@language": "hr", "@value": "Povezuje proizvod sa svim zabrinjavajućim tvarima koje sadrži." },
          { "@language": "hu", "@value": "Összekapcsolja a terméket a benne található különös aggodalomra okot adó anyagokkal." },
          { "@language": "it", "@value": "Mette in relazione il prodotto con eventuali sostanze estremamente problematiche che contiene." },
          { "@language": "lt", "@value": "Susieja gaminį su bet kokiomis jame esančiomis didelį susirūpinimą keliančiomis medžiagomis." },
          { "@language": "lv", "@value": "Saista produktu ar visām tajā esošajām vielām, kas rada bažas." },
          { "@language": "mt", "@value": "Jorbot il-prodott ma' kwalunkwe sustanza ta' tħassib li jkun fih." },
          { "@language": "nl", "@value": "Koppelt het product aan eventuele zeer zorgwekkende stoffen die het bevat." },
          { "@language": "pl", "@value": "Wiąże produkt ze wszystkimi substancjami wzbudzającymi obawy, które zawiera." },
          { "@language": "pt", "@value": "Relaciona o produto a quaisquer substâncias que suscitam preocupação que ele contenha." },
          { "@language": "ro", "@value": "Relaționează produsul cu orice substanțe care prezintă motive de îngrijorare pe care le conține." },
          { "@language": "sk", "@value": "Spája produkt s akýmikoľvek látkami vzbudzujúcimi obavy, ktoré obsahuje." },
          { "@language": "sl", "@value": "Povezuje izdelek s katerimi koli snovmi, ki vzbujajo skrb in jih vsebuje." },
          { "@language": "sv", "@value": "Relaterar produkten till eventuella särskilt farliga ämnen den innehåller." }
        ],
        "rdfs:domain": { "@id": "dppk:Product" },
        "rdfs:range": { "@id": "dppk:Component" }
    },

