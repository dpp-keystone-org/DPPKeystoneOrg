          { "@language": "ro", "@value": "Numele sau descrierea etapei de producție (de ex., Asamblare, Țesut, Topire)." },
          { "@language": "sk", "@value": "Názov alebo popis výrobného kroku (napr. Montáž, Tkanie, Tavenie)." },
          { "@language": "sl", "@value": "Ime ali opis proizvodnega koraka (npr. Montaža, Tkanje, Taljenje)." },
          { "@language": "sv", "@value": "Namnet eller beskrivningen av produktionssteget (t.ex. Montering, Vävning, Smältning)." }
