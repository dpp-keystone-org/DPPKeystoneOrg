          { "@language": "el", "@value": "Το όνομα ή η περιγραφή του σταδίου παραγωγής (π.χ. Συναρμολόγηση, Ύφανση, Τήξη)." },
          { "@language": "es", "@value": "El nombre o la descripción del paso de producción (por ejemplo, Ensamblaje, Tejido, Fundición)." },
          { "@language": "et", "@value": "Tootmissammu nimi või kirjeldus (nt Koostamine, Kudumine, Sulatamine)." },
          { "@language": "fi", "@value": "Tuotantovaiheen nimi tai kuvaus (esim. Kokoonpano, Kudonta, Sulatus)." },
          { "@language": "fr", "@value": "Le nom ou la description de l'étape de production (par exemple, Assemblage, Tissage, Fusion)." },
          { "@language": "ga", "@value": "Ainm nó cur síos na céime táirgthe (m.sh., Cóimeáil, Fíodóireacht, Bruithniú)." },
          { "@language": "hr", "@value": "Naziv ili opis proizvodnog koraka (npr. Sastavljanje, Tkanje, Taljenje)." },
          { "@language": "hu", "@value": "A gyártási lépés neve vagy leírása (pl. Összeszerelés, Szövés, Olvasztás)." },
          { "@language": "it", "@value": "Il nome o la descrizione della fase di produzione (es. Assemblaggio, Tessitura, Fusione)." },
          { "@language": "lt", "@value": "Gamybos etapo pavadinimas arba aprašymas (pvz., Surinkimas, Audimas, Lydymas)." },
          { "@language": "lv", "@value": "Ražošanas posma nosaukums vai apraksts (piem., Montāža, Aušana, Kausēšana)." },
          { "@language": "mt", "@value": "L-isem jew id-deskrizzjoni tal-pass tal-produzzjoni (eż., Assemblaġġ, Insiġ, Tidwib)." },
          { "@language": "nl", "@value": "De naam of beschrijving van de productiestap (bijv. Assemblage, Weven, Smelten)." },
          { "@language": "pl", "@value": "Nazwa lub opis kroku produkcji (np. Montaż, Tkanie, Wytapianie)." },
