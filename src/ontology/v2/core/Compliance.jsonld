  "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Compliance",
  "@type": "owl:Ontology",
  "dcterms:title": [
    { "@language": "en", "@value": "DPP Core Ontology - Compliance and Regulatory Definitions ({{VERSION}})" },
    { "@language": "bg", "@value": "Основна онтология на DPP - Определения за съответствие и регулации ({{VERSION}})" },
    { "@language": "cs", "@value": "Základní ontologie DPP - Definice shody a regulací ({{VERSION}})" },
    { "@language": "da", "@value": "DPP Kerneontologi - Compliance og regulatoriske definitioner ({{VERSION}})" },
    { "@language": "de", "@value": "DPP-Kernontologie - Konformitäts- und regulatorische Definitionen ({{VERSION}})" },
    { "@language": "el", "@value": "Βασική οντολογία DPP - Ορισμοί συμμόρφωσης και κανονισμών ({{VERSION}})" },
    { "@language": "es", "@value": "Ontología central de DPP - Definiciones normativas y de cumplimiento ({{VERSION}})" },
    { "@language": "et", "@value": "DPP tuumontoloogia - Vastavuse ja regulatiivsed definitsioonid ({{VERSION}})" },
    { "@language": "fi", "@value": "DPP-ydinontologia - Vaatimustenmukaisuuden ja sääntelyn määritykset ({{VERSION}})" },
    { "@language": "fr", "@value": "Ontologie de base DPP - Définitions de conformité et de réglementation ({{VERSION}})" },
    { "@language": "ga", "@value": "Príomhointeolaíocht DPP - Sainmhínithe Comhlíonta agus Rialála ({{VERSION}})" },
    { "@language": "hr", "@value": "Osnovna ontologija DPP-a - Definicije sukladnosti i propisa ({{VERSION}})" },
    { "@language": "hu", "@value": "DPP alapontológia - Megfelelőségi és szabályozási definíciók ({{VERSION}})" },
    { "@language": "it", "@value": "Ontologia di base DPP - Definizioni di conformità e normative ({{VERSION}})" },
    { "@language": "lt", "@value": "DPP pagrindinė ontologija - Atitikties ir normatyviniai apibrėžimai ({{VERSION}})" },
    { "@language": "lv", "@value": "DPP pamata ontoloģija - Atbilstības un normatīvās definīcijas ({{VERSION}})" },
    { "@language": "mt", "@value": "Ontoloġija Ewlenija tad-DPP - Definizzjonijiet ta' Konformità u Regolatorji ({{VERSION}})" },
    { "@language": "nl", "@value": "DPP Kernontologie - Nalevings- en regelgevende definities ({{VERSION}})" },
    { "@language": "pl", "@value": "Główna ontologia DPP - Definicje zgodności i przepisów ({{VERSION}})" },
    { "@language": "pt", "@value": "Ontologia Central do DPP - Definições de Conformidade e Regulamentares ({{VERSION}})" },
    { "@language": "ro", "@value": "Ontologia de bază DPP - Definiții de conformitate și reglementare ({{VERSION}})" },
    { "@language": "sk", "@value": "Základná ontológia DPP - Definície zhody a regulácií ({{VERSION}})" },
    { "@language": "sl", "@value": "Osnovna ontologija DPP - Definicije skladnosti in predpisov ({{VERSION}})" },
    { "@language": "sv", "@value": "DPP-kärnontologi - Efterlevnad och regulatoriska definitioner ({{VERSION}})" }
  ],
  "dcterms:description": [
    { "@language": "en", "@value": "Defines horizontal concepts related to Documents, Certifications, Substances of Concern, Eco-Design, Packaging, and Production Steps." },
    { "@language": "bg", "@value": "Определя хоризонтални концепции, свързани с документи, сертификации, вещества, пораждащи безпокойство, екодизайн, опаковки и производствени стъпки." },
    { "@language": "cs", "@value": "Definuje horizontální koncepty týkající se dokumentů, certifikací, látek vzbuzujících obavy, ekodesignu, obalů a výrobních kroků." },
    { "@language": "da", "@value": "Definerer horisontale koncepter relateret til dokumenter, certificeringer, problematiske stoffer, miljøvenligt design, emballage og produktionstrin." },
    { "@language": "de", "@value": "Definiert horizontale Konzepte in Bezug auf Dokumente, Zertifizierungen, besorgniserregende Stoffe, Ökodesign, Verpackung und Produktionsschritte." },
    { "@language": "el", "@value": "Καθορίζει οριζόντιες έννοιες που σχετίζονται με έγγραφα, πιστοποιήσεις, ουσίες που προκαλούν ανησυχία, οικολογικό σχεδιασμό, συσκευασία και στάδια παραγωγής." },
    { "@language": "es", "@value": "Define conceptos horizontales relacionados con Documentos, Certificaciones, Sustancias preocupantes, Ecodiseño, Embalaje y Pasos de producción." },
    { "@language": "et", "@value": "Määratleb horisontaalsed kontseptsioonid seoses dokumentide, sertifikaatide, murettekitavate ainete, ökodisaini, pakendite ja tootmissammudega." },
    { "@language": "fi", "@value": "Määrittää horisontaalisia käsitteitä, jotka liittyvät asiakirjoihin, sertifiointeihin, huolta aiheuttaviin aineisiin, ekosuunnitteluun, pakkauksiin ja tuotantovaiheisiin." },
    { "@language": "fr", "@value": "Définit les concepts horizontaux liés aux documents, certifications, substances extrêmement préoccupantes, écoconception, emballage et étapes de production." },
    { "@language": "ga", "@value": "Sainmhíníonn sé coincheapa cothrománacha abhaineann le Doiciméid, Deimhnithe, Substaintí is Ábhar Imní, Éicidhearthóireacht, Pacáistiú, agus Céimeanna Táirgthe." },
    { "@language": "hr", "@value": "Definira horizontalne koncepte povezane s dokumentima, certifikatima, zabrinjavajućim tvarima, ekološkim dizajnom, ambalažom i proizvodnim koracima." },
    { "@language": "hu", "@value": "Meghatározza a dokumentumokhoz, tanúsítványokhoz, különös aggodalomra okot adó anyagokhoz, környezettudatos tervezéshez, csomagoláshoz és gyártási lépésekhez kapcsolódó horizontális fogalmakat." },
    { "@language": "it", "@value": "Definisce concetti orizzontali relativi a documenti, certificazioni, sostanze estremamente problematiche, progettazione ecocompatibile, imballaggio e fasi di produzione." },
    { "@language": "lt", "@value": "Apibrėžia horizontalias koncepcijas, susijusias su dokumentais, sertifikatais, didelį susirūpinimą keliančiomis medžiagomis, ekologiniu projektavimu, pakuotėmis ir gamybos etapais." },
    { "@language": "lv", "@value": "Nosaka horizontālus jēdzienus, kas saistīti ar dokumentiem, sertifikātiem, vielām, kas rada bažas, ekodizainu, iepakojumu un ražošanas posmiem." },
    { "@language": "mt", "@value": "Jiddefinixxi kunċetti orizzontali relatati ma' Dokumenti, Ċertifikazzjonijiet, Sustanzi ta' Tħassib, Ekodisinn, Imballaġġ, u Passi tal-Produzzjoni." },
    { "@language": "nl", "@value": "Definieert horizontale concepten met betrekking tot documenten, certificeringen, zeer zorgwekkende stoffen, ecologisch ontwerp, verpakking en productiestappen." },
    { "@language": "pl", "@value": "Określa poziome pojęcia związane z dokumentami, certyfikatami, substancjami wzbudzającymi obawy, ekoprojektem, opakowaniami i krokami produkcji." },
    { "@language": "pt", "@value": "Define conceitos horizontais relacionados a Documentos, Certificações, Substâncias que suscitam preocupação, Ecodesign, Embalagem e Etapas de Produção." },
    { "@language": "ro", "@value": "Definește concepte orizontale referitoare la documente, certificări, substanțe care prezintă motive de îngrijorare, proiectare ecologică, ambalaje și etape de producție." },
    { "@language": "sk", "@value": "Definuje horizontálne koncepty týkajúce sa dokumentov, certifikácií, látok vzbudzujúcich obavy, ekodizajnu, obalov a výrobných krokov." },
    { "@language": "sl", "@value": "Določa horizontalne koncepte, povezane z dokumenti, certifikati, snovmi, ki vzbujajo skrb, okoljsko primerno zasnovo, embalažo in proizvodnimi koraki." },
    { "@language": "sv", "@value": "Definierar horisontella begrepp relaterade till dokument, certifieringar, särskilt farliga ämnen, ekodesign, förpackningar och produktionssteg." }
  ],
  "owl:versionInfo": "{{VERSION}}",
  // Import Product and Organization ontologies as they are used in the domain/range of properties here.
  "owl:imports": [
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Product.jsonld" },
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Organization.jsonld" },
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/RelatedResource.jsonld" }
  ],

  "@graph": [
    // ==================================================================
    // Classes
    // ==================================================================

    {
        "@id": "dppk:Certification",
        "@type": "rdfs:Class",
        "rdfs:label": [
          { "@language": "en", "@value": "Certification" },
          { "@language": "bg", "@value": "Сертификация" },
          { "@language": "cs", "@value": "Certifikace" },
          { "@language": "da", "@value": "Certificering" },
          { "@language": "de", "@value": "Zertifizierung" },
          { "@language": "el", "@value": "Πιστοποίηση" },
          { "@language": "es", "@value": "Certificación" },
          { "@language": "et", "@value": "Sertifitseerimine" },
          { "@language": "fi", "@value": "Sertifiointi" },
          { "@language": "fr", "@value": "Certification" },
          { "@language": "ga", "@value": "Deimhniú" },
          { "@language": "hr", "@value": "Certifikacija" },
          { "@language": "hu", "@value": "Tanúsítás" },
          { "@language": "it", "@value": "Certificazione" },
          { "@language": "lt", "@value": "Sertifikavimas" },
          { "@language": "lv", "@value": "Sertifikācija" },
          { "@language": "mt", "@value": "Ċertifikazzjoni" },
          { "@language": "nl", "@value": "Certificering" },
          { "@language": "pl", "@value": "Certyfikacja" },
          { "@language": "pt", "@value": "Certificação" },
          { "@language": "ro", "@value": "Certificare" },
          { "@language": "sk", "@value": "Certifikácia" },
          { "@language": "sl", "@value": "Certificiranje" },
          { "@language": "sv", "@value": "Certifiering" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "A confirmation that the product meets the requirements of a specific standard or regulation (e.g., CE Marking, EPD)." },
          { "@language": "bg", "@value": "Потвърждение, че продуктът отговаря на изискванията на специфичен стандарт или регламент (напр. CE маркировка, EPD)." },
          { "@language": "cs", "@value": "Potvrzení, že výrobek splňuje požadavky specifické normy nebo předpisu (např. označení CE, EPD)." },
          { "@language": "da", "@value": "En bekræftelse på, at produktet opfylder kravene i en specifik standard eller forordning (f.eks. CE-mærkning, EPD)." },
          { "@language": "de", "@value": "Eine Bestätigung, dass das Produkt die Anforderungen einer bestimmten Norm oder Vorschrift erfüllt (z. B. CE-Kennzeichnung, EPD)." },
          { "@language": "el", "@value": "Επιβεβαίωση ότι το προϊόν πληροί τις απαιτήσεις ενός συγκεκριμένου προτύπου ή κανονισμού (π.χ. σήμανση CE, EPD)." },
          { "@language": "es", "@value": "Una confirmación de que el producto cumple con los requisitos de un estándar o regulación específica (por ejemplo, marcado CE, EPD)." },
          { "@language": "et", "@value": "Kinnitus, et toode vastab kindla standardi või määruse nõuetele (nt CE-märgis, EPD)." },
          { "@language": "fi", "@value": "Vahvistus siitä, että tuote täyttää tietyn standardin tai säännöksen vaatimukset (esim. CE-merkintä, EPD)." },
          { "@language": "fr", "@value": "Une confirmation que le produit répond aux exigences d'une norme ou d'une réglementation spécifique (par exemple, marquage CE, EPD)." },
          { "@language": "ga", "@value": "Deimhniú go gcomhlíonann an táirge riachtanais caighdeáin nó rialacháin shonraigh (m.sh., Marcáil CE, EPD)." },
          { "@language": "hr", "@value": "Potvrda da proizvod ispunjava zahtjeve određenog standarda ili propisa (npr. CE oznaka, EPD)." },
          { "@language": "hu", "@value": "Megerősítés arról, hogy a termék megfelel egy adott szabvány vagy előírás követelményeinek (pl. CE jelölés, EPD)." },
          { "@language": "it", "@value": "Una conferma che il prodotto soddisfa i requisiti di uno standard o di un regolamento specifico (es. marcatura CE, EPD)." },
          { "@language": "lt", "@value": "Patvirtinimas, kad gaminys atitinka konkretaus standarto ar reglamento reikalavimus (pvz., CE ženklinimas, EPD)." },
          { "@language": "lv", "@value": "Apstiprinājums, ka produkts atbilst noteikta standarta vai regulas prasībām (piem., CE marķējums, EPD)." },
          { "@language": "mt", "@value": "Konferma li l-prodott jissodisfa r-rekwiżiti ta' standard jew regolament speċifiku (eż., Marka CE, EPD)." },
          { "@language": "nl", "@value": "Een bevestiging dat het product voldoet aan de eisen van een specifieke norm of regelgeving (bijv. CE-markering, EPD)." },
          { "@language": "pl", "@value": "Potwierdzenie, że produkt spełnia wymagania określonej normy lub przepisu (np. oznakowanie CE, EPD)." },
          { "@language": "pt", "@value": "Uma confirmação de que o produto atende aos requisitos de uma norma ou regulamento específico (por exemplo, marcação CE, EPD)." },
          { "@language": "ro", "@value": "O confirmare a faptului că produsul îndeplinește cerințele unui anumit standard sau regulament (de ex., Marcajul CE, EPD)." },
          { "@language": "sk", "@value": "Potvrdenie, že výrobok spĺňa požiadavky špecifickej normy alebo predpisu (napr. označenie CE, EPD)." },
          { "@language": "sl", "@value": "Potrditev, da izdelek izpolnjuje zahteve določenega standarda ali predpisa (npr. oznaka CE, EPD)." },
          { "@language": "sv", "@value": "En bekräftelse på att produkten uppfyller kraven i en specifik standard eller förordning (t.ex. CE-märkning, EPD)." }
        ],
        "rdfs:subClassOf": { "@id": "dppk:RelatedResource" },
        "owl:equivalentClass": [
          { "@id": "schema:Certification" },
          { "@id": "gs1:CertificationDetails" },
          { "@id": "unece:certificationEvidenceDocument" }
        ]
    },

    {
        "@id": "dppk:Packaging",
        "@type": "rdfs:Class",
        "rdfs:label": [
          { "@language": "en", "@value": "Packaging" },
          { "@language": "bg", "@value": "Опаковка" },
          { "@language": "cs", "@value": "Obal" },
          { "@language": "da", "@value": "Emballage" },
          { "@language": "de", "@value": "Verpackung" },
          { "@language": "el", "@value": "Συσκευασία" },
          { "@language": "es", "@value": "Embalaje" },
          { "@language": "et", "@value": "Pakend" },
          { "@language": "fi", "@value": "Pakkaus" },
          { "@language": "fr", "@value": "Emballage" },
          { "@language": "ga", "@value": "Pacáistiú" },
          { "@language": "hr", "@value": "Ambalaža" },
          { "@language": "hu", "@value": "Csomagolás" },
          { "@language": "it", "@value": "Imballaggio" },
          { "@language": "lt", "@value": "Pakuotė" },
          { "@language": "lv", "@value": "Iepakojums" },
          { "@language": "mt", "@value": "Imballaġġ" },
          { "@language": "nl", "@value": "Verpakking" },
          { "@language": "pl", "@value": "Opakowanie" },
          { "@language": "pt", "@value": "Embalagem" },
          { "@language": "ro", "@value": "Ambalaj" },
          { "@language": "sk", "@value": "Obal" },
          { "@language": "sl", "@value": "Embalaža" },
          { "@language": "sv", "@value": "Förpackning" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Information about the materials and properties of the product's packaging." },
          { "@language": "bg", "@value": "Информация за материалите и свойствата на опаковката на продукта." },
          { "@language": "cs", "@value": "Informace o materiálech a vlastnostech obalu produktu." },
          { "@language": "da", "@value": "Information om materialer og egenskaber ved produktets emballage." },
          { "@language": "de", "@value": "Informationen über die Materialien und Eigenschaften der Produktverpackung." },
          { "@language": "el", "@value": "Πληροφορίες σχετικά με τα υλικά και τις ιδιότητες της συσκευασίας του προϊόντος." },
          { "@language": "es", "@value": "Información sobre los materiales y propiedades del embalaje del producto." },
          { "@language": "et", "@value": "Teave toote pakendi materjalide ja omaduste kohta." },
          { "@language": "fi", "@value": "Tietoja tuotteen pakkauksen materiaaleista ja ominaisuuksista." },
          { "@language": "fr", "@value": "Informations sur les matériaux et les propriétés de l'emballage du produit." },
          { "@language": "ga", "@value": "Faisnéis faoi ábhair agus airíonna phacáistiú an táirge." },
          { "@language": "hr", "@value": "Informacije o materijalima i svojstvima ambalaže proizvoda." },
          { "@language": "hu", "@value": "Információ a termék csomagolásának anyagairól és tulajdonságairól." },
          { "@language": "it", "@value": "Informazioni sui materiali e sulle proprietà dell'imballaggio del prodotto." },
          { "@language": "lt", "@value": "Informacija apie gaminio pakuotės medžiagas ir savybes." },
          { "@language": "lv", "@value": "Informācija par produkta iepakojuma materiāliem un īpašībām." },
          { "@language": "mt", "@value": "Informazzjoni dwar il-materjali u l-proprjetajiet tal-imballaġġ tal-prodott." },
          { "@language": "nl", "@value": "Informatie over de materialen en eigenschappen van de verpakking van het product." },
          { "@language": "pl", "@value": "Informacje o materiałach i właściwościach opakowania produktu." },
          { "@language": "pt", "@value": "Informações sobre os materiais e propriedades da embalagem do produto." },
          { "@language": "ro", "@value": "Informații despre materialele și proprietățile ambalajului produsului." },
          { "@language": "sk", "@value": "Informácie o materiáloch a vlastnostiach obalu produktu." },
          { "@language": "sl", "@value": "Informacije o materialih in lastnostih embalaže izdelka." },
          { "@language": "sv", "@value": "Information om material och egenskaper hos produktens förpackning." }
        ],
        "owl:equivalentClass": [
            { "@id": "gs1:PackagingMaterialDetails" }
        ]
    },
    {
        "@id": "dppk:ProductionStep",
        "@type": "rdfs:Class",
        "rdfs:label": [
          { "@language": "en", "@value": "Production Step" },
          { "@language": "bg", "@value": "Производствена стъпка" },
          { "@language": "cs", "@value": "Výrobní krok" },
          { "@language": "da", "@value": "Produktionstrin" },
          { "@language": "de", "@value": "Produktionsschritt" },
          { "@language": "el", "@value": "Στάδιο παραγωγής" },
          { "@language": "es", "@value": "Paso de producción" },
          { "@language": "et", "@value": "Tootmissamm" },
          { "@language": "fi", "@value": "Tuotantovaihe" },
          { "@language": "fr", "@value": "Étape de production" },
          { "@language": "ga", "@value": "Céim Táirgthe" },
          { "@language": "hr", "@value": "Proizvodni korak" },
          { "@language": "hu", "@value": "Gyártási lépés" },
          { "@language": "it", "@value": "Fase di produzione" },
          { "@language": "lt", "@value": "Gamybos etapas" },
          { "@language": "lv", "@value": "Ražošanas posms" },
          { "@language": "mt", "@value": "Pass tal-Produzzjoni" },
          { "@language": "nl", "@value": "Productiestap" },
          { "@language": "pl", "@value": "Krok produkcji" },
          { "@language": "pt", "@value": "Etapa de produção" },
          { "@language": "ro", "@value": "Etapă de producție" },
          { "@language": "sk", "@value": "Výrobný krok" },
          { "@language": "sl", "@value": "Proizvodni korak" },
          { "@language": "sv", "@value": "Produktionssteg" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "A significant step in the manufacturing or processing chain of the product, including its location." },
          { "@language": "bg", "@value": "Значителна стъпка в производствената или преработвателната верига на продукта, включително неговото местоположение." },
          { "@language": "cs", "@value": "Významný krok ve výrobním nebo zpracovatelském řetězci produktu, včetně jeho umístění." },
          { "@language": "da", "@value": "Et væsentligt trin i produktions- eller forarbejdningskæden for produktet, herunder dets placering." },
          { "@language": "de", "@value": "Ein wichtiger Schritt in der Herstellungs- oder Verarbeitungskette des Produkts, einschließlich des Standorts." },
          { "@language": "el", "@value": "Σημαντικό στάδιο στην αλυσίδα κατασκευής ή επεξεργασίας του προϊόντος, συμπεριλαμβανομένης της τοποθεσίας του." },
          { "@language": "es", "@value": "Un paso significativo en la cadena de fabricación o procesamiento del producto, incluida su ubicación." },
          { "@language": "et", "@value": "Oluline samm toote tootmis- või töötlemisahelas, sealhulgas selle asukoht." },
          { "@language": "fi", "@value": "Merkittävä vaihe tuotteen valmistus- tai jalostusketjussa, mukaan lukien sen sijainti." },
          { "@language": "fr", "@value": "Une étape importante dans la chaîne de fabrication ou de transformation du produit, y compris son emplacement." },
          { "@language": "ga", "@value": "Céim shuntasach i slabhra déantúsaíochta nó próiseála an táirge, lena n-áirítear a shuíomh." },
          { "@language": "hr", "@value": "Značajan korak u proizvodnom lancu ili lancu obrade proizvoda, uključujući njegovu lokaciju." },
          { "@language": "hu", "@value": "Jelentős lépés a termék gyártási vagy feldolgozási láncában, beleértve a helyszínét is." },
          { "@language": "it", "@value": "Una fase significativa nella catena di produzione o trasformazione del prodotto, compresa la sua ubicazione." },
          { "@language": "lt", "@value": "Reikšmingas gaminio gamybos ar perdirbimo grandinės etapas, įskaitant jo vietą." },
          { "@language": "lv", "@value": "Būtisks posms produkta ražošanas vai apstrādes ķēdē, tostarp tā atrašanās vieta." },
          { "@language": "mt", "@value": "Pass sinifikanti fil-katina tal-manifattura jew tal-ipproċessar tal-prodott, inkluż il-post tiegħu." },
          { "@language": "nl", "@value": "Een belangrijke stap in de productie- of verwerkingsketen van het product, inclusief de locatie." },
          { "@language": "pl", "@value": "Istotny krok w łańcuchu produkcyjnym lub przetwórczym produktu, w tym jego lokalizacja." },
          { "@language": "pt", "@value": "Uma etapa significativa na cadeia de fabricação ou processamento do produto, incluindo sua localização." },
          { "@language": "ro", "@value": "Un pas semnificativ în lanțul de fabricație sau de procesare a produsului, inclusiv locația acestuia." },
          { "@language": "sk", "@value": "Významný krok vo výrobnom alebo spracovateľskom reťazci produktu, vrátane jeho umiestnenia." },
          { "@language": "sl", "@value": "Pomemben korak v proizvodni ali predelovalni verigi izdelka, vključno z njegovo lokacijo." },
          { "@language": "sv", "@value": "Ett betydande steg i produktens tillverknings- eller bearbetningskedja, inklusive dess plats." }
        ]
    },

