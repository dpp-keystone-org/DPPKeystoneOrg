    {
        "@id": "dppk:packagingSubstanceOfConcern",
        "@type": "owl:DatatypeProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Packaging Substance of Concern Present" },
          { "@language": "bg", "@value": "Наличие на вещество, пораждащо безпокойство, в опаковката" },
          { "@language": "cs", "@value": "Přítomnost látky vzbuzující obavy v obalu" },
          { "@language": "da", "@value": "Problematisk stof til stede i emballage" },
          { "@language": "de", "@value": "Vorhandensein besorgniserregender Stoffe in der Verpackung" },
          { "@language": "el", "@value": "Παρουσία ουσίας που προκαλεί ανησυχία στη συσκευασία" },
          { "@language": "es", "@value": "Presencia de sustancias preocupantes en el embalaje" },
          { "@language": "et", "@value": "Murettekitava aine esinemine pakendis" },
          { "@language": "fi", "@value": "Pakkauksessa on huolta aiheuttavia aineita" },
          { "@language": "fr", "@value": "Présence de substances extrêmement préoccupantes dans l'emballage" },
          { "@language": "ga", "@value": "Substaint is Ábhar Imní i Láthair sa Phacáistiú" },
          { "@language": "hr", "@value": "Prisutnost zabrinjavajuće tvari u ambalaži" },
          { "@language": "hu", "@value": "Különös aggodalomra okot adó anyag jelenléte a csomagolásban" },
          { "@language": "it", "@value": "Presenza di sostanze estremamente problematiche nell'imballaggio" },
          { "@language": "lt", "@value": "Pakuotėje yra didelį susirūpinimą keliančios medžiagos" },
          { "@language": "lv", "@value": "Iepakojumā ir viela, kas rada bažas" },
          { "@language": "mt", "@value": "Preżenza ta' Sustanza ta' Tħassib fl-Imballaġġ" },
          { "@language": "nl", "@value": "Aanwezigheid van zeer zorgwekkende stof in verpakking" },
          { "@language": "pl", "@value": "Obecność substancji wzbudzającej obawy w opakowaniu" },
          { "@language": "pt", "@value": "Presença de substância que suscita preocupação na embalagem" },
          { "@language": "ro", "@value": "Prezența unei substanțe care prezintă motive de îngrijorare în ambalaj" },
          { "@language": "sk", "@value": "Prítomnosť látky vzbudzujúcej obavy v obale" },
          { "@language": "sl", "@value": "Prisotnost snovi, ki vzbuja skrb, v embalaži" },
          { "@language": "sv", "@value": "Förekomst av särskilt farligt ämne i förpackning" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Indicates if any substances of concern are present in the packaging." },
          { "@language": "bg", "@value": "Посочва дали в опаковката има вещества, пораждащи безпокойство." },
          { "@language": "cs", "@value": "Označuje, zda jsou v obalu přítomny nějaké látky vzbuzující obavy." },
          { "@language": "da", "@value": "Angiver, om der er problematiske stoffer til stede i emballagen." },
          { "@language": "de", "@value": "Gibt an, ob in der Verpackung besorgniserregende Stoffe vorhanden sind." },
          { "@language": "el", "@value": "Υποδεικνύει εάν υπάρχουν ουσίες που προκαλούν ανησυχία στη συσκευασία." },
          { "@language": "es", "@value": "Indica si hay sustancias preocupantes presentes en el embalaje." },
          { "@language": "et", "@value": "Näitab, kas pakendis on murettekitavaid aineid." },
          { "@language": "fi", "@value": "Osoittaa, onko pakkauksessa huolta aiheuttavia aineita." },
          { "@language": "fr", "@value": "Indique si des substances extrêmement préoccupantes sont présentes dans l'emballage." },
          { "@language": "ga", "@value": "Léiríonn sé an bhfuil aon substaintí is ábhar imní i láthair sa phacáistiú." },
          { "@language": "hr", "@value": "Označava jesu li u ambalaži prisutne zabrinjavajuće tvari." },
          { "@language": "hu", "@value": "Jelzi, hogy vannak-e különös aggodalomra okot adó anyagok a csomagolásban." },
          { "@language": "it", "@value": "Indica se nell'imballaggio sono presenti sostanze estremamente problematiche." },
          { "@language": "lt", "@value": "Nurodo, ar pakuotėje yra didelį susirūpinimą keliančių medžiagų." },
          { "@language": "lv", "@value": "Norāda, vai iepakojumā ir vielas, kas rada bažas." },
          { "@language": "mt", "@value": "Jindika jekk hemmx xi sustanzi ta' tħassib fl-imballaġġ." },
          { "@language": "nl", "@value": "Geeft aan of er zeer zorgwekkende stoffen aanwezig zijn in de verpakking." },
          { "@language": "pl", "@value": "Wskazuje, czy w opakowaniu obecne są jakiekolwiek substancje wzbudzające obawy." },
          { "@language": "pt", "@value": "Indica se existem substâncias que suscitam preocupação presentes na embalagem." },
          { "@language": "ro", "@value": "Indică dacă există substanțe care prezintă motive de îngrijorare în ambalaj." },
          { "@language": "sk", "@value": "Označuje, či sú v obale prítomné nejaké látky vzbudzujúce obavy." },
          { "@language": "sl", "@value": "Označuje, ali so v embalaži prisotne snovi, ki vzbujajo skrb." },
          { "@language": "sv", "@value": "Anger om det finns några särskilt farliga ämnen i förpackningen." }
        ],
        "rdfs:domain": { "@id": "dppk:Packaging" }
    },


