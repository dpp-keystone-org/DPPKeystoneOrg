          { "@language": "mt", "@value": "Tip ta' Proċess ta' Riċiklaġġ tal-Imballaġġ" },
          { "@language": "nl", "@value": "Type verpakkingsrecyclingproces" },
          { "@language": "pl", "@value": "Rodzaj procesu recyklingu opakowań" },
          { "@language": "pt", "@value": "Tipo de processo de reciclagem de embalagens" },
          { "@language": "ro", "@value": "Tipul procesului de reciclare a ambalajului" },
          { "@language": "sk", "@value": "Typ procesu recyklácie obalu" },
          { "@language": "sl", "@value": "Vrsta procesa recikliranja embalaže" },
          { "@language": "sv", "@value": "Typ av återvinningsprocess för förpackning" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Indicates if the packaging is RECYCLABLE, REUSABLE, or COMPOSTABLE." },
          { "@language": "bg", "@value": "Посочва дали опаковката е РЕЦИКЛИРУЕМА, ЗА МНОГОКРАТНА УПОТРЕБА или КОМПОСТИРУЕМА." },
          { "@language": "cs", "@value": "Označuje, zda je obal RECYKLOVATELNÝ, ZNOVU POUŽITELNÝ nebo KOMPOSTOVATELNÝ." },
          { "@language": "da", "@value": "Angiver, om emballagen er GENANVENDELIG, GENBRUGELIG eller KOMPOSTERBAR." },
          { "@language": "de", "@value": "Gibt an, ob die Verpackung RECYCELBAR, WIEDERVERWENDBAR oder KOMPOSTIERBAR ist." },
          { "@language": "el", "@value": "Υποδεικνύει εάν η συσκευασία είναι ΑΝΑΚΥΚΛΩΣΙΜΗ, ΕΠΑΝΑΧΡΗΣΙΜΟΠΟΙΗΣΙΜΗ ή ΚΟΜΠΟΣΤΟΠΟΙΗΣΙΜΗ." },
          { "@language": "es", "@value": "Indica si el embalaje es RECICLABLE, REUTILIZABLE o COMPOSTABLE." },
          { "@language": "et", "@value": "Näitab, kas pakend on RINGLUSSEVÕETAV, KORDUSKASUTATAV või KOMPOSTITAV." },
          { "@language": "fi", "@value": "Osoittaa, onko pakkaus KIERRÄTETTÄVÄ, UUDELLEENKÄYTETTÄVÄ vai KOMPOSTOITAVA." },
          { "@language": "fr", "@value": "Indique si l'emballage est RECYCLABLE, RÉUTILISABLE ou COMPOSTABLE." },
          { "@language": "ga", "@value": "Léiríonn sé an bhfuil an pacáistiú IN-ATHCHÚRSÁILTE, IN-ATHÚSÁIDTE nó INMHÚIRÍNITHE." },
          { "@language": "hr", "@value": "Označava je li ambalaža RECIKLAŽNA, ZA VIŠEKRATNU UPOTREBU ili KOMPOSTABILNA." },
          { "@language": "hu", "@value": "Jelzi, hogy a csomagolás ÚJRAHASZNOSÍTHATÓ, ÚJRAFELHASZNÁLHATÓ vagy KOMPOSZTÁLHATÓ-e." },
          { "@language": "it", "@value": "Indica se l'imballaggio è RICICLABILE, RIUTILIZZABILE o COMPOSTABILE." },
          { "@language": "lt", "@value": "Nurodo, ar pakuotė yra PERDIRBAMA, DAUGKARTINIO NAUDOJIMO ar KOMPOSTUOJAMA." },
          { "@language": "lv", "@value": "Norāda, vai iepakojums ir PĀRSTRĀDĀJAMS, ATKĀRTOTI IZMANTOJAMS vai KOMPOSTĒJAMS." },
          { "@language": "mt", "@value": "Jindika jekk l-imballaġġ huwiex RIĊIKLABBLI, JISTA' JINTUŻA MILL-ĠDID, jew JISTA' JIKKOMPOSTA." },
          { "@language": "nl", "@value": "Geeft aan of de verpakking RECYCLEBAAR, HERBRUIKBAAR of COMPOSTEERBAAR is." },
          { "@language": "pl", "@value": "Wskazuje, czy opakowanie nadaje się do RECYKLINGU, PONOWNEGO UŻYCIA lub KOMPOSTOWANIA." },
          { "@language": "pt", "@value": "Indica se a embalagem é RECICLÁVEL, REUTILIZÁVEL ou COMPOSTÁVEL." },
          { "@language": "ro", "@value": "Indică dacă ambalajul este RECICLABIL, REUTILIZABIL sau COMPOSTABIL." },
          { "@language": "sk", "@value": "Označuje, či je obal RECYKLOVATEĽNÝ, ZNOVU POUŽITEĽNÝ alebo KOMPOSTOVATEĽNÝ." },
          { "@language": "sl", "@value": "Označuje, ali je embalažo mogoče RECIKLIRATI, PONOVNO UPORABITI ali KOMPOSTIRATI." },
          { "@language": "sv", "@value": "Anger om förpackningen är ÅTERVINNINGSBAR, ÅTERANVÄNDBAR eller KOMPOSTERBAR." }
        ],
        "rdfs:domain": { "@id": "dppk:Packaging" },
        "owl:equivalentProperty": { "@id": "gs1:packagingRecyclingProcessType" }
    },
