    {
      "@id": "dppk:technicalAssessmentBody",
      "@type": "owl:ObjectProperty",
      "rdfs:label": [
        { "@language": "en", "@value": "Technical Assessment Body (TAB) Details" },
        { "@language": "bg", "@value": "Подробности за органа за техническа оценка (TAB)" },
        { "@language": "cs", "@value": "Podrobnosti o subjektu pro technické posuzování (TAB)" },
