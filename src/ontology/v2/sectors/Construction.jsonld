    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Organization.jsonld" },
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/EPD.jsonld" },
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/RelatedResource.jsonld" },
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/DoPC.jsonld" }
  ],
  "@graph": [
    {
      "@id": "dppk:ConstructionProduct",
      "@type": "rdfs:Class",
      "rdfs:label": [
        { "@language": "en", "@value": "Construction Product" },
        { "@language": "bg", "@value": "Строителен продукт" },
        { "@language": "cs", "@value": "Stavební výrobek" },
        { "@language": "da", "@value": "Byggevare" },
        { "@language": "de", "@value": "Bauprodukt" },
        { "@language": "el", "@value": "Δομικό προϊόν" },
        { "@language": "es", "@value": "Producto de construcción" },
        { "@language": "et", "@value": "Ehitustoode" },
        { "@language": "fi", "@value": "Rakennustuote" },
        { "@language": "fr", "@value": "Produit de construction" },
        { "@language": "ga", "@value": "Táirge Tógála" },
        { "@language": "hr", "@value": "Građevni proizvod" },
        { "@language": "hu", "@value": "Építési termék" },
        { "@language": "it", "@value": "Prodotto da costruzione" },
        { "@language": "lt", "@value": "Statybos produktas" },
        { "@language": "lv", "@value": "Būvizstrādājums" },
        { "@language": "mt", "@value": "Prodott tal-kostruzzjoni" },
        { "@language": "nl", "@value": "Bouwproduct" },
        { "@language": "pl", "@value": "Wyrób budowlany" },
        { "@language": "pt", "@value": "Produto de construção" },
        { "@language": "ro", "@value": "Produs pentru construcții" },
        { "@language": "sk", "@value": "Stavebný výrobok" },
        { "@language": "sl", "@value": "Gradbeni proizvod" },
        { "@language": "sv", "@value": "Byggprodukt" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "Any product or kit which is produced and placed on the market for incorporation in a permanent manner in construction works or parts thereof, as defined by the Construction Products Regulation (CPR)." },
        { "@language": "bg", "@value": "Всякакъв продукт или комплект, който е произведен и пуснат на пазара за трайно влагане в строежи или части от тях, както е определено в Регламента за строителните продукти (CPR)." },
        { "@language": "cs", "@value": "Jakýkoli výrobek nebo sestava, které jsou vyrobeny a uvedeny na trh za účelem trvalého zabudování do stavby nebo její části, jak je definováno v nařízení o stavebních výrobcích (CPR)." },
        { "@language": "da", "@value": "Enhver byggevare eller et sæt af byggevarer, der fremstilles og bringes i omsætning med henblik på at indgå varigt i bygværker eller dele heraf, som defineret i byggevareforordningen (CPR)." },
        { "@language": "de", "@value": "Jedes Produkt oder jeder Bausatz, das bzw. der hergestellt und in Verkehr gebracht wird, um dauerhaft in Bauwerke oder Teile davon eingebaut zu werden, wie in der Bauproduktenverordnung (CPR) definiert." },
        { "@language": "el", "@value": "Κάθε προϊόν ή κιτ που παράγεται και διατίθεται στην αγορά για να ενσωματωθεί με μόνιμο τρόπο σε δομικά έργα ή μέρη αυτών, όπως ορίζεται στον Κανονισμό για τα Δομικά Προϊόντα (CPR)." },
        { "@language": "es", "@value": "Cualquier producto o kit fabricado y comercializado para su incorporación permanente en obras de construcción o partes de las mismas, tal como se define en el Reglamento de Productos de Construcción (CPR)." },
        { "@language": "et", "@value": "Mis tahes toode või komplekt, mis on toodetud ja turule lastud eesmärgiga see püsivalt ehitistesse või nende osadesse paigaldada, nagu on määratletud ehitustoodete määruses (CPR)." },
        { "@language": "fi", "@value": "Mikä tahansa tuote tai sarja, joka on valmistettu ja saatettu markkinoille tarkoituksena asentaa se pysyvästi rakennuskohteisiin tai niiden osiin rakennustuoteasetuksen (CPR) mukaisesti." },
        { "@language": "fr", "@value": "Tout produit ou kit fabriqué et mis sur le marché en vue d'être incorporé de façon permanente dans des ouvrages de construction ou des parties d'ouvrages, tel que défini par le règlement sur les produits de construction (RPC)." },
        { "@language": "ga", "@value": "Aon táirge nó trealamh a tháirgtear agus a chuirtear ar an margadh lena chorprú go buan in oibreacha foirgníochta nó i gcodanna díobh, mar a shainítear sa Rialachán maidir le Táirgí Foirgníochta (CPR)." },
        { "@language": "hr", "@value": "Bilo koji proizvod ili sklop proizveden i stavljen na tržište radi trajne ugradnje u građevine ili njihove dijelove, kako je definirano Uredbom o građevnim proizvodima (CPR)." },
        { "@language": "hu", "@value": "Minden olyan termék vagy készlet, amelyet azért gyártanak és forgalmaznak, hogy tartósan beépítsék építményekbe vagy azok részeibe, az építési termékekről szóló rendelet (CPR) meghatározása szerint." },
        { "@language": "it", "@value": "Qualsiasi prodotto o kit fabbricato e immesso sul mercato per essere incorporato in modo permanente in opere di costruzione o in parti di esse, come definito dal regolamento sui prodotti da costruzione (CPR)." },
        { "@language": "lt", "@value": "Bet koks gaminys ar rinkinys, pagamintas ir pateiktas į rinką siekiant jį nuolatiniam naudojimui įmontuoti į statinius ar jų dalis, kaip apibrėžta Statybos produktų reglamente (CPR)." },
        { "@language": "lv", "@value": "Jebkurš izstrādājums vai komplekts, kas ražots un laists tirgū, lai to pastāvīgi iestrādātu būvēs vai to daļās, kā noteikts Būvizstrādājumu regulā (CPR)." },
        { "@language": "mt", "@value": "Kwalunkwe prodott jew kitt li jkun prodott u mqiegħed fis-suq għal inkorporazzjoni b'mod permanenti f'xogħlijiet ta' kostruzzjoni jew partijiet minnhom, kif definit fir-Regolament dwar il-Prodotti għall-Kostruzzjoni (CPR)." },
        { "@language": "nl", "@value": "Elk product of elke kit die is geproduceerd en in de handel is gebracht om permanent in bouwwerken of delen daarvan te worden verwerkt, zoals gedefinieerd in de bouwproductenverordening (CPR)." },
        { "@language": "pl", "@value": "Każdy wyrób lub zestaw wyprodukowany i wprowadzony do obrotu w celu trwałego wbudowania w obiekty budowlane lub ich części, zgodnie z definicją w rozporządzeniu w sprawie wyrobów budowlanych (CPR)." },
        { "@language": "pt", "@value": "Qualquer produto ou kit fabricado e colocado no mercado para ser incorporado de forma permanente em obras de construção ou partes destas, conforme definido no Regulamento dos Produtos de Construção (CPR)." },
        { "@language": "ro", "@value": "Orice produs sau kit fabricat și introdus pe piață pentru a fi încorporat în mod permanent în construcții sau părți ale acestora, așa cum este definit în Regulamentul privind produsele pentru construcții (CPR)." },
        { "@language": "sk", "@value": "Akýkoľvek výrobok alebo zostava, ktoré sú vyrobené a uvedené na trh s cieľom ich trvalého zabudovania do stavieb alebo ich častí, ako je definované v nariadení o stavebných výrobkoch (CPR)." },
        { "@language": "sl", "@value": "Kateri koli proizvod ali komplet, ki je proizveden in dan na trg z namenom trajne vgradnje v gradbene objekte ali njihove dele, kot je opredeljeno v Uredbi o gradbenih proizvodih (CPR)." },
        { "@language": "sv", "@value": "Varje produkt eller byggsats som tillverkas och släpps ut på marknaden för att varaktigt ingå i byggnadsverk eller delar därav, enligt definitionen i byggproduktförordningen (CPR)." }
      ],
      "dcterms:source": {
        "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32011R0305",
        "rdfs:label": "Regulation (EU) No 305/2011 (Construction Products Regulation - CPR)"
      },
      "rdfs:subClassOf": { "@id": "dppk:Product" }
    },
    {
      "@id": "dppk:DeclarationOfPerformance",
      "@type": "rdfs:Class",
      "rdfs:label": [
        { "@language": "en", "@value": "Declaration of Performance (DoP)" },
        { "@language": "bg", "@value": "Декларация за експлоатационни показатели (DoP)" },
        { "@language": "cs", "@value": "Prohlášení o vlastnostech (DoP)" },
        { "@language": "da", "@value": "Ydeevnedeklaration (DoP)" },
        { "@language": "de", "@value": "Leistungserklärung (DoP)" },
        { "@language": "el", "@value": "Δήλωση Επιδόσεων (DoP)" },
        { "@language": "es", "@value": "Declaración de prestaciones (DoP)" },
        { "@language": "et", "@value": "Toimivusdeklaratsioon (DoP)" },
        { "@language": "fi", "@value": "Suoritustasoilmoitus (DoP)" },
        { "@language": "fr", "@value": "Déclaration des performances (DoP)" },
        { "@language": "ga", "@value": "Dearbhú Feidhmíochta (DoP)" },
        { "@language": "hr", "@value": "Izjava o svojstvima (DoP)" },
        { "@language": "hu", "@value": "Teljesítménynyilatkozat (DoP)" },
        { "@language": "it", "@value": "Dichiarazione di prestazione (DoP)" },
        { "@language": "lt", "@value": "Eksploatacinių savybių deklaracija (DoP)" },
        { "@language": "lv", "@value": "Ekspluatācijas īpašību deklarācija (DoP)" },
        { "@language": "mt", "@value": "Dikjarazzjoni ta' Prestazzjoni (DoP)" },
        { "@language": "nl", "@value": "Prestatieverklaring (DoP)" },
        { "@language": "pl", "@value": "Deklaracja właściwości użytkowych (DoP)" },
        { "@language": "pt", "@value": "Declaração de Desempenho (DoP)" },
        { "@language": "ro", "@value": "Declarația de performanță (DoP)" },
        { "@language": "sk", "@value": "Vyhlásenie o parametroch (DoP)" },
        { "@language": "sl", "@value": "Izjava o lastnostih (DoP)" },
        { "@language": "sv", "@value": "Prestandadeklaration (DoP)" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "A document drawn up by the manufacturer expressing the performance of a construction product in relation to the essential characteristics of that product." },
        { "@language": "bg", "@value": "Документ, изготвен от производителя, изразяващ експлоатационните показатели на строителен продукт във връзка със съществените характеристики на този продукт." },
        { "@language": "cs", "@value": "Dokument vypracovaný výrobcem vyjadřující vlastnosti stavebního výrobku ve vztahu k základním charakteristikám tohoto výrobku." },
        { "@language": "da", "@value": "Et dokument udarbejdet af fabrikanten, der angiver en byggevares ydeevne i relation til dennes væsentlige egenskaber." },
        { "@language": "de", "@value": "Ein vom Hersteller erstelltes Dokument, das die Leistung eines Bauprodukts in Bezug auf die wesentlichen Merkmale dieses Produkts zum Ausdruck bringt." },
        { "@language": "el", "@value": "Έγγραφο που συντάσσεται από τον κατασκευαστή και εκφράζει την επίδοση ενός δομικού προϊόντος σε σχέση με τα ουσιώδη χαρακτηριστικά του εν λόγω προϊόντος." },
        { "@language": "es", "@value": "Documento elaborado por el fabricante que expresa las prestaciones de un producto de construcción en relación con las características esenciales de dicho producto." },
        { "@language": "et", "@value": "Tootja koostatud dokument, mis väljendab ehitustoote toimivust seoses selle toote põhiomadustega." },
        { "@language": "fi", "@value": "Valmistajan laatima asiakirja, joka ilmaisee rakennustuotteen suoritustason suhteessa kyseisen tuotteen perusominaisuuksiin." },
        { "@language": "fr", "@value": "Document établi par le fabricant exprimant les performances d'un produit de construction par rapport aux caractéristiques essentielles de ce produit." },
        { "@language": "ga", "@value": "Doiciméad a tharraingíonn an monaróir suas lena gcuirtear in iúl feidhmíocht táirge foirgníochta maidir le saintréithe bunriachtanacha an táirge sin." },
        { "@language": "hr", "@value": "Dokument koji izrađuje proizvođač, a u kojem se izražavaju svojstva građevnog proizvoda u odnosu na bitne značajke tog proizvoda." },
        { "@language": "hu", "@value": "A gyártó által kiállított dokumentum, amely kifejezi az építési termék teljesítményét annak alapvető jellemzői tekintetében." },
        { "@language": "it", "@value": "Un documento redatto dal fabbricante che esprime le prestazioni di un prodotto da costruzione in relazione alle caratteristiche essenziali di tale prodotto." },
        { "@language": "lt", "@value": "Gamintojo parengtas dokumentas, kuriame nurodomos statybos produkto eksploatacinės savybės, susijusios su esminėmis to produkto charakteristikomis." },
        { "@language": "lv", "@value": "Ražotāja sagatavots dokuments, kurā izteiktas būvizstrādājuma ekspluatācijas īpašības attiecībā uz šā izstrādājuma pamatīpašībām." },
        { "@language": "mt", "@value": "Dokument imfassal mill-manifattur li jesprimi l-prestazzjoni ta' prodott għall-kostruzzjoni b'rabta mal-karatteristiċi essenzjali ta' dak il-prodott." },
        { "@language": "nl", "@value": "Een door de fabrikant opgesteld document waarin de prestaties van een bouwproduct worden uitgedrukt met betrekking tot de essentiële kenmerken van dat product." },
        { "@language": "pl", "@value": "Dokument sporządzony przez producenta, wyrażający właściwości użytkowe wyrobu budowlanego w odniesieniu do jego zasadniczych charakterystyk." },
        { "@language": "pt", "@value": "Um documento elaborado pelo fabricante que expressa o desempenho de um produto de construção em relação às características essenciais desse produto." },
        { "@language": "ro", "@value": "Un document elaborat de producător care exprimă performanța unui produs pentru construcții în raport cu caracteristicile esențiale ale produsului respectiv." },
        { "@language": "sk", "@value": "Dokument vypracovaný výrobcom vyjadrujúci parametre stavebného výrobku vo vzťahu k jeho podstatným vlastnostiam." },
        { "@language": "sl", "@value": "Dokument, ki ga pripravi proizvajalec in izraža lastnosti gradbenega proizvoda v zvezi z bistvenimi značilnostmi tega proizvoda." },
        { "@language": "sv", "@value": "Ett dokument som upprättas av tillverkaren och som anger en byggprodukts prestanda i förhållande till produktens väsentliga egenskaper." }
      ],
      "rdfs:subClassOf": { "@id": "dppk:DigitalDocument" }
    },
    {
      "@id": "dppk:hasDoP",
      "@type": "owl:ObjectProperty",
      "rdfs:label": [
        { "@language": "en", "@value": "Has Declaration of Performance" },
        { "@language": "bg", "@value": "Има декларация за експлоатационни показатели" },
        { "@language": "cs", "@value": "Má prohlášení o vlastnostech" },
        { "@language": "da", "@value": "Har ydeevnedeklaration" },
        { "@language": "de", "@value": "Hat Leistungserklärung" },
        { "@language": "el", "@value": "Διαθέτει Δήλωση Επιδόσεων" },
        { "@language": "es", "@value": "Tiene declaración de prestaciones" },
        { "@language": "et", "@value": "Omab toimivusdeklaratsiooni" },
        { "@language": "fi", "@value": "On suoritustasoilmoitus" },
        { "@language": "fr", "@value": "A une déclaration des performances" },
        { "@language": "ga", "@value": "Tá Dearbhú Feidhmíochta aige" },
        { "@language": "hr", "@value": "Ima izjavu o svojstvima" },
        { "@language": "hu", "@value": "Rendelkezik teljesítménynyilatkozattal" },
