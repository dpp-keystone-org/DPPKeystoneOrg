        { "@language": "it", "@value": "Dettagli dell'organismo di valutazione tecnica (TAB)" },
        { "@language": "lt", "@value": "Techninio vertinimo įstaigos (TAB) duomenys" },
        { "@language": "lv", "@value": "Informācija par tehniskā novērtējuma iestādi (TAB)" },
        { "@language": "mt", "@value": "Dettalji tal-Korp tal-Valutazzjoni Teknika (TAB)" },
        { "@language": "nl", "@value": "Gegevens technische beoordelingsinstantie (TAB)" },
        { "@language": "pl", "@value": "Szczegóły jednostki oceny technicznej (JOT)" },
        { "@language": "pt", "@value": "Detalhes do Organismo de Avaliação Técnica (OET)" },
        { "@language": "ro", "@value": "Detalii organism de evaluare tehnică (TAB)" },
        { "@language": "sk", "@value": "Podrobnosti o orgáne pre technické posudzovanie (TAB)" },
        { "@language": "sl", "@value": "Podrobnosti o organu za tehnično ocenjevanje (TAB)" },
        { "@language": "sv", "@value": "Information om tekniskt bedömningsorgan (TAB)" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "The technical assessment body that independently evaluates a product's technical characteristics" },
        { "@language": "bg", "@value": "Органът за техническа оценка, който независимо оценява техническите характеристики на продукта" },
        { "@language": "cs", "@value": "Subjekt pro technické posuzování, který nezávisle hodnotí technické vlastnosti výrobku" },
        { "@language": "da", "@value": "Det tekniske vurderingsorgan, der uafhængigt evaluerer et produkts tekniske egenskaber" },
        { "@language": "de", "@value": "Die technische Bewertungsstelle, die die technischen Merkmale eines Produkts unabhängig bewertet" },
        { "@language": "el", "@value": "Ο οργανισμός τεχνικής αξιολόγησης που αξιολογεί ανεξάρτητα τα τεχνικά χαρακτηριστικά ενός προϊόντος" },
        { "@language": "es", "@value": "El organismo de evaluación técnica que evalúa de forma independiente las características técnicas de un producto" },
        { "@language": "et", "@value": "Tehnilise hindamise asutus, mis hindab sõltumatult toote tehnilisi omadusi" },
        { "@language": "fi", "@value": "Tekninen arviointilaitos, joka arvioi riippumattomasti tuotteen teknisiä ominaisuuksia" },
        { "@language": "fr", "@value": "L'organisme d'évaluation technique qui évalue de manière indépendante les caractéristiques techniques d'un produit" },
        { "@language": "ga", "@value": "An comhlacht um measúnú teicniúil a dhéanann meastóireacht neamhspleách ar shaintréithe teicniúla táirge" },
        { "@language": "hr", "@value": "Tijelo za tehničko ocjenjivanje koje neovisno ocjenjuje tehničke značajke proizvoda" },
        { "@language": "hu", "@value": "A műszaki értékelő szervezet, amely függetlenül értékeli a termék műszaki jellemzőit" },
        { "@language": "it", "@value": "L'organismo di valutazione tecnica che valuta in modo indipendente le caratteristiche tecniche di un prodotto" },
        { "@language": "lt", "@value": "Techninio vertinimo įstaiga, kuri nepriklausomai vertina produkto technines charakteristikas" },
        { "@language": "lv", "@value": "Tehniskā novērtējuma iestāde, kas neatkarīgi novērtē izstrādājuma tehniskās īpašības" },
        { "@language": "mt", "@value": "Il-korp tal-valutazzjoni teknika li jevalwa b'mod indipendenti l-karatteristiċi tekniċi ta' prodott" },
        { "@language": "nl", "@value": "De technische beoordelingsinstantie die onafhankelijk de technische kenmerken van een product evalueert" },
        { "@language": "pl", "@value": "Jednostka oceny technicznej, która niezależnie ocenia właściwości techniczne wyrobu" },
        { "@language": "pt", "@value": "O organismo de avaliação técnica que avalia de forma independente as características técnicas de um produto" },
        { "@language": "ro", "@value": "Organismul de evaluare tehnică care evaluează independent caracteristicile tehnice ale unui produs" },
        { "@language": "sk", "@value": "Orgán pre technické posudzovanie, ktorý nezávisle hodnotí technické vlastnosti výrobku" },
        { "@language": "sl", "@value": "Organ za tehnično ocenjevanje, ki neodvisno ocenjuje tehnične značilnosti proizvoda" },
        { "@language": "sv", "@value": "Det tekniska bedömningsorganet som oberoende utvärderar en produkts tekniska egenskaper" }
      ],
      "rdfs:domain": { "@id": "dppk:ConstructionProduct" },
      "rdfs:range": { "@id": "dppk:Organization" }
    },
    {
      "@id": "dppk:validationReports",
