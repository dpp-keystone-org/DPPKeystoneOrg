        { "@language": "mt", "@value": "Standard Ewropew Armonizzat (hEN)" },
        { "@language": "nl", "@value": "Geharmoniseerde Europese norm (hEN)" },
        { "@language": "pl", "@value": "Zharmonizowana norma europejska (hEN)" },
        { "@language": "pt", "@value": "Norma Europeia Harmonizada (hEN)" },
        { "@language": "ro", "@value": "Standard european armonizat (hEN)" },
        { "@language": "sk", "@value": "Harmonizovaná európska norma (hEN)" },
        { "@language": "sl", "@value": "Harmonizirani evropski standard (hEN)" },
        { "@language": "sv", "@value": "Harmoniserad europeisk standard (hEN)" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "A reference (URI or identifier) to the applicable Harmonised European Standard (hEN) used for assessing the product." },
        { "@language": "bg", "@value": "Препратка (URI или идентификатор) към приложимия Хармонизиран европейски стандарт (hEN), използван за оценка на продукта." },
        { "@language": "cs", "@value": "Odkaz (URI nebo identifikátor) na příslušnou harmonizovanou evropskou normu (hEN) použitou k posouzení výrobku." },
        { "@language": "da", "@value": "En reference (URI eller identifikator) til den gældende harmoniserede europæiske standard (hEN), der er brugt til at vurdere produktet." },
        { "@language": "de", "@value": "Ein Verweis (URI oder Kennung) auf die anwendbare harmonisierte europäische Norm (hEN), die zur Bewertung des Produkts herangezogen wird." },
        { "@language": "el", "@value": "Αναφορά (URI ή αναγνωριστικό) στο ισχύον Εναρμονισμένο Ευρωπαϊκό Πρότυπο (hEN) που χρησιμοποιείται για την αξιολόγηση του προϊόντος." },
        { "@language": "es", "@value": "Una referencia (URI o identificador) a la norma europea armonizada (hEN) aplicable utilizada para evaluar el producto." },
        { "@language": "et", "@value": "Viide (URI või identifikaator) toote hindamiseks kasutatavale asjakohasele harmoneeritud Euroopa standardile (hEN)." },
        { "@language": "fi", "@value": "Viite (URI tai tunniste) sovellettavaan yhdenmukaistettuun eurooppalaiseen standardiin (hEN), jota käytetään tuotteen arvioinnissa." },
        { "@language": "fr", "@value": "Une référence (URI ou identifiant) à la norme européenne harmonisée (hEN) applicable utilisée pour évaluer le produit." },
        { "@language": "ga", "@value": "Tagairt (URI nó aitheantóir) don Chaighdeán Eorpach Comhchuibhithe (hEN) is infheidhme a úsáidtear chun an táirge a mheasúnú." },
        { "@language": "hr", "@value": "Referenca (URI ili identifikator) na primjenjivu usklađenu europsku normu (hEN) koja se upotrebljava za ocjenjivanje proizvoda." },
        { "@language": "hu", "@value": "Hivatkozás (URI vagy azonosító) a termék értékeléséhez használt vonatkozó harmonizált európai szabványra (hEN)." },
        { "@language": "it", "@value": "Un riferimento (URI o identificatore) alla norma europea armonizzata (hEN) applicabile utilizzata per valutare il prodotto." },
        { "@language": "lt", "@value": "Nuoroda (URI arba identifikatorius) į taikomą darnųjį Europos standartą (hEN), naudojamą produktui vertinti." },
        { "@language": "lv", "@value": "Atsauce (URI vai identifikators) uz piemērojamo saskaņoto Eiropas standartu (hEN), ko izmanto izstrādājuma novērtēšanai." },
        { "@language": "mt", "@value": "Referenza (URI jew identifikatur) għall-Istandard Ewropew Armonizzat (hEN) applikabbli użat għall-valutazzjoni tal-prodott." },
        { "@language": "nl", "@value": "Een referentie (URI of identificatiecode) naar de toepasselijke geharmoniseerde Europese norm (hEN) die is gebruikt voor de beoordeling van het product." },
        { "@language": "pl", "@value": "Odniesienie (URI lub identyfikator) do odpowiedniej zharmonizowanej normy europejskiej (hEN) użytej do oceny wyrobu." },
        { "@language": "pt", "@value": "Uma referência (URI ou identificador) à Norma Europeia Harmonizada (hEN) aplicável utilizada para avaliar o produto." },
        { "@language": "ro", "@value": "O referință (URI sau identificator) la standardul european armonizat (hEN) aplicabil utilizat pentru evaluarea produsului." },
        { "@language": "sk", "@value": "Odkaz (URI alebo identifikátor) na príslušnú harmonizovanú európsku normu (hEN) použitú na posúdenie výrobku." },
        { "@language": "sl", "@value": "Referenca (URI ali identifikator) na veljavni harmonizirani evropski standard (hEN), ki se uporablja za ocenjevanje proizvoda." },
        { "@language": "sv", "@value": "En referens (URI eller identifierare) till den tillämpliga harmoniserade europeiska standarden (hEN) som används för att bedöma produkten." }
      ],
      "rdfs:domain": { "@id": "dppk:ConstructionProduct" },
      "rdfs:range": { "@id": "xsd:anyURI" }
    },
