        { "@language": "pl", "@value": "Odniesienie do raportów walidacyjnych" },
        { "@language": "pt", "@value": "Referência dos relatórios de validação" },
        { "@language": "ro", "@value": "Referință rapoarte de validare" },
        { "@language": "sk", "@value": "Odkaz na validačné správy" },
