        { "@language": "sv", "@value": "Referens till valideringsrapporter" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "Reference to reports validating the performance or conformity of the product." },
        { "@language": "bg", "@value": "Препратка към доклади, валидиращи експлоатационните показатели или съответствието на продукта." },
        { "@language": "cs", "@value": "Odkaz na zprávy potvrzující vlastnosti nebo shodu výrobku." },
        { "@language": "da", "@value": "Reference til rapporter, der validerer produktets ydeevne eller overensstemmelse." },
        { "@language": "de", "@value": "Verweis auf Berichte zur Validierung der Leistung oder Konformität des Produkts." },
        { "@language": "el", "@value": "Αναφορά σε εκθέσεις που επικυρώνουν την επίδοση ή τη συμμόρφωση του προϊόντος." },
        { "@language": "es", "@value": "Referencia a los informes que validan las prestaciones o la conformidad del producto." },
        { "@language": "et", "@value": "Viide aruannetele, mis kinnitavad toote toimivust või vastavust." },
        { "@language": "fi", "@value": "Viittaus raportteihin, joilla vahvistetaan tuotteen suoritustaso tai vaatimustenmukaisuus." },
        { "@language": "fr", "@value": "Référence aux rapports validant les performances ou la conformité du produit." },
        { "@language": "ga", "@value": "Tagairt do thuarascálacha a bhailíochtaíonn feidhmíocht nó comhréireacht an táirge." },
        { "@language": "hr", "@value": "Referenca na izvješća kojima se potvrđuju svojstva ili sukladnost proizvoda." },
        { "@language": "hu", "@value": "Hivatkozás a termék teljesítményét vagy megfelelőségét igazoló jelentésekre." },
        { "@language": "it", "@value": "Riferimento ai rapporti che convalidano le prestazioni o la conformità del prodotto." },
        { "@language": "lt", "@value": "Nuoroda į ataskaitas, patvirtinančias produkto eksploatacines savybes arba atitiktį." },
        { "@language": "lv", "@value": "Atsauce uz ziņojumiem, kuros apstiprinātas izstrādājuma ekspluatācijas īpašības vai atbilstība." },
        { "@language": "mt", "@value": "Referenza għal rapporti li jivalidaw il-prestazzjoni jew il-konformità tal-prodott." },
        { "@language": "nl", "@value": "Referentie naar rapporten die de prestaties of conformiteit van het product valideren." },
        { "@language": "pl", "@value": "Odniesienie do raportów potwierdzających właściwości użytkowe lub zgodność wyrobu." },
        { "@language": "pt", "@value": "Referência aos relatórios que validam o desempenho ou a conformidade do produto." },
        { "@language": "ro", "@value": "Referință la rapoartele care validează performanța sau conformitatea produsului." },
        { "@language": "sk", "@value": "Odkaz na správy potvrdzujúce parametre alebo zhodu výrobku." },
        { "@language": "sl", "@value": "Referenca na poročila, ki potrjujejo lastnosti ali skladnost proizvoda." },
        { "@language": "sv", "@value": "Referens till rapporter som validerar produktens prestanda eller överensstämmelse." }
      ],
      "rdfs:domain": { "@id": "dppk:ConstructionProduct" },
      "rdfs:range": { "@id": "dppk:RelatedResource" }
    },
