        { "@language": "lt", "@value": "Turi eksploatacinių savybių deklaraciją" },
        { "@language": "lv", "@value": "Ir ekspluatācijas īpašību deklarācija" },
        { "@language": "mt", "@value": "Għandu Dikjarazzjoni ta' Prestazzjoni" },
        { "@language": "nl", "@value": "Heeft prestatieverklaring" },
        { "@language": "pl", "@value": "Posiada deklarację właściwości użytkowych" },
        { "@language": "pt", "@value": "Tem Declaração de Desempenho" },
        { "@language": "ro", "@value": "Are declarație de performanță" },
        { "@language": "sk", "@value": "Má vyhlásenie o parametroch" },
        { "@language": "sl", "@value": "Ima izjavo o lastnostih" },
        { "@language": "sv", "@value": "Har prestandadeklaration" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "Relates the construction product to its Declaration of Performance." },
        { "@language": "bg", "@value": "Свързва строителния продукт с неговата Декларация за експлоатационни показатели." },
        { "@language": "cs", "@value": "Spojuje stavební výrobek s jeho prohlášením o vlastnostech." },
        { "@language": "da", "@value": "Relaterer byggevaren til dens ydeevnedeklaration." },
        { "@language": "de", "@value": "Setzt das Bauprodukt in Beziehung zu seiner Leistungserklärung." },
        { "@language": "el", "@value": "Συσχετίζει το δομικό προϊόν με τη Δήλωση Επιδόσεών του." },
        { "@language": "es", "@value": "Relaciona el producto de construcción con su declaración de prestaciones." },
        { "@language": "et", "@value": "Seob ehitustoote selle toimivusdeklaratsiooniga." },
        { "@language": "fi", "@value": "Yhdistää rakennustuotteen sen suoritustasoilmoitukseen." },
        { "@language": "fr", "@value": "Relie le produit de construction à sa déclaration des performances." },
        { "@language": "ga", "@value": "Nascann an táirge foirgníochta lena Dhearbhú Feidhmíochta." },
        { "@language": "hr", "@value": "Povezuje građevni proizvod s njegovom izjavom o svojstvima." },
        { "@language": "hu", "@value": "Összekapcsolja az építési terméket a teljesítménynyilatkozatával." },
        { "@language": "it", "@value": "Mette in relazione il prodotto da costruzione con la sua dichiarazione di prestazione." },
        { "@language": "lt", "@value": "Susieja statybos produktą su jo eksploatacinių savybių deklaracija." },
        { "@language": "lv", "@value": "Saista būvizstrādājumu ar tā ekspluatācijas īpašību deklarāciju." },
        { "@language": "mt", "@value": "Jirrelata l-prodott għall-kostruzzjoni mad-Dikjarazzjoni ta' Prestazzjoni tiegħu." },
        { "@language": "nl", "@value": "Relateert het bouwproduct aan zijn prestatieverklaring." },
        { "@language": "pl", "@value": "Powiązuje wyrób budowlany z jego deklaracją właściwości użytkowych." },
        { "@language": "pt", "@value": "Relaciona o produto de construção com a sua Declaração de Desempenho." },
        { "@language": "ro", "@value": "Relaționează produsul pentru construcții cu declarația sa de performanță." },
        { "@language": "sk", "@value": "Spája stavebný výrobok s jeho vyhlásením o parametroch." },
        { "@language": "sl", "@value": "Povezuje gradbeni proizvod z njegovo izjavo o lastnostih." },
        { "@language": "sv", "@value": "Relaterar byggprodukten till dess prestandadeklaration." }
      ],
      "rdfs:domain": { "@id": "dppk:ConstructionProduct" },
      "rdfs:range": { "@id": "dppk:DeclarationOfPerformance" }
    },
