      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "The EU-recognized notified body that verifies a product's conformance to European regulations" },
        { "@language": "bg", "@value": "Признатият в ЕС нотифициран орган, който проверява съответствието на продукта с европейските регламенти" },
        { "@language": "cs", "@value": "Oznámený subjekt uznaný EU, který ověřuje shodu výrobku s evropskými předpisy" },
        { "@language": "da", "@value": "Det EU-anerkendte bemyndigede organ, der bekræfter et produkts overensstemmelse med europæiske forordninger" },
        { "@language": "de", "@value": "Die EU-anerkannte notifizierte Stelle, die die Konformität eines Produkts mit europäischen Vorschriften überprüft" },
        { "@language": "el", "@value": "Ο αναγνωρισμένος από την ΕΕ κοινοποιημένος οργανισμός που επαληθεύει τη συμμόρφωση ενός προϊόντος με τους ευρωπαϊκούς κανονισμούς" },
        { "@language": "es", "@value": "El organismo notificado reconocido por la UE que verifica la conformidad de un producto con las normativas europeas" },
        { "@language": "et", "@value": "ELi poolt tunnustatud teavitatud asutus, mis kontrollib toote vastavust Euroopa eeskirjadele" },
        { "@language": "fi", "@value": "EU:n tunnustama ilmoitettu laitos, joka varmentaa tuotteen vaatimustenmukaisuuden eurooppalaisten säännösten suhteen" },
        { "@language": "fr", "@value": "L'organisme notifié reconnu par l'UE qui vérifie la conformité d'un produit aux réglementations européennes" },
        { "@language": "ga", "@value": "An comhlacht a dtugtar fógra dó atá aitheanta ag an AE a fhíoraíonn comhréireacht táirge le rialacháin na hEorpa" },
        { "@language": "hr", "@value": "Prijavljeno tijelo priznato u EU-u koje provjerava sukladnost proizvoda s europskim propisima" },
        { "@language": "hu", "@value": "Az EU által elismert bejelentett szervezet, amely ellenőrzi a termék európai előírásoknak való megfelelését" },
        { "@language": "it", "@value": "L'organismo notificato riconosciuto dall'UE che verifica la conformità di un prodotto alle normative europee" },
        { "@language": "lt", "@value": "ES pripažinta notifikuotoji įstaiga, kuri tikrina produkto atitiktį Europos reglamentams" },
        { "@language": "lv", "@value": "ES atzītā paziņotā iestāde, kas pārbauda izstrādājuma atbilstību Eiropas regulām" },
        { "@language": "mt", "@value": "Il-korp notifikat rikonoxxut mill-UE li jivverifika l-konformità ta' prodott mar-regolamenti Ewropej" },
        { "@language": "nl", "@value": "De door de EU erkende aangemelde instantie die controleert of een product voldoet aan de Europese regelgeving" },
        { "@language": "pl", "@value": "Uznana w UE jednostka notyfikowana, która weryfikuje zgodność wyrobu z przepisami europejskimi" },
        { "@language": "pt", "@value": "O organismo notificado reconhecido pela UE que verifica a conformidade de um produto com os regulamentos europeus" },
        { "@language": "ro", "@value": "Organismul notificat recunoscut de UE care verifică conformitatea unui produs cu reglementările europene" },
        { "@language": "sk", "@value": "Notifikovaná osoba uznaná EÚ, ktorá overuje zhodu výrobku s európskymi predpismi" },
        { "@language": "sl", "@value": "Priglašeni organ, priznan v EU, ki preverja skladnost proizvoda z evropskimi predpisi" },
        { "@language": "sv", "@value": "Det EU-erkända anmälda organet som verifierar en produkts överensstämmelse med europeiska förordningar" }
      ],
