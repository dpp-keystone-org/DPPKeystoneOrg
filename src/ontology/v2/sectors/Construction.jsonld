      "rdfs:comment": [
        { "@language": "en", "@value": "The system for Assessment and Verification of Constancy of Performance (e.g., System 1, 1+, 2+, 3, 4)." },
        { "@language": "bg", "@value": "Системата за оценяване и проверка на постоянството на експлоатационните показатели (напр. Система 1, 1+, 2+, 3, 4)." },
        { "@language": "cs", "@value": "Systém posuzování a ověřování stálosti vlastností (např. systém 1, 1+, 2+, 3, 4)." },
        { "@language": "da", "@value": "Systemet til vurdering og kontrol af ydeevnens konstans (f.eks. system 1, 1+, 2+, 3, 4)." },
        { "@language": "de", "@value": "Das System zur Bewertung und Überprüfung der Leistungsbeständigkeit (z. B. System 1, 1+, 2+, 3, 4)." },
        { "@language": "el", "@value": "Το σύστημα αξιολόγησης και επαλήθευσης της σταθερότητας της επίδοσης (π.χ. Σύστημα 1, 1+, 2+, 3, 4)." },
        { "@language": "es", "@value": "El sistema de evaluación y verificación de la constancia de las prestaciones (por ejemplo, Sistema 1, 1+, 2+, 3, 4)." },
        { "@language": "et", "@value": "Toimivuse püsivuse hindamise ja kontrollimise süsteem (nt süsteem 1, 1+, 2+, 3, 4)." },
        { "@language": "fi", "@value": "Suoritustason pysyvyyden arviointi- ja varmennusjärjestelmä (esim. järjestelmä 1, 1+, 2+, 3, 4)." },
        { "@language": "fr", "@value": "Le système d'évaluation et de vérification de la constance des performances (par exemple, Système 1, 1+, 2+, 3, 4)." },
        { "@language": "ga", "@value": "An córas um Measúnú agus Fíorú ar Sheasmhacht Feidhmíochta (e.g., Córas 1, 1+, 2+, 3, 4)." },
        { "@language": "hr", "@value": "Sustav ocjenjivanja i provjere stalnosti svojstava (npr. sustav 1, 1+, 2+, 3, 4)." },
        { "@language": "hu", "@value": "A teljesítmény állandóságának értékelésére és ellenőrzésére szolgáló rendszer (pl. 1., 1+., 2+., 3., 4. rendszer)." },
        { "@language": "it", "@value": "Il sistema per la valutazione e la verifica della costanza della prestazione (es. Sistema 1, 1+, 2+, 3, 4)." },
        { "@language": "lt", "@value": "Eksploatacinių savybių pastovumo vertinimo ir tikrinimo sistema (pvz., 1, 1+, 2+, 3, 4 sistema)." },
        { "@language": "lv", "@value": "Ekspluatācijas īpašību noturības novērtējuma un pārbaudes sistēma (piem., 1., 1.+, 2.+, 3., 4. sistēma)." },
        { "@language": "mt", "@value": "Is-sistema għall-Valutazzjoni u l-Verifika tal-Kostanza tal-Prestazzjoni (eż., Sistema 1, 1+, 2+, 3, 4)." },
        { "@language": "nl", "@value": "Het systeem voor beoordeling en verificatie van de prestatiebestendigheid (bijv. systeem 1, 1+, 2+, 3, 4)." },
        { "@language": "pl", "@value": "System oceny i weryfikacji stałości właściwości użytkowych (np. system 1, 1+, 2+, 3, 4)." },
        { "@language": "pt", "@value": "O sistema de Avaliação e Verificação da Regularidade do Desempenho (por exemplo, Sistema 1, 1+, 2+, 3, 4)." },
        { "@language": "ro", "@value": "Sistemul de evaluare și verificare a constanței performanței (de ex., Sistemul 1, 1+, 2+, 3, 4)." },
        { "@language": "sk", "@value": "Systém posudzovania a overovania nemennosti parametrov (napr. systém 1, 1+, 2+, 3, 4)." },
        { "@language": "sl", "@value": "Sistem ocenjevanja in preverjanja nespremenljivosti lastnosti (npr. sistem 1, 1+, 2+, 3, 4)." },
        { "@language": "sv", "@value": "Systemet för bedömning och fortlöpande kontroll av prestanda (t.ex. system 1, 1+, 2+, 3, 4)." }
