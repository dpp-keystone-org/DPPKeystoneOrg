  "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/sectors/Construction",
  "@type": "owl:Ontology",
  "dcterms:title": [
    { "@language": "en", "@value": "DPP Sector Ontology - Construction and Heavy Industry Definitions ({{VERSION}})" },
    { "@language": "bg", "@value": "Онтология на сектора на DPP - Определения за строителството и тежката промишленост ({{VERSION}})" },
    { "@language": "cs", "@value": "Ontologie odvětví DPP - Definice stavebnictví a těžkého průmyslu ({{VERSION}})" },
    { "@language": "da", "@value": "DPP-sektorontologi - Definitioner for bygge- og tungindustri ({{VERSION}})" },
    { "@language": "de", "@value": "DPP-Sektor-Ontologie - Definitionen für Baugewerbe und Schwerindustrie ({{VERSION}})" },
    { "@language": "el", "@value": "Οντολογία Τομέα DPP - Ορισμοί Κατασκευών και Βαριάς Βιομηχανίας ({{VERSION}})" },
    { "@language": "es", "@value": "Ontología del Sector DPP - Definiciones de construcción e industria pesada ({{VERSION}})" },
    { "@language": "et", "@value": "DPP sektori ontoloogia - Ehituse ja rasketööstuse definitsioonid ({{VERSION}})" },
    { "@language": "fi", "@value": "DPP-sektoriontologia - Rakentamisen ja raskaan teollisuuden määritelmät ({{VERSION}})" },
    { "@language": "fr", "@value": "Ontologie sectorielle DPP - Définitions de la construction et de l'industrie lourde ({{VERSION}})" },
    { "@language": "ga", "@value": "Ointeolaíocht Earnála DPP - Sainmhínithe ar Fhoirgníocht agus ar Thionscal Trom ({{VERSION}})" },
    { "@language": "hr", "@value": "Ontologija sektora DPP - Definicije građevinarstva i teške industrije ({{VERSION}})" },
    { "@language": "hu", "@value": "DPP ágazati ontológia - Építőipari és nehézipari fogalmak ({{VERSION}})" },
    { "@language": "it", "@value": "Ontologia del settore DPP - Definizioni per l'edilizia e l'industria pesante ({{VERSION}})" },
    { "@language": "lt", "@value": "DPP sektoriaus ontologija - Statybos ir sunkiosios pramonės apibrėžimai ({{VERSION}})" },
    { "@language": "lv", "@value": "DPP nozares ontoloģija - Būvniecības un smagās rūpniecības definīcijas ({{VERSION}})" },
    { "@language": "mt", "@value": "Ontoloġija tas-Settur DPP - Definizzjonijiet tal-Kostruzzjoni u l-Industrija Tqila ({{VERSION}})" },
    { "@language": "nl", "@value": "DPP Sectorontologie - Definities voor bouw en zware industrie ({{VERSION}})" },
    { "@language": "pl", "@value": "Ontologia sektora DPP - Definicje dotyczące budownictwa i przemysłu ciężkiego ({{VERSION}})" },
    { "@language": "pt", "@value": "Ontologia do Setor DPP - Definições de Construção e Indústria Pesada ({{VERSION}})" },
    { "@language": "ro", "@value": "Ontologia sectorului DPP - Definiții pentru construcții și industria grea ({{VERSION}})" },
    { "@language": "sk", "@value": "Ontológia sektora DPP - Definície stavebníctva a ťažkého priemyslu ({{VERSION}})" },
    { "@language": "sl", "@value": "Sektorska ontologija DPP - Definicije gradbeništva in težke industrije ({{VERSION}})" },
    { "@language": "sv", "@value": "DPP-sektorontologi - Definitioner för bygg- och tung industri ({{VERSION}})" }
  ],
  "dcterms:description": [
    { "@language": "en", "@value": "Defines concepts for Construction Products (aligning with CPR) and related heavy industries such as steel and rail." },
    { "@language": "bg", "@value": "Определя концепции за строителни продукти (в съответствие с CPR) и свързаните с тях тежки индустрии като стомана и железопътен транспорт." },
    { "@language": "cs", "@value": "Definuje koncepty pro stavební výrobky (v souladu s CPR) a související odvětví těžkého průmyslu, jako je ocel a železnice." },
    { "@language": "da", "@value": "Definerer koncepter for byggevarer (i overensstemmelse med CPR) og relaterede tunge industrier såsom stål og jernbane." },
    { "@language": "de", "@value": "Definiert Konzepte für Bauprodukte (in Übereinstimmung mit der CPR) und verwandte Schwerindustrien wie Stahl und Eisenbahn." },
    { "@language": "el", "@value": "Καθορίζει έννοιες για δομικά προϊόντα (σε ευθυγράμμιση με τον CPR) και συναφείς βαριές βιομηχανίες, όπως ο χάλυβας και οι σιδηρόδρομοι." },
    { "@language": "es", "@value": "Define conceptos para productos de construcción (en línea con el CPR) y las industrias pesadas relacionadas, como el acero y el ferrocarril." },
    { "@language": "et", "@value": "Määratleb ehitustoodete (kooskõlas CPR-iga) ja nendega seotud rasketööstuse (nagu teras ja raudtee) kontseptsioonid." },
    { "@language": "fi", "@value": "Määrittää käsitteitä rakennustuotteille (CPR:n mukaisesti) ja niihin liittyville raskaille teollisuudenaloille, kuten teräs- ja rautatieteollisuudelle." },
    { "@language": "fr", "@value": "Définit des concepts pour les produits de construction (en s'alignant sur le CPR) et les industries lourdes connexes telles que l'acier et le rail." },
    { "@language": "ga", "@value": "Sainmhínítear coincheapa do Tháirgí Foirgníochta (ag ailíniú le CPR) agus tionscail throma gaolmhara mar chruach agus iarnród." },
    { "@language": "hr", "@value": "Definira koncepte za građevne proizvode (u skladu s CPR-om) i povezane teške industrije kao što su industrija čelika i željeznice." },
    { "@language": "hu", "@value": "Fogalmakat határoz meg az építési termékek (a CPR-hez igazodva) és a kapcsolódó nehéziparok, például az acél és a vasút tekintetében." },
    { "@language": "it", "@value": "Definisce concetti per i prodotti da costruzione (in linea con il CPR) e le relative industrie pesanti come l'acciaio e le ferrovie." },
    { "@language": "lt", "@value": "Apibrėžia statybos produktų (suderintų su CPR) ir susijusių sunkiosios pramonės šakų, tokių kaip plienas ir geležinkeliai, sąvokas." },
    { "@language": "lv", "@value": "Nosaka būvizstrādājumu (saskaņā ar CPR) un saistīto smagās rūpniecības nozaru, piemēram, tērauda un dzelzceļa, jēdzienus." },
    { "@language": "mt", "@value": "Jiddefinixxi kunċetti għall-Prodotti tal-Kostruzzjoni (b'allinjament mas-CPR) u industriji tqal relatati bħall-azzar u l-ferroviji." },
    { "@language": "nl", "@value": "Definieert concepten voor bouwproducten (in overeenstemming met de CPR) en gerelateerde zware industrieën zoals staal en spoorwegen." },
    { "@language": "pl", "@value": "Definiuje pojęcia dotyczące wyrobów budowlanych (zgodnie z CPR) i powiązanych gałęzi przemysłu ciężkiego, takich jak stal i kolej." },
    { "@language": "pt", "@value": "Define conceitos para produtos de construção (em alinhamento com o CPR) e indústrias pesadas relacionadas, como o aço e o caminho-de-ferro." },
    { "@language": "ro", "@value": "Definește concepte pentru produsele pentru construcții (în conformitate cu CPR) și industriile grele conexe, cum ar fi oțelul și căile ferate." },
    { "@language": "sk", "@value": "Definuje koncepty pre stavebné výrobky (v súlade s CPR) a súvisiace odvetvia ťažkého priemyslu, ako je ocel a železnice." },
    { "@language": "sl", "@value": "Določa koncepte za gradbene proizvode (v skladu s CPR) in povezane težke industrije, kot sta jeklo in železnice." },
    { "@language": "sv", "@value": "Definierar koncept för byggprodukter (i linje med CPR) och relaterade tunga industrier som stål och järnväg." }
  ],
  "owl:versionInfo": "1.0.0",
  "owl:imports": [
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Product.jsonld" },
