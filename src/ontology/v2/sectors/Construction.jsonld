        { "@language": "es", "@value": "La clasificación del acero en función de su composición y propiedades físicas (por ejemplo, R260, S355)." },
        { "@language": "et", "@value": "Terase klassifikatsioon selle koostise ja füüsikaliste omaduste põhjal (nt R260, S355)." },
        { "@language": "fi", "@value": "Teräksen luokitus sen koostumuksen ja fysikaalisten ominaisuuksien perusteella (esim. R260, S355)." },
        { "@language": "fr", "@value": "La classification de l'acier en fonction de sa composition et de ses propriétés physiques (par exemple, R260, S355)." },
        { "@language": "ga", "@value": "Aicmiú na cruach bunaithe ar a comhdhéanamh agus ar a hairíonna fisiceacha (e.g., R260, S355)." },
