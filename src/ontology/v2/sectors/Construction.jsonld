        { "@language": "nl", "@value": "Druksterkte" },
        { "@language": "pl", "@value": "Wytrzymałość na ściskanie" },
        { "@language": "pt", "@value": "Resistência à compressão" },
        { "@language": "ro", "@value": "Rezistență la compresiune" },
        { "@language": "sk", "@value": "Pevnosť v tlaku" },
        { "@language": "sl", "@value": "Tlačna trdnost" },
        { "@language": "sv", "@value": "Tryckhållfasthet" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "The capacity of a material or structure to withstand loads tending to reduce size." },
        { "@language": "bg", "@value": "Способността на материал или конструкция да издържа на натоварвания, които имат за цел да намалят размера." },
        { "@language": "cs", "@value": "Schopnost materiálu nebo konstrukce odolávat zatížení směřujícímu ke zmenšení velikosti." },
        { "@language": "da", "@value": "Et materiales eller en strukturs evne til at modstå belastninger, der har tendens til at reducere størrelsen." },
        { "@language": "de", "@value": "Die Fähigkeit eines Materials oder einer Struktur, Belastungen standzuhalten, die dazu neigen, die Größe zu verringern." },
        { "@language": "el", "@value": "Η ικανότητα ενός υλικού ή δομής να αντέχει σε φορτία που τείνουν να μειώσουν το μέγεθος." },
        { "@language": "es", "@value": "La capacidad de un material o estructura para soportar cargas que tienden a reducir su tamaño." },
        { "@language": "et", "@value": "Materjali või konstruktsiooni võime taluda koormusi, mis kipuvad suurust vähendama." },
        { "@language": "fi", "@value": "Materiaalin tai rakenteen kyky kestää kuormituksia, jotka pyrkivät pienentämään sen kokoa." },
        { "@language": "fr", "@value": "La capacité d'un matériau ou d'une structure à résister à des charges tendant à réduire sa taille." },
        { "@language": "ga", "@value": "Cumas ábhair nó struchtúir chun ualaí a sheasamh a d'fhéadfadh a mhéid a laghdú." },
        { "@language": "hr", "@value": "Sposobnost materijala ili konstrukcije da izdrži opterećenja koja teže smanjenju veličine." },
        { "@language": "hu", "@value": "Egy anyag vagy szerkezet képessége, hogy ellenálljon a méretcsökkenést előidéző terheléseknek." },
        { "@language": "it", "@value": "La capacità di un materiale o di una struttura di resistere a carichi che tendono a ridurne le dimensioni." },
        { "@language": "lt", "@value": "Medžiagos ar konstrukcijos gebėjimas atlaikyti apkrovas, kurios linkusios sumažinti dydį." },
        { "@language": "lv", "@value": "Materiāla vai konstrukcijas spēja izturēt slodzi, kas tiecas samazināt izmēru." },
        { "@language": "mt", "@value": "Il-kapaċità ta' materjal jew struttura li tiflaħ tagħbijiet li jxaqilbu biex inaqqsu d-daqs." },
        { "@language": "nl", "@value": "De capaciteit van een materiaal of constructie om weerstand te bieden aan belastingen die de neiging hebben de omvang te verkleinen." },
        { "@language": "pl", "@value": "Zdolność materiału lub konstrukcji do wytrzymywania obciążeń zmierzających do zmniejszenia rozmiaru." },
        { "@language": "pt", "@value": "A capacidade de um material ou estrutura para suportar cargas que tendem a reduzir o tamanho." },
        { "@language": "ro", "@value": "Capacitatea unui material sau a unei structuri de a rezista la sarcini care tind să reducă dimensiunea." },
        { "@language": "sk", "@value": "Schopnosť materiálu alebo konštrukcie odolávať zaťaženiu, ktoré má tendenciu zmenšovať veľkosť." },
        { "@language": "sl", "@value": "Sposobnost materiala ali konstrukcije, da vzdrži obremenitve, ki težijo k zmanjšanju velikosti." },
        { "@language": "sv", "@value": "Förmågan hos ett material eller en struktur att motstå belastningar som tenderar att minska storleken." }
      ],
      "rdfs:domain": { "@id": "dppk:ConstructionProduct" },
      "rdfs:range": { "@id": "dppk:QuantitativeValue" }
    },
