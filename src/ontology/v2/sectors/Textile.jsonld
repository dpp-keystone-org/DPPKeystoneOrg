              { "@language": "et", "@value": "Juhised ja suunised tekstiiltoote ohutuks kasutamiseks ja hooldamiseks." },
              { "@language": "fi", "@value": "Ohjeet ja suuntaviivat tekstiilituotteen turvallista käyttöä ja kunnossapitoa varten." },
