              { "@language": "fi", "@value": "Mittamuutos (kutistuminen tai laajeneminen) testauksen jälkeen." },
              { "@language": "fr", "@value": "Le changement dimensionnel (retrait ou expansion) après les essais." },
              { "@language": "ga", "@value": "An t-athrú toiseach (crapadh nó fairsingiú) tar éis tástála." },
              { "@language": "hr", "@value": "Dimenzionalna promjena (skupljanje ili širenje) nakon testiranja." },
              { "@language": "hu", "@value": "A méretváltozás (zsugorodás vagy tágulás) a tesztelés után." },
              { "@language": "it", "@value": "La variazione dimensionale (restringimento o espansione) dopo i test." },
              { "@language": "lt", "@value": "Matmenų pokytis (susitraukimas arba išsiplėtimas) po bandymo." },
              { "@language": "lv", "@value": "Izmēru izmaiņas (saraušanās vai izplešanās) pēc testēšanas." },
              { "@language": "mt", "@value": "Il-bidla dimensjonali (tiċkin jew espansjoni) wara l-ittestjar." },
              { "@language": "nl", "@value": "De dimensionale verandering (krimp of uitzetting) na het testen." },
              { "@language": "pl", "@value": "Zmiana wymiarowa (kurczenie się lub rozszerzanie) po testach." },
              { "@language": "pt", "@value": "A mudança dimensional (encolhimento ou expansão) após o teste." },
              { "@language": "ro", "@value": "Modificarea dimensională (contracție sau dilatare) după testare." },
