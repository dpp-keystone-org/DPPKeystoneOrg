            "rdfs:comment": [
              { "@language": "en", "@value": "The dimensional change (shrinkage or expansion) after testing." },
              { "@language": "bg", "@value": "Изменението на размерите (свиване или разширяване) след тестване." },
              { "@language": "cs", "@value": "Rozměrová změna (srážení nebo rozpínání) po testování." },
              { "@language": "da", "@value": "Dimensionsændringen (krympning eller udvidelse) efter testning." },
              { "@language": "de", "@value": "Die Maßänderung (Schrumpfung oder Dehnung) nach dem Testen." },
              { "@language": "el", "@value": "Η διαστατική αλλαγή (συρρίκνωση ή διαστολή) μετά τη δοκιμή." },
