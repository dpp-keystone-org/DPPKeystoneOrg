                  { "@language": "da", "@value": "Kilde: ESPR - DA's anvendelsesområde" },
                  { "@language": "de", "@value": "Quelle: ESPR - Geltungsbereich der DA" },
                  { "@language": "el", "@value": "Πηγή: ESPR - Πεδίο εφαρμογής της πράξης" },
                  { "@language": "es", "@value": "Fuente: ESPR - Ámbito de aplicación del AD" },
                  { "@language": "et", "@value": "Allikas: ESPR - DA kohaldamisala" },
