              { "@language": "mt", "@value": "Kategorija PEFCR" },
              { "@language": "nl", "@value": "PEFCR-categorie" },
              { "@language": "pl", "@value": "Kategoria PEFCR" },
              { "@language": "pt", "@value": "Categoria PEFCR" },
              { "@language": "ro", "@value": "Categoria PEFCR" },
              { "@language": "sk", "@value": "Kategória PEFCR" },
              { "@language": "sl", "@value": "Kategorija PEFCR" },
              { "@language": "sv", "@value": "PEFCR-kategori" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "The Product Environmental Footprint Category Rules (PEFCR) category to which the product belongs." },
              { "@language": "bg", "@value": "Категорията на правилата за продуктовия отпечатък върху околната среда (PEFCR), към която принадлежи продуктът." },
              { "@language": "cs", "@value": "Kategorie pravidel pro environmentální stopu produktu (PEFCR), do které produkt patří." },
              { "@language": "da", "@value": "Kategorien for produktets miljøaftryk (PEFCR), som produktet tilhører." },
              { "@language": "de", "@value": "Die Kategorie der Product Environmental Footprint Category Rules (PEFCR), zu der das Produkt gehört." },
              { "@language": "el", "@value": "Η κατηγορία των κανόνων κατηγορίας περιβαλλοντικού αποτυπώματος προϊόντος (PEFCR) στην οποία ανήκει το προϊόν." },
              { "@language": "es", "@value": "La categoría de las Reglas de Categoría de Huella Ambiental de Producto (PEFCR) a la que pertenece el producto." },
              { "@language": "et", "@value": "Toote keskkonnajalajälje kategooria reeglite (PEFCR) kategooria, millesse toode kuulub." },
              { "@language": "fi", "@value": "Tuotteen ympäristöjalanjäljen luokkasääntöjen (PEFCR) luokka, johon tuote kuuluu." },
              { "@language": "fr", "@value": "La catégorie des règles de catégorie d'empreinte environnementale de produit (PEFCR) à laquelle le produit appartient." },
              { "@language": "ga", "@value": "Catagóir Rialacha Catagóir Lorg Comhshaoil ​​Táirge (PEFCR) a mbaineann an táirge léi." },
              { "@language": "hr", "@value": "Kategorija pravila o ekološkom otisku proizvoda (PEFCR) kojoj proizvod pripada." },
              { "@language": "hu", "@value": "A termék környezeti lábnyomára vonatkozó kategóriaszabályok (PEFCR) szerinti kategória, amelybe a termék tartozik." },
              { "@language": "it", "@value": "La categoria delle regole di categoria dell'impronta ambientale di prodotto (PEFCR) a cui appartiene il prodotto." },
              { "@language": "lt", "@value": "Produkto aplinkosauginio pėdsako kategorijos taisyklių (PEFCR) kategorija, kuriai priklauso produktas." },
              { "@language": "lv", "@value": "Produkta vidiskās pēdas kategorijas noteikumu (PEFCR) kategorija, kurai produkts pieder." },
              { "@language": "mt", "@value": "Il-kategorija tar-Regoli tal-Kategorija tal-Impronta Ambjentali tal-Prodott (PEFCR) li għaliha jappartjeni l-prodott." },
              { "@language": "nl", "@value": "De categorie van de Product Environmental Footprint Category Rules (PEFCR) waartoe het product behoort." },
              { "@language": "pl", "@value": "Kategoria zasad obliczania śladu środowiskowego produktu (PEFCR), do której należy produkt." },
              { "@language": "pt", "@value": "A categoria das Regras de Categoria de Pegada Ambiental de Produto (PEFCR) à qual o produto pertence." },
              { "@language": "ro", "@value": "Categoria Regulilor privind amprenta de mediu a produsului (PEFCR) din care face parte produsul." },
              { "@language": "sk", "@value": "Kategória pravidiel pre environmentálnu stopu výrobku (PEFCR), do ktorej výrobok patrí." },
              { "@language": "sl", "@value": "Kategorija pravil za okoljski odtis izdelka (PEFCR), v katero izdelek spada." },
              { "@language": "sv", "@value": "Den kategori i reglerna för produktens miljöavtryck (PEFCR) som produkten tillhör." }
            ],
            "dppk:visibility": { "@id": "dppk:Public" },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "dppk:PefcrCategoryValue" }
        },
        {
            "@id": "dppk:PefcrCategoryValue",
            "@type": "rdfs:Class",
            "rdfs:label": [
              { "@language": "en", "@value": "PEFCR Category Value" },
              { "@language": "bg", "@value": "Стойност на категорията PEFCR" },
              { "@language": "cs", "@value": "Hodnota kategorie PEFCR" },
              { "@language": "da", "@value": "PEFCR-kategoriværdi" },
              { "@language": "de", "@value": "PEFCR-Kategoriewert" },
              { "@language": "el", "@value": "Τιμή κατηγορίας PEFCR" },
              { "@language": "es", "@value": "Valor de la categoría PEFCR" },
              { "@language": "et", "@value": "PEFCR-kategooria väärtus" },
              { "@language": "fi", "@value": "PEFCR-luokan arvo" },
              { "@language": "fr", "@value": "Valeur de la catégorie PEFCR" },
              { "@language": "ga", "@value": "Luach Catagóir PEFCR" },
              { "@language": "hr", "@value": "Vrijednost kategorije PEFCR" },
              { "@language": "hu", "@value": "PEFCR kategóriaérték" },
              { "@language": "it", "@value": "Valore della categoria PEFCR" },
              { "@language": "lt", "@value": "PEFCR kategorijos vertė" },
              { "@language": "lv", "@value": "PEFCR kategorijas vērtība" },
              { "@language": "mt", "@value": "Valur tal-Kategorija PEFCR" },
              { "@language": "nl", "@value": "PEFCR-categoriewaarde" },
              { "@language": "pl", "@value": "Wartość kategorii PEFCR" },
              { "@language": "pt", "@value": "Valor da Categoria PEFCR" },
              { "@language": "ro", "@value": "Valoarea categoriei PEFCR" },
              { "@language": "sk", "@value": "Hodnota kategórie PEFCR" },
              { "@language": "sl", "@value": "Vrednost kategorije PEFCR" },
              { "@language": "sv", "@value": "PEFCR-kategorivärde" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "An enumeration of the allowed PEFCR categories for apparel and footwear." },
              { "@language": "bg", "@value": "Изброяване на разрешените категории PEFCR за облекло и обувки." },
              { "@language": "cs", "@value": "Výčet povolených kategorií PEFCR pro oděvy a obuv." },
              { "@language": "da", "@value": "En opregning af de tilladte PEFCR-kategorier for beklædning og fodtøj." },
              { "@language": "de", "@value": "Eine Aufzählung der zulässigen PEFCR-Kategorien für Bekleidung und Schuhe." },
              { "@language": "el", "@value": "Μια απαρίθμηση των επιτρεπόμενων κατηγοριών PEFCR για ένδυση και υπόδηση." },
              { "@language": "es", "@value": "Una enumeración de las categorías PEFCR permitidas para prendas de vestir y calzado." },
              { "@language": "et", "@value": "Rõivaste ja jalatsite lubatud PEFCR-kategooriate loetelu." },
              { "@language": "fi", "@value": "Luettelo sallituista PEFCR-luokista vaatteille ja jalkineille." },
              { "@language": "fr", "@value": "Une énumération des catégories PEFCR autorisées pour les vêtements et les chaussures." },
              { "@language": "ga", "@value": "Liosta de na catagóirí PEFCR atá ceadaithe le haghaidh éadaí agus coisbheart." },
              { "@language": "hr", "@value": "Popis dopuštenih kategorija PEFCR za odjeću i obuću." },
              { "@language": "hu", "@value": "A ruházati és lábbelitermékek engedélyezett PEFCR-kategóriáinak felsorolása." },
              { "@language": "it", "@value": "Un'enumerazione delle categorie PEFCR consentite per abbigliamento e calzature." },
              { "@language": "lt", "@value": "Leidžiamų drabužių ir avalynės PEFCR kategorijų sąrašas." },
              { "@language": "lv", "@value": "Atļauto PEFCR kategoriju uzskaitījums apģērbiem un apaviem." },
              { "@language": "mt", "@value": "Enumerazzjoni tal-kategoriji PEFCR permessi għall-ilbies u x-xedd tas-saqajn." },
              { "@language": "nl", "@value": "Een opsomming van de toegestane PEFCR-categorieën voor kleding en schoeisel." },
              { "@language": "pl", "@value": "Wyliczenie dozwolonych kategorii PEFCR dla odzieży i obuwia." },
              { "@language": "pt", "@value": "Uma enumeração das categorias PEFCR permitidas para vestuário e calçado." },
              { "@language": "ro", "@value": "O enumerare a categoriilor PEFCR permise pentru îmbrăcăminte și încălțăminte." },
              { "@language": "sk", "@value": "Výpočet povolených kategórií PEFCR pre odevy a obuv." },
              { "@language": "sl", "@value": "Naštevanje dovoljenih kategorij PEFCR za oblačila in obutev." },
              { "@language": "sv", "@value": "En uppräkning av de tillåtna PEFCR-kategorierna för kläder och skor." }
            ],
            "rdfs:subClassOf": { "@id": "rdfs:Resource" },
            "owl:oneOf": [
                { "@id": "dppk:PefcrTShirts" },
                { "@id": "dppk:PefcrShirtsAndBlouses" },
                { "@id": "dppk:PefcrSweatersAndMidlayers" },
                { "@id": "dppk:PefcrJacketsAndCoats" },
                { "@id": "dppk:PefcrPantsAndShorts" },
                { "@id": "dppk:PefcrDressesSkirtsAndJumpsuits" },
                { "@id": "dppk:PefcrLeggingsStockingsTightsAndSocks" },
                { "@id": "dppk:PefcrUnderwear" },
                { "@id": "dppk:PefcrSwimwear" },
                { "@id": "dppk:PefcrApparelAccessories" },
                { "@id": "dppk:PefcrOpenToedShoes" },
                { "@id": "dppk:PefcrClosedToedShoes" },
                { "@id": "dppk:PefcrBoots" }
            ]
        },
        {
            "@id": "dppk:PefcrTShirts",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "T-shirts" },
              { "@language": "bg", "@value": "Тениски" },
              { "@language": "cs", "@value": "Trička" },
              { "@language": "da", "@value": "T-shirts" },
              { "@language": "de", "@value": "T-Shirts" },
              { "@language": "el", "@value": "Μπλουζάκια" },
              { "@language": "es", "@value": "Camisetas" },
              { "@language": "et", "@value": "T-särgid" },
              { "@language": "fi", "@value": "T-paidat" },
              { "@language": "fr", "@value": "T-shirts" },
              { "@language": "ga", "@value": "T-léinte" },
              { "@language": "hr", "@value": "Majice kratkih rukava" },
              { "@language": "hu", "@value": "Pólók" },
              { "@language": "it", "@value": "T-shirt" },
              { "@language": "lt", "@value": "Marškinėliai" },
              { "@language": "lv", "@value": "T-krekli" },
              { "@language": "mt", "@value": "T-shirts" },
              { "@language": "nl", "@value": "T-shirts" },
              { "@language": "pl", "@value": "T-shirty" },
              { "@language": "pt", "@value": "T-shirts" },
              { "@language": "ro", "@value": "Tricouri" },
              { "@language": "sk", "@value": "Tričká" },
              { "@language": "sl", "@value": "T-majice" },
              { "@language": "sv", "@value": "T-shirts" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garment to cover the upper body to the elbow. Typical products included: Singlets, t-shirts, polo shirts, other short-sleeved shirts." },
              { "@language": "bg", "@value": "Дреха, която покрива горната част на тялото до лактите. Типични включени продукти: Потници, тениски, поло тениски, други ризи с къс ръкав." },
              { "@language": "cs", "@value": "Oděv pokrývající horní část těla po loket. Typické zahrnuté produkty: Tílka, trička, polokošile, jiné košile s krátkým rukávem." },
              { "@language": "da", "@value": "Beklædningsgenstand til at dække overkroppen til albuen. Typiske produkter inkluderet: Undertrøjer, t-shirts, poloshirts, andre kortærmede skjorter." },
              { "@language": "de", "@value": "Kleidungsstück, das den Oberkörper bis zum Ellbogen bedeckt. Typische Produkte: Unterhemden, T-Shirts, Poloshirts, andere kurzärmelige Hemden." },
              { "@language": "el", "@value": "Ένδυμα που καλύπτει το πάνω μέρος του σώματος μέχρι τον αγκώνα. Τυπικά προϊόντα που περιλαμβάνονται: Φανελάκια, t-shirts, μπλούζες πόλο, άλλα κοντομάνικα πουκάμισα." },
              { "@language": "es", "@value": "Prenda para cubrir la parte superior del cuerpo hasta el codo. Productos típicos incluidos: Camisetas de tirantes, camisetas, polos, otras camisas de manga corta." },
              { "@language": "et", "@value": "Rõivaese, mis katab ülakeha kuni küünarnukini. Tüüpilised tooted on: Särgid, t-särgid, polosärgid, muud lühikeste varrukatega särgid." },
              { "@language": "fi", "@value": "Vaate, joka peittää ylävartalon kyynärpäähän asti. Tyypilliset tuotteet: Aluspaidat, t-paidat, pikeepaidat, muut lyhythihaiset paidat." },
              { "@language": "fr", "@value": "Vêtement couvrant le haut du corps jusqu'au coude. Produits typiques inclus : Maillots de corps, t-shirts, polos, autres chemises à manches courtes." },
              { "@language": "ga", "@value": "Éadaí chun corp uachtarach a chlúdach don uillinn. Táirgí tipiciúla a chuirtear san áireamh: Singiléid, t-léinte, léinte póló, léinte gearr-mhuinchille eile." },
              { "@language": "hr", "@value": "Odjevni predmet koji prekriva gornji dio tijela do lakta. Tipični uključeni proizvodi: Potkošulje, majice kratkih rukava, polo majice, ostale košulje kratkih rukava." },
              { "@language": "hu", "@value": "A felsőtestet a könyékig fedő ruhadarab. Jellemző termékek: Trikók, pólók, galléros pólók, egyéb rövid ujjú ingek." },
              { "@language": "it", "@value": "Indumento che copre la parte superiore del corpo fino al gomito. Prodotti tipici inclusi: Canottiere, magliette, polo, altre camicie a maniche corte." },
              { "@language": "lt", "@value": "Drabužis, dengiantis viršutinę kūno dalį iki alkūnės. Tipiški produktai: Berankoviai marškinėliai, marškinėliai, polo marškinėliai, kiti marškinėliai trumpomis rankovėmis." },
              { "@language": "lv", "@value": "Apģērbs, kas nosedz ķermeņa augšdaļu līdz elkonim. Tipiski iekļautie produkti: Krekliņi, t-krekli, polo krekli, citi krekli ar īsām piedurknēm." },
              { "@language": "mt", "@value": "Ilbies biex jgħatti l-parti ta 'fuq tal-ġisem sal-minkeb. Prodotti tipiċi jinkludu: Flokkijiet, t-shirts, polo shirts, qomos oħra bi kmiem qosra." },
              { "@language": "nl", "@value": "Kledingstuk om het bovenlichaam tot aan de elleboog te bedekken. Typische inbegrepen producten: Hemden, t-shirts, poloshirts, andere shirts met korte mouwen." },
              { "@language": "pl", "@value": "Odzież zakrywająca górną część ciała do łokcia. Typowe produkty: Podkoszulki, t-shirty, koszulki polo, inne koszule z krótkim rękawem." },
              { "@language": "pt", "@value": "Peça de vestuário para cobrir a parte superior do corpo até o cotovelo. Produtos típicos incluídos: Camisolas interiores, t-shirts, polos, outras camisas de manga curta." },
              { "@language": "ro", "@value": "Îmbrăcăminte pentru a acoperi partea superioară a corpului până la cot. Produse tipice incluse: Maiouri, tricouri, tricouri polo, alte cămăși cu mâneci scurte." },
              { "@language": "sk", "@value": "Odev zakrývajúci hornú časť tela po lakeť. Typické zahrnuté produkty: Tielka, tričká, polokošele, iné košele s krátkym rukávom." },
              { "@language": "sl", "@value": "Oblačilo, ki prekriva zgornji del telesa do komolca. Tipični vključeni izdelki: Spodnje majice, t-majice, polo majice, druge srajce s kratkimi rokavi." },
              { "@language": "sv", "@value": "Plagg som täcker överkroppen till armbågen. Typiska produkter som ingår: Linnen, t-shirts, pikétröjor, andra kortärmade skjortor." }
            ]
        },
        {
            "@id": "dppk:PefcrShirtsAndBlouses",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Shirts and blouses" },
              { "@language": "bg", "@value": "Ризи и блузи" },
              { "@language": "cs", "@value": "Košile a halenky" },
              { "@language": "da", "@value": "Skjorter og bluser" },
              { "@language": "de", "@value": "Hemden und Blusen" },
              { "@language": "el", "@value": "Πουκάμισα και μπλούζες" },
              { "@language": "es", "@value": "Camisas y blusas" },
              { "@language": "et", "@value": "Särgid ja pluusid" },
              { "@language": "fi", "@value": "Paidat ja puserot" },
              { "@language": "fr", "@value": "Chemises et chemisiers" },
              { "@language": "ga", "@value": "Léinte agus blúsléinte" },
              { "@language": "hr", "@value": "Košulje i bluze" },
              { "@language": "hu", "@value": "Ingek és blúzok" },
              { "@language": "it", "@value": "Camicie e camicette" },
              { "@language": "lt", "@value": "Marškiniai ir palaidinės" },
              { "@language": "lv", "@value": "Krekli un blūzes" },
              { "@language": "mt", "@value": "Qomos u blużi" },
              { "@language": "nl", "@value": "Overhemden en blouses" },
              { "@language": "pl", "@value": "Koszule i bluzki" },
              { "@language": "pt", "@value": "Camisas e blusas" },
              { "@language": "ro", "@value": "Cămăși și bluze" },
              { "@language": "sk", "@value": "Košele a blúzky" },
              { "@language": "sl", "@value": "Srajce in bluze" },
              { "@language": "sv", "@value": "Skjortor och blusar" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garment to cover the upper body including the entire arm. Typical products included: Long-sleeved shirts, blouses, tunics, base layers." },
              { "@language": "bg", "@value": "Дреха, която покрива горната част на тялото, включително цялата ръка. Типични включени продукти: Ризи с дълъг ръкав, блузи, туники, основни слоеве." },
              { "@language": "cs", "@value": "Oděv pokrývající horní část těla včetně celé paže. Typické zahrnuté produkty: Košile s dlouhým rukávem, halenky, tuniky, základní vrstvy." },
              { "@language": "da", "@value": "Beklædningsgenstand til at dække overkroppen inklusive hele armen. Typiske produkter inkluderet: Langærmede skjorter, bluser, tunikaer, basislag." },
              { "@language": "de", "@value": "Kleidungsstück, das den Oberkörper einschließlich des gesamten Arms bedeckt. Typische Produkte: Langärmelige Hemden, Blusen, Tuniken, Baselayer." },
              { "@language": "el", "@value": "Ένδυμα που καλύπτει το πάνω μέρος του σώματος συμπεριλαμβανομένου ολόκληρου του βραχίονα. Τυπικά προϊόντα που περιλαμβάνονται: Πουκάμισα με μακριά μανίκια, μπλούζες, τουνίκ, ισοθερμικά." },
              { "@language": "es", "@value": "Prenda para cubrir la parte superior del cuerpo, incluido todo el brazo. Productos típicos incluidos: Camisas de manga larga, blusas, túnicas, capas base." },
              { "@language": "et", "@value": "Rõivaese, mis katab ülakeha ja kogu käe. Tüüpilised tooted on: Pikkade varrukatega särgid, pluusid, tuunikad, aluskihid." },
              { "@language": "fi", "@value": "Vaate, joka peittää ylävartalon koko käsivarsi mukaan lukien. Tyypilliset tuotteet: Pitkähihaiset paidat, puserot, tunikat, aluskerrastot." },
              { "@language": "fr", "@value": "Vêtement couvrant le haut du corps, y compris tout le bras. Produits typiques inclus : Chemises à manches longues, chemisiers, tuniques, couches de base." },
              { "@language": "ga", "@value": "Éadaí chun an corp uachtarach a chlúdach, an lámh ar fad san áireamh. Táirgí tipiciúla a chuirtear san áireamh: Léinte fada-mhuinchille, blúsléinte, tiúnicí, bunteagmhálacha." },
              { "@language": "hr", "@value": "Odjevni predmet koji prekriva gornji dio tijela uključujući cijelu ruku. Tipični uključeni proizvodi: Košulje dugih rukava, bluze, tunike, osnovni slojevi." },
              { "@language": "hu", "@value": "A felsőtestet és a teljes kart fedő ruhadarab. Jellemző termékek: Hosszú ujjú ingek, blúzok, tunikák, aláöltözetek." },
              { "@language": "it", "@value": "Indumento che copre la parte superiore del corpo includendo l'intero braccio. Prodotti tipici inclusi: Camicie a maniche lunghe, camicette, tuniche, strati base." },
              { "@language": "lt", "@value": "Drabužis, dengiantis viršutinę kūno dalį, įskaitant visą ranką. Tipiški produktai: Marškiniai ilgomis rankovėmis, palaidinės, tunikos, apatiniai sluoksniai." },
              { "@language": "lv", "@value": "Apģērbs, kas nosedz ķermeņa augšdaļu, ieskaitot visu roku. Tipiski iekļautie produkti: Krekli ar garām piedurknēm, blūzes, tunikas, bāzes slāņi." },
              { "@language": "mt", "@value": "Ilbies biex jgħatti l-parti ta 'fuq tal-ġisem inkluż id-driegħ kollu. Prodotti tipiċi jinkludu: Qomos bil-kmiem twal, blużi, tuniċi, saffi bażi." },
              { "@language": "nl", "@value": "Kledingstuk om het bovenlichaam te bedekken, inclusief de hele arm. Typische inbegrepen producten: Shirts met lange mouwen, blouses, tunieken, basislagen." },
              { "@language": "pl", "@value": "Odzież zakrywająca górną część ciała wraz z całą ręką. Typowe produkty: Koszule z długim rękawem, bluzki, tuniki, warstwy podstawowe." },
              { "@language": "pt", "@value": "Peça de vestuário para cobrir a parte superior do corpo, incluindo todo o braço. Produtos típicos incluídos: Camisas de manga comprida, blusas, túnicas, camadas base." },
              { "@language": "ro", "@value": "Îmbrăcăminte pentru a acoperi partea superioară a corpului, inclusiv întregul braț. Produse tipice incluse: Cămăși cu mâneci lungi, bluze, tunici, straturi de bază." },
              { "@language": "sk", "@value": "Odev zakrývajúci hornú časť tela vrátane celej paže. Typické zahrnuté produkty: Košele s dlhým rukávom, blúzky, tuniky, základné vrstvy." },
              { "@language": "sl", "@value": "Oblačilo, ki prekriva zgornji del telesa, vključno s celotno roko. Tipični vključeni izdelki: Srajce z dolgimi rokavi, bluze, tunike, osnovni sloji." },
              { "@language": "sv", "@value": "Plagg som täcker överkroppen inklusive hela armen. Typiska produkter som ingår: Långärmade skjortor, blusar, tunikor, baslager." }
            ]
        },
        {
            "@id": "dppk:PefcrSweatersAndMidlayers",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Sweaters and midlayers" },
              { "@language": "bg", "@value": "Пуловери и средни слоеве" },
              { "@language": "cs", "@value": "Svetry a střední vrstvy" },
              { "@language": "da", "@value": "Trøjer og mellemlag" },
              { "@language": "de", "@value": "Pullover und Midlayer" },
              { "@language": "el", "@value": "Πουλόβερ και ενδιάμεσα στρώματα" },
              { "@language": "es", "@value": "Jerséis y capas intermedias" },
              { "@language": "et", "@value": "Kampsunid ja vahekihid" },
              { "@language": "fi", "@value": "Villapaidat ja välikerrokset" },
              { "@language": "fr", "@value": "Pulls et couches intermédiaires" },
              { "@language": "ga", "@value": "Geansaithe agus sraitheanna lár" },
              { "@language": "hr", "@value": "Džemperi i srednji slojevi" },
              { "@language": "hu", "@value": "Pulóverek és középrétegek" },
              { "@language": "it", "@value": "Maglioni e strati intermedi" },
              { "@language": "lt", "@value": "Megztiniai ir viduriniai sluoksniai" },
              { "@language": "lv", "@value": "Džemperi un vidējie slāņi" },
              { "@language": "mt", "@value": "Ġerżijiet u saffi tan-nofs" },
              { "@language": "nl", "@value": "Truien en tussenlagen" },
              { "@language": "pl", "@value": "Swetry i warstwy środkowe" },
              { "@language": "pt", "@value": "Camisolas e camadas intermédias" },
              { "@language": "ro", "@value": "Pulovere și straturi intermediare" },
              { "@language": "sk", "@value": "Svetre a stredné vrstvy" },
              { "@language": "sl", "@value": "Puloverji in vmesni sloji" },
              { "@language": "sv", "@value": "Tröjor och mellanlager" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garment to keep the upper body warm and covered. Typical products included: Pullovers, cardigans, hoodies, jerseys, sweatshirts, knitted and wool sweaters, vests." },
              { "@language": "bg", "@value": "Дреха, която да поддържа горната част на тялото топла и покрита. Типични включени продукти: Пуловери, жилетки, суичъри, фланелки, плетени и вълнени пуловери, елеци." },
              { "@language": "cs", "@value": "Oděv k udržení tepla a zakrytí horní části těla. Typické zahrnuté produkty: Pulovry, kardigany, mikiny s kapucí, dresy, mikiny, pletené a vlněné svetry, vesty." },
              { "@language": "da", "@value": "Beklædningsgenstand for at holde overkroppen varm og dækket. Typiske produkter inkluderet: Pullovers, cardigans, hættetrøjer, trøjer, sweatshirts, strikkede og uldtrøjer, veste." },
              { "@language": "de", "@value": "Kleidungsstück, das den Oberkörper warm hält und bedeckt. Typische Produkte: Pullover, Strickjacken, Hoodies, Trikots, Sweatshirts, Strick- und Wollpullover, Westen." },
              { "@language": "el", "@value": "Ένδυμα για να διατηρείται το πάνω μέρος του σώματος ζεστό και καλυμμένο. Τυπικά προϊόντα που περιλαμβάνονται: Πουλόβερ, ζακέτες, φούτερ με κουκούλα, φανέλες, φούτερ, πλεκτά και μάλλινα πουλόβερ, γιλέκα." },
              { "@language": "es", "@value": "Prenda para mantener la parte superior del cuerpo abrigada y cubierta. Productos típicos incluidos: Pulóveres, cárdigans, sudaderas con capucha, jerséis, sudaderas, jerséis de punto y lana, chalecos." },
              { "@language": "et", "@value": "Rõivaese, mis hoiab ülakeha soojas ja kaetud. Tüüpilised tooted on: Pulloverid, kardiganid, kapuutsiga pusad, kampsunid, dressipluusid, kootud ja villased kampsunid, vestid." },
              { "@language": "fi", "@value": "Vaate, joka pitää ylävartalon lämpimänä ja peitettynä. Tyypilliset tuotteet: Villapaidat, neuletakit, hupparit, jerseyt, colleget, neulotut ja villapaidat, liivit." },
              { "@language": "fr", "@value": "Vêtement pour garder le haut du corps au chaud et couvert. Produits typiques inclus : Pulls, gilets, sweats à capuche, maillots, sweat-shirts, pulls en tricot et en laine, vestes sans manches." },
              { "@language": "ga", "@value": "Éadaí chun an corp uachtarach a choinneáil te agus clúdaithe. Táirgí tipiciúla a chuirtear san áireamh: Geansaithe, cardigain, cochaill, geansaithe, geansaithe allais, geansaithe cniotáilte agus olann, veisteanna." },
              { "@language": "hr", "@value": "Odjevni predmet za održavanje gornjeg dijela tijela toplim i pokrivenim. Tipični uključeni proizvodi: Puloveri, kardigani, majice s kapuljačom, dresovi, trenirke, pleteni i vuneni džemperi, prsluci." },
              { "@language": "hu", "@value": "A felsőtestet melegen tartó és fedő ruhadarab. Jellemző termékek: Pulóverek, kardigánok, kapucnis pulóverek, mezek, pamut pulóverek, kötött és gyapjú pulóverek, mellények." },
              { "@language": "it", "@value": "Indumento per mantenere la parte superiore del corpo calda e coperta. Prodotti tipici inclusi: Pullover, cardigan, felpe con cappuccio, maglie, felpe, maglioni lavorati a maglia e di lana, gilet." },
              { "@language": "lt", "@value": "Drabužis, skirtas išlaikyti viršutinę kūno dalį šiltą ir uždengtą. Tipiški produktai: Puloveriai, kardiganai, džemperiai su gobtuvu, megztiniai, sportiniai megztiniai, megzti ir vilnoniai megztiniai, liemenės." },
              { "@language": "lv", "@value": "Apģērbs, kas uztur ķermeņa augšdaļu siltu un apsegtu. Tipiski iekļautie produkti: Puloveri, jaciņas, džemperi ar kapuci, džemperi, sporta džemperi, trikotāžas un vilnas džemperi, vestes." },
              { "@language": "mt", "@value": "Ilbies biex jinżamm il-parti ta 'fuq tal-ġisem sħun u kopert. Prodotti tipiċi jinkludu: Pullovers, cardigans, hoodies, ġerżijiet, sweatshirts, ġerżijiet innittjati u tas-suf, flokkijiet." },
              { "@language": "nl", "@value": "Kledingstuk om het bovenlichaam warm en bedekt te houden. Typische inbegrepen producten: Pullovers, vesten, hoodies, truien, sweatshirts, gebreide en wollen truien, bodywarmers." },
              { "@language": "pl", "@value": "Odzież utrzymująca ciepło i zakrywająca górną część ciała. Typowe produkty: Pulowery, rozpinane swetry, bluzy z kapturem, koszulki, bluzy sportowe, swetry dzianinowe i wełniane, kamizelki." },
              { "@language": "pt", "@value": "Peça de vestuário para manter a parte superior do corpo quente e coberta. Produtos típicos incluídos: Pulôveres, cardigãs, camisolas com capuz, camisolas, sweatshirts, camisolas de malha e de lã, coletes." },
              { "@language": "ro", "@value": "Îmbrăcăminte pentru a menține partea superioară a corpului caldă și acoperită. Produse tipice incluse: Pulovere, cardigane, hanorace, bluze, treninguri, pulovere tricotate și din lână, veste." },
              { "@language": "sk", "@value": "Odev na udržanie tepla a zakrytie hornej časti tela. Typické zahrnuté produkty: Pulóvre, kardigány, mikiny s kapucňou, dresy, mikiny, pletené a vlnené svetre, vesty." },
              { "@language": "sl", "@value": "Oblačilo za ohranjanje toplega in pokritega zgornjega dela telesa. Tipični vključeni izdelki: Puloverji, jopice, puloverji s kapuco, majice, trenirke, pleteni in volneni puloverji, telovniki." },
              { "@language": "sv", "@value": "Plagg för att hålla överkroppen varm och täckt. Typiska produkter som ingår: Pullovrar, koftor, luvtröjor, tröjor, sweatshirts, stickade och ylletröjor, västar." }
            ]
        },
        {
            "@id": "dppk:PefcrJacketsAndCoats",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Jackets and coats" },
              { "@language": "bg", "@value": "Якета и палта" },
              { "@language": "cs", "@value": "Bundy a kabáty" },
              { "@language": "da", "@value": "Jakker og frakker" },
              { "@language": "de", "@value": "Jacken und Mäntel" },
              { "@language": "el", "@value": "Μπουφάν και παλτά" },
              { "@language": "es", "@value": "Chaquetas y abrigos" },
              { "@language": "et", "@value": "Joped ja mantlid" },
              { "@language": "fi", "@value": "Takit ja päällystakit" },
              { "@language": "fr", "@value": "Vestes et manteaux" },
              { "@language": "ga", "@value": "Seaicéid agus cótaí" },
              { "@language": "hr", "@value": "Jakne i kaputi" },
              { "@language": "hu", "@value": "Dzsekik és kabátok" },
              { "@language": "it", "@value": "Giacche e cappotti" },
              { "@language": "lt", "@value": "Striukės ir paltai" },
              { "@language": "lv", "@value": "Jakas un mēteļi" },
              { "@language": "mt", "@value": "Ġkieket u kowtijiet" },
              { "@language": "nl", "@value": "Jassen en mantels" },
              { "@language": "pl", "@value": "Kurtki i płaszcze" },
              { "@language": "pt", "@value": "Casacos e sobretudos" },
              { "@language": "ro", "@value": "Jachete și paltoane" },
              { "@language": "sk", "@value": "Bundy a kabáty" },
              { "@language": "sl", "@value": "Jakne in plašči" },
              { "@language": "sv", "@value": "Jackor och rockar" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garment to put on top of a shirt or sweater or to protect from the elements. Typical products included: Blazers, suit jackets, overcoats, other light jackets, rain jackets, outdoor winter jackets, parkas, down jackets, fur jackets, outdoor vests, leather jackets." },
              { "@language": "bg", "@value": "Дреха, която се слага върху риза или пуловер или за защита от елементите. Типични включени продукти: Блейзъри, костюмни якета, палта, други леки якета, дъждобрани, зимни якета за открито, парки, пухени якета, кожени якета, елеци за открито." },
              { "@language": "cs", "@value": "Oděv, který se obléká přes košili nebo svetr nebo chrání před přírodními vlivy. Typické zahrnuté produkty: Blejzry, obleková saka, převlečníky, další lehké bundy, pláštěnky, outdoorové zimní bundy, parky, péřové bundy, kožešinové bundy, outdoorové vesty, kožené bundy." },
              { "@language": "da", "@value": "Beklædningsgenstand til at tage uden på en skjorte eller trøje eller for at beskytte mod vejret. Typiske produkter inkluderet: Blazere, habitjakker, overfrakker, andre lette jakker, regnjakker, udendørs vinterjakker, parkaer, dunjakker, pelsjakker, udendørs veste, læderjakker." },
              { "@language": "de", "@value": "Kleidungsstück, das über einem Hemd oder Pullover getragen wird oder vor den Elementen schützt. Typische Produkte: Blazer, Anzugjacken, Mäntel, andere leichte Jacken, Regenjacken, Outdoor-Winterjacken, Parkas, Daunenjacken, Pelzjacken, Outdoor-Westen, Lederjacken." },
              { "@language": "el", "@value": "Ένδυμα για να φορεθεί πάνω από πουκάμισο ή πουλόβερ ή για προστασία από τα στοιχεία της φύσης. Τυπικά προϊόντα: Μπλέιζερ, σακάκια, πανωφόρια, άλλα ελαφριά μπουφάν, αδιάβροχα, χειμερινά μπουφάν, παρκά, πουπουλένια μπουφάν, γούνινα μπουφάν, γιλέκα, δερμάτινα μπουφάν." },
              { "@language": "es", "@value": "Prenda para ponerse encima de una camisa o jersey o para proteger de los elementos. Productos típicos incluidos: Blazers, chaquetas de traje, abrigos, otras chaquetas ligeras, impermeables, chaquetas de invierno para exteriores, parkas, chaquetas de plumas, chaquetas de piel, chalecos para exteriores, chaquetas de cuero." },
              { "@language": "et", "@value": "Rõivaese särgi või kampsuni peal kandmiseks või ilmastikuolude eest kaitsmiseks. Tüüpilised tooted: Bleiserid, ülikonnajakid, mantlid, muud kerged jakid, vihmajoped, talvised välisjoped, parkad, sulejoped, karusnahast jakid, välisvestid, nahkjakid." },
              { "@language": "fi", "@value": "Päällysvaate, joka puetaan paidan tai villapaidan päälle tai suojaamaan säältä. Tyypilliset tuotteet: Bleiserit, pukutakit, päällystakit, muut kevyet takit, sadetakit, talvitakit, parkat, untuvatakit, turkistakit, ulkoliivit, nahkatakit." },
              { "@language": "fr", "@value": "Vêtement à mettre par-dessus une chemise ou un pull ou pour protéger des intempéries. Produits typiques inclus : Blazers, vestes de costume, pardessus, autres vestes légères, imperméables, vestes d'hiver d'extérieur, parkas, doudounes, vestes en fourrure, gilets d'extérieur, vestes en cuir." },
              { "@language": "ga", "@value": "Éadaí le cur ar bharr léine nó geansaí nó chun cosaint ar na heilimintí. Táirgí tipiciúla a chuirtear san áireamh: Bléasair, seaicéid chulaith, cótaí móra, seaicéid éadroma eile, seaicéid bháistí, seaicéid gheimhridh amuigh faoin aer, parcas, seaicéid anuas, seaicéid fionnaidh, veisteanna amuigh faoin aer, seaicéid leathair." },
              { "@language": "hr", "@value": "Odjevni predmet za nošenje preko košulje ili džempera ili za zaštitu od vremenskih nepogoda. Tipični uključeni proizvodi: Blejzeri, sakoi, kaputi, ostale lagane jakne, kabanice, zimske jakne za otvoreno, parke, pernate jakne, krznene jakne, prsluci za otvoreno, kožne jakne." },
              { "@language": "hu", "@value": "Ing vagy pulóver fölé, vagy az időjárás viszontagságai elleni védelemként felvehető ruhadarab. Jellemző termékek: Blézerek, öltönykabátok, felöltők, egyéb könnyű dzsekik, esőkabátok, szabadtéri téli dzsekik, parkák, pehelykabátok, szőrmekabátok, szabadtéri mellények, bőrkabátok." },
              { "@language": "it", "@value": "Indumento da indossare sopra una camicia o un maglione o per proteggere dalle intemperie. Prodotti tipici inclusi: Blazer, giacche da abito, soprabiti, altre giacche leggere, impermeabili, giacche invernali da esterno, parka, piumini, giacche di pelliccia, gilet da esterno, giacche di pelle." },
              { "@language": "lt", "@value": "Drabužis, dedamas ant marškinių ar megztinio, arba skirtas apsaugoti nuo gamtos stichijų. Tipiški produktai: Švarkai, kostiumų švarkai, paltai, kitos lengvos striukės, lietpalčiai, žieminės striukės laukui, parkos, pūkinės striukės, kailinės striukės, lauko liemenės, odinės striukės." },
              { "@language": "lv", "@value": "Apģērbs, ko uzvelk pa virsu kreklam vai džemperim vai lai pasargātu no laikapstākļiem. Tipiski iekļautie produkti: Žaketes, uzvalku žaketes, mēteļi, citas vieglas jakas, lietus jakas, āra ziemas jakas, parkas, dūnu jakas, kažokādas jakas, āra vestes, ādas jakas." },
              { "@language": "mt", "@value": "Ilbies li jitpoġġa fuq qmis jew ġerżi jew biex jipproteġi mill-elementi. Prodotti tipiċi jinkludu: Blazers, ġkieket tal-libsa, overcoats, ġkieket ħfief oħra, ġkieket tax-xita, ġkieket tax-xitwa ta 'barra, parkas, ġkieket tar-rix, ġkieket tal-pil, flokkijiet ta' barra, ġkieket tal-ġilda." },
              { "@language": "nl", "@value": "Kledingstuk om over een overhemd of trui aan te trekken of om te beschermen tegen de weersomstandigheden. Typische inbegrepen producten: Blazers, colberts, overjassen, andere lichte jassen, regenjassen, winterjassen voor buiten, parka's, donsjassen, bontjassen, bodywarmers voor buiten, leren jassen." },
              { "@language": "pl", "@value": "Odzież zakładana na koszulę lub sweter albo w celu ochrony przed warunkami atmosferycznymi. Typowe produkty: Marynarki, żakiety, płaszcze, inne lekkie kurtki, płaszcze przeciwdeszczowe, zimowe kurtki outdoorowe, parki, kurtki puchowe, kurtki futrzane, kamizelki outdoorowe, kurtki skórzane." },
              { "@language": "pt", "@value": "Peça de vestuário para colocar por cima de uma camisa ou camisola ou para proteger dos elementos. Produtos típicos incluídos: Blazers, casacos de fato, sobretudos, outros casacos leves, impermeáveis, casacos de inverno para exterior, parkas, casacos de penas, casacos de peles, coletes para exterior, casacos de couro." },
              { "@language": "ro", "@value": "Îmbrăcăminte care se pune peste o cămașă sau un pulover sau pentru a proteja de intemperii. Produse tipice incluse: Sacouri, jachete de costum, paltoane, alte jachete ușoare, pelerine de ploaie, jachete de iarnă pentru exterior, geci, jachete cu puf, jachete de blană, veste pentru exterior, jachete de piele." },
              { "@language": "sk", "@value": "Odev, ktorý sa oblieka na košeľu alebo sveter, alebo chráni pred nepriaznivým počasím. Typické zahrnuté produkty: Saká, oblekové saká, zvrchníky, iné ľahké bundy, pršiplášte, outdoorové zimné bundy, parky, páperové bundy, kožušinové bundy, outdoorové vesty, kožené bundy." },
              { "@language": "sl", "@value": "Oblačilo, ki se obleče čez srajco ali pulover ali za zaščito pred vremenskimi vplivi. Tipični vključeni izdelki: Blazerji, suknjiči, plašči, druge lahke jakne, dežni plašči, zimske jakne za na prosto, parke, puhovke, krznene jakne, telovniki za na prosto, usnjene jakne." },
              { "@language": "sv", "@value": "Plagg att ta på sig över en skjorta eller tröja eller för att skydda mot väder och vind. Typiska produkter som ingår: Kavajer, kostymjackor, överrockar, andra lätta jackor, regnjackor, vinterjackor för utomhusbruk, parkas, dunjackor, pälsjackor, utomhusvästar, skinnjackor." }
            ]
        },
        {
            "@id": "dppk:PefcrPantsAndShorts",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Pants and shorts" },
              { "@language": "bg", "@value": "Панталони и къси панталони" },
              { "@language": "cs", "@value": "Kalhoty a šortky" },
              { "@language": "da", "@value": "Bukser og shorts" },
              { "@language": "de", "@value": "Hosen und Shorts" },
              { "@language": "el", "@value": "Παντελόνια και σορτς" },
              { "@language": "es", "@value": "Pantalones y pantalones cortos" },
              { "@language": "et", "@value": "Püksid ja lühikesed püksid" },
              { "@language": "fi", "@value": "Housut ja shortsit" },
              { "@language": "fr", "@value": "Pantalons et shorts" },
              { "@language": "ga", "@value": "Pants agus shorts" },
              { "@language": "hr", "@value": "Hlače i kratke hlače" },
              { "@language": "hu", "@value": "Nadrágok és rövidnadrágok" },
              { "@language": "it", "@value": "Pantaloni e pantaloncini" },
              { "@language": "lt", "@value": "Kelnės ir šortai" },
              { "@language": "lv", "@value": "Bikses un šorti" },
              { "@language": "mt", "@value": "Qliezet u xorts" },
              { "@language": "nl", "@value": "Broeken en shorts" },
              { "@language": "pl", "@value": "Spodnie i szorty" },
              { "@language": "pt", "@value": "Calças e calções" },
              { "@language": "ro", "@value": "Pantaloni și pantaloni scurți" },
              { "@language": "sk", "@value": "Nohavice a šortky" },
              { "@language": "sl", "@value": "Hlače in kratke hlače" },
              { "@language": "sv", "@value": "Byxor och shorts" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garment to cover the lower body, may protect from the elements. Typical products included: Casual pants, outdoor pants, dress pants, jeans, sports pants, capri pants, shorts." },
              { "@language": "bg", "@value": "Дреха за покриване на долната част на тялото, може да предпазва от елементите. Типични продукти: Ежедневни панталони, външни панталони, официални панталони, дънки, спортни панталони, капри, къси панталони." },
              { "@language": "cs", "@value": "Oděv pokrývající spodní část těla, může chránit před přírodními vlivy. Typické produkty: Neformální kalhoty, outdoorové kalhoty, společenské kalhoty, džíny, sportovní kalhoty, capri kalhoty, šortky." },
              { "@language": "da", "@value": "Beklædningsgenstand til at dække underkroppen, kan beskytte mod vejret. Typiske produkter: Fritidsbukser, friluftsbukser, pæne bukser, jeans, sportsbukser, capribukser, shorts." },
              { "@language": "de", "@value": "Kleidungsstück zur Bedeckung des Unterkörpers, das vor den Elementen schützen kann. Typische Produkte: Freizeithosen, Outdoorhosen, Anzughosen, Jeans, Sporthosen, Caprihosen, Shorts." },
              { "@language": "el", "@value": "Ένδυμα για την κάλυψη του κάτω μέρους του σώματος, μπορεί να προστατεύει από τα στοιχεία της φύσης. Τυπικά προϊόντα: Καθημερινά παντελόνια, παντελόνια για εξωτερικούς χώρους, καλά παντελόνια, τζιν, αθλητικά παντελόνια, κάπρι, σορτς." },
              { "@language": "es", "@value": "Prenda para cubrir la parte inferior del cuerpo, puede proteger de los elementos. Productos típicos: Pantalones informales, pantalones de exterior, pantalones de vestir, vaqueros, pantalones de deporte, pantalones pirata, pantalones cortos." },
              { "@language": "et", "@value": "Rõivaese alakeha katmiseks, võib kaitsta ilmastiku eest. Tüüpilised tooted: Vabaajapüksid, välipüksid, viigipüksid, teksad, spordipüksid, kapri püksid, lühikesed püksid." },
              { "@language": "fi", "@value": "Alavartalon peittävä vaate, joka voi suojata säältä. Tyypilliset tuotteet: Vapaa-ajan housut, ulkoiluhousut, suorat housut, farkut, urheiluhousut, caprit, shortsit." },
              { "@language": "fr", "@value": "Vêtement couvrant le bas du corps, pouvant protéger des intempéries. Produits typiques : Pantalons décontractés, pantalons d'extérieur, pantalons habillés, jeans, pantalons de sport, pantacourts, shorts." },
              { "@language": "ga", "@value": "Éadaí chun an corp íochtair a chlúdach, a fhéadfaidh cosaint a dhéanamh ar na heilimintí. Táirgí tipiciúla: Pants ócáideacha, pants amuigh faoin aer, pants gúna, jeans, pants spóirt, pants capri, shorts." },
              { "@language": "hr", "@value": "Odjevni predmet za pokrivanje donjeg dijela tijela, može štititi od vremenskih nepogoda. Tipični proizvodi: Svakodnevne hlače, hlače za van, svečane hlače, traperice, sportske hlače, capri hlače, kratke hlače." },
              { "@language": "hu", "@value": "Az alsótestet fedő ruhadarab, amely védhet az időjárás viszontagságaitól. Jellemző termékek: Szabadidőnadrágok, szabadtéri nadrágok, öltönynadrágok, farmerek, sportnadrágok, capri nadrágok, rövidnadrágok." },
              { "@language": "it", "@value": "Indumento che copre la parte inferiore del corpo, può proteggere dalle intemperie. Prodotti tipici: Pantaloni casual, pantaloni da esterno, pantaloni eleganti, jeans, pantaloni sportivi, pantaloni capri, pantaloncini." },
              { "@language": "lt", "@value": "Drabužis apatinei kūno daliai dengti, gali apsaugoti nuo gamtos stichijų. Tipiški produktai: Laisvalaikio kelnės, lauko kelnės, kostiuminės kelnės, džinsai, sportinės kelnės, kapri kelnės, šortai." },
              { "@language": "lv", "@value": "Apģērbs ķermeņa apakšdaļas nosegšanai, var pasargāt no laikapstākļiem. Tipiski produkti: Ikdienas bikses, āra bikses, uzvalka bikses, džinsi, sporta bikses, kapri bikses, šorti." },
              { "@language": "mt", "@value": "Ilbies biex jgħatti l-parti t'isfel tal-ġisem, jista 'jipproteġi mill-elementi. Prodotti tipiċi: Qliezet każwali, qliezet ta' barra, qliezet formali, jeans, qliezet sportivi, qliezet capri, xorts." },
              { "@language": "nl", "@value": "Kledingstuk om het onderlichaam te bedekken, kan beschermen tegen weersomstandigheden. Typische producten: Casual broeken, outdoorbroeken, pantalons, jeans, sportbroeken, capribroeken, shorts." },
              { "@language": "pl", "@value": "Odzież zakrywająca dolną część ciała, mogąca chronić przed warunkami atmosferycznymi. Typowe produkty: Spodnie codzienne, spodnie outdoorowe, spodnie wyjściowe, dżinsy, spodnie sportowe, rybaczki, szorty." },
              { "@language": "pt", "@value": "Peça de vestuário para cobrir a parte inferior do corpo, pode proteger dos elementos. Produtos típicos: Calças casuais, calças de exterior, calças de fato, calças de ganga, calças de desporto, calças capri, calções." },
              { "@language": "ro", "@value": "Îmbrăcăminte pentru a acoperi partea inferioară a corpului, poate proteja de intemperii. Produse tipice: Pantaloni casual, pantaloni de exterior, pantaloni de costum, blugi, pantaloni sport, pantaloni capri, pantaloni scurți." },
              { "@language": "sk", "@value": "Odev na zakrytie spodnej časti tela, môže chrániť pred nepriaznivým počasím. Typické produkty: Ležérne nohavice, outdoorové nohavice, oblekové nohavice, džínsy, športové nohavice, capri nohavice, šortky." },
              { "@language": "sl", "@value": "Oblačilo za prekrivanje spodnjega dela telesa, lahko ščiti pred vremenskimi vplivi. Tipični izdelki: Priložnostne hlače, hlače za na prosto, elegantne hlače, kavbojke, športne hlače, kapri hlače, kratke hlače." },
              { "@language": "sv", "@value": "Plagg som täcker underkroppen, kan skydda mot väder och vind. Typiska produkter: Fritidsbyxor, friluftsbyxor, kostymbyxor, jeans, sportbyxor, capribyxor, shorts." }
            ]
        },
        {
            "@id": "dppk:PefcrDressesSkirtsAndJumpsuits",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Dresses, skirts and jumpsuits" },
              { "@language": "bg", "@value": "Рокли, поли и гащеризони" },
              { "@language": "cs", "@value": "Šaty, sukně a overaly" },
              { "@language": "da", "@value": "Kjoler, nederdele og jumpsuits" },
              { "@language": "de", "@value": "Kleider, Röcke und Jumpsuits" },
              { "@language": "el", "@value": "Φορέματα, φούστες και ολόσωμες φόρμες" },
              { "@language": "es", "@value": "Vestidos, faldas y monos" },
              { "@language": "et", "@value": "Kleidid, seelikud ja kombinesoonid" },
              { "@language": "fi", "@value": "Mekot, hameet ja haalarit" },
              { "@language": "fr", "@value": "Robes, jupes et combinaisons" },
              { "@language": "ga", "@value": "Gúnaí, sciortaí agus rabhlaeir" },
              { "@language": "hr", "@value": "Haljine, suknje i kombinezoni" },
              { "@language": "hu", "@value": "Ruhák, szoknyák és kezeslábasok" },
              { "@language": "it", "@value": "Abiti, gonne e tute" },
              { "@language": "lt", "@value": "Suknelės, sijonai ir kombinezonai" },
              { "@language": "lv", "@value": "Kleitas, svārki un kombinezoni" },
              { "@language": "mt", "@value": "Ilbiesi, dbielet u jumpsuits" },
              { "@language": "nl", "@value": "Jurken, rokken en jumpsuits" },
              { "@language": "pl", "@value": "Sukienki, spódnice i kombinezony" },
              { "@language": "pt", "@value": "Vestidos, saias e macacões" },
              { "@language": "ro", "@value": "Rochii, fuste și salopete" },
              { "@language": "sk", "@value": "Šaty, sukne a overaly" },
              { "@language": "sl", "@value": "Obleke, krila in kombinezoni" },
              { "@language": "sv", "@value": "Klänningar, kjolar och jumpsuits" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "One-piece garment that covers both the upper and lower body, or the lower body only, other than pants and shorts. Typical products included: Short- and long-sleeved, strapless, wrap, long and short, one-piece suits." },
              { "@language": "bg", "@value": "Цяла дреха, която покрива както горната, така и долната част на тялото, или само долната част, различна от панталони. Типични продукти: Къси и дълги ръкави, без презрамки, тип прегърни ме, дълги и къси, цели костюми." },
              { "@language": "cs", "@value": "Jednodílný oděv zakrývající horní i spodní část těla, nebo jen spodní část, s výjimkou kalhot a šortek. Typické produkty: S krátkým a dlouhým rukávem, bez ramínek, zavinovací, dlouhé a krátké, jednodílné obleky." },
              { "@language": "da", "@value": "Heldragt, der dækker både over- og underkrop, eller kun underkrop, bortset fra bukser og shorts. Typiske produkter: Kort- og langærmet, stropløs, slå-om, lang og kort, heldragter." },
              { "@language": "de", "@value": "Einteiliges Kleidungsstück, das sowohl den Ober- als auch den Unterkörper oder nur den Unterkörper bedeckt, ausgenommen Hosen und Shorts. Typische Produkte: Kurz- und langärmelig, trägerlos, Wickeloptik, lang und kurz, Einteiler." },
              { "@language": "el", "@value": "Μονοκόμματο ένδυμα που καλύπτει τόσο το πάνω όσο και το κάτω μέρος του σώματος ή μόνο το κάτω μέρος, εκτός από παντελόνια και σορτς. Τυπικά προϊόντα: Κοντομάνικα και μακρυμάνικα, στράπλες, κρουαζέ, μακριά και κοντά, ολόσωμες φόρμες." },
              { "@language": "es", "@value": "Prenda de una sola pieza que cubre tanto la parte superior como la inferior del cuerpo, o solo la parte inferior, distinta de pantalones y pantalones cortos. Productos típicos: De manga corta y larga, sin tirantes, cruzados, largos y cortos, monos de una pieza." },
              { "@language": "et", "@value": "Ühes tükis rõivaese, mis katab nii üla- kui alakeha või ainult alakeha, v.a püksid ja lühikesed püksid. Tüüpilised tooted: Lühikeste ja pikkade varrukatega, olapaelteta, hõlmik-, pikad ja lühikesed, ühes tükis kostüümid." },
              { "@language": "fi", "@value": "Yksiosainen vaate, joka peittää sekä ylä- että alavartalon, tai pelkän alavartalon, muu kuin housut ja shortsit. Tyypilliset tuotteet: Lyhyt- ja pitkähihaiset, olkaimettomat, kietaisumallit, pitkät ja lyhyet, yksiosaiset puvut." },
              { "@language": "fr", "@value": "Vêtement d'une seule pièce qui couvre à la fois le haut et le bas du corps, ou seulement le bas du corps, autre que les pantalons et les shorts. Produits typiques : À manches courtes et longues, sans bretelles, portefeuille, longs et courts, combinaisons une pièce." },
              { "@language": "ga", "@value": "Éadaí aon-phíosa a chlúdaíonn an corp uachtarach agus íochtarach, nó an corp íochtarach amháin, seachas brístí agus shorts. Táirgí tipiciúla: muinchille gearr agus fada, gan strapaí, wrap, fada agus gearr, culaith aon-phíosa." },
              { "@language": "hr", "@value": "Jednodijelni odjevni predmet koji pokriva gornji i donji dio tijela, ili samo donji dio, osim hlača i kratkih hlača. Tipični proizvodi: Kratkih i dugih rukava, bez naramenica, na preklop, dugi i kratki, jednodijelna odijela." },
              { "@language": "hu", "@value": "Egyrészes ruhadarab, amely mind a felső-, mind az alsótestet, vagy csak az alsótestet fedi, a nadrágok kivételével. Jellemző termékek: Rövid és hosszú ujjú, pánt nélküli, átlapolós, hosszú és rövid, egyrészes ruhák." },
              { "@language": "it", "@value": "Indumento in un solo pezzo che copre sia la parte superiore che quella inferiore del corpo, o solo la parte inferiore, diverso da pantaloni e pantaloncini. Prodotti tipici: A maniche corte e lunghe, senza spalline, a portafoglio, lunghi e corti, tute intere." },
              { "@language": "lt", "@value": "Vientisas drabužis, dengiantis ir viršutinę, ir apatinę kūno dalis, arba tik apatinę dalį, išskyrus kelnes ir šortus. Tipiški produktai: Trumpomis ir ilgomis rankovėmis, be petnešėlių, susiaučiami, ilgi ir trumpi, vientisi kostiumai." },
              { "@language": "lv", "@value": "Viengabala apģērbs, kas nosedz gan ķermeņa augšdaļu, gan apakšdaļu, vai tikai apakšdaļu, izņemot bikses un šortus. Tipiski produkti: Ar īsām un garām piedurknēm, bez lencītēm, pārliekami, gari un īsi, viengabala uzvalki." },
              { "@language": "mt", "@value": "Ilbies ta 'biċċa waħda li jkopri kemm il-parti ta' fuq kif ukoll ta 'isfel tal-ġisem, jew il-parti t'isfel biss, minbarra qliezet u xorts. Prodotti tipiċi: bi kmiem qosra u twal, mingħajr ċineg, wrap, twal u qosra, ilbiesi ta' biċċa waħda." },
              { "@language": "nl", "@value": "Eendelig kledingstuk dat zowel het boven- als onderlichaam bedekt, of alleen het onderlichaam, anders dan broeken en shorts. Typische producten: Met korte en lange mouwen, strapless, overslag, lang en kort, eendelige pakken." },
              { "@language": "pl", "@value": "Odzież jednoczęściowa zakrywająca górną i dolną część ciała lub tylko dolną część, inna niż spodnie i szorty. Typowe produkty: Z krótkim i długim rękawem, bez ramiączek, kopertowe, długie i krótkie, jednoczęściowe kombinezony." },
              { "@language": "pt", "@value": "Peça de vestuário de uma só peça que cobre tanto a parte superior como a inferior do corpo, ou apenas a parte inferior, que não sejam calças e calções. Produtos típicos: De manga curta e comprida, sem alças, traçados, compridos e curtos, fatos de uma só peça." },
              { "@language": "ro", "@value": "Îmbrăcăminte dintr-o singură piesă care acoperă atât partea superioară, cât și pe cea inferioară a corpului, sau doar partea inferioară, alta decât pantaloni și pantaloni scurți. Produse tipice: Cu mâneci scurte și lungi, fără bretele, parte peste parte, lungi și scurte, costume dintr-o singură piesă." },
              { "@language": "sk", "@value": "Jednodielny odev zakrývajúci hornú aj spodnú časť tela, alebo len spodnú časť, s výnimkou nohavíc a šortiek. Typické produkty: S krátkym a dlhým rukávom, bez ramienok, zavinovacie, dlhé a krátke, jednodielne overaly." },
              { "@language": "sl", "@value": "Enodelno oblačilo, ki prekriva zgornji in spodnji del telesa ali samo spodnji del, razen hlač in kratkih hlač. Tipični izdelki: S kratkimi in dolgimi rokavi, brez naramnic, na preklop, dolgi in kratki, enodelne obleke." },
              { "@language": "sv", "@value": "Heldräkt som täcker både över- och underkropp, eller endast underkropp, annat än byxor och shorts. Typiska produkter: Kort- och långärmade, axelbandslösa, omlott, långa och korta, heldräkter." }
            ]
        },
        {
            "@id": "dppk:PefcrLeggingsStockingsTightsAndSocks",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Leggings, stockings, tights and socks" },
              { "@language": "bg", "@value": "Клинове, чорапи, чорапогащи и къси чорапи" },
              { "@language": "cs", "@value": "Legíny, punčochy, punčocháče a ponožky" },
              { "@language": "da", "@value": "Leggings, strømper, strømpebukser og sokker" },
              { "@language": "de", "@value": "Leggings, Strümpfe, Strumpfhosen und Socken" },
              { "@language": "el", "@value": "Κολάν, κάλτσες, καλσόν και κοντές κάλτσες" },
              { "@language": "es", "@value": "Leggings, medias, pantimedias y calcetines" },
              { "@language": "et", "@value": "Säärised, sukad, sukkpüksid ja sokid" },
              { "@language": "fi", "@value": "Leggingsit, sukat, sukkahousut ja lyhyet sukat" },
              { "@language": "fr", "@value": "Leggings, bas, collants et chaussettes" },
              { "@language": "ga", "@value": "Luiteoga, stocaí, riteoga agus stocaí gearra" },
              { "@language": "hr", "@value": "Tajice, čarape, hulahopke i kratke čarape" },
              { "@language": "hu", "@value": "Leggings, harisnyák, harisnyanadrágok és zoknik" },
              { "@language": "it", "@value": "Leggings, calze, collant e calzini" },
              { "@language": "lt", "@value": "Tamprės, kojinės, pėdkelnės ir trumpos kojinės" },
              { "@language": "lv", "@value": "Legingi, zeķes, zeķubikses un īsās zeķes" },
              { "@language": "mt", "@value": "Leggings, kalzetti, tights u kalzetti qosra" },
              { "@language": "nl", "@value": "Leggings, kousen, panty's en sokken" },
              { "@language": "pl", "@value": "Leginsy, pończochy, rajstopy i skarpety" },
              { "@language": "pt", "@value": "Leggings, meias, collants e peúgas" },
              { "@language": "ro", "@value": "Colanți, ciorapi, dresuri și șosete" },
              { "@language": "sk", "@value": "Legíny, pančuchy, pančucháče a ponožky" },
              { "@language": "sl", "@value": "Pajkice, nogavice, hlačne nogavice in kratke nogavice" },
              { "@language": "sv", "@value": "Leggings, strumpor, strumpbyxor och sockor" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Tight garment to cover the legs and/or feet. Typical products included: Opaque and sheer tights, pantyhose, fishnets, ankle socks, knee socks, low-cut socks." },
              { "@language": "bg", "@value": "Плътно прилепнала дреха за покриване на краката и/или стъпалата. Типични продукти: Непрозрачни и прозрачни чорапогащи, мрежести, чорапи до глезена, чорапи до коляното, изрязани чорапи." },
              { "@language": "cs", "@value": "Přiléhavý oděv zakrývající nohy a/nebo chodidla. Typické produkty: Neprůhledné a průsvitné punčocháče, síťované punčochy, kotníkové ponožky, podkolenky, nízké ponožky." },
              { "@language": "da", "@value": "Stramtsiddende beklædningsgenstand til at dække ben og/eller fødder. Typiske produkter: Uigennemsigtige og gennemsigtige strømpebukser, netstrømper, ankelsokker, knæstrømper, lave sokker." },
              { "@language": "de", "@value": "Eng anliegendes Kleidungsstück zur Bedeckung der Beine und/oder Füße. Typische Produkte: Blickdichte und durchsichtige Strumpfhosen, Netzstrumpfhosen, Knöchelsocken, Kniestrümpfe, Füßlinge." },
              { "@language": "el", "@value": "Εφαρμοστό ένδυμα για την κάλυψη των ποδιών ή/και των πελμάτων. Τυπικά προϊόντα: Οπάκ και διάφανα καλσόν, διχτυωτά, καλτσάκια αστραγάλου, κάλτσες μέχρι το γόνατο, χαμηλές κάλτσες." },
              { "@language": "es", "@value": "Prenda ajustada para cubrir las piernas y/o los pies. Productos típicos: Medias opacas y transparentes, pantimedias, medias de rejilla, calcetines tobilleros, calcetines hasta la rodilla, calcetines cortos." },
              { "@language": "et", "@value": "Liibuv rõivaese jalgade ja/või jalalabade katmiseks. Tüüpilised tooted: Läbipaistmatud ja õhukesed sukkpüksid, võrksukad, sokid, põlvikud, madala lõikega sokid." },
              { "@language": "fi", "@value": "Tiukka vaate, joka peittää jalat ja/tai jalkaterät. Tyypilliset tuotteet: Peittävät ja ohuet sukkahousut, verkkosukat, nilkkasukat, polvisukat, matalat sukat." },
              { "@language": "fr", "@value": "Vêtement moulant pour couvrir les jambes et/ou les pieds. Produits typiques : Collants opaques et transparents, bas, résilles, socquettes, mi-bas, chaussettes basses." },
              { "@language": "ga", "@value": "Éadaí daingean chun na cosa agus/nó na cosa a chlúdach. Táirgí tipiciúla: Riteoga teimhneacha agus fórsa, pantyhose, eangacha éisc, stocaí rúitín, stocaí glúine, stocaí ísle." },
              { "@language": "hr", "@value": "Uski odjevni predmet za pokrivanje nogu i/ili stopala. Tipični proizvodi: Neprozirne i prozirne hulahopke, mrežaste čarape, čarape do gležnja, dokoljenke, niske čarape." },
              { "@language": "hu", "@value": "Szoros ruhadarab a lábak és/vagy lábfejek fedésére. Jellemző termékek: Átlátszatlan és áttetsző harisnyanadrágok, neccharisnyák, bokazoknik, térdzoknik, titokzoknik." },
              { "@language": "it", "@value": "Indumento aderente per coprire le gambe e/o i piedi. Prodotti tipici: Collant coprenti e velati, calze a rete, calzini alla caviglia, calzettoni, fantasmini." },
              { "@language": "lt", "@value": "Prie kūno priglundantis drabužis, skirtas kojoms ir (arba) pėdoms apdengti. Tipiški produktai: Nepermatomos ir permatomos pėdkelnės, tinklinės pėdkelnės, kojinės iki kulkšnies, puskojinės, žemos kojinės." },
              { "@language": "lv", "@value": "Cieši pieguļošs apģērbs kāju un/vai pēdu nosegšanai. Tipiski produkti: Necaurspīdīgas un caurspīdīgas zeķubikses, tīkliņzeķes, potīšu zeķes, zeķes līdz celim, pēdiņas." },
              { "@language": "mt", "@value": "Ilbies strett biex jgħatti s-saqajn u/jew is-saqajn. Prodotti tipiċi: Tights opaki u trasparenti, pantyhose, fishnets, kalzetti ta 'l-għaksa, kalzetti ta' l-irkoppa, kalzetti qosra." },
              { "@language": "nl", "@value": "Strak kledingstuk om de benen en/of voeten te bedekken. Typische producten: Ondoorzichtige en doorschijnende panty's, netkousen, enkelsokken, kniekousen, lage sokken." },
              { "@language": "pl", "@value": "Obcisła odzież zakrywająca nogi i/lub stopy. Typowe produkty: Nieprzezroczyste i przezroczyste rajstopy, kabaretki, skarpetki do kostki, podkolanówki, stopki." },
              { "@language": "pt", "@value": "Peça de vestuário justa para cobrir as pernas e/ou os pés. Produtos típicos: Collants opacos e transparentes, meias de rede, meias pelo tornozelo, meias até ao joelho, soquetes." },
              { "@language": "ro", "@value": "Îmbrăcăminte mulată pentru a acoperi picioarele și/sau tălpile. Produse tipice: Dresuri opace și transparente, ciorapi plasă, șosete până la gleznă, șosete până la genunchi, șosete scurte." },
              { "@language": "sk", "@value": "Priliehavý odev na zakrytie nôh a/alebo chodidiel. Typické produkty: Nepriehľadné a priesvitné pančucháče, sieťované pančuchy, ponožky po členky, podkolienky, nízke ponožky." },
              { "@language": "sl", "@value": "Tesno oblačilo za prekrivanje nog in/ali stopal. Tipični izdelki: Neprozorne in prosojne hlačne nogavice, mrežaste nogavice, nogavice do gležnja, dokolenke, nizke nogavice." },
              { "@language": "sv", "@value": "Åtsittande plagg för att täcka ben och/eller fötter. Typiska produkter: Ogenomskinliga och skira strumpbyxor, nätstrumpor, ankelsockor, knästrumpor, låga sockor." }
            ]
        },
        {
            "@id": "dppk:PefcrUnderwear",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Underwear" },
              { "@language": "bg", "@value": "Бельо" },
              { "@language": "cs", "@value": "Spodní prádlo" },
              { "@language": "da", "@value": "Undertøj" },
              { "@language": "de", "@value": "Unterwäsche" },
              { "@language": "el", "@value": "Εσώρουχα" },
              { "@language": "es", "@value": "Ropa interior" },
              { "@language": "et", "@value": "Aluspesu" },
              { "@language": "fi", "@value": "Alusvaatteet" },
              { "@language": "fr", "@value": "Sous-vêtements" },
              { "@language": "ga", "@value": "Fo-éadaí" },
              { "@language": "hr", "@value": "Donje rublje" },
              { "@language": "hu", "@value": "Alsónemű" },
              { "@language": "it", "@value": "Biancheria intima" },
              { "@language": "lt", "@value": "Apatiniai drabužiai" },
              { "@language": "lv", "@value": "Apakšveļa" },
              { "@language": "mt", "@value": "Ħwejjeġ ta' taħt" },
              { "@language": "nl", "@value": "Ondergoed" },
              { "@language": "pl", "@value": "Bielizna" },
              { "@language": "pt", "@value": "Roupa interior" },
              { "@language": "ro", "@value": "Lenjerie intimă" },
              { "@language": "sk", "@value": "Spodná bielizeň" },
              { "@language": "sl", "@value": "Spodnje perilo" },
              { "@language": "sv", "@value": "Underkläder" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garment worn under clothes, often next to the skin of the upper or lower body. Typical products included: Boxers, briefs, panties, bras, body-shaping suits." },
              { "@language": "bg", "@value": "Дреха, носена под дрехите, често до кожата на горната или долната част на тялото. Типични продукти: Боксерки, слипове, бикини, сутиени, оформящи костюми." },
              { "@language": "cs", "@value": "Oděv nošený pod oblečením, často přímo na kůži horní nebo spodní části těla. Typické produkty: Boxerky, slipy, kalhotky, podprsenky, tvarující oblečení." },
              { "@language": "da", "@value": "Beklædningsgenstand båret under tøj, ofte mod huden på over- eller underkroppen. Typiske produkter: Boxershorts, underbukser, trusser, bh'er, bodystockings." },
              { "@language": "de", "@value": "Kleidungsstück, das unter der Kleidung getragen wird, oft direkt auf der Haut des Ober- oder Unterkörpers. Typische Produkte: Boxershorts, Slips, Höschen, BHs, figurbetonte Anzüge." },
              { "@language": "el", "@value": "Ένδυμα που φοριέται κάτω από τα ρούχα, συχνά σε επαφή με το δέρμα του άνω ή κάτω μέρους του σώματος. Τυπικά προϊόντα: Μπόξερ, σλιπ, κιλότες, σουτιέν, κορσέδες." },
              { "@language": "es", "@value": "Prenda que se lleva debajo de la ropa, a menudo junto a la piel de la parte superior o inferior del cuerpo. Productos típicos: Bóxers, calzoncillos, bragas, sujetadores, trajes moldeadores." },
              { "@language": "et", "@value": "Rõivaese, mida kantakse riiete all, sageli vastu üla- või alakeha nahka. Tüüpilised tooted: Bokserid, püksikud, aluspüksid, rinnahoidjad, vormivad pesud." },
              { "@language": "fi", "@value": "Vaate, jota pidetään vaatteiden alla, usein ylä- tai alavartalon ihoa vasten. Tyypilliset tuotteet: Bokserit, alushousut, pikkuhousut, rintaliivit, muotoilevat asut." },
              { "@language": "fr", "@value": "Vêtement porté sous les vêtements, souvent à même la peau du haut ou du bas du corps. Produits typiques : Boxers, slips, culottes, soutiens-gorge, combinaisons sculptantes." },
              { "@language": "ga", "@value": "Éadaí a chaitear faoi éadaí, is minic in aice le craiceann an choirp uachtaraigh nó íochtair. Táirgí tipiciúla: dornálaithe, mionbhrístíní, mionbhrístíní, bras, cultacha múnlaithe coirp." },
              { "@language": "hr", "@value": "Odjevni predmet koji se nosi ispod odjeće, često uz kožu gornjeg ili donjeg dijela tijela. Tipični proizvodi: Bokserice, gaćice, ženske gaćice, grudnjaci, odijela za oblikovanje tijela." },
              { "@language": "hu", "@value": "Ruházat alatt, gyakran a felső- vagy alsótest bőrével érintkezve viselt ruhadarab. Jellemző termékek: Bokszeralsók, fecskék, női alsók, melltartók, alakformáló ruhák." },
              { "@language": "it", "@value": "Indumento indossato sotto i vestiti, spesso a contatto con la pelle della parte superiore o inferiore del corpo. Prodotti tipici: Boxer, slip, mutandine, reggiseni, body modellanti." },
              { "@language": "lt", "@value": "Drabužis, nešiojamas po drabužiais, dažnai prie viršutinės ar apatinės kūno dalies odos. Tipiški produktai: Bokseriai, glaudės, kelnaitės, liemenėlės, kūną formuojantys kostiumai." },
              { "@language": "lv", "@value": "Apģērbs, ko valkā zem drēbēm, bieži vien uz ķermeņa augšdaļas vai apakšdaļas ādas. Tipiski produkti: Bokseršorti, apenes, biksītes, krūšturi, ķermeni veidojoši tērpi." },
              { "@language": "mt", "@value": "Ilbies li jintlibes taħt il-ħwejjeġ, ħafna drabi ħdejn il-ġilda tal-parti ta 'fuq jew ta' isfel tal-ġisem. Prodotti tipiċi: Boxers, briefs, qliezet ta' taħt, bras, ilbiesi għat-tiswir tal-ġisem." },
              { "@language": "nl", "@value": "Kledingstuk gedragen onder kleding, vaak direct op de huid van het boven- of onderlichaam. Typische producten: Boxershorts, slips, slipjes, bh's, corrigerend ondergoed." },
              { "@language": "pl", "@value": "Odzież noszona pod ubraniem, często przy skórze górnej lub dolnej części ciała. Typowe produkty: Bokserki, slipy, majtki, biustonosze, body modelujące." },
              { "@language": "pt", "@value": "Peça de vestuário usada debaixo da roupa, frequentemente em contacto com a pele da parte superior ou inferior do corpo. Produtos típicos: Boxers, slips, cuecas, sutiãs, cintas modeladoras." },
              { "@language": "ro", "@value": "Îmbrăcăminte purtată pe sub haine, adesea pe pielea părții superioare sau inferioare a corpului. Produse tipice: Boxeri, chiloți, slipi, sutiene, costume modelatoare." },
              { "@language": "sk", "@value": "Odev nosený pod oblečením, často priamo na koži hornej alebo spodnej časti tela. Typické produkty: Boxerky, slipy, nohavičky, podprsenky, formovacie oblečenie." },
              { "@language": "sl", "@value": "Oblačilo, ki se nosi pod oblačili, pogosto ob koži zgornjega ali spodnjega dela telesa. Tipični izdelki: Boksarice, spodnje hlače, hlačke, nedrčki, oblačila za oblikovanje postave." },
              { "@language": "sv", "@value": "Plagg som bärs under kläder, ofta närmast huden på över- eller underkroppen. Typiska produkter: Kalsonger, trosor, bh:ar, figurformande plagg." }
            ]
        },
        {
            "@id": "dppk:PefcrSwimwear",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Swimwear" },
              { "@language": "bg", "@value": "Бански костюми" },
              { "@language": "cs", "@value": "Plavky" },
              { "@language": "da", "@value": "Badetøj" },
              { "@language": "de", "@value": "Bademode" },
              { "@language": "el", "@value": "Μαγιό" },
              { "@language": "es", "@value": "Ropa de baño" },
              { "@language": "et", "@value": "Ujumisriided" },
              { "@language": "fi", "@value": "Uimapuvut" },
              { "@language": "fr", "@value": "Maillots de bain" },
              { "@language": "ga", "@value": "Éadaí snámha" },
              { "@language": "hr", "@value": "Kupaći kostimi" },
              { "@language": "hu", "@value": "Fürdőruhák" },
              { "@language": "it", "@value": "Costumi da bagno" },
              { "@language": "lt", "@value": "Maudymosi apranga" },
              { "@language": "lv", "@value": "Peldkostīmi" },
              { "@language": "mt", "@value": "Ilbies għall-għawm" },
              { "@language": "nl", "@value": "Zwemkleding" },
              { "@language": "pl", "@value": "Stroje kąpielowe" },
              { "@language": "pt", "@value": "Fatos de banho" },
              { "@language": "ro", "@value": "Costume de baie" },
              { "@language": "sk", "@value": "Plavky" },
              { "@language": "sl", "@value": "Kopalke" },
              { "@language": "sv", "@value": "Badkläder" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garment worn for water-based or sunbased activities. Typical products included: Bikinis, bathing suits, racing-style swimwear, board shorts." },
              { "@language": "bg", "@value": "Дреха, носена за дейности на вода или слънце. Типични продукти: Бикини, бански костюми, състезателни бански, борд шорти." },
              { "@language": "cs", "@value": "Oděv nošený pro vodní nebo sluneční aktivity. Typické produkty: Bikiny, plavky, závodní plavky, koupací šortky." },
              { "@language": "da", "@value": "Beklædningsgenstand båret til vand- eller solbaserede aktiviteter. Typiske produkter: Bikinier, badedragter, konkurrencebadetøj, badeshorts." },
              { "@language": "de", "@value": "Kleidungsstück für Aktivitäten im Wasser oder in der Sonne. Typische Produkte: Bikinis, Badeanzüge, wettkampforientierte Bademode, Boardshorts." },
              { "@language": "el", "@value": "Ένδυμα που φοριέται για δραστηριότητες στο νερό ή στον ήλιο. Τυπικά προϊόντα: Μπικίνι, ολόσωμα μαγιό, αγωνιστικά μαγιό, σορτς κολύμβησης." },
              { "@language": "es", "@value": "Prenda que se lleva para actividades acuáticas o bajo el sol. Productos típicos: Bikinis, bañadores, trajes de baño de competición, pantalones cortos de baño." },
              { "@language": "et", "@value": "Rõivaese vee- või päikesepõhisteks tegevusteks. Tüüpilised tooted: Bikiinid, trikood, võistlusujumisriided, surfaripüksid." },
              { "@language": "fi", "@value": "Vaate, jota pidetään vesi- tai aurinkopohjaisissa aktiviteeteissa. Tyypilliset tuotteet: Bikinit, uimapuvut, kilpauimapuvut, uimashortsit." },
              { "@language": "fr", "@value": "Vêtement porté pour les activités aquatiques ou au soleil. Produits typiques : Bikinis, maillots de bain, maillots de bain de compétition, shorts de bain." },
              { "@language": "ga", "@value": "Éadaí a chaitear le haghaidh gníomhaíochtaí uisce nó gréine. Táirgí tipiciúla: Bikinis, feistis snámha, éadaí snámha rásaíochta, shorts boird." },
              { "@language": "hr", "@value": "Odjevni predmet koji se nosi za aktivnosti na vodi ili suncu. Tipični proizvodi: Bikiniji, kupaći kostimi, natjecateljski kupaći kostimi, kratke hlače za kupanje." },
              { "@language": "hu", "@value": "Vízi vagy napozási tevékenységekhez viselt ruhadarab. Jellemző termékek: Bikinik, fürdőruhák, versenydresszek, szörfnadrágok." },
              { "@language": "it", "@value": "Indumento indossato per attività acquatiche o al sole. Prodotti tipici: Bikini, costumi interi, costumi da bagno da gara, pantaloncini da surf." },
              { "@language": "lt", "@value": "Drabužis, skirtas vandens ar saulės vonių veiklai. Tipiški produktai: Bikiniai, maudymosi kostiumėliai, sportiniai maudymosi kostiumai, maudymosi šortai." },
              { "@language": "lv", "@value": "Apģērbs ūdens vai saules aktivitātēm. Tipiski produkti: Bikini, peldkostīmi, sporta peldkostīmi, peldšorti." },
              { "@language": "mt", "@value": "Ilbies milbus għal attivitajiet ibbażati fuq l-ilma jew fuq ix-xemx. Prodotti tipiċi: Bikinis, ilbiesi tal-għawm, ilbies għall-għawm stil tat-tlielaq, xorts tal-bord." },
              { "@language": "nl", "@value": "Kledingstuk gedragen voor water- of zongerelateerde activiteiten. Typische producten: Bikini's, badpakken, wedstrijdzwemkleding, zwemshorts." },
              { "@language": "pl", "@value": "Odzież noszona do aktywności w wodzie lub na słońcu. Typowe produkty: Bikini, kostiumy kąpielowe, stroje startowe, szorty kąpielowe." },
              { "@language": "pt", "@value": "Peça de vestuário usada para atividades aquáticas ou ao sol. Produtos típicos: Biquínis, fatos de banho, fatos de banho de competição, calções de banho." },
              { "@language": "ro", "@value": "Îmbrăcăminte purtată pentru activități acvatice sau la soare. Produse tipice: Bikini, costume de baie, costume de baie de competiție, șorturi de baie." },
              { "@language": "sk", "@value": "Odev nosený pri aktivitách vo vode alebo na slnku. Typické produkty: Bikiny, plavky, pretekárske plavky, kúpacie šortky." },
              { "@language": "sl", "@value": "Oblačilo za vodne aktivnosti ali sončenje. Tipični izdelki: Bikiniji, enodelne kopalke, tekmovalne kopalke, kopalne hlače." },
              { "@language": "sv", "@value": "Plagg som bärs för vatten- eller solbaserade aktiviteter. Typiska produkter: Bikinis, baddräkter, tävlingsbadkläder, badbyxor." }
            ]
        },
        {
            "@id": "dppk:PefcrApparelAccessories",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Apparel Accessories" },
              { "@language": "bg", "@value": "Аксесоари за облекло" },
              { "@language": "cs", "@value": "Oděvní doplňky" },
              { "@language": "da", "@value": "Beklædningstilbehør" },
              { "@language": "de", "@value": "Bekleidungszubehör" },
              { "@language": "el", "@value": "Αξεσουάρ ένδυσης" },
              { "@language": "es", "@value": "Accesorios de vestir" },
              { "@language": "et", "@value": "Rõivalisandid" },
              { "@language": "fi", "@value": "Vaateasusteet" },
              { "@language": "fr", "@value": "Accessoires vestimentaires" },
              { "@language": "ga", "@value": "Gabhálais Éadaí" },
              { "@language": "hr", "@value": "Odjevni dodaci" },
              { "@language": "hu", "@value": "Ruházati kiegészítők" },
              { "@language": "it", "@value": "Accessori di abbigliamento" },
              { "@language": "lt", "@value": "Drabužių priedai" },
              { "@language": "lv", "@value": "Apģērbu aksesuāri" },
              { "@language": "mt", "@value": "Aċċessorji tal-ilbies" },
              { "@language": "nl", "@value": "Kledingaccessoires" },
              { "@language": "pl", "@value": "Akcesoria odzieżowe" },
              { "@language": "pt", "@value": "Acessórios de vestuário" },
              { "@language": "ro", "@value": "Accesorii de îmbrăcăminte" },
              { "@language": "sk", "@value": "Odevné doplnky" },
              { "@language": "sl", "@value": "Oblačilni dodatki" },
              { "@language": "sv", "@value": "Klädtillbehör" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Garments for the head, neck, waist, or hands to protect from elements or secure clothing. Typical products included: Hats (Caps, flat caps, woollen hats/beanies, fedoras, panamas, bowlers, newsboys, berets), Scarves and ties (Warm and light scarves, buffs, neckerchiefs, headscarves, shawls, bowties), Belts (Dress belts, casual belts, buckle belts, tie-up belts, suspenders), Gloves and mittens (fingerless gloves, fashion gloves, outdoor sports gloves, mittens)." },
              { "@language": "bg", "@value": "Дрехи за главата, врата, талията или ръцете за предпазване от елементите или закрепване на дрехите. Типични включени продукти: Шапки (Кепета, каскети, вълнени шапки, федори, панами, бомбета, вестникарски шапки, барети), Шалове и вратовръзки (Топли и леки шалове, бъфове, кърпи за врат, забрадки, шалове за рамене, папионки), Колани (Официални колани, ежедневни колани, колани с катарами, колани за връзване, тиранти), Ръкавици и ръкавици без пръсти (ръкавици без пръсти, модни ръкавици, ръкавици за спорт на открито, ръкавици с един пръст)." },
              { "@language": "cs", "@value": "Oděvy na hlavu, krk, pas nebo ruce k ochraně před živly nebo k upevnění oděvu. Typické zahrnuté produkty: Klobouky (Čepice, bekovky, vlněné čepice/kulichy, fedory, panamáky, buřinky, baretky), Šály a kravaty (Teplé a lehké šály, nákrčníky, šátky na krk, šátky na hlavu, plédy, motýlky), Opasky (Společenské opasky, neformální opasky, opasky s přezkou, zavazovací opasky, šle), Rukavice a palčáky (rukavice bez prstů, módní rukavice, outdoorové sportovní rukavice, palčáky)." },
              { "@language": "da", "@value": "Beklædningsgenstande til hoved, hals, talje eller hænder for at beskytte mod vejret eller fastgøre tøj. Typiske produkter inkluderet: Hatte (Kasketter, flat caps, uldhuer/beanies, fedoraer, panamahatte, bowlerhatte, sixpences, baretter), Tørklæder og slips (Varme og lette tørklæder, halsedisser, halstørklæder, hovedtørklæder, sjaler, butterflys), Bælter (Kjolebælter, hverdagsbælter, spændebælter, bindebælter, seler), Handsker og luffer (fingerløse handsker, modehandsker, udendørs sportshandsker, luffer)." },
              { "@language": "de", "@value": "Kleidungsstücke für Kopf, Hals, Taille oder Hände zum Schutz vor den Elementen oder zur Befestigung von Kleidung. Typische Produkte: Hüte/Mützen (Kappen, Schiebermützen, Wollmützen/Beanies, Fedoras, Panamahüte, Melonen, Schirmmützen, Barette), Schals und Krawatten (Warme und leichte Schals, Schlauchtücher, Halstücher, Kopftücher, Umschlagtücher, Fliegen), Gürtel (Anzuggürtel, Freizeitgürtel, Schnallengürtel, Bindegürtel, Hosenträger), Handschuhe und Fäustlinge (fingerlose Handschuhe, Modehandschuhe, Outdoor-Sporthandschuhe, Fäustlinge)." },
              { "@language": "el", "@value": "Ενδύματα για το κεφάλι, τον λαιμό, τη μέση ή τα χέρια για προστασία από τα στοιχεία της φύσης ή για τη στερέωση ρούχων. Τυπικά προϊόντα που περιλαμβάνονται: Καπέλα (Τραγιάσκες, μάλλινοι σκούφοι, φεντόρες, παναμάδες, ημίψηλα, μπερέδες), Κασκόλ και γραβάτες (Ζεστά και ελαφριά κασκόλ, φουλάρια, μαντήλια λαιμού, μαντήλια κεφαλιού, σάλια, παπιγιόν), Ζώνες (Επίσημες ζώνες, καθημερινές ζώνες, ζώνες με αγκράφα, ζώνες που δένουν, τιράντες), Γάντια (γάντια χωρίς δάχτυλα, γάντια μόδας, γάντια υπαίθριων αθλημάτων, γάντια χωρίς χωρίσματα)." },
              { "@language": "es", "@value": "Prendas para la cabeza, el cuello, la cintura o las manos para proteger de los elementos o asegurar la ropa. Productos típicos incluidos: Sombreros (Gorras, gorras planas, gorros de lana/beanies, fedoras, panamás, bombines, boinas), Bufandas y corbatas (Bufandas cálidas y ligeras, bragas de cuello, pañuelos para el cuello, pañuelos para la cabeza, chales, pajaritas), Cinturones (Cinturones de vestir, cinturones informales, cinturones con hebilla, cinturones para anudar, tirantes), Guantes y manoplas (guantes sin dedos, guantes de moda, guantes para deportes al aire libre, manoplas)." },
              { "@language": "et", "@value": "Rõivaesemed peale, kaelale, vöökohale või kätele kaitseks ilmastikuolude eest või riiete kinnitamiseks. Tüüpilised tooted: Mütsid (Nokamütsid, läkiläkid, villased mütsid/kootud mütsid, kaabud, panamamütsid, kõvakübarad, baretid), Sallid ja lipsud (Soojad ja kerged sallid, torusallid, kaelarätikud, pearätikud, õlasallid, kikilipsud), Vööd (Ülikonnavööd, vabaajavööd, pandlaga vööd, seotavad vööd, traksid), Kindad ja käpikud (sõrmedeta kindad, moekindad, välispordikindad, käpikud)." },
              { "@language": "fi", "@value": "Päähän, kaulaan, vyötärölle tai käsiin tarkoitetut vaatteet säältä suojautumiseen tai vaatteiden kiinnittämiseen. Tyypillisiä tuotteita: Hatut (Lippalakit, lätsät, villapipot, fedorat, panamahatut, knallit, baskerit), Huivit ja solmiot (Lämpimät ja kevyet huivit, tuubihuivit, kaulahuivit, päänauhat, saalit, rusetit), Vyöt (Pukuvyöt, vapaa-ajan vyöt, solkivyöt, solmittavat vyöt, henkselit), Käsineet ja lapaset (sormettomat käsineet, muotikäsineet, ulkourheilukäsineet, lapaset)." },
              { "@language": "fr", "@value": "Vêtements pour la tête, le cou, la taille ou les mains afin de protéger des intempéries ou d'ajuster les vêtements. Produits typiques inclus : Chapeaux (Casquettes, casquettes plates, bonnets en laine, fedoras, panamas, chapeaux melons, gavroches, bérets), Écharpes et cravates (Écharpes chaudes et légères, tours de cou, foulards, foulards de tête, châles, nœuds papillon), Ceintures (Ceintures de costume, ceintures décontractées, ceintures à boucle, ceintures à nouer, bretelles), Gants et moufles (gants sans doigts, gants de mode, gants de sports d'extérieur, moufles)." },
              { "@language": "ga", "@value": "Baill éadaigh don cheann, muineál, coim, nó lámha chun éadaí a chosaint ó na heilimintí nó a dhaingniú. Táirgí tipiciúla san áireamh: Hataí (Caipíní, caipíní cothroma, hataí olann, fedoras, panamas, babhléirí, caipíní nuachtáin, bearéid), Scaifeanna agus carbhat (Scaifeanna te agus éadrom, buffs, muince, scaifeanna cloiginn, seálta, carbhait bhabha), Criosanna (Criosanna gúna, criosanna ócáideacha, criosanna búcla, criosanna comhionannas vótaí, crochadóirí), Lámhainní agus miotóga (lámhainní gan mhéara, lámhainní faisin, lámhainní spóirt amuigh faoin aer, miotóga)." },
              { "@language": "hr", "@value": "Odjevni predmeti za glavu, vrat, struk ili ruke za zaštitu od vremenskih nepogoda ili pričvršćivanje odjeće. Tipični proizvodi uključuju: Kape i šešire (Šilterice, ravne kape, vunene kape, fedore, panama šeširi, polucilindri, beretke), Šalove i kravate (Topli i lagani šalovi, marame za vrat, rubci, marame za glavu, šalovi za ramena, leptir mašne), Remenje (Svečano remenje, svakodnevno remenje, remenje s kopčom, remenje na vezivanje, naramenice), Rukavice (rukavice bez prstiju, modne rukavice, rukavice za sportove na otvorenom, rukavice s jednim prstom)." },
              { "@language": "hu", "@value": "A fej, nyak, derék vagy kezek fedésére szolgáló ruhadarabok az időjárás elleni védelem vagy a ruházat rögzítése céljából. Jellemző termékek: Kalapok és sapkák (Bellsapkák, lapos sapkák, gyapjúsapkák/kötött sapkák, fedorák, panamakalapok, keménykalapok, barett sapkák), Sálak és nyakkendők (Meleg és könnyű sálak, csősálak, nyakkendők, fejkendők, vállkendők, csokornyakkendők), Övek (Öltönyövek, hétköznapi övek, csatos övek, megkötős övek, nadrágtartók), Kesztyűk és egyujjas kesztyűk (ujj nélküli kesztyűk, divatkesztyűk, szabadtéri sportkesztyűk, egyujjas kesztyűk)." },
              { "@language": "it", "@value": "Indumenti per la testa, il collo, la vita o le mani per proteggere dalle intemperie o fissare i vestiti. Prodotti tipici inclusi: Cappelli (Berretti, coppole, cappelli di lana/berretti, fedora, panama, bombette, berretti da strillone, baschi), Sciarpe e cravatte (Sciarpe calde e leggere, scaldacollo, foulard, foulard per la testa, scialli, papillon), Cinture (Cinture eleganti, cinture casual, cinture con fibbia, cinture da annodare, bretelle), Guanti e muffole (guanti senza dita, guanti alla moda, guanti per sport all'aperto, muffole)." },
              { "@language": "lt", "@value": "Drabužiai galvai, kaklui, juosmeniui ar rankoms, skirti apsaugoti nuo stichijų ar pritvirtinti drabužius. Tipiški įtraukti produktai: Kepurės (Kepuraitės su snapeliu, plokščios kepurės, vilnonės kepurės, fedoros, panamos, katiliukai, laikraščių išnešiotojų kepurės, beretės), Šalikai ir kaklaraiščiai (Šilti ir lengvi šalikai, kaklo movos, kaklaskarės, skarelės, skaros, varlytės), Diržai (Kostiuminiai diržai, kasdieniai diržai, diržai su sagtimi, surišami diržai, petnešos), Pirštinės ir kumštinės pirštinės (pirštinės be pirštų, madingos pirštinės, lauko sporto pirštinės, kumštinės pirštinės)." },
              { "@language": "lv", "@value": "Apģērbs galvai, kaklam, viduklim vai rokām, lai pasargātu no laikapstākļiem vai nostiprinātu apģērbu. Tipiski iekļautie produkti: Cepures (Naģenes, plakanās naģenes, vilnas cepures, fedoras, panamas, katliņi, beretes), Šalles un kaklasaites (Siltas un vieglas šalles, tuneļšalles, kaklauti, lakati, lakati pleciem, tauriņi), Jostas (Uzvilkuma jostas, ikdienas jostas, jostas ar sprādzi, sasienamas jostas, bikšturi), Cimdi un dūraiņi (cimdi bez pirkstiem, modes cimdi, brīvdabas sporta cimdi, dūraiņi)." },
              { "@language": "mt", "@value": "Ħwejjeġ għar-ras, l-għonq, il-qadd, jew l-idejn biex jipproteġu minn elementi jew ħwejjeġ siguri. Prodotti tipiċi inklużi: Kpiepel (Brieret, brieret ċatti, kpiepel tas-suf/beanies, fedoras, panamas, bowlers, newsboys, berets), Xalpi u ingravati (Xalpi sħan u ħfief, buffs, mkatar tal-għonq, xalpi tar-ras, xalel, bowties), Ċinturini (Ċinturini tal-libsa, ċinturini każwali, ċinturini bil-bokkla, ċinturini tal-irbit, suspenders), Ingwanti u mittens (ingwanti mingħajr swaba, ingwanti tal-moda, ingwanti għall-isports fil-beraħ, mittens)." },
              { "@language": "nl", "@value": "Kledingstukken voor het hoofd, de hals, de taille of de handen ter bescherming tegen de elementen of om kleding vast te zetten. Typische producten inbegrepen: Hoeden (Petten, platte petten, wollen mutsen/beanies, fedora's, panama's, bolhoeden, newsboy-petten, baretten), Sjaals en dassen (Warme en lichte sjaals, colsjaals, halsdoeken, hoofddoeken, omslagdoeken, vlinderdassen), Riemen (Nette riemen, vrijetijdsriemen, gespriemen, strikriemen, bretels), Handschoenen en wanten (vingerloze handschoenen, modehandschoenen, buitensporthandschoenen, wanten)." },
              { "@language": "pl", "@value": "Odzież na głowę, szyję, talię lub dłonie w celu ochrony przed warunkami atmosferycznymi lub mocowania odzieży. Typowe produkty w zestawie: Czapki i kapelusze (Czapki z daszkiem, kaszkiety, czapki wełniane, fedory, panamy, meloniki, gawroszki, berety), Szaliki i krawaty (Ciepłe i lekkie szaliki, kominy, apaszki, chusty na głowę, szale, muchy), Paski (Paski wizytowe, paski na co dzień, paski z klamrą, paski wiązane, szelki), Rękawiczki i rękawice z jednym palcem (rękawiczki bez palców, rękawiczki modowe, rękawiczki do sportów na świeżym powietrzu, rękawice z jednym palcem)." },
              { "@language": "pt", "@value": "Peças de vestuário para a cabeça, pescoço, cintura ou mãos para proteger dos elementos ou fixar o vestuário. Produtos típicos incluídos: Chapéus (Bonés, boinas, gorros de lã, fedoras, panamás, chapéus-coco, boinas de ardina, boinas francesas), Cachecóis e gravatas (Cachecóis quentes e leves, golas, lenços de pescoço, lenços de cabeça, xales, laços), Cintos (Cintos de cerimónia, cintos casuais, cintos com fivela, cintos de atar, suspensórios), Luvas e mitenes (luvas sem dedos, luvas de moda, luvas para desportos ao ar livre, mitenes)." },
              { "@language": "ro", "@value": "Îmbrăcăminte pentru cap, gât, talie sau mâini pentru a proteja de intemperii sau pentru a asigura îmbrăcămintea. Produse tipice incluse: Pălării și șepci (Șepci, șepci plate, căciuli de lână, fedora, panama, melon, șepci de ziarist, berete), Eșarfe și cravate (Eșarfe calde și ușoare, fulare circulare, baticuri, eșarfe pentru cap, șaluri, papioane), Curele (Curele de costum, curele casual, curele cu cataramă, curele de legat, bretele), Mănuși (mănuși fără degete, mănuși de modă, mănuși pentru sporturi în aer liber, mănuși cu un deget)." },
              { "@language": "sk", "@value": "Odevy na hlavu, krk, pás alebo ruky na ochranu pred nepriaznivým počasím alebo zaistenie oblečenia. Typické zahrnuté produkty: Čiapky a klobúky (Šiltovky, bekovky, vlnené čiapky, fedory, panamáky, burinky, barety), Šály a kravaty (Teplé a ľahké šály, nákrčníky, šatky na krk, šatky na hlavu, plédy, motýliky), Opasky (Oblekové opasky, neformálne opasky, opasky s prackou, zaväzovacie opasky, traky), Rukavice a palčiaky (rukavice bez prstov, módne rukavice, outdoorové športové rukavice, palčiaky)." },
              { "@language": "sl", "@value": "Oblačila za glavo, vrat, pas ali roke za zaščito pred vremenskimi vplivi ali pritrditev oblačil. Tipični vključeni izdelki: Kape in klobuki (Kape s šiltom, baretke, volnene kape, fedore, paname, polcilindri, baretke), Šali in kravate (Topli in lahki šali, ovratni šali, rutke, naglavne rute, šali, metuljčki), Pasovi (Svečani pasovi, vsakodnevni pasovi, pasovi z zaponko, pasovi za zavezovanje, naramnice), Rokavice (rokavice brez prstov, modne rokavice, rokavice za športe na prostem, rokavice na en prst)." },
              { "@language": "sv", "@value": "Plagg för huvud, hals, midja eller händer för att skydda mot väder eller fästa kläder. Typiska produkter som ingår: Hattar och mössor (Kepsar, gubbkepsar, ullmössor/beanies, fedorahattar, panamahattar, plommonstop, newsboy-kepsar, baskrar), Halsdukar och slipsar (Varma och lätta halsdukar, tubhalsdukar, snusnesnäsar, huvuddukar, sjalar, flugor), Bälten (Kostymbälten, vardagsbälten, spännbälten, knytbälten, hängslen), Handskar och vantar (torgvantar, modehandskar, utomhussportvantar, tumvantar)." }
            ]
        },
        {
            "@id": "dppk:PefcrOpenToedShoes",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Open-toed shoes" },
              { "@language": "bg", "@value": "Обувки с отворени пръсти" },
              { "@language": "cs", "@value": "Boty s otevřenou špičkou" },
              { "@language": "da", "@value": "Sko med åben tå" },
              { "@language": "de", "@value": "Offene Schuhe" },
              { "@language": "el", "@value": "Παπούτσια ανοιχτά μπροστά" },
              { "@language": "es", "@value": "Zapatos con punta abierta" },
              { "@language": "et", "@value": "Lahtise ninaga kingad" },
              { "@language": "fi", "@value": "Avokärkiset kengät" },
              { "@language": "fr", "@value": "Chaussures à bout ouvert" },
              { "@language": "ga", "@value": "Bróga oscailte le ladhar" },
              { "@language": "hr", "@value": "Cipele s otvorenim prstima" },
              { "@language": "hu", "@value": "Nyitott orrú cipők" },
              { "@language": "it", "@value": "Scarpe spuntate" },
              { "@language": "lt", "@value": "Batai atvirais pirštais" },
              { "@language": "lv", "@value": "Kurpes ar vaļēju purngalu" },
              { "@language": "mt", "@value": "Żraben miftuħin" },
              { "@language": "nl", "@value": "Schoenen met open neus" },
              { "@language": "pl", "@value": "Buty z odkrytymi palcami" },
              { "@language": "pt", "@value": "Sapatos abertos à frente" },
              { "@language": "ro", "@value": "Încălțăminte decupată la vârf" },
              { "@language": "sk", "@value": "Topánky s otvorenou špičkou" },
              { "@language": "sl", "@value": "Čevlji z odprtimi prsti" },
              { "@language": "sv", "@value": "Skor med öppen tå" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Open-toed shoes, providing protection from the ground. Used in pairs. Typical products included: Flip-flops, casual /fashion sandals, sports sandals, slippers." },
              { "@language": "bg", "@value": "Обувки с отворени пръсти, осигуряващи защита от земята. Използват се по двойки. Типични включени продукти: Джапанки, ежедневни/модни сандали, спортни сандали, чехли." },
              { "@language": "cs", "@value": "Boty s otevřenou špičkou, poskytující ochranu od země. Používají se v párech. Typické zahrnuté produkty: Žabky, neformální/módní sandály, sportovní sandály, pantofle." },
              { "@language": "da", "@value": "Sko med åben tå, der giver beskyttelse mod jorden. Bruges i par. Typiske produkter inkluderet: Klipklapper, fritids-/modesandaler, sportssandaler, hjemmesko." },
              { "@language": "de", "@value": "Offene Schuhe, die Schutz vor dem Boden bieten. Werden paarweise getragen. Typische Produkte: Flip-Flops, Freizeit-/Modensandalen, Sportsandalen, Hausschuhe." },
              { "@language": "el", "@value": "Παπούτσια ανοιχτά μπροστά, που παρέχουν προστασία από το έδαφος. Χρησιμοποιούνται σε ζεύγη. Τυπικά προϊόντα που περιλαμβάνονται: Σαγιονάρες, καθημερινά/μοδάτα σανδάλια, αθλητικά σανδάλια, παντόφλες." },
              { "@language": "es", "@value": "Zapatos con punta abierta, que brindan protección contra el suelo. Se usan en pares. Productos típicos incluidos: Chanclas, sandalias informales/de moda, sandalias deportivas, zapatillas de casa." },
              { "@language": "et", "@value": "Lahtise ninaga kingad, mis pakuvad kaitset maapinna eest. Kasutatakse paaridena. Tüüpilised tooted: Plätud, vabaaja-/moesandaalid, spordisandaalid, sussid." },
              { "@language": "fi", "@value": "Avokärkiset kengät, jotka suojaavat jalkaa maalta. Käytetään pareittain. Tyypillisiä tuotteita: Varvassandaalit, vapaa-ajan/muotisandaalit, urheilusandaalit, tohvelit." },
              { "@language": "fr", "@value": "Chaussures à bout ouvert, offrant une protection contre le sol. Utilisées par paires. Produits typiques inclus : Tongs, sandales décontractées/de mode, sandales de sport, pantoufles." },
              { "@language": "ga", "@value": "Bróga le ladhar oscailte, a thugann cosaint ón talamh. Úsáidtear ina mbeirteanna. Táirgí tipiciúla san áireamh: Smeach-flops, sandals ócáideacha/faisin, sandals spóirt, slipéir." },
              { "@language": "hr", "@value": "Cipele s otvorenim prstima koje pružaju zaštitu od tla. Koriste se u paru. Tipični proizvodi uključuju: Japanke, ležerne/modne sandale, sportske sandale, papuče." },
              { "@language": "hu", "@value": "Nyitott orrú cipők, amelyek védelmet nyújtanak a talajjal szemben. Párban használatosak. Jellemző termékek: Strandpapucsok, hétköznapi/divatszandálok, sportszandálok, papucsok." },
              { "@language": "it", "@value": "Scarpe spuntate, che offrono protezione dal suolo. Usate in paia. Prodotti tipici inclusi: Infradito, sandali casual/alla moda, sandali sportivi, pantofole." },
              { "@language": "lt", "@value": "Batai atvirais pirštais, apsaugantys nuo žemės. Naudojami poromis. Tipiški įtraukti produktai: Paplūdimio šlepetės, kasdienės/madingos basutės, sportinės basutės, šlepetės." },
              { "@language": "lv", "@value": "Kurpes ar vaļēju purngalu, kas nodrošina aizsardzību no zemes. Izmanto pa pāriem. Tipiski iekļautie produkti: Vjetnamkas, ikdienas/modes sandales, sporta sandales, čības." },
              { "@language": "mt", "@value": "Żraben miftuħin, li jipprovdu protezzjoni mill-art. Użati f'pari. Prodotti tipiċi inklużi: Flip-flops, sandlijiet każwali/tal-moda, sandlijiet sportivi, papoċċi." },
              { "@language": "nl", "@value": "Schoenen met open neus, die bescherming bieden tegen de grond. Worden per paar gebruikt. Typische producten inbegrepen: Teenslippers, casual/mode sandalen, sportsandalen, pantoffels." },
              { "@language": "pl", "@value": "Buty z odkrytymi palcami, zapewniające ochronę przed podłożem. Używane w parach. Typowe produkty w zestawie: Klapki, sandały na co dzień/modowe, sandały sportowe, kapcie." },
              { "@language": "pt", "@value": "Sapatos abertos à frente, proporcionando proteção contra o solo. Usados em pares. Produtos típicos incluídos: Chinelos, sandálias casuais/de moda, sandálias de desporto, pantufas." },
              { "@language": "ro", "@value": "Încălțăminte decupată la vârf, care oferă protecție față de sol. Folosită în perechi. Produse tipice incluse: Șlapi, sandale casual/de modă, sandale sport, papuci de casă." },
              { "@language": "sk", "@value": "Topánky s otvorenou špičkou, poskytujúce ochranu pred zemou. Používajú sa v pároch. Typické zahrnuté produkty: Žabky, neformálne/módne sandále, športové sandále, papuče." },
              { "@language": "sl", "@value": "Čevlji z odprtimi prsti, ki zagotavljajo zaščito pred tlemi. Uporabljajo se v parih. Tipični vključeni izdelki: Japonke, vsakodnevni/modni sandali, športni sandali, copati." },
              { "@language": "sv", "@value": "Skor med öppen tå, ger skydd från marken. Används i par. Typiska produkter som ingår: Flip-flops, vardags-/modesandaler, sportsandaler, tofflor." }
            ]
        },

        {
            "@id": "dppk:PefcrClosedToedShoes",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Closed-toed shoes" },
              { "@language": "bg", "@value": "Обувки със затворени пръсти" },
              { "@language": "cs", "@value": "Boty s uzavřenou špičkou" },
              { "@language": "da", "@value": "Lukkede sko" },
              { "@language": "de", "@value": "Geschlossene Schuhe" },
              { "@language": "el", "@value": "Κλειστά παπούτσια" },
              { "@language": "es", "@value": "Zapatos cerrados" },
              { "@language": "et", "@value": "Kinnise ninaga kingad" },
              { "@language": "fi", "@value": "Umpikärkiset kengät" },
              { "@language": "fr", "@value": "Chaussures fermées" },
              { "@language": "ga", "@value": "Bróga dúnta" },
              { "@language": "hr", "@value": "Zatvorene cipele" },
              { "@language": "hu", "@value": "Zárt cipők" },
              { "@language": "it", "@value": "Scarpe chiuse" },
              { "@language": "lt", "@value": "Uždari batai" },
              { "@language": "lv", "@value": "Slēgtas kurpes" },
              { "@language": "mt", "@value": "Żraben magħluqa" },
              { "@language": "nl", "@value": "Gesloten schoenen" },
              { "@language": "pl", "@value": "Buty z zakrytymi palcami" },
              { "@language": "pt", "@value": "Sapatos fechados" },
              { "@language": "ro", "@value": "Încălțăminte închisă" },
              { "@language": "sk", "@value": "Topánky s uzavretou špičkou" },
              { "@language": "sl", "@value": "Zaprti čevlji" },
              { "@language": "sv", "@value": "Stängda skor" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Closed-toed shoes, providing protection from the ground. They may protect against water, the elements and/or heavy objects. Used in pairs. Typical products included: Slippers, tennis shoes, moccasins, espadrilles, sneakers, cleats, athletic shoes, dress shoes, protective toecap – toed shoes." },
              { "@language": "bg", "@value": "Обувки със затворени пръсти, осигуряващи защита от земята. Могат да предпазват от вода, елементите и/или тежки предмети. Използват се по двойки. Типични включени продукти: Чехли, обувки за тенис, мокасини, еспадрили, маратонки, бутонки, спортни обувки, официални обувки, обувки със защитно бомбе." },
              { "@language": "cs", "@value": "Boty s uzavřenou špičkou, poskytující ochranu od země. Mohou chránit před vodou, živly a/nebo těžkými předměty. Používají se v párech. Typické zahrnuté produkty: Pantofle, tenisové boty, mokasíny, espadrilky, tenisky, kopačky, sportovní obuv, společenská obuv, boty s ochrannou špičkou." },
              { "@language": "da", "@value": "Lukkede sko, der giver beskyttelse mod jorden. De kan beskytte mod vand, vejret og/eller tunge genstande. Bruges i par. Typiske produkter inkluderet: Hjemmesko, tennissko, mokkasiner, espadriller, sneakers, knopper, sportssko, pæne sko, sikkerhedssko." },
              { "@language": "de", "@value": "Geschlossene Schuhe, die Schutz vor dem Boden bieten. Sie können vor Wasser, den Elementen und/oder schweren Gegenständen schützen. Werden paarweise getragen. Typische Produkte: Hausschuhe, Tennisschuhe, Mokassins, Espadrilles, Sneakers, Stollenschuhe, Sportschuhe, Anzugschuhe, Sicherheitsschuhe mit Zehenkappe." },
              { "@language": "el", "@value": "Κλειστά παπούτσια, που παρέχουν προστασία από το έδαφος. Μπορούν να προστατεύσουν από νερό, καιρικές συνθήκες και/ή βαριά αντικείμενα. Χρησιμοποιούνται σε ζεύγη. Τυπικά προϊόντα που περιλαμβάνονται: Παντόφλες, παπούτσια τένις, μοκασίνια, εσπαντρίγιες, αθλητικά παπούτσια (sneakers), παπούτσια με τάπες, αθλητικά υποδήματα, επίσημα παπούτσια, παπούτσια με προστατευτικό δακτύλων." },
              { "@language": "es", "@value": "Zapatos cerrados, que brindan protección contra el suelo. Pueden proteger contra el agua, los elementos y/o objetos pesados. Se usan en pares. Productos típicos incluidos: Zapatillas de casa, zapatillas de tenis, mocasines, alpargatas, zapatillas de deporte, tacos, calzado deportivo, zapatos de vestir, zapatos con puntera protectora." },
              { "@language": "et", "@value": "Kinnise ninaga kingad, mis pakuvad kaitset maapinna eest. Võivad kaitsta vee, ilmastiku ja/või raskete esemete eest. Kasutatakse paaridena. Tüüpilised tooted: Sussid, tennised, mokassiinid, espadrillid, tossud, naelikud, spordijalatsid, viigikingad, turvaninaga kingad." },
              { "@language": "fi", "@value": "Umpikärkiset kengät, jotka suojaavat jalkaa maalta. Ne voivat suojata vedeltä, säältä ja/tai raskailta esineiltä. Käytetään pareittain. Tyypillisiä tuotteita: Tohvelit, tenniskengät, mokkasiinit, espadrillot, lenkkarit, nappulakengät, urheilukengät, pukukengät, turvakärkiset kengät." },
              { "@language": "fr", "@value": "Chaussures fermées, offrant une protection contre le sol. Elles peuvent protéger contre l'eau, les intempéries et/ou les objets lourds. Utilisées par paires. Produits typiques inclus : Pantoufles, chaussures de tennis, mocassins, espadrilles, baskets, crampons, chaussures de sport, chaussures de ville, chaussures à embout de protection." },
              { "@language": "ga", "@value": "Bróga dúnta, a thugann cosaint ón talamh. Féadfaidh siad cosaint a dhéanamh ar uisce, na heilimintí agus/nó rudaí troma. Úsáidtear ina mbeirteanna. Táirgí tipiciúla san áireamh: Slipéir, bróga leadóige, moccasins, espadrilles, sneakers, cleats, bróga lúthchleasa, bróga gúna, bróga le caipín cosanta." },
              { "@language": "hr", "@value": "Zatvorene cipele koje pružaju zaštitu od tla. Mogu štititi od vode, vremenskih neprilika i/ili teških predmeta. Koriste se u paru. Tipični proizvodi uključuju: Papuče, tenisice, mokasinke, espadrile, sportske tenisice, kopačke, atletske cipele, svečane cipele, cipele sa zaštitnom kapicom." },
              { "@language": "hu", "@value": "Zárt cipők, amelyek védelmet nyújtanak a talajjal szemben. Védhetnek a víztől, az időjárás viszontagságaitól és/vagy nehéz tárgyaktól. Párban használatosak. Jellemző termékek: Papucsok, teniszcipők, mokaszinok, espadrille-ek, tornacipők, stoplis cipők, sportcipők, alkalmi cipők, acélbetétes védőcipők." },
              { "@language": "it", "@value": "Scarpe chiuse, che offrono protezione dal suolo. Possono proteggere da acqua, intemperie e/o oggetti pesanti. Usate in paia. Prodotti tipici inclusi: Pantofole, scarpe da tennis, mocassini, espadrillas, scarpe da ginnastica, scarpe con tacchetti, scarpe sportive, scarpe eleganti, scarpe con puntale protettivo." },
              { "@language": "lt", "@value": "Uždari batai, apsaugantys nuo žemės. Gali apsaugoti nuo vandens, gamtos stichijų ir (arba) sunkių daiktų. Naudojami poromis. Tipiški įtraukti produktai: Šlepetės, teniso batai, mokasinai, espadrilės, sportbačiai, bucai, sporto batai, išeiginiai batai, batai su apsaugine nosimi." },
              { "@language": "lv", "@value": "Slēgtas kurpes, kas nodrošina aizsardzību no zemes. Var aizsargāt pret ūdeni, laikapstākļiem un/vai smagiem priekšmetiem. Izmanto pa pāriem. Tipiski iekļautie produkti: Čības, tenisa kurpes, mokasīni, espadrilas, kedas, buči, sporta apavi, izejamās kurpes, kurpes ar aizsargpurngalu." },
              { "@language": "mt", "@value": "Żraben magħluqa, li jipprovdu protezzjoni mill-art. Jistgħu jipproteġu mill-ilma, elementi u/jew oġġetti tqal. Użati f'pari. Prodotti tipiċi inklużi: Papoċċi, żraben tat-tennis, moccasins, espadrilles, sneakers, bitti, żraben atletiċi, żraben tal-libsa, żraben bil-ponta protettiva." },
              { "@language": "nl", "@value": "Gesloten schoenen, die bescherming bieden tegen de grond. Ze kunnen beschermen tegen water, de elementen en/of zware voorwerpen. Worden per paar gebruikt. Typische producten inbegrepen: Pantoffels, tennisschoenen, mocassins, espadrilles, sneakers, noppenschoenen, sportschoenen, nette schoenen, veiligheidsschoenen." },
              { "@language": "pl", "@value": "Buty z zakrytymi palcami, zapewniające ochronę przed podłożem. Mogą chronić przed wodą, warunkami atmosferycznymi i/lub ciężkimi przedmiotami. Używane w parach. Typowe produkty w zestawie: Kapcie, buty do tenisa, mokasyny, espadryle, sneakersy, korki, buty sportowe, wizytowe, buty z noskiem ochronnym." },
              { "@language": "pt", "@value": "Sapatos fechados, proporcionando proteção contra o solo. Podem proteger contra água, elementos e/ou objetos pesados. Usados em pares. Produtos típicos incluídos: Pantufas, sapatos de ténis, mocassins, alpercatas, sapatilhas, chuteiras, calçado desportivo, sapatos de cerimónia, sapatos com biqueira de proteção." },
              { "@language": "ro", "@value": "Încălțăminte închisă, care oferă protecție față de sol. Poate proteja de apă, intemperii și/sau obiecte grele. Folosită în perechi. Produse tipice incluse: Papuci de casă, pantofi de tenis, mocasini, espadrile, adidași, ghete cu crampoane, pantofi de sport, pantofi eleganți, pantofi cu bombeu de protecție." },
              { "@language": "sk", "@value": "Topánky s uzavretou špičkou, poskytujúce ochranu pred zemou. Môžu chrániť pred vodou, nepriaznivým počasím a/alebo ťažkými predmetmi. Používajú sa v pároch. Typické zahrnuté produkty: Papuče, tenisové topánky, mokasíny, espadrilky, tenisky, kopačky, športová obuv, spoločenská obuv, topánky s ochrannou špičkou." },
              { "@language": "sl", "@value": "Zaprti čevlji, ki zagotavljajo zaščito pred tlemi. Lahko ščitijo pred vodo, vremenskimi vplivi in/ali težkimi predmeti. Uporabljajo se v parih. Tipični vključeni izdelki: Copati, teniški copati, mokasini, espadrile, superge, kopačke, športni čevlji, svečani čevlji, čevlji z zaščitno kapico." },
              { "@language": "sv", "@value": "Stängda skor, ger skydd från marken. De kan skydda mot vatten, väder och/eller tunga föremål. Används i par. Typiska produkter som ingår: Tofflor, tennisskor, mockasiner, espadriller, sneakers, fotbollsskor, atletiska skor, finskor, skyddsskor med stålhätta." }
            ]
        },
        {
            "@id": "dppk:PefcrBoots",
            "@type": "dppk:PefcrCategoryValue",
            "rdfs:label": [
              { "@language": "en", "@value": "Boots" },
              { "@language": "bg", "@value": "Ботуши" },
              { "@language": "cs", "@value": "Kozačky/boty" },
              { "@language": "da", "@value": "Støvler" },
              { "@language": "de", "@value": "Stiefel" },
              { "@language": "el", "@value": "Μπότες" },
              { "@language": "es", "@value": "Botas" },
              { "@language": "et", "@value": "Saapad" },
              { "@language": "fi", "@value": "Saappaat" },
              { "@language": "fr", "@value": "Bottes" },
              { "@language": "ga", "@value": "Buataisí" },
              { "@language": "hr", "@value": "Čizme" },
              { "@language": "hu", "@value": "Csizmák" },
              { "@language": "it", "@value": "Stivali" },
              { "@language": "lt", "@value": "Batai (auliniai)" },
              { "@language": "lv", "@value": "Zābaki" },
              { "@language": "mt", "@value": "Stvali" },
              { "@language": "nl", "@value": "Laarzen" },
              { "@language": "pl", "@value": "Buty/Kozaki" },
              { "@language": "pt", "@value": "Botas" },
              { "@language": "ro", "@value": "Cizme" },
              { "@language": "sk", "@value": "Čižmy/topánky" },
              { "@language": "sl", "@value": "Škornji" },
              { "@language": "sv", "@value": "Stövlar" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Boots that cover the ankle, providing protection from the ground. They may protect against water, the elements, heavy objects and/or ankle injuries. Used in pairs. Typical products included: Polymer boots, winter boots, hiking boots, dress boots, protective toecap - toed boots." },
              { "@language": "bg", "@value": "Ботуши, които покриват глезена и осигуряват защита от земята. Могат да предпазват от вода, елементите, тежки предмети и/или наранявания на глезена. Използват се по двойки. Типични включени продукти: Полимерни ботуши, зимни ботуши, туристически обувки, официални ботуши, ботуши със защитно бомбе." },
              { "@language": "cs", "@value": "Boty, které zakrývají kotník a poskytují ochranu od země. Mohou chránit před vodou, živly, těžkými předměty a/nebo zraněním kotníku. Používají se v párech. Typické zahrnuté produkty: Polymerové boty, zimní boty, turistické boty, společenské boty, boty s ochrannou špičkou." },
              { "@language": "da", "@value": "Støvler, der dækker anklen, og giver beskyttelse fra jorden. De kan beskytte mod vand, elementerne, tunge genstande og/eller ankelskader. Bruges i par. Typiske produkter inkluderet: Polymerstøvler, vinterstøvler, vandrestøvler, pæne støvler, støvler med beskyttende tåkappe." },
              { "@language": "de", "@value": "Stiefel, die den Knöchel bedecken und Schutz vor dem Boden bieten. Sie können vor Wasser, den Elementen, schweren Gegenständen und/oder Knöchelverletzungen schützen. Werden paarweise getragen. Typische Produkte: Polymerstiefel, Winterstiefel, Wanderstiefel, Anzugstiefel, Stiefel mit Zehenschutzkappe." },
              { "@language": "el", "@value": "Μπότες που καλύπτουν τον αστράγαλο, παρέχοντας προστασία από το έδαφος. Μπορούν να προστατεύσουν από το νερό, τα στοιχεία της φύσης, βαριά αντικείμενα ή/και τραυματισμούς στον αστράγαλο. Χρησιμοποιούνται σε ζευγάρια. Τυπικά προϊόντα που περιλαμβάνονται: Μπότες από πολυμερές, χειμερινές μπότες, μπότες πεζοπορίας, επίσημες μπότες, μπότες με προστατευτικό κάλυμμα δακτύλων." },
              { "@language": "es", "@value": "Botas que cubren el tobillo, proporcionando protección del suelo. Pueden proteger contra el agua, los elementos, objetos pesados y/o lesiones en el tobillo. Se usan en pares. Productos típicos incluidos: Botas de polímero, botas de invierno, botas de senderismo, botas de vestir, botas con puntera protectora." },
              { "@language": "et", "@value": "Saapad, mis katavad pahkluu ja pakuvad kaitset maapinna eest. Võivad kaitsta vee, ilmastikuolude, raskete esemete ja/või pahkluuvigastuste eest. Kantakse paaris. Tüüpilised tooted: Polümeersaapad, talvesaapad, matkasaapad, viigisaapad, kaitsevarbaga saapad." },
              { "@language": "fi", "@value": "Nilkan peittävät saappaat, jotka antavat suojaa maalta. Voivat suojata vedeltä, säältä, raskailta esineiltä ja/tai nilkkavammoilta. Käytetään pareittain. Tyypillisiä tuotteita ovat: Polymeerisaappaat, talvisaappaat, vaelluskengät, pukusaappaat, turvakärjellä varustetut saappaat." },
              { "@language": "fr", "@value": "Bottes qui couvrent la cheville, offrant une protection par rapport au sol. Elles peuvent protéger de l'eau, des intempéries, des objets lourds et/ou des blessures à la cheville. Portées par paires. Produits typiques inclus : Bottes en polymère, bottes d'hiver, chaussures de randonnée, bottes habillées, bottes avec embout de protection." },
              { "@language": "ga", "@value": "Buataisí a chlúdaíonn an rúitín, a thugann cosaint ón talamh. D'fhéadfadh siad cosaint a dhéanamh i gcoinne uisce, na heilimintí, rudaí troma agus/nó gortuithe rúitín. Úsáidtear ina mbeirteanna. Táirgí tipiciúla san áireamh: Buataisí polaiméire, buataisí geimhridh, buataisí fánaíochta, buataisí gúna, buataisí le caipín cosanta." },
              { "@language": "hr", "@value": "Čizme koje prekrivaju gležanj, pružajući zaštitu od tla. Mogu štititi od vode, vremenskih neprilika, teških predmeta i/ili ozljeda gležnja. Koriste se u paru. Tipični proizvodi uključuju: Polimerne čizme, zimske čizme, planinarske cipele, svečane čizme, čizme sa zaštitnom kapicom." },
              { "@language": "hu", "@value": "Bokát takaró csizmák, amelyek védelmet nyújtanak a talajjal szemben. Védhetnek a víztől, az időjárás viszontagságaitól, nehéz tárgyaktól és/vagy a boka sérüléseitől. Párban használatosak. Jellemző termékek: Polimer csizmák, téli csizmák, túrabakancsok, alkalmi csizmák, acélbetétes védőcsizmák." },
              { "@language": "it", "@value": "Stivali che coprono la caviglia, offrendo protezione dal suolo. Possono proteggere da acqua, intemperie, oggetti pesanti e/o lesioni alla caviglia. Usati in paia. Prodotti tipici inclusi: Stivali in polimero, stivali invernali, scarponi da trekking, stivali eleganti, stivali con puntale protettivo." },
              { "@language": "lt", "@value": "Batai, dengiantys kulkšnį ir apsaugantys nuo žemės. Gali apsaugoti nuo vandens, gamtos stichijų, sunkių daiktų ir (arba) kulkšnies sužalojimų. Naudojami poromis. Tipiški įtraukti produktai: Polimeriniai batai, žieminiai batai, žygio batai, išeiginiai batai, batai su apsaugine nosimi." },
              { "@language": "lv", "@value": "Zābaki, kas nosedz potīti, nodrošinot aizsardzību no zemes. Var aizsargāt pret ūdeni, laikapstākļiem, smagiem priekšmetiem un/vai potīšu traumām. Izmanto pa pāriem. Tipiski iekļautie produkti: Polimēra zābaki, ziemas zābaki, pārgājienu zābaki, izejamie zābaki, zābaki ar aizsargpurngalu." },
              { "@language": "mt", "@value": "Stvali li jkopru l-għaksa, u jipprovdu protezzjoni mill-art. Jistgħu jipproteġu mill-ilma, elementi, oġġetti tqal u/jew korrimenti fl-għaksa. Użati f'pari. Prodotti tipiċi inklużi: Stvali tal-polimeru, stvali tax-xitwa, stvali tal-mixi, stvali tal-libsa, stvali bil-ponta protettiva." },
              { "@language": "nl", "@value": "Laarzen die de enkel bedekken en bescherming bieden tegen de grond. Ze kunnen beschermen tegen water, de elementen, zware voorwerpen en/of enkelblessures. Worden per paar gebruikt. Typische producten inbegrepen: Polymeerlaarzen, winterlaarzen, wandelschoenen, nette laarzen, laarzen met beschermende neus." },
              { "@language": "pl", "@value": "Buty zakrywające kostkę, zapewniające ochronę przed podłożem. Mogą chronić przed wodą, warunkami atmosferycznymi, ciężkimi przedmiotami i/lub urazami kostki. Używane w parach. Typowe produkty w zestawie: Buty polimerowe, buty zimowe, buty trekkingowe, eleganckie kozaki, buty z noskiem ochronnym." },
              { "@language": "pt", "@value": "Botas que cobrem o tornozelo, proporcionando proteção contra o solo. Podem proteger contra água, elementos, objetos pesados e/ou lesões no tornozelo. Usadas em pares. Produtos típicos incluídos: Botas de polímero, botas de inverno, botas de caminhada, botas de cerimónia, botas com biqueira de proteção." },
              { "@language": "ro", "@value": "Cizme care acoperă glezna, oferind protecție față de sol. Pot proteja de apă, intemperii, obiecte grele și/sau leziuni ale gleznei. Folosite în perechi. Produse tipice incluse: Cizme din polimer, cizme de iarnă, bocanci de drumeție, cizme elegante, cizme cu bombeu de protecție." },
              { "@language": "sk", "@value": "Topánky, ktoré zakrývajú členok a poskytujú ochranu pred zemou. Môžu chrániť pred vodou, nepriaznivým počasím, ťažkými predmetmi a/alebo zranením členku. Používajú sa v pároch. Typické zahrnuté produkty: Polymérové topánky, zimné topánky, turistické topánky, spoločenské topánky, topánky s ochrannou špičkou." },
              { "@language": "sl", "@value": "Škornji, ki prekrivajo gleženj in zagotavljajo zaščito pred tlemi. Lahko ščitijo pred vodo, vremenskimi vplivi, težkimi predmeti in/ali poškodbami gležnja. Uporabljajo se v parih. Tipični vključeni izdelki: Polimerni škornji, zimski škornji, pohodniški čevlji, svečani škornji, škornji z zaščitno kapico." },
              { "@language": "sv", "@value": "Stövlar som täcker vristen och ger skydd från marken. De kan skydda mot vatten, väder, tunga föremål och/eller vristskador. Används i par. Typiska produkter som ingår: Polymerstövlar, vinterstövlar, vandringskängor, finskor av stöveltyp, skyddsstövlar med stålhätta." }
            ]
        },
        {
            "@id": "dppk:textileCertifications",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Textile ESPR Conformity Certifications" },
              { "@language": "bg", "@value": "Сертификати за съответствие на текстила с ESPR" },
              { "@language": "cs", "@value": "Certifikace shody textilu s ESPR" },
              { "@language": "da", "@value": "Tekstil ESPR overensstemmelsescertifikater" },
              { "@language": "de", "@value": "ESPR-Konformitätszertifikate für Textilien" },
              { "@language": "el", "@value": "Πιστοποιήσεις συμμόρφωσης κλωστοϋφαντουργικών προϊόντων με ESPR" },
              { "@language": "es", "@value": "Certificaciones de conformidad ESPR textil" },
              { "@language": "et", "@value": "Tekstiili ESPR vastavussertifikaadid" },
              { "@language": "fi", "@value": "Tekstiilien ESPR-vaatimustenmukaisuussertifikaatit" },
              { "@language": "fr", "@value": "Certifications de conformité ESPR des textiles" },
              { "@language": "ga", "@value": "Deimhnithe Comhréireachta ESPR Teicstíle" },
              { "@language": "hr", "@value": "Certifikati o sukladnosti tekstila s ESPR-om" },
              { "@language": "hu", "@value": "Textil ESPR megfelelőségi tanúsítványok" },
              { "@language": "it", "@value": "Certificazioni di conformità ESPR per prodotti tessili" },
              { "@language": "lt", "@value": "Tekstilės ESPR atitikties sertifikatai" },
              { "@language": "lv", "@value": "Tekstilizstrādājumu ESPR atbilstības sertifikāti" },
              { "@language": "mt", "@value": "Ċertifikazzjonijiet tal-Konformità ESPR tat-Tessuti" },
              { "@language": "nl", "@value": "Textiel ESPR conformiteitscertificaten" },
              { "@language": "pl", "@value": "Certyfikaty zgodności tekstyliów z ESPR" },
              { "@language": "pt", "@value": "Certificações de conformidade ESPR de têxteis" },
              { "@language": "ro", "@value": "Certificate de conformitate ESPR pentru textile" },
              { "@language": "sk", "@value": "Certifikáty zhody textilu s ESPR" },
              { "@language": "sl", "@value": "Certifikati o skladnosti tekstila z ESPR" },
              { "@language": "sv", "@value": "Textil ESPR överensstämmelseintyg" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Certifications specifically verifying ESPR textile claims (e.g. recycled content, recyclability, mechanical properties)." },
              { "@language": "bg", "@value": "Сертификати, потвърждаващи специфични ESPR твърдения за текстил (напр. съдържание на рециклирани материали, рециклируемост, механични свойства)." },
              { "@language": "cs", "@value": "Certifikace výslovně ověřující tvrzení ESPR o textilu (např. obsah recyklovaného materiálu, recyklovatelnost, mechanické vlastnosti)." },
              { "@language": "da", "@value": "Certificeringer, der specifikt verificerer ESPR tekstilpåstande (f.eks. genanvendt indhold, genanvendelighed, mekaniske egenskaber)." },
              { "@language": "de", "@value": "Zertifizierungen zur spezifischen Überprüfung von ESPR-Textilbehauptungen (z. B. Anteil an recyceltem Material, Recyclingfähigkeit, mechanische Eigenschaften)." },
              { "@language": "el", "@value": "Πιστοποιήσεις που επαληθεύουν συγκεκριμένα τους ισχυρισμούς ESPR για κλωστοϋφαντουργικά προϊόντα (π.χ. περιεχόμενο ανακυκλωμένου υλικού, ανακυκλωσιμότητα, μηχανικές ιδιότητες)." },
              { "@language": "es", "@value": "Certificaciones que verifican específicamente las declaraciones de textiles ESPR (p. ej., contenido reciclado, reciclabilidad, propiedades mecánicas)." },
              { "@language": "et", "@value": "Sertifikaadid, mis kontrollivad konkreetselt ESPR-i tekstiilinõudeid (nt ringlussevõetud sisu, ringlussevõetavus, mehaanilised omadused)." },
              { "@language": "fi", "@value": "Sertifikaatit, joilla todennetaan erityisesti ESPR-tekstiiliväitteet (esim. kierrätyssisältö, kierrätettävyys, mekaaniset ominaisuudet)." },
              { "@language": "fr", "@value": "Certifications vérifiant spécifiquement les allégations ESPR relatives aux textiles (par ex. contenu recyclé, recyclabilité, propriétés mécaniques)." },
              { "@language": "ga", "@value": "Deimhnithe a fhíoraíonn go sonrach éilimh teicstíle ESPR (e.g. ábhar athchúrsáilte, in-athchúrsáilteacht, airíonna meicniúla)." },
              { "@language": "hr", "@value": "Certifikati kojima se posebno potvrđuju tvrdnje o tekstilu u okviru ESPR-a (npr. reciklirani sadržaj, reciklabilnost, mehanička svojstva)." },
              { "@language": "hu", "@value": "A textíliákra vonatkozó ESPR-állításokat kifejezetten igazoló tanúsítványok (pl. újrahasznosított tartalom, újrahasznosíthatóság, mechanikai tulajdonságok)." },
              { "@language": "it", "@value": "Certificazioni che verificano specificamente le dichiarazioni sui tessili ESPR (ad es. contenuto riciclato, riciclabilità, proprietà meccaniche)." },
              { "@language": "lt", "@value": "Sertifikatai, kuriais konkrečiai patikrinami ESPR su tekstile susiję teiginiai (pvz., perdirbto turinio dalis, perdirbamumas, mechaninės savybės)." },
              { "@language": "lv", "@value": "Sertifikāti, kas īpaši pārbauda ESPR apgalvojumus par tekstilizstrādājumiem (piem., reciklēts saturs, pārstrādājamība, mehāniskās īpašības)." },
              { "@language": "mt", "@value": "Ċertifikazzjonijiet li jivverifikaw speċifikament it-talbiet tat-tessuti tal-ESPR (eż. kontenut riċiklat, riċiklabbiltà, proprjetajiet mekkaniċi)." },
              { "@language": "nl", "@value": "Certificeringen die specifiek de ESPR-textielclaims verifiëren (bijv. gerecycleerde inhoud, recyclebaarheid, mechanische eigenschappen)." },
              { "@language": "pl", "@value": "Certyfikaty weryfikujące w szczególności oświadczenia dotyczące tekstyliów ESPR (np. zawartość materiałów z recyklingu, przydatność do recyklingu, właściwości mechaniczne)." },
              { "@language": "pt", "@value": "Certificações que verificam especificamente as alegações da ESPR sobre os têxteis (por ex., conteúdo reciclado, reciclabilidade, propriedades mecânicas)." },
              { "@language": "ro", "@value": "Certificări care verifică în mod specific mențiunile ESPR referitoare la textile (de ex. conținut reciclat, reciclabilitate, proprietăți mecanice)." },
              { "@language": "sk", "@value": "Certifikácie výslovne overujúce tvrdenia ESPR o textile (napr. obsah recyklovaného materiálu, recyklovateľnosť, mechanické vlastnosti)." },
              { "@language": "sl", "@value": "Certifikati, ki posebej preverjajo trditve ESPR o tekstilu (npr. vsebnost recikliranega materiala, možnost recikliranja, mehanske lastnosti)." },
              { "@language": "sv", "@value": "Certifieringar som specifikt verifierar ESPR-textilpåståenden (t.ex. återvunnet innehåll, återvinningsbarhet, mekaniska egenskaper)." }
            ],
