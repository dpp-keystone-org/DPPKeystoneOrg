        {
            "@id": "dppk:textileEndOfLifeInstructions",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Textile End of Life Instructions" },
              { "@language": "bg", "@value": "Инструкции за края на жизнения цикъл на текстила" },
              { "@language": "cs", "@value": "Pokyny pro konec životnosti textilu" },
              { "@language": "da", "@value": "Anvisninger for udtjente tekstiler" },
              { "@language": "de", "@value": "Anweisungen für das Ende der Lebensdauer von Textilien" },
              { "@language": "el", "@value": "Οδηγίες για το τέλος του κύκλου ζωής των υφασμάτων" },
              { "@language": "es", "@value": "Instrucciones sobre el fin de vida del tejido" },
              { "@language": "et", "@value": "Tekstiili olelusringi lõpu juhised" },
              { "@language": "fi", "@value": "Tekstiilin elinkaaren lopun ohjeet" },
              { "@language": "fr", "@value": "Instructions sur la fin de vie des textiles" },
              { "@language": "ga", "@value": "Treoracha ag Deireadh Ré na dTeicstílí" },
              { "@language": "hr", "@value": "Upute za kraj životnog vijeka tekstila" },
              { "@language": "hu", "@value": "Textil életciklusának végére vonatkozó utasítások" },
              { "@language": "it", "@value": "Istruzioni per il fine vita dei tessuti" },
              { "@language": "lt", "@value": "Tekstilės eksploatavimo pabaigos instrukcijos" },
              { "@language": "lv", "@value": "Tekstilizstrādājumu kalpošanas laika beigu norādījumi" },
              { "@language": "mt", "@value": "Istruzzjonijiet dwar it-Tmiem tal-Ħajja tat-Tessut" },
              { "@language": "nl", "@value": "Instructies voor het einde van de levensduur van textiel" },
              { "@language": "pl", "@value": "Instrukcje dotyczące zakończenia cyklu życia wyrobów włókienniczych" },
              { "@language": "pt", "@value": "Instruções de fim de vida dos têxteis" },
              { "@language": "ro", "@value": "Instrucțiuni privind sfârșitul ciclului de viață al textilelor" },
              { "@language": "sk", "@value": "Pokyny na konci životnosti textílií" },
              { "@language": "sl", "@value": "Navodila za konec življenjske dobe tekstila" },
              { "@language": "sv", "@value": "Anvisningar för uttjänta textilier" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Instructions for the proper disassembly, recycling, or disposal of the textile product at the end of its life." },
              { "@language": "bg", "@value": "Инструкции за правилното разглобяване, рециклиране или изхвърляне на текстилния продукт в края на жизнения му цикъл." },
              { "@language": "cs", "@value": "Pokyny pro správnou demontáž, recyklaci nebo likvidaci textilního výrobku na konci jeho životnosti." },
              { "@language": "da", "@value": "Anvisninger for korrekt demontering, genanvendelse eller bortskaffelse af tekstilproduktet ved slutningen af dets levetid." },
              { "@language": "de", "@value": "Anweisungen für die ordnungsgemäße Demontage, das Recycling oder die Entsorgung des Textilprodukts am Ende seiner Lebensdauer." },
              { "@language": "el", "@value": "Οδηγίες για τη σωστή αποσυναρμολόγηση, ανακύκλωση ή απόρριψη του κλωστοϋφαντουργικού προϊόντος στο τέλος της ζωής του." },
              { "@language": "es", "@value": "Instrucciones para el correcto desmontaje, reciclaje o eliminación del producto textil al final de su vida útil." },
              { "@language": "et", "@value": "Juhised tekstiiltoote nõuetekohaseks demonteerimiseks, ringlussevõtuks või kõrvaldamiseks selle olelusringi lõpus." },
              { "@language": "fi", "@value": "Ohjeet tekstiilituotteen asianmukaiseen purkamiseen, kierrätykseen tai hävittämiseen sen elinkaaren lopussa." },
              { "@language": "fr", "@value": "Instructions pour le démontage, le recyclage ou l'élimination appropriés du produit textile à la fin de sa vie." },
              { "@language": "ga", "@value": "Treoracha maidir le díchóimeáil, athchúrsáil nó diúscairt cheart an táirge teicstíle ag deireadh a shaolré." },
              { "@language": "hr", "@value": "Upute za pravilno rastavljanje, recikliranje ili odlaganje tekstilnog proizvoda na kraju njegovog životnog vijeka." },
              { "@language": "hu", "@value": "Útmutatások a textiltermék életciklusának végén történő megfelelő szétszereléshez, újrahasznosításhoz vagy ártalmatlanításhoz." },
              { "@language": "it", "@value": "Istruzioni per il corretto smontaggio, riciclaggio o smaltimento del prodotto tessile alla fine del suo ciclo di vita." },
              { "@language": "lt", "@value": "Tinkamo tekstilės gaminio išardymo, perdirbimo ar šalinimo pasibaigus jo eksploatavimo laikui instrukcijos." },
              { "@language": "lv", "@value": "Norādījumi par tekstilizstrādājuma pareizu demontāžu, pārstrādi vai apglabāšanu tā kalpošanas laika beigās." },
              { "@language": "mt", "@value": "Istruzzjonijiet għaż-żarmar, ir-riċiklaġġ jew ir-rimi xieraq tal-prodott tat-tessut fi tmiem ħajtu." },
              { "@language": "nl", "@value": "Instructies voor de juiste demontage, recycling of verwijdering van het textielproduct aan het einde van zijn levensduur." },
              { "@language": "pl", "@value": "Instrukcje dotyczące prawidłowego demontażu, recyklingu lub utylizacji wyrobu włókienniczego po zakończeniu jego cyklu życia." },
              { "@language": "pt", "@value": "Instruções para a desmontagem, reciclagem ou eliminação adequada do produto têxtil no fim da sua vida útil." },
              { "@language": "ro", "@value": "Instrucțiuni pentru dezasamblarea, reciclarea sau eliminarea corespunzătoare a produsului textil la sfârșitul duratei sale de viață." },
              { "@language": "sk", "@value": "Pokyny na správnu demontáž, recykláciu alebo likvidáciu textilného výrobku na konci jeho životnosti." },
              { "@language": "sl", "@value": "Navodila za pravilno razstavljanje, recikliranje ali odstranjevanje tekstilnega izdelka ob koncu njegove življenjske dobe." },
              { "@language": "sv", "@value": "Anvisningar för korrekt demontering, återvinning eller bortskaffande av textilprodukten i slutet av dess livslängd." }
            ],
            "dppk:governedBy": "Best Practice",
            "dcterms:source": {
