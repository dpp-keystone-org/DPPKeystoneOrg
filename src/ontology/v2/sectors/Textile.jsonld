            "rdfs:comment": [
              { "@language": "en", "@value": "The type of activity performed (e.g., Spinning, Weaving, Dyeing)." },
              { "@language": "bg", "@value": "Видът на извършената дейност (напр. предене, тъкане, боядисване)." },
              { "@language": "cs", "@value": "Typ prováděné činnosti (např. předení, tkaní, barvení)." },
              { "@language": "da", "@value": "Den type aktivitet, der udføres (f.eks. spinding, vævning, farvning)." },
              { "@language": "de", "@value": "Die Art der durchgeführten Tätigkeit (z. B. Spinnen, Weben, Färben)." },
              { "@language": "el", "@value": "Το είδος της δραστηριότητας που εκτελείται (π.χ. κλώσιμο, ύφανση, βαφή)." },
              { "@language": "es", "@value": "El tipo de actividad realizada (por ejemplo, hilado, tejido, teñido)." },
              { "@language": "et", "@value": "Tehtud tegevuse liik (nt ketramine, kudumine, värvimine)." },
              { "@language": "fi", "@value": "Suoritetun toiminnan tyyppi (esim. kehräys, kudonta, värjäys)." },
              { "@language": "fr", "@value": "Le type d'activité réalisée (par ex., filage, tissage, teinture)." },
              { "@language": "ga", "@value": "An cineál gníomhaíochta a dhéantar (m.sh., Sníomh, Fíodóireacht, Ruaimniú)." },
              { "@language": "hr", "@value": "Vrsta obavljene aktivnosti (npr. predenje, tkanje, bojenje)." },
              { "@language": "hu", "@value": "A végzett tevékenység típusa (pl. fonás, szövés, festés)." },
              { "@language": "it", "@value": "Il tipo di attività svolta (ad es. filatura, tessitura, tintura)." },
              { "@language": "lt", "@value": "Atliktos veiklos tipas (pvz., verpimas, audimas, dažymas)." },
              { "@language": "lv", "@value": "Veiktās darbības veids (piemēram, vērpšana, aušana, krāsošana)." },
              { "@language": "mt", "@value": "It-tip ta' attività mwettqa (eż., Għażil, Insiġ, Żebgħa)." },
              { "@language": "nl", "@value": "Het type activiteit dat is uitgevoerd (bijv. spinnen, weven, verven)." },
              { "@language": "pl", "@value": "Rodzaj wykonywanej działalności (np. przędzenie, tkanie, farbowanie)." },
              { "@language": "pt", "@value": "O tipo de atividade realizada (por exemplo, fiação, tecelagem, tingimento)." },
              { "@language": "ro", "@value": "Tipul de activitate desfășurată (de ex., filare, țesere, vopsire)." },
              { "@language": "sk", "@value": "Typ vykonávanej činnosti (napr. pradenie, tkanie, farbenie)." },
              { "@language": "sl", "@value": "Vrsta izvedene dejavnosti (npr. predenje, tkanje, barvanje)." },
              { "@language": "sv", "@value": "Typ av utförd aktivitet (t.ex. spinning, vävning, färgning)." }
            ],
