            "rdfs:label": [
              { "@language": "en", "@value": "PEFCR Category" },
              { "@language": "bg", "@value": "Категория PEFCR" },
              { "@language": "cs", "@value": "Kategorie PEFCR" },
              { "@language": "da", "@value": "PEFCR-kategori" },
              { "@language": "de", "@value": "PEFCR-Kategorie" },
              { "@language": "el", "@value": "Κατηγορία PEFCR" },
              { "@language": "es", "@value": "Categoría PEFCR" },
              { "@language": "et", "@value": "PEFCR-kategooria" },
              { "@language": "fi", "@value": "PEFCR-luokka" },
              { "@language": "fr", "@value": "Catégorie PEFCR" },
              { "@language": "ga", "@value": "Catagóir PEFCR" },
              { "@language": "hr", "@value": "Kategorija PEFCR" },
              { "@language": "hu", "@value": "PEFCR-kategória" },
              { "@language": "it", "@value": "Categoria PEFCR" },
              { "@language": "lt", "@value": "PEFCR kategorija" },
