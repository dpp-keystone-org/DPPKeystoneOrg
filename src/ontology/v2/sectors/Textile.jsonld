            "rdfs:comment": [
              { "@language": "en", "@value": "The average final product weight including trims, in kilograms." },
              { "@language": "bg", "@value": "Средното крайно тегло на продукта, включително гарнитурите, в килограми." },
              { "@language": "cs", "@value": "Průměrná konečná hmotnost produktu včetně ozdob v kilogramech." },
              { "@language": "da", "@value": "Den gennemsnitlige slutproduktvægt inklusive besætninger i kg." },
              { "@language": "de", "@value": "Das durchschnittliche Endproduktgewicht einschließlich Besätzen in Kilogramm." },
              { "@language": "el", "@value": "Το μέσο τελικό βάρος του προϊόντος συμπεριλαμβανομένων των διακοσμητικών, σε κιλά." },
              { "@language": "es", "@value": "El peso medio final del producto, incluidos los adornos, en kilogramos." },
              { "@language": "et", "@value": "Keskmine lõpptoote kaal koos kaunistustega kilodes." },
              { "@language": "fi", "@value": "Keskimääräinen lopputuotteen paino koristeet mukaan lukien kilogrammoina." },
              { "@language": "fr", "@value": "Le poids moyen du produit final, y compris les garnitures, en kilogrammes." },
              { "@language": "ga", "@value": "Meánmheáchan an táirge deiridh lena n-áirítear baill mhaisiúcháin, i gcileagraim." },
              { "@language": "hr", "@value": "Prosječna konačna težina proizvoda, uključujući ukrase, u kilogramima." },
              { "@language": "hu", "@value": "A termék átlagos végső súlya a díszítésekkel együtt, kilogrammban." },
              { "@language": "it", "@value": "Il peso medio del prodotto finale compresi i rifinimenti, in chilogrammi." },
              { "@language": "lt", "@value": "Vidutinis galutinio produkto svoris įskaitant apdailą, kilogramais." },
              { "@language": "lv", "@value": "Vidējais galaprodukta svars, ieskaitot apdari, kilogramos." },
              { "@language": "mt", "@value": "Il-piż medju tal-prodott finali inklużi t-trims, f'kilogrammi." },
              { "@language": "nl", "@value": "Het gemiddelde eindgewicht van het product inclusief afwerking, in kilogram." },
              { "@language": "pl", "@value": "Średnia masa końcowa produktu wraz z wykończeniami w kilogramach." },
              { "@language": "pt", "@value": "O peso médio do produto final, incluindo os acabamentos, em quilogramas." },
              { "@language": "ro", "@value": "Greutatea medie a produsului final, inclusiv garniturile, în kilograme." },
              { "@language": "sk", "@value": "Priemerná konečná hmotnosť produktu vrátane ozdôb v kilogramoch." },
