            "rdfs:comment": [
              { "@language": "en", "@value": "Instructions and guidelines for the safe use and maintenance of the textile product." },
              { "@language": "bg", "@value": "Инструкции и насоки за безопасна употреба и поддръжка на текстилния продукт." },
              { "@language": "cs", "@value": "Pokyny a směrnice pro bezpečné používání a údržbu textilního výrobku." },
              { "@language": "da", "@value": "Anvisninger og retningslinjer for sikker brug og vedligeholdelse af tekstilproduktet." },
              { "@language": "de", "@value": "Anweisungen und Richtlinien für die sichere Verwendung und Pflege des Textilprodukts." },
              { "@language": "el", "@value": "Οδηγίες και κατευθυντήριες γραμμές για την ασφαλή χρήση και συντήρηση του κλωστοϋφαντουργικού προϊόντος." },
