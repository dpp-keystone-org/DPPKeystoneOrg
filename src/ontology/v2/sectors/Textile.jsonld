              { "@language": "hr", "@value": "Upute za popravak tekstila" },
              { "@language": "hu", "@value": "Textiljavítási útmutató" },
              { "@language": "it", "@value": "Istruzioni per la riparazione dei tessuti" },
              { "@language": "lt", "@value": "Tekstilės taisymo instrukcijos" },
              { "@language": "lv", "@value": "Tekstilizstrādājumu labošanas norādījumi" },
              { "@language": "mt", "@value": "Istruzzjonijiet dwar it-Tiswija tat-Tessuti" },
              { "@language": "nl", "@value": "Reparatie-instructies voor textiel" },
              { "@language": "pl", "@value": "Instrukcje naprawy wyrobów włókienniczych" },
              { "@language": "pt", "@value": "Instruções de reparação de têxteis" },
              { "@language": "ro", "@value": "Instrucțiuni de reparare a textilelor" },
              { "@language": "sk", "@value": "Pokyny na opravu textílií" },
              { "@language": "sl", "@value": "Navodila za popravilo tekstila" },
              { "@language": "sv", "@value": "Reparationsanvisningar för textil" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Instructions on how to repair or replace components of the textile product." },
              { "@language": "bg", "@value": "Инструкции как да се ремонтират или заменят компоненти на текстилния продукт." },
              { "@language": "cs", "@value": "Pokyny, jak opravit nebo vyměnit součásti textilního výrobku." },
              { "@language": "da", "@value": "Anvisninger i, hvordan man reparerer eller udskifter komponenter i tekstilproduktet." },
              { "@language": "de", "@value": "Anweisungen zur Reparatur oder zum Austausch von Komponenten des Textilprodukts." },
              { "@language": "el", "@value": "Οδηγίες σχετικά με τον τρόπο επισκευής ή αντικατάστασης εξαρτημάτων του κλωστοϋφαντουργικού προϊόντος." },
              { "@language": "es", "@value": "Instrucciones sobre cómo reparar o sustituir los componentes del producto textil." },
              { "@language": "et", "@value": "Juhised selle kohta, kuidas parandada või asendada tekstiiltoote komponente." },
              { "@language": "fi", "@value": "Ohjeet tekstiilituotteen osien korjaamiseen tai vaihtamiseen." },
              { "@language": "fr", "@value": "Instructions sur la façon de réparer ou de remplacer les composants du produit textile." },
              { "@language": "ga", "@value": "Treoracha maidir le conas comhpháirteanna den táirge teicstíle a dheisiú nó a athsholáthar." },
              { "@language": "hr", "@value": "Upute o tome kako popraviti ili zamijeniti komponente tekstilnog proizvoda." },
              { "@language": "hu", "@value": "Útmutatás a textiltermék alkatrészeinek javításához vagy cseréjéhez." },
              { "@language": "it", "@value": "Istruzioni su come riparare o sostituire i componenti del prodotto tessile." },
              { "@language": "lt", "@value": "Instrukcijos, kaip taisyti ar keisti tekstilės gaminio komponentus." },
              { "@language": "lv", "@value": "Norādījumi par tekstilizstrādājuma sastāvdaļu labošanu vai nomaiņu." },
              { "@language": "mt", "@value": "Istruzzjonijiet dwar kif jissewwew jew jinbidlu komponenti tal-prodott tat-tessut." },
              { "@language": "nl", "@value": "Instructies voor het repareren of vervangen van onderdelen van het textielproduct." },
              { "@language": "pl", "@value": "Instrukcje dotyczące sposobów naprawy lub wymiany elementów wyrobu włókienniczego." },
              { "@language": "pt", "@value": "Instruções sobre como reparar ou substituir componentes do produto têxtil." },
              { "@language": "ro", "@value": "Instrucțiuni privind modul de reparare sau înlocuire a componentelor produsului textil." },
              { "@language": "sk", "@value": "Pokyny, ako opraviť alebo vymeniť komponenty textilného výrobku." },
              { "@language": "sl", "@value": "Navodila za popravilo ali zamenjavo sestavnih delov tekstilnega izdelka." },
              { "@language": "sv", "@value": "Anvisningar om hur man reparerar eller byter ut komponenter i textilprodukten." }
            ],
            "dppk:governedBy": "Best Practice",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0142",
