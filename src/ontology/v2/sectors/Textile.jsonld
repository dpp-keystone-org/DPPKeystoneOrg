              { "@language": "it", "@value": "Il codice del paese (ISO 3166-1 alpha-3) in cui si è svolta la fase di produzione." },
              { "@language": "lt", "@value": "Šalies, kurioje vyko gamybos etapas, kodas (ISO 3166-1 alfa-3)." },
              { "@language": "lv", "@value": "Valsts kods (ISO 3166-1 alfa-3), kurā norisinājās ražošanas posms." },
              { "@language": "mt", "@value": "Il-kodiċi tal-pajjiż (ISO 3166-1 alpha-3) fejn seħħ il-pass tal-produzzjoni." },
              { "@language": "nl", "@value": "De landcode (ISO 3166-1 alpha-3) waar de productiestap heeft plaatsgevonden." },
              { "@language": "pl", "@value": "Kod kraju (ISO 3166-1 alfa-3), w którym miał miejsce etap produkcji." },
              { "@language": "pt", "@value": "O código do país (ISO 3166-1 alfa-3) onde a etapa de produção ocorreu." },
              { "@language": "ro", "@value": "Codul țării (ISO 3166-1 alfa-3) unde a avut loc etapa de producție." },
              { "@language": "sk", "@value": "Kód krajiny (ISO 3166-1 alfa-3), v ktorej sa uskutočnil výrobný krok." },
              { "@language": "sl", "@value": "Koda države (ISO 3166-1 alpha-3), kjer se je zgodil korak proizvodnje." },
              { "@language": "sv", "@value": "Landskoden (ISO 3166-1 alpha-3) där produktionssteget ägde rum." }
            ],
