            "rdfs:comment": [
              { "@language": "en", "@value": "A numeric score representing the product's robustness (typically 0-10 scale)." },
              { "@language": "bg", "@value": "Цифрова оценка, представяща здравината на продукта (обикновено по скала от 0 до 10)." },
              { "@language": "cs", "@value": "Číselné skóre představující robustnost produktu (obvykle na stupnici 0-10)." },
              { "@language": "da", "@value": "En numerisk score, der repræsenterer produktets robusthed (typisk en skala fra 0-10)." },
              { "@language": "de", "@value": "Eine numerische Bewertung, die die Robustheit des Produkts darstellt (normalerweise auf einer Skala von 0 bis 10)." },
              { "@language": "el", "@value": "Μια αριθμητική βαθμολογία που αντιπροσωπεύει την ευρωστία του προϊόντος (συνήθως σε κλίμακα 0-10)." },
              { "@language": "es", "@value": "Una puntuación numérica que representa la robustez del producto (generalmente en una escala de 0 a 10)." },
              { "@language": "et", "@value": "Numbriline skoor, mis tähistab toote tugevust (tavaliselt skaalal 0-10)." },
              { "@language": "fi", "@value": "Numeerinen pistemäärä, joka edustaa tuotteen vankkuutta (yleensä asteikolla 0-10)." },
              { "@language": "fr", "@value": "Un score numérique représentant la robustesse du produit (généralement sur une échelle de 0 à 10)." },
              { "@language": "ga", "@value": "Scór uimhriúil a sheasann do stóinseacht an táirge (scála 0-10 de ghnáth)." },
              { "@language": "hr", "@value": "Brojčana ocjena koja predstavlja robusnost proizvoda (obično na ljestvici od 0 do 10)." },
              { "@language": "hu", "@value": "A termék robusztusságát jelző numerikus pontszám (általában 0-10 közötti skálán)." },
              { "@language": "it", "@value": "Un punteggio numerico che rappresenta la robustezza del prodotto (tipicamente su una scala da 0 a 10)." },
              { "@language": "lt", "@value": "Skaitinis balas, atspindintis produkto tvirtumą (paprastai 0–10 skalėje)." },
              { "@language": "lv", "@value": "Skaitlisks rādītājs, kas atspoguļo produkta izturību (parasti skalā no 0 līdz 10)." },
              { "@language": "mt", "@value": "Punteġġ numeriku li jirrappreżenta r-robustezza tal-prodott (tipikament skala 0-10)." },
              { "@language": "nl", "@value": "Een numerieke score die de robuustheid van het product weergeeft (meestal op een schaal van 0-10)." },
              { "@language": "pl", "@value": "Ocena liczbowa reprezentująca wytrzymałość produktu (zwykle w skali 0-10)." },
              { "@language": "pt", "@value": "Uma pontuação numérica que representa a robustez do produto (normalmente em uma escala de 0 a 10)." },
              { "@language": "ro", "@value": "Un scor numeric care reprezintă robustețea produsului (în mod normal, pe o scară de la 0 la 10)." },
              { "@language": "sk", "@value": "Číselné skóre predstavujúce robustnosť produktu (zvyčajne na stupnici 0-10)." },
              { "@language": "sl", "@value": "Številčna ocena, ki predstavlja robustnost izdelka (običajno na lestvici od 0 do 10)." },
              { "@language": "sv", "@value": "Ett numeriskt betyg som representerar produktens robusthet (vanligtvis på en skala 0-10)." }
            ],
