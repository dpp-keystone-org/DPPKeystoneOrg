              { "@language": "sl", "@value": "Vrsta odpadkov pred uporabo" },
              { "@language": "sv", "@value": "Typ av avfall före konsumentledet" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "The classification or source of the pre-consumer waste used for recycled content." },
              { "@language": "bg", "@value": "Класификацията или източникът на отпадъка преди потреблението, използван за рециклирано съдържание." },
              { "@language": "cs", "@value": "Klasifikace nebo zdroj předspotřebitelského odpadu použitého pro recyklovaný obsah." },
              { "@language": "da", "@value": "Klassificeringen eller kilden til affaldet fra før forbrugerleddet, der anvendes til genbrugt indhold." },
              { "@language": "de", "@value": "Die Klassifizierung oder Herkunft des Pre-Consumer-Abfalls, der für den Recyclinganteil verwendet wird." },
              { "@language": "el", "@value": "Η ταξινόμηση ή η πηγή των απορριμμάτων πριν από την κατανάλωση που χρησιμοποιούνται για το ανακυκλωμένο περιεχόμενο." },
              { "@language": "es", "@value": "La clasificación o procedencia de los residuos preconsumo utilizados para el contenido reciclado." },
              { "@language": "et", "@value": "Ringlussevõetud sisuks kasutatud tarbijaeelse jäätme klassifikatsioon või allikas." },
              { "@language": "fi", "@value": "Kierrätettyyn sisältöön käytetyn kuluttajaa edeltävän jätteen luokitus tai lähde." },
              { "@language": "fr", "@value": "La classification ou la source des déchets pré-consommation utilisés pour le contenu recyclé." },
              { "@language": "ga", "@value": "Aicmiú nó foinse na dramhaíola réamhthomhaltóra a úsáidtear don ábhar athchúrsáilte." },
              { "@language": "hr", "@value": "Klasifikacija ili izvor otpada prije potrošnje koji se koristi za reciklirani sadržaj." },
              { "@language": "hu", "@value": "Az újrahasznosított tartalomhoz felhasznált fogyasztás előtti hulladék besorolása vagy forrása." },
              { "@language": "it", "@value": "La classificazione o la fonte del rifiuto pre-consumo utilizzato per il contenuto riciclato." },
              { "@language": "lt", "@value": "Prieš vartojimą atsirandančių atliekų, naudojamų perdirbtam turiniui, klasifikacija arba šaltinis." },
              { "@language": "lv", "@value": "Pirms patērētāja atkritumu, kas izmantoti pārstrādātam saturam, klasifikācija vai avots." },
              { "@language": "mt", "@value": "Il-klassifikazzjoni jew sors tal-iskart qabel il-konsumatur użat għall-kontenut riċiklat." },
              { "@language": "nl", "@value": "De classificatie of bron van het pre-consument afval dat is gebruikt voor het gerecyclede materiaal." },
              { "@language": "pl", "@value": "Klasyfikacja lub źródło odpadów przedkonsumenckich wykorzystywanych do produkcji zawartości z recyklingu." },
              { "@language": "pt", "@value": "A classificação ou origem dos resíduos pré-consumo utilizados para conteúdo reciclado." },
              { "@language": "ro", "@value": "Clasificarea sau sursa deșeurilor pre-consumator utilizate pentru conținutul reciclat." },
              { "@language": "sk", "@value": "Klasifikácia alebo zdroj predspotrebiteľského odpadu použitého pre recyklovaný obsah." },
              { "@language": "sl", "@value": "Klasifikacija ali vir odpadkov pred uporabo, uporabljenih za reciklirano vsebino." },
              { "@language": "sv", "@value": "Klassificeringen eller källan till avfallet före konsumentledet som används för återvunnet innehåll." }
            ],
            "dppk:visibility": { "@id": "dppk:Public" },
            "dppk:governedBy": "ISO 14021:2016",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0142",
