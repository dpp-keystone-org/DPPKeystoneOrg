        {
            "@id": "dppk:carbonFootprintCalculationParameters",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Carbon Footprint Calculation Parameters" },
              { "@language": "bg", "@value": "Параметри за изчисляване на въглеродния отпечатък" },
              { "@language": "cs", "@value": "Parametry výpočtu uhlíkové stopy" },
              { "@language": "da", "@value": "Parametre for beregning af kulstofaftryk" },
              { "@language": "de", "@value": "Parameter zur Berechnung des CO2-Fußabdrucks" },
              { "@language": "el", "@value": "Παράμετροι υπολογισμού ανθρακικού αποτυπώματος" },
              { "@language": "es", "@value": "Parámetros de Cálculo de la Huella de Carbono" },
              { "@language": "et", "@value": "Süsinikujalajälje arvutamise parameetrid" },
              { "@language": "fi", "@value": "Hiilijalanjäljen laskentaparametrit" },
              { "@language": "fr", "@value": "Paramètres de calcul de l'empreinte carbone" },
              { "@language": "ga", "@value": "Paraiméadair Ríomha Lorg Carbóin" },
              { "@language": "hr", "@value": "Parametri izračuna ugljičnog otiska" },
              { "@language": "hu", "@value": "Szénlábnyom számítási paraméterek" },
              { "@language": "it", "@value": "Parametri di calcolo dell'impronta di carbonio" },
              { "@language": "lt", "@value": "Anglies pėdsako skaičiavimo parametrai" },
              { "@language": "lv", "@value": "Oglekļa pēdas nospieduma aprēķināšanas parametri" },
              { "@language": "mt", "@value": "Parametri tal-Kalkolu tal-Impronta tal-Karbonju" },
              { "@language": "nl", "@value": "Berekeningsparameters voor koolstofvoetafdruk" },
              { "@language": "pl", "@value": "Parametry obliczania śladu węglowego" },
              { "@language": "pt", "@value": "Parâmetros de Cálculo da Pegada de Carbono" },
              { "@language": "ro", "@value": "Parametri de calcul a amprentei de carbon" },
              { "@language": "sk", "@value": "Parametre výpočtu uhlíkovej stopy" },
              { "@language": "sl", "@value": "Parametri za izračun ogljičnega odtisa" },
              { "@language": "sv", "@value": "Parametrar för beräkning av koldioxidavtryck" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "A reference to the document or resource describing the parameters used for the carbon footprint calculation." },
              { "@language": "bg", "@value": "Справка към документа или ресурса, описващ параметрите, използвани за изчисляване на въглеродния отпечатък." },
              { "@language": "cs", "@value": "Odkaz na dokument nebo zdroj popisující parametry použité pro výpočet uhlíkové stopy." },
              { "@language": "da", "@value": "En reference til dokumentet eller ressourcen, der beskriver de parametre, der anvendes til beregning af kulstofaftryk." },
              { "@language": "de", "@value": "Ein Verweis auf das Dokument oder die Ressource, die die Parameter zur Berechnung des CO2-Fußabdrucks beschreibt." },
              { "@language": "el", "@value": "Παραπομπή στο έγγραφο ή στον πόρο που περιγράφει τις παραμέτρους που χρησιμοποιούνται για τον υπολογισμό του ανθρακικού αποτυπώματος." },
              { "@language": "es", "@value": "Una referencia al documento o recurso que describe los parámetros utilizados para el cálculo de la huella de carbono." },
              { "@language": "et", "@value": "Viide dokumendile või ressursile, mis kirjeldab süsinikujalajälje arvutamiseks kasutatud parameetreid." },
              { "@language": "fi", "@value": "Viittaus asiakirjaan tai resurssiin, jossa kuvataan hiilijalanjäljen laskennassa käytetyt parametrit." },
              { "@language": "fr", "@value": "Une référence au document ou à la ressource décrivant les paramètres utilisés pour le calcul de l'empreinte carbone." },
              { "@language": "ga", "@value": "Tagairt don doiciméad nó acmhainn a chuireann síos ar na paraiméadair a úsáideadh do ríomh lorg carbóin." },
              { "@language": "hr", "@value": "Referenca na dokument ili resurs koji opisuje parametre korištene za izračun ugljičnog otiska." },
              { "@language": "hu", "@value": "Hivatkozás a szénlábnyom kiszámításához használt paramétereket leíró dokumentumra vagy erőforrásra." },
              { "@language": "it", "@value": "Un riferimento al documento o alla risorsa che descrive i parametri utilizzati per il calcolo dell'impronta di carbonio." },
              { "@language": "lt", "@value": "Nuoroda į dokumentą arba išteklių, kuriame aprašomi anglies pėdsako skaičiavimui naudojami parametrai." },
              { "@language": "lv", "@value": "Atsauce uz dokumentu vai resursu, kas apraksta oglekļa pēdas nospieduma aprēķināšanai izmantotos parametrus." },
              { "@language": "mt", "@value": "Referenza għad-dokument jew riżorsa li tiddeskrivi l-parametri użati għall-kalkolu tal-impronta tal-karbonju." },
              { "@language": "nl", "@value": "Een verwijzing naar het document of de bron die de parameters beschrijft die zijn gebruikt voor de berekening van de koolstofvoetafdruk." },
              { "@language": "pl", "@value": "Odniesienie do dokumentu lub zasobu opisującego parametry wykorzystane do obliczenia śladu węglowego." },
              { "@language": "pt", "@value": "Uma referência ao documento ou recurso que descreve os parâmetros utilizados para o cálculo da pegada de carbono." },
              { "@language": "ro", "@value": "O referință la documentul sau resursa care descrie parametrii utilizați pentru calcularea amprentei de carbon." },
              { "@language": "sk", "@value": "Odkaz na dokument alebo zdroj popisujúci parametre použité na výpočet uhlíkovej stopy." },
              { "@language": "sl", "@value": "Sklicevanje na dokument ali vir, ki opisuje parametre, uporabljene za izračun ogljičnega odtisa." },
              { "@language": "sv", "@value": "En hänvisning till det dokument eller den resurs som beskriver de parametrar som använts för beräkning av koldioxidavtrycket." }
            ],
            "dppk:visibility": { "@id": "dppk:LegitimateInterestOrAuthority" },
            "dppk:governedBy": "PEFCR",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0142",
                "rdfs:label": "Source: ESPR - Annex I(n)"
            },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "dppk:RelatedResource" }
        },
        {
            "@id": "dppk:robustnessScore",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Robustness Score" },
              { "@language": "bg", "@value": "Оценка за здравина" },
              { "@language": "cs", "@value": "Skóre robustnosti" },
