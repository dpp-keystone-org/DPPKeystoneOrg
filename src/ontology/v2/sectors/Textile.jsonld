        {
            "@id": "dppk:textileSubstancesOfConcern",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Textile Substances of Concern" },
              { "@language": "bg", "@value": "Текстилни вещества, пораждащи безпокойство" },
              { "@language": "cs", "@value": "Textilní látky vzbuzující obavy" },
              { "@language": "da", "@value": "Tekstil problematiske stoffer" },
              { "@language": "de", "@value": "Besorgniserregende Stoffe in Textilien" },
              { "@language": "el", "@value": "Ουσίες ανησυχίας στα υφάσματα" },
              { "@language": "es", "@value": "Sustancias preocupantes en los tejidos" },
              { "@language": "et", "@value": "Tekstiilis sisalduvad ohtlikud ained" },
              { "@language": "fi", "@value": "Tekstiilien huolta aiheuttavat aineet" },
              { "@language": "fr", "@value": "Substances préoccupantes dans les textiles" },
              { "@language": "ga", "@value": "Substaintí is Údar Imní i dTeicstílí" },
              { "@language": "hr", "@value": "Zabrinjavajuće tvari u tekstilu" },
              { "@language": "hu", "@value": "Különös aggodalomra okot adó textilanyagok" },
              { "@language": "it", "@value": "Sostanze problematiche nei tessuti" },
              { "@language": "lt", "@value": "Tekstilės susirūpinimą keliančios medžiagos" },
              { "@language": "lv", "@value": "Tekstilizstrādājumos esošās vielas, kas rada bažas" },
              { "@language": "mt", "@value": "Sustanzi ta' Tħassib fit-Tessuti" },
              { "@language": "nl", "@value": "Zorgwekkende stoffen in textiel" },
              { "@language": "pl", "@value": "Substancje wzbudzające obawy w wyrobach włókienniczych" },
              { "@language": "pt", "@value": "Substâncias que suscitam preocupação nos têxteis" },
              { "@language": "ro", "@value": "Substanțe care prezintă motive de îngrijorare în textile" },
              { "@language": "sk", "@value": "Textilné látky vzbudzujúce obavy" },
              { "@language": "sl", "@value": "Snovi, ki zbujajo skrb, v tekstilu" },
              { "@language": "sv", "@value": "Särskilt farliga ämnen i textilier" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Substances of concern present in the textile product." },
              { "@language": "bg", "@value": "Вещества, пораждащи безпокойство, присъстващи в текстилния продукт." },
              { "@language": "cs", "@value": "Látky vzbuzující obavy přítomné v textilním výrobku." },
              { "@language": "da", "@value": "Problematiske stoffer til stede i tekstilproduktet." },
              { "@language": "de", "@value": "Im Textilprodukt enthaltene besorgniserregende Stoffe." },
              { "@language": "el", "@value": "Ουσίες ανησυχίας που υπάρχουν στο κλωστοϋφαντουργικό προϊόν." },
              { "@language": "es", "@value": "Sustancias preocupantes presentes en el producto textil." },
              { "@language": "et", "@value": "Tekstiiltootes esinevad ohtlikud ained." },
              { "@language": "fi", "@value": "Tekstiilituotteessa olevat huolta aiheuttavat aineet." },
              { "@language": "fr", "@value": "Substances préoccupantes présentes dans le produit textile." },
              { "@language": "ga", "@value": "Substaintí is údar imní atá i láthair sa táirge teicstíle." },
              { "@language": "hr", "@value": "Zabrinjavajuće tvari prisutne u tekstilnom proizvodu." },
              { "@language": "hu", "@value": "A textiltermékben jelen lévő, különös aggodalomra okot adó anyagok." },
              { "@language": "it", "@value": "Sostanze problematiche presenti nel prodotto tessile." },
              { "@language": "lt", "@value": "Tekstilės gaminyje esančios susirūpinimą keliančios medžiagos." },
              { "@language": "lv", "@value": "Tekstilizstrādājumā klātesošās vielas, kas rada bažas." },
              { "@language": "mt", "@value": "Sustanzi ta' tħassib preżenti fil-prodott tat-tessut." },
              { "@language": "nl", "@value": "Zorgwekkende stoffen die aanwezig zijn in het textielproduct." },
              { "@language": "pl", "@value": "Substancje wzbudzające obawy obecne w wyrobie włókienniczym." },
              { "@language": "pt", "@value": "Substâncias que suscitam preocupação presentes no produto têxtil." },
              { "@language": "ro", "@value": "Substanțe care prezintă motive de îngrijorare prezente în produsul textil." },
              { "@language": "sk", "@value": "Látky vzbudzujúce obavy prítomné v textilnom výrobku." },
              { "@language": "sl", "@value": "Snovi, ki zbujajo skrb, prisotne v tekstilnem izdelku." },
              { "@language": "sv", "@value": "Särskilt farliga ämnen som finns i textilprodukten." }
            ],
            "dppk:governedBy": "REACH / ESPR",
