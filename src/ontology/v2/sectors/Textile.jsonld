              { "@language": "et", "@value": "Keskkonnajalajälje võrdlusprotsent" },
              { "@language": "fi", "@value": "Ympäristöjalanjäljen vertailuprosentti" },
              { "@language": "fr", "@value": "Pourcentage de référence de l'empreinte environnementale" },
              { "@language": "ga", "@value": "Céatadán Tagarmharc Lorg Comhshaoil" },
              { "@language": "hr", "@value": "Referentni postotak ekološkog otiska" },
              { "@language": "hu", "@value": "Környezeti lábnyom referencia-százalék" },
              { "@language": "it", "@value": "Percentuale di riferimento dell'impronta ambientale" },
              { "@language": "lt", "@value": "Aplinkosauginio pėdsako lyginamasis procentas" },
              { "@language": "lv", "@value": "Vides pēdas etalona procentuālā daļa" },
              { "@language": "mt", "@value": "Perċentwal ta' Referenza tal-Impronta Ambjentali" },
              { "@language": "nl", "@value": "Benchmarkpercentage milieuvoetafdruk" },
              { "@language": "pl", "@value": "Wartość referencyjna śladu środowiskowego w procentach" },
              { "@language": "pt", "@value": "Percentagem de referência da pegada ambiental" },
              { "@language": "ro", "@value": "Procentul de referință al amprentei de mediu" },
              { "@language": "sk", "@value": "Referenčné percento environmentálnej stopy" },
              { "@language": "sl", "@value": "Referenčni odstotek okoljskega odtisa" },
              { "@language": "sv", "@value": "Referensprocent för miljöavtryck" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "The product's environmental footprint performance compared to the established benchmark, expressed as a percentage." },
              { "@language": "bg", "@value": "Ефективността на отпечатъка върху околната среда на продукта в сравнение с установения еталон, изразена като процент." },
              { "@language": "cs", "@value": "Výkonnost environmentální stopy produktu v porovnání se stanovenou referenční hodnotou, vyjádřená v procentech." },
              { "@language": "da", "@value": "Produktets præstation for miljøaftryk sammenlignet med det fastsatte benchmark, udtrykt som en procentdel." },
              { "@language": "de", "@value": "Die Leistung des Umweltfußabdrucks des Produkts im Vergleich zum festgelegten Richtwert, ausgedrückt als Prozentsatz." },
              { "@language": "el", "@value": "Η επίδοση του περιβαλλοντικού αποτυπώματος του προϊόντος σε σύγκριση με το καθορισμένο σημείο αναφοράς, εκφραζόμενη ως ποσοστό." },
              { "@language": "es", "@value": "El rendimiento de la huella ambiental del producto en comparación con el punto de referencia establecido, expresado como porcentaje." },
              { "@language": "et", "@value": "Toote keskkonnajalajälje toimivus võrreldes kehtestatud võrdlusalusega, väljendatuna protsentides." },
              { "@language": "fi", "@value": "Tuotteen ympäristöjalanjäljen suorituskyky verrattuna vahvistettuun vertailuarvoon prosentteina ilmaistuna." },
              { "@language": "fr", "@value": "La performance de l'empreinte environnementale du produit par rapport à l'indice de référence établi, exprimée en pourcentage." },
              { "@language": "ga", "@value": "Feidhmíocht lorg comhshaoil an táirge i gcomparáid leis an tagarmharc bunaithe, curtha in iúl mar chéatadán." },
              { "@language": "hr", "@value": "Učinak ekološkog otiska proizvoda u usporedbi s utvrđenom referentnom vrijednošću, izražen kao postotak." },
              { "@language": "hu", "@value": "A termék környezeti lábnyom-teljesítménye a megállapított referenciamutatóhoz viszonyítva, százalékban kifejezve." },
              { "@language": "it", "@value": "Le prestazioni dell'impronta ambientale del prodotto rispetto al parametro di riferimento stabilito, espresse in percentuale." },
              { "@language": "lt", "@value": "Produkto aplinkosauginio pėdsako veiksmingumas, palyginti su nustatytu lyginamuoju indeksu, išreikštas procentais." },
              { "@language": "lv", "@value": "Produkta vides pēdas sniegums salīdzinājumā ar noteikto etalonu, izteikts procentos." },
              { "@language": "mt", "@value": "Il-prestazzjoni tal-impronta ambjentali tal-prodott meta mqabbla mal-parametru referenzjarju stabbilit, espressa bħala perċentwal." },
              { "@language": "nl", "@value": "De prestatie van de milieuvoetafdruk van het product in vergelijking met de vastgestelde benchmark, uitgedrukt als een percentage." },
              { "@language": "pl", "@value": "Wydajność śladu środowiskowego produktu w porównaniu do ustalonego poziomu odniesienia, wyrażona w procentach." },
              { "@language": "pt", "@value": "O desempenho da pegada ambiental do produto em comparação com o valor de referência estabelecido, expresso em percentagem." },
              { "@language": "ro", "@value": "Performanța amprentei de mediu a produsului comparativ cu valoarea de referință stabilită, exprimată ca procent." },
              { "@language": "sk", "@value": "Výkonnosť environmentálnej stopy výrobku v porovnaní so stanovenou referenčnou hodnotou, vyjadrená v percentách." },
              { "@language": "sl", "@value": "Uspešnost okoljskega odtisa izdelka v primerjavi z določenim referenčnim merilom, izražena v odstotkih." },
              { "@language": "sv", "@value": "Produktens prestanda för miljöavtryck jämfört med det fastställda riktmärket, uttryckt i procent." }
            ],
            "dppk:unit": "%",
            "dppk:visibility": { "@id": "dppk:LegitimateInterestOrAuthority" },
            "dppk:governedBy": "PEFCR benchmark (single score)",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0142",
                "rdfs:label": "Source: ESPR - Annex I(n), III(e)"
            },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
