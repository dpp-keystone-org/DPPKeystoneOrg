              { "@language": "sv", "@value": "Skötselråd för textil" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Instructions and manuals for the care, washing, and maintenance of the textile product." },
              { "@language": "bg", "@value": "Инструкции и ръководства за грижа, пране и поддръжка на текстилния продукт." },
              { "@language": "cs", "@value": "Pokyny a návody pro péči, praní a údržbu textilního výrobku." },
              { "@language": "da", "@value": "Anvisninger og manualer til pleje, vask og vedligeholdelse af tekstilproduktet." },
              { "@language": "de", "@value": "Anleitungen und Handbücher für die Pflege, das Waschen und die Wartung des Textilprodukts." },
              { "@language": "el", "@value": "Οδηγίες και εγχειρίδια για τη φροντίδα, το πλύσιμο και τη συντήρηση του κλωστοϋφαντουργικού προϊόντος." },
              { "@language": "es", "@value": "Instrucciones y manuales para el cuidado, lavado y mantenimiento del producto textil." },
              { "@language": "et", "@value": "Tekstiiltoote hoolduse, pesemise ja korrashoiu juhised ja käsiraamatud." },
              { "@language": "fi", "@value": "Ohjeet ja käsikirjat tekstiilituotteen hoitoa, pesua ja ylläpitoa varten." },
              { "@language": "fr", "@value": "Instructions et manuels pour l'entretien, le lavage et la maintenance du produit textile." },
              { "@language": "ga", "@value": "Treoracha agus lámhleabhair maidir le cúram, níochán agus cothabháil an táirge teicstíle." },
              { "@language": "hr", "@value": "Upute i priručnici za njegu, pranje i održavanje tekstilnog proizvoda." },
              { "@language": "hu", "@value": "Útmutatók és kézikönyvek a textiltermék ápolásához, mosásához és karbantartásához." },
              { "@language": "it", "@value": "Istruzioni e manuali per la cura, il lavaggio e la manutenzione del prodotto tessile." },
              { "@language": "lt", "@value": "Tekstilės gaminio priežiūros, skalbimo ir techninės priežiūros instrukcijos ir vadovai." },
              { "@language": "lv", "@value": "Tekstilizstrādājuma kopšanas, mazgāšanas un uzturēšanas norādījumi un rokasgrāmatas." },
              { "@language": "mt", "@value": "Istruzzjonijiet u manwali għall-kura, il-ħasil, u l-manutenzjoni tal-prodott tat-tessut." },
              { "@language": "nl", "@value": "Instructies en handleidingen voor de verzorging, het wassen en het onderhoud van het textielproduct." },
              { "@language": "pl", "@value": "Instrukcje i podręczniki dotyczące pielęgnacji, prania i konserwacji wyrobu włókienniczego." },
              { "@language": "pt", "@value": "Instruções e manuais para o cuidado, lavagem e manutenção do produto têxtil." },
              { "@language": "ro", "@value": "Instrucțiuni și manuale pentru îngrijirea, spălarea și întreținerea produsului textil." },
              { "@language": "sk", "@value": "Pokyny a návody na ošetrovanie, pranie a údržbu textilného výrobku." },
              { "@language": "sl", "@value": "Navodila in priročniki za nego, pranje in vzdrževanje tekstilnega izdelka." },
              { "@language": "sv", "@value": "Anvisningar och manualer för skötsel, tvätt och underhåll av textilprodukten." }
            ],
