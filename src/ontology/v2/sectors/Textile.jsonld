              { "@language": "cs", "@value": "Výsledek vizuální kontroly (např. Vyhovuje/Nevyhovuje nebo poznámky)." },
              { "@language": "da", "@value": "Resultatet af den visuelle inspektion (f.eks. Bestået/Ikke bestået eller noter)." },
              { "@language": "de", "@value": "Das Ergebnis der visuellen Inspektion (z.B. Bestanden/Nicht bestanden oder Anmerkungen)." },
              { "@language": "el", "@value": "Το αποτέλεσμα της οπτικής επιθεώρησης (π.χ. Επιτυχία/Αποτυχία ή σημειώσεις)." },
              { "@language": "es", "@value": "El resultado de la inspección visual (por ejemplo, Aprobado/Reprobado o notas)." },
              { "@language": "et", "@value": "Visuaalse kontrolli tulemus (nt Läbis/Ei läbinud või märkused)." },
              { "@language": "fi", "@value": "Silmämääräisen tarkastuksen tulos (esim. Hyväksytty/Hylätty tai huomautukset)." },
              { "@language": "fr", "@value": "Le résultat de l'inspection visuelle (par ex. Réussite/Échec ou notes)." },
              { "@language": "ga", "@value": "Toradh an amharciniúchta (m.sh. Pas/Teip nó nótaí)." },
              { "@language": "hr", "@value": "Rezultat vizualnog pregleda (npr. Prošao/Nije prošao ili bilješke)." },
              { "@language": "hu", "@value": "A vizuális ellenőrzés eredménye (pl. Megfelelt/Nem felelt meg vagy megjegyzések)." },
              { "@language": "it", "@value": "Il risultato dell'ispezione visiva (ad es. Superato/Fallito o note)." },
              { "@language": "lt", "@value": "Vizualinio patikrinimo rezultatas (pvz., Išlaikė/Neišlaikė arba pastabos)." },
              { "@language": "lv", "@value": "Vizuālās pārbaudes rezultāts (piem., Nokārtots/Nenokārtots vai piezīmes)." },
              { "@language": "mt", "@value": "Ir-riżultat tal-ispezzjoni viżwali (eż. Għadda/Ma Għaddiex jew noti)." },
              { "@language": "nl", "@value": "Het resultaat van de visuele inspectie (bijv. Geslaagd/Gezakt of opmerkingen)." },
              { "@language": "pl", "@value": "Wynik kontroli wizualnej (np. Zdał/Nie zdał lub uwagi)." },
              { "@language": "pt", "@value": "O resultado da inspeção visual (por exemplo, Aprovado/Reprovado ou notas)." },
              { "@language": "ro", "@value": "Rezultatul inspecției vizuale (de ex. Admis/Respins sau note)." },
              { "@language": "sk", "@value": "Výsledok vizuálnej kontroly (napr. Vyhovel/Nevyhovel alebo poznámky)." },
              { "@language": "sl", "@value": "Rezultat vizualnega pregleda (npr. Opravil/Ni opravil ali opombe)." },
              { "@language": "sv", "@value": "Resultatet av den visuella inspektionen (t.ex. Godkänd/Underkänd eller anteckningar)." }
            ],
            "dppk:visibility": { "@id": "dppk:Public" },
            "dppk:governedBy": "ISO 15487",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0142",
                "rdfs:label": "Source: ESPR - Article 7(2)(b), Annex I(a), III(e)"
            },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "dppk:animalOriginNonTextile",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Contains Non-Textile Parts of Animal Origin" },
              { "@language": "bg", "@value": "Съдържа нетекстилни части от животински произход" },
              { "@language": "cs", "@value": "Obsahuje netextilní části živočišného původu" },
              { "@language": "da", "@value": "Indeholder ikke-tekstildele af animalsk oprindelse" },
              { "@language": "de", "@value": "Enthält nichttextile Teile tierischen Ursprungs" },
              { "@language": "el", "@value": "Περιέχει μη κλωστοϋφαντουργικά μέρη ζωικής προέλευσης" },
              { "@language": "es", "@value": "Contiene Partes No Textiles de Origen Animal" },
              { "@language": "et", "@value": "Sisaldab loomse päritoluga mittetekstiilist osi" },
              { "@language": "fi", "@value": "Sisältää eläinperäisiä ei-tekstiiliosia" },
              { "@language": "fr", "@value": "Contient des parties non textiles d'origine animale" },
              { "@language": "ga", "@value": "Go bhfuil Codanna Neamhtheicstíle de Bhunadh Ainmhíoch" },
              { "@language": "hr", "@value": "Sadrži netekstilne dijelove životinjskog podrijetla" },
              { "@language": "hu", "@value": "Állati eredetű nem textil részeket tartalmaz" },
              { "@language": "it", "@value": "Contiene parti non tessili di origine animale" },
              { "@language": "lt", "@value": "Sudėtyje yra gyvūninės kilmės ne tekstilės dalių" },
              { "@language": "lv", "@value": "Satur dzīvnieku izcelsmes netekstila daļas" },
              { "@language": "mt", "@value": "Fih Partijiet Mhux tat-Tessuti ta' Oriġini mill-Annimali" },
              { "@language": "nl", "@value": "Bevat niet-textieldelen van dierlijke oorsprong" },
              { "@language": "pl", "@value": "Zawiera nietekstylne części pochodzenia zwierzęcego" },
              { "@language": "pt", "@value": "Contém Partes Não Têxteis de Origem Animal" },
              { "@language": "ro", "@value": "Conține părți netextile de origine animală" },
              { "@language": "sk", "@value": "Obsahuje netextilné časti živočíšneho pôvodu" },
              { "@language": "sl", "@value": "Vsebuje netekstilne dele živalskega izvora" },
              { "@language": "sv", "@value": "Innehåller icke-textila delar av animaliskt ursprung" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Indicates whether the product contains non-textile parts of animal origin, as required by the EU Textile Labelling Regulation." },
              { "@language": "bg", "@value": "Посочва дали продуктът съдържа нетекстилни части от животински произход, както се изисква от Регламента на ЕС за етикетиране на текстил." },
              { "@language": "cs", "@value": "Udává, zda výrobek obsahuje netextilní části živočišného původu, jak to vyžaduje nařízení EU o označování textilií." },
              { "@language": "da", "@value": "Angiver, om produktet indeholder ikke-tekstildele af animalsk oprindelse, som krævet i EU's forordning om tekstilmærkning." },
              { "@language": "de", "@value": "Gibt an, ob das Produkt nichttextile Teile tierischen Ursprungs enthält, wie in der EU-Textilkennzeichnungsverordnung gefordert." },
              { "@language": "el", "@value": "Υποδεικνύει εάν το προϊόν περιέχει μη κλωστοϋφαντουργικά μέρη ζωικής προέλευσης, όπως απαιτείται από τον κανονισμό της ΕΕ για την επισήμανση των κλωστοϋφαντουργικών προϊόντων." },
              { "@language": "es", "@value": "Indica si el producto contiene partes no textiles de origen animal, como exige el Reglamento de Etiquetado de Textiles de la UE." },
              { "@language": "et", "@value": "Näitab, kas toode sisaldab loomse päritoluga mittetekstiilist osi, nagu on nõutud ELi tekstiilitoodete märgistamise määruses." },
              { "@language": "fi", "@value": "Ilmoittaa, sisältääkö tuote eläinperäisiä ei-tekstiiliosia EU:n tekstiilien merkintäasetuksen mukaisesti." },
              { "@language": "fr", "@value": "Indique si le produit contient des parties non textiles d'origine animale, comme l'exige le règlement de l'UE sur l'étiquetage des textiles." },
              { "@language": "ga", "@value": "Léiríonn sé an bhfuil codanna neamhtheicstíle de bhunadh ainmhíoch sa táirge, mar a éilítear le Rialachán AE um Lipéadú Teicstíle." },
              { "@language": "hr", "@value": "Označava sadrži li proizvod netekstilne dijelove životinjskog podrijetla, kako to zahtijeva Uredba EU-a o označivanju tekstila." },
              { "@language": "hu", "@value": "Jelzi, hogy a termék tartalmaz-e állati eredetű nem textil részeket, ahogy azt az EU textilcímkézési rendelete megköveteli." },
              { "@language": "it", "@value": "Indica se il prodotto contiene parti non tessili di origine animale, come richiesto dal regolamento UE sull'etichettatura dei prodotti tessili." },
              { "@language": "lt", "@value": "Nurodo, ar gaminyje yra gyvūninės kilmės ne tekstilės dalių, kaip to reikalaujama ES tekstilės gaminių ženklinimo reglamente." },
              { "@language": "lv", "@value": "Norāda, vai produkts satur dzīvnieku izcelsmes netekstila daļas, kā to prasa ES tekstilizstrādājumu marķēšanas regula." },
              { "@language": "mt", "@value": "Jindika jekk il-prodott fihx partijiet mhux tat-tessuti ta' oriġini mill-annimali, kif meħtieġ mir-Regolament tal-UE dwar it-Tikkettar tat-Tessuti." },
              { "@language": "nl", "@value": "Geeft aan of het product niet-textieldelen van dierlijke oorsprong bevat, zoals vereist door de EU-verordening inzake textieletikettering." },
              { "@language": "pl", "@value": "Wskazuje, czy produkt zawiera nietekstylne części pochodzenia zwierzęcego, zgodnie z wymogami rozporządzenia UE w sprawie etykietowania wyrobów włókienniczych." },
              { "@language": "pt", "@value": "Indica se o produto contém partes não têxteis de origem animal, conforme exigido pelo Regulamento de Rotulagem Têxtil da UE." },
              { "@language": "ro", "@value": "Indică dacă produsul conține părți netextile de origine animală, așa cum prevede Regulamentul UE privind etichetarea textilelor." },
              { "@language": "sk", "@value": "Indikuje, či výrobok obsahuje netextilné časti živočíšneho pôvodu, ako si to vyžaduje nariadenie EÚ o označovaní textílií." },
              { "@language": "sl", "@value": "Označuje, ali izdelek vsebuje netekstilne dele živalskega izvora, kot to zahteva Uredba EU o označevanju tekstilnih izdelkov." },
              { "@language": "sv", "@value": "Anger om produkten innehåller icke-textila delar av animaliskt ursprung, enligt EU:s förordning om textilmärkning." }
            ],
            "dppk:visibility": { "@id": "dppk:Public" },
            "dppk:governedBy": "Textiles Labelling Regulation (EU) No 1007/2011",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32011R1007",
                "rdfs:label": "Source: ESPR - Annex III (a)"
            },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:boolean" }
        },
        {
            "@id": "dppk:euEcolabel",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "EU Ecolabel" },
              { "@language": "bg", "@value": "Екомаркировка на ЕС" },
              { "@language": "cs", "@value": "Ekoznačka EU" },
              { "@language": "da", "@value": "EU-miljømærke" },
              { "@language": "de", "@value": "EU-Ecolabel" },
              { "@language": "el", "@value": "Οικολογικό σήμα της ΕΕ" },
              { "@language": "es", "@value": "Etiqueta Ecológica de la UE" },
              { "@language": "et", "@value": "ELi ökomärgis" },
              { "@language": "fi", "@value": "EU-ympäristömerkki" },
              { "@language": "fr", "@value": "Écolabel européen" },
              { "@language": "ga", "@value": "Éicilipéad an AE" },
              { "@language": "hr", "@value": "Znak zaštite okoliša EU-a" },
              { "@language": "hu", "@value": "EU ökocímke" },
              { "@language": "it", "@value": "Ecolabel UE" },
              { "@language": "lt", "@value": "ES ekologinis ženklas" },
              { "@language": "lv", "@value": "ES ekomarķējums" },
              { "@language": "mt", "@value": "Ekotikketta tal-UE" },
              { "@language": "nl", "@value": "EU-ecolabel" },
              { "@language": "pl", "@value": "Oznakowanie ekologiczne UE" },
              { "@language": "pt", "@value": "Rótulo Ecológico da UE" },
              { "@language": "ro", "@value": "Eticheta ecologică a UE" },
              { "@language": "sk", "@value": "Environmentálna značka EÚ" },
              { "@language": "sl", "@value": "Znak za okolje EU" },
              { "@language": "sv", "@value": "EU-miljömärke" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Indicates whether the product has been awarded the EU Ecolabel. The label should be found in the certifications array as well, if present." },
              { "@language": "bg", "@value": "Посочва дали продуктът е получил екомаркировката на ЕС. Етикетът трябва да се намира и в масива със сертификати, ако има такъв." },
              { "@language": "cs", "@value": "Udává, zda byla produktu udělena ekoznačka EU. Tato značka by se měla nacházet také v poli certifikací, pokud je přítomna." },
              { "@language": "da", "@value": "Angiver, om produktet er blevet tildelt EU-miljømærket. Mærket bør også findes i certificeringsarrayet, hvis det er til stede." },
              { "@language": "de", "@value": "Gibt an, ob das Produkt mit dem EU-Ecolabel ausgezeichnet wurde. Das Label sollte auch im Zertifizierungs-Array zu finden sein, falls vorhanden." },
              { "@language": "el", "@value": "Υποδεικνύει εάν το προϊόν έχει λάβει το Οικολογικό σήμα της ΕΕ. Η ετικέτα θα πρέπει να βρίσκεται επίσης στον πίνακα πιστοποιήσεων, εάν υπάρχει." },
              { "@language": "es", "@value": "Indica si el producto ha obtenido la Etiqueta Ecológica de la UE. La etiqueta también debe encontrarse en la matriz de certificaciones, si está presente." },
              { "@language": "et", "@value": "Näitab, kas tootele on antud ELi ökomärgis. See märgis peaks olema ka sertifikaatide massiivis, kui see on olemas." },
              { "@language": "fi", "@value": "Ilmoittaa, onko tuotteelle myönnetty EU-ympäristömerkki. Merkin tulisi löytyä myös sertifiointitaulukosta, jos se on olemassa." },
              { "@language": "fr", "@value": "Indique si le produit a obtenu l'écolabel européen. L'étiquette doit également se trouver dans le tableau des certifications, le cas échéant." },
              { "@language": "ga", "@value": "Léiríonn sé an bhfuil Éicilipéad an AE bronnta ar an táirge. Ba cheart go mbeadh an lipéad le fáil san eagar deimhnithe freisin, más ann dó." },
              { "@language": "hr", "@value": "Označava je li proizvodu dodijeljen znak zaštite okoliša EU-a. Oznaka se također treba nalaziti u nizu certifikata, ako je prisutna." },
              { "@language": "hu", "@value": "Jelzi, hogy a termék megkapta-e az EU ökocímkét. A címkének a tanúsítványok tömbjében is szerepelnie kell, ha van." },
              { "@language": "it", "@value": "Indica se il prodotto ha ottenuto l'Ecolabel UE. L'etichetta dovrebbe essere presente anche nell'array delle certificazioni, se presente." },
              { "@language": "lt", "@value": "Nurodo, ar gaminiui suteiktas ES ekologinis ženklas. Jei yra, šis ženklas taip pat turėtų būti sertifikatų masyve." },
              { "@language": "lv", "@value": "Norāda, vai produktam ir piešķirts ES ekomarķējums. Šim marķējumam vajadzētu atrasties arī sertifikātu masīvā, ja tas ir pieejams." },
              { "@language": "mt", "@value": "Jindika jekk il-prodott ġiex mogħti l-Ekotikketta tal-UE. It-tikketta għandha tinstab ukoll fl-array taċ-ċertifikazzjonijiet, jekk preżenti." },
              { "@language": "nl", "@value": "Geeft aan of het product het EU-ecolabel heeft gekregen. Het label moet ook in de certificeringenarray te vinden zijn, indien aanwezig." },
              { "@language": "pl", "@value": "Wskazuje, czy produktowi przyznano oznakowanie ekologiczne UE. Etykieta ta powinna również znajdować się w tablicy certyfikatów, jeśli jest obecna." },
              { "@language": "pt", "@value": "Indica se o produto recebeu o Rótulo Ecológico da UE. O rótulo também deve ser encontrado na matriz de certificações, se presente." },
              { "@language": "ro", "@value": "Indică dacă produsului i-a fost acordată Eticheta ecologică a UE. Eticheta ar trebui să se găsească și în matricea de certificări, dacă este prezentă." },
              { "@language": "sk", "@value": "Indikuje, či výrobku bola udelená environmentálna značka EÚ. Táto značka by sa mala nachádzať aj v poli certifikácií, ak je prítomná." },
              { "@language": "sl", "@value": "Označuje, ali je bil izdelku podeljen znak za okolje EU. Ta znak bi moral biti tudi v polju certifikatov, če je prisoten." },
              { "@language": "sv", "@value": "Anger om produkten har tilldelats EU-miljömärket. Märket bör också finnas i certifieringsfältet, om sådant finns." }
            ],
            "dppk:visibility": { "@id": "dppk:Public" },
            "dppk:governedBy": "EU Ecolabel Certification",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0142",
                "rdfs:label": "Source: ESPR - Annex III (a)"
            },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:boolean" }
        },
        {
            "@id": "dppk:weightExcludingTrims",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Weight Excluding Trims" },
              { "@language": "bg", "@value": "Тегло без гарнитури" },
              { "@language": "cs", "@value": "Hmotnost bez ozdob" },
              { "@language": "da", "@value": "Vægt eksklusiv besætninger" },
              { "@language": "de", "@value": "Gewicht ohne Besätze" },
              { "@language": "el", "@value": "Βάρος χωρίς διακοσμητικά" },
              { "@language": "es", "@value": "Peso Excluyendo Adornos" },
              { "@language": "et", "@value": "Kaal ilma kaunistusteta" },
              { "@language": "fi", "@value": "Paino ilman koristeita" },
              { "@language": "fr", "@value": "Poids hors garnitures" },
              { "@language": "ga", "@value": "Meáchan Gan Bhaill Mhaisiúcháin a Áireamh" },
              { "@language": "hr", "@value": "Težina bez ukrasa" },
              { "@language": "hu", "@value": "Súly díszítések nélkül" },
              { "@language": "it", "@value": "Peso esclusi i rifinimenti" },
              { "@language": "lt", "@value": "Svoris be apdailos" },
              { "@language": "lv", "@value": "Svars bez apdares" },
              { "@language": "mt", "@value": "Piż Esklużi Trims" },
              { "@language": "nl", "@value": "Gewicht exclusief afwerking" },
              { "@language": "pl", "@value": "Waga bez wykończeń" },
              { "@language": "pt", "@value": "Peso Excluindo Acabamentos" },
              { "@language": "ro", "@value": "Greutate fără garnituri" },
              { "@language": "sk", "@value": "Hmotnosť bez ozdôb" },
              { "@language": "sl", "@value": "Teža brez obrob" },
              { "@language": "sv", "@value": "Vikt exklusive beslag" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "The weight of the product excluding non-textile trims (e.g. buttons, zippers), used as a base for calculations." },
              { "@language": "bg", "@value": "Теглото на продукта без нетекстилни гарнитури (напр. копчета, ципове), използвано като база за изчисления." },
              { "@language": "cs", "@value": "Hmotnost výrobku bez netextilních ozdob (např. knoflíky, zipy), používaná jako základ pro výpočty." },
              { "@language": "da", "@value": "Produktets vægt eksklusiv ikke-tekstilbesætninger (f.eks. knapper, lynlåse), brugt som grundlag for beregninger." },
              { "@language": "de", "@value": "Das Gewicht des Produkts ohne nichttextile Besätze (z.B. Knöpfe, Reißverschlüsse), das als Grundlage für Berechnungen dient." },
              { "@language": "el", "@value": "Το βάρος του προϊόντος χωρίς τα μη κλωστοϋφαντουργικά διακοσμητικά (π.χ. κουμπιά, φερμουάρ), που χρησιμοποιείται ως βάση για υπολογισμούς." },
              { "@language": "es", "@value": "El peso del producto excluyendo los adornos no textiles (por ejemplo, botones, cremalleras), utilizado como base para cálculos." },
              { "@language": "et", "@value": "Toote kaal ilma mittetekstiilist kaunistusteta (nt nööbid, tõmblukud), mida kasutatakse arvutuste alusena." },
              { "@language": "fi", "@value": "Tuotteen paino ilman ei-tekstiilikoristeita (esim. napit, vetoketjut), jota käytetään laskelmien perustana." },
              { "@language": "fr", "@value": "Le poids du produit à l'exclusion des garnitures non textiles (par ex. boutons, fermetures éclair), utilisé comme base de calcul." },
              { "@language": "ga", "@value": "Meáchan an táirge gan baill mhaisiúcháin neamhtheicstíle a áireamh (m.sh. cnaipí, zipeanna), a úsáidtear mar bhonn do ríomha." },
              { "@language": "hr", "@value": "Težina proizvoda isključujući netekstilne ukrase (npr. gumbe, patentne zatvarače), koja se koristi kao osnova za izračune." },
              { "@language": "hu", "@value": "A termék súlya a nem textil díszítések (pl. gombok, cipzárak) nélkül, számítások alapjául szolgál." },
              { "@language": "it", "@value": "Il peso del prodotto esclusi i rifinimenti non tessili (ad es. bottoni, cerniere), utilizzato come base per i calcoli." },
              { "@language": "lt", "@value": "Produkto svoris be ne tekstilės apdailos (pvz., sagų, užtrauktukų), naudojamas kaip skaičiavimų pagrindas." },
              { "@language": "lv", "@value": "Produkta svars bez netekstila apdares (piem., pogas, rāvējslēdzēji), ko izmanto kā pamatu aprēķiniem." },
              { "@language": "mt", "@value": "Il-piż tal-prodott esklużi t-trims mhux tat-tessuti (eż. buttuni, żippijiet), użat bħala bażi għall-kalkoli." },
              { "@language": "nl", "@value": "Het gewicht van het product exclusief niet-textiele afwerking (bijv. knopen, ritsen), gebruikt als basis voor berekeningen." },
              { "@language": "pl", "@value": "Masa produktu bez wykończeń nietekstylnych (np. guzików, zamków błyskawicznych), wykorzystywana jako podstawa do obliczeń." },
              { "@language": "pt", "@value": "O peso do produto excluindo acabamentos não têxteis (por exemplo, botões, zíperes), usado como base para cálculos." },
              { "@language": "ro", "@value": "Greutatea produsului fără garniturile netextile (de ex. nasturi, fermoare), utilizată ca bază pentru calcule." },
              { "@language": "sk", "@value": "Hmotnosť výrobku bez netextilných ozdôb (napr. gombíky, zipsy), ktorá sa používa ako základ pre výpočty." },
              { "@language": "sl", "@value": "Teža izdelka brez netekstilnih obrob (npr. gumbi, zadrge), ki se uporablja kot osnova za izračune." },
              { "@language": "sv", "@value": "Produktens vikt exklusive icke-textila beslag (t.ex. knappar, dragkedjor), som används som underlag för beräkningar." }
            ],
            "dppk:unit": "kg",
            "dppk:visibility": { "@id": "dppk:LegitimateInterestOrAuthority" },
            "dppk:governedBy": "EN ISO 80000-1",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32011R1007",
                "rdfs:label": "Source: ESPR - Annex III(e)"
            },
            "rdfs:domain": { "@id": "dppk:TextileProduct" },
            "rdfs:range": { "@id": "xsd:double" }
        },
