              { "@language": "hr", "@value": "Klasa izvedbe ekološkog otiska proizvoda." },
              { "@language": "hu", "@value": "A termék környezeti lábnyomának teljesítményosztálya." },
              { "@language": "it", "@value": "La classe di prestazione dell'impronta ambientale del prodotto." },
              { "@language": "lt", "@value": "Produkto aplinkosauginio pėdsako veiksmingumo klasė." },
              { "@language": "lv", "@value": "Produkta vides pēdas nospieduma veiktspējas klase." },
              { "@language": "mt", "@value": "Il-klassi ta' prestazzjoni tal-impronta ambjentali tal-prodott." },
              { "@language": "nl", "@value": "De prestatieklasse van de milieuvoetafdruk van het product." },
              { "@language": "pl", "@value": "Klasa wydajności śladu środowiskowego produktu." },
              { "@language": "pt", "@value": "A classe de desempenho da pegada ambiental do produto." },
              { "@language": "ro", "@value": "Clasa de performanță a amprentei de mediu a produsului." },
              { "@language": "sk", "@value": "Trieda výkonnosti environmentálnej stopy produktu." },
              { "@language": "sl", "@value": "Razred učinkovitosti okoljskega odtisa izdelka." },
              { "@language": "sv", "@value": "Prestandaklassen för produktens miljöavtryck." }
