        {
            "@id": "dppk:fibreComposition",
            "@type": "owl:ObjectProperty",
            "rdfs:label": [
              { "@language": "en", "@value": "Fibre Composition" },
              { "@language": "bg", "@value": "Влакнест състав" },
              { "@language": "cs", "@value": "Složení vláken" },
              { "@language": "da", "@value": "Fibersammensætning" },
              { "@language": "de", "@value": "Faserzusammensetzung" },
              { "@language": "el", "@value": "Σύνθεση ινών" },
              { "@language": "es", "@value": "Composición de las fibras" },
              { "@language": "et", "@value": "Kiuline koostis" },
              { "@language": "fi", "@value": "Kuitukoostumus" },
              { "@language": "fr", "@value": "Composition fibreuse" },
              { "@language": "ga", "@value": "Comhdhéanamh Snáithíneach" },
              { "@language": "hr", "@value": "Sastav vlakana" },
              { "@language": "hu", "@value": "Szálösszetétel" },
              { "@language": "it", "@value": "Composizione fibrosa" },
              { "@language": "lt", "@value": "Pluošto sudėtis" },
              { "@language": "lv", "@value": "Šķiedru sastāvs" },
              { "@language": "mt", "@value": "Kompożizzjoni tal-Fibri" },
              { "@language": "nl", "@value": "Vezelsamenstelling" },
              { "@language": "pl", "@value": "Skład surowcowy" },
              { "@language": "pt", "@value": "Composição das fibras" },
              { "@language": "ro", "@value": "Compoziția fibrelor" },
              { "@language": "sk", "@value": "Zloženie vlákien" },
              { "@language": "sl", "@value": "Sestava vlaken" },
              { "@language": "sv", "@value": "Fibersammansättning" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Relates the textile product to its constituent fibres and their proportions." },
              { "@language": "bg", "@value": "Свързва текстилния продукт с съставящите го влакна и техните пропорции." },
              { "@language": "cs", "@value": "Vztahuje se na textilní výrobek z hlediska jeho základních vláken a jejich poměrů." },
              { "@language": "da", "@value": "Knytter tekstilproduktet til dets indgående fibre og deres proportioner." },
              { "@language": "de", "@value": "Setzt das Textilprodukt mit seinen Bestandteilsfasern und deren Anteilen in Beziehung." },
              { "@language": "el", "@value": "Συσχετίζει το κλωστοϋφαντουργικό προϊόν με τις συστατικές του ίνες και τις αναλογίες τους." },
              { "@language": "es", "@value": "Relaciona el producto textil con sus fibras constituyentes y sus proporciones." },
              { "@language": "et", "@value": "Seostab tekstiiltoodet selle koostiskiudude ja nende proportsioonidega." },
              { "@language": "fi", "@value": "Liittää tekstiilituotteen sen muodostaviin kuituihin ja niiden osuuksiin." },
              { "@language": "fr", "@value": "Relie le produit textile à ses fibres constitutives et à leurs proportions." },
              { "@language": "ga", "@value": "Nascann sé an táirge teicstíle lena shnáithíní comhpháirteacha agus a gcionmhaireachtaí." },
              { "@language": "hr", "@value": "Povezuje tekstilni proizvod s njegovim sastavnim vlaknima i njihovim omjerima." },
              { "@language": "hu", "@value": "Összekapcsolja a textilterméket az azt alkotó szálakkal és azok arányaival." },
              { "@language": "it", "@value": "Mette in relazione il prodotto tessile con le sue fibre costituenti e le loro proporzioni." },
              { "@language": "lt", "@value": "Sieja tekstilės gaminį su jį sudarančiais pluoštais ir jų proporcijomis." },
              { "@language": "lv", "@value": "Saista tekstilizstrādājumu ar to veidojošajām šķiedrām un to proporcijām." },
              { "@language": "mt", "@value": "Tqabbad il-prodott tat-tessut mal-fibri kostitwenti tiegħu u l-proporzjonijiet tagħhom." },
              { "@language": "nl", "@value": "Relateert het textielproduct aan zijn samenstellende vezels en de verhoudingen daarvan." },
              { "@language": "pl", "@value": "Odnosi wyrób włókienniczy do jego włókien składowych i ich proporcji." },
              { "@language": "pt", "@value": "Relaciona o produto têxtil com as suas fibras constituintes e as respetivas proporções." },
              { "@language": "ro", "@value": "Corelează produsul textil cu fibrele sale constitutive și proporțiile acestora." },
              { "@language": "sk", "@value": "Vzťahuje textilný výrobok na jeho základné vlákna a ich pomery." },
              { "@language": "sl", "@value": "Povezuje tekstilni izdelek s sestavnimi vlakni in njihovimi deleži." },
              { "@language": "sv", "@value": "Relaterar textilprodukten till dess ingående fibrer och deras proportioner." }
            ],
            "dppk:governedBy": "Textiles Labelling Regulation (EU) No 1007/2011",
            "dcterms:source": {
                "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0142",
                "rdfs:label": [
                  { "@language": "en", "@value": "Source: ESPR - Annex I(d), Annex III(a)" },
