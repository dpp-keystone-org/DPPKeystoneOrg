              { "@language": "hr", "@value": "Upute i smjernice za sigurnu upotrebu i održavanje tekstilnog proizvoda." },
              { "@language": "hu", "@value": "Útmutatók és irányelvek a textiltermék biztonságos használatához és karbantartásához." },
              { "@language": "it", "@value": "Istruzioni e linee guida per l'uso e la manutenzione sicuri del prodotto tessile." },
              { "@language": "lt", "@value": "Tekstilės gaminio saugaus naudojimo ir priežiūros instrukcijos ir gairės." },
              { "@language": "lv", "@value": "Norādījumi un vadlīnijas par tekstilizstrādājuma drošu lietošanu un uzturēšanu." },
              { "@language": "mt", "@value": "Istruzzjonijiet u linji gwida għall-użu sikur u l-manutenzjoni tal-prodott tat-tessut." },
              { "@language": "nl", "@value": "Instructies en richtlijnen voor veilig gebruik en onderhoud van het textielproduct." },
              { "@language": "pl", "@value": "Instrukcje i wytyczne dotyczące bezpiecznego użytkowania i konserwacji wyrobu włókienniczego." },
              { "@language": "pt", "@value": "Instruções e diretrizes para o uso seguro e manutenção do produto têxtil." },
              { "@language": "ro", "@value": "Instrucțiuni și orientări pentru utilizarea și întreținerea în siguranță a produsului textil." },
              { "@language": "sk", "@value": "Pokyny a usmernenia na bezpečné používanie a údržbu textilného výrobku." },
              { "@language": "sl", "@value": "Navodila in smernice za varno uporabo in vzdrževanje tekstilnega izdelka." },
              { "@language": "sv", "@value": "Anvisningar och riktlinjer för säker användning och underhåll av textilprodukten." }
            ],
