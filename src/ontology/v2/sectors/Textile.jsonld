              { "@language": "mt", "@value": "Perċentwal ta' Referenza tal-Marka tal-Karbonju" },
              { "@language": "nl", "@value": "Benchmarkpercentage koolstofvoetafdruk" },
              { "@language": "pl", "@value": "Wartość referencyjna śladu węglowego w procentach" },
              { "@language": "pt", "@value": "Percentagem de referência da pegada de carbono" },
              { "@language": "ro", "@value": "Procentul de referință al amprentei de carbon" },
              { "@language": "sk", "@value": "Referenčné percento uhlíkovej stopy" },
              { "@language": "sl", "@value": "Referenčni odstotek ogljičnega odtisa" },
              { "@language": "sv", "@value": "Referensprocent för koldioxidavtryck" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "The product's carbon footprint performance compared to the established benchmark, expressed as a percentage." },
              { "@language": "bg", "@value": "Ефективността на въглеродния отпечатък на продукта в сравнение с установения еталон, изразена като процент." },
              { "@language": "cs", "@value": "Výkonnost uhlíkové stopy produktu v porovnání se stanovenou referenční hodnotou, vyjádřená v procentech." },
              { "@language": "da", "@value": "Produktets præstation for CO2-aftryk sammenlignet med det fastsatte benchmark, udtrykt som en procentdel." },
              { "@language": "de", "@value": "Die Leistung des CO2-Fußabdrucks des Produkts im Vergleich zum festgelegten Richtwert, ausgedrückt als Prozentsatz." },
              { "@language": "el", "@value": "Η επίδοση του αποτυπώματος άνθρακα του προϊόντος σε σύγκριση με το καθορισμένο σημείο αναφοράς, εκφραζόμενη ως ποσοστό." },
              { "@language": "es", "@value": "El rendimiento de la huella de carbono del producto en comparación con el punto de referencia establecido, expresado como porcentaje." },
              { "@language": "et", "@value": "Toote süsinikujalajälje toimivus võrreldes kehtestatud võrdlusalusega, väljendatuna protsentides." },
              { "@language": "fi", "@value": "Tuotteen hiilijalanjäljen suorituskyky verrattuna vahvistettuun vertailuarvoon prosentteina ilmaistuna." },
              { "@language": "fr", "@value": "La performance de l'empreinte carbone du produit par rapport à l'indice de référence établi, exprimée en pourcentage." },
              { "@language": "ga", "@value": "Feidhmíocht lorg carbóin an táirge i gcomparáid leis an tagarmharc bunaithe, curtha in iúl mar chéatadán." },
              { "@language": "hr", "@value": "Učinak ugljičnog otiska proizvoda u usporedbi s utvrđenom referentnom vrijednošću, izražen kao postotak." },
              { "@language": "hu", "@value": "A termék karbonlábnyom-teljesítménye a megállapított referenciamutatóhoz viszonyítva, százalékban kifejezve." },
              { "@language": "it", "@value": "Le prestazioni dell'impronta di carbonio del prodotto rispetto al parametro di riferimento stabilito, espresse in percentuale." },
              { "@language": "lt", "@value": "Produkto anglies pėdsako veiksmingumas, palyginti su nustatytu lyginamuoju indeksu, išreikštas procentais." },
              { "@language": "lv", "@value": "Produkta oglekļa pēdas sniegums salīdzinājumā ar noteikto etalonu, izteikts procentos." },
              { "@language": "mt", "@value": "Il-prestazzjoni tal-impronta tal-karbonju tal-prodott meta mqabbla mal-parametru referenzjarju stabbilit, espressa bħala perċentwal." },
              { "@language": "nl", "@value": "De prestatie van de koolstofvoetafdruk van het product in vergelijking met de vastgestelde benchmark, uitgedrukt als een percentage." },
              { "@language": "pl", "@value": "Wydajność śladu węglowego produktu w porównaniu do ustalonego poziomu odniesienia, wyrażona w procentach." },
              { "@language": "pt", "@value": "O desempenho da pegada de carbono do produto em comparação com o valor de referência estabelecido, expresso em percentagem." },
              { "@language": "ro", "@value": "Performanța amprentei de carbon a produsului comparativ cu valoarea de referință stabilită, exprimată ca procent." },
              { "@language": "sk", "@value": "Výkonnosť uhlíkovej stopy výrobku v porovnaní so stanovenou referenčnou hodnotou, vyjadrená v percentách." },
              { "@language": "sl", "@value": "Uspešnost ogljičnega odtisa izdelka v primerjavi z določenim referenčnim merilom, izražena v odstotkih." },
              { "@language": "sv", "@value": "Produktens prestanda för koldioxidavtryck jämfört med det fastställda riktmärket, uttryckt i procent." }
            ],
            "dppk:unit": "%",
            "dppk:visibility": { "@id": "dppk:LegitimateInterestOrAuthority" },
            "dppk:governedBy": "PEFCR benchmark",
