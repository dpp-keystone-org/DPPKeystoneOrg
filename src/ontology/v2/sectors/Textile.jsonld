              { "@language": "de", "@value": "Ein spezifischer Schritt im Herstellungsprozess des Produkts." },
              { "@language": "el", "@value": "Ένα συγκεκριμένο βήμα στη διαδικασία κατασκευής του προϊόντος." },
              { "@language": "es", "@value": "Un paso específico en el proceso de fabricación del producto." },
              { "@language": "et", "@value": "Konkreetne etapp toote tootmisprotsessis." },
              { "@language": "fi", "@value": "Tuotteen valmistusprosessin tietty vaihe." },
              { "@language": "fr", "@value": "Une étape spécifique dans le processus de fabrication du produit." },
              { "@language": "ga", "@value": "Céim shonrach i bpróiseas monaraíochta an táirge." },
              { "@language": "hr", "@value": "Određeni korak u proizvodnom procesu proizvoda." },
              { "@language": "hu", "@value": "A termék gyártási folyamatának egy meghatározott lépése." },
              { "@language": "it", "@value": "Una fase specifica nel processo di fabbricazione del prodotto." },
              { "@language": "lt", "@value": "Konkretus gaminio gamybos proceso etapas." },
              { "@language": "lv", "@value": "Konkrēts posms produkta ražošanas procesā." },
              { "@language": "mt", "@value": "Pass speċifiku fil-proċess tal-manifattura tal-prodott." },
              { "@language": "nl", "@value": "Een specifieke stap in het fabricageproces van het product." },
              { "@language": "pl", "@value": "Konkretny krok w procesie produkcji wyrobu." },
              { "@language": "pt", "@value": "Um passo específico no processo de fabrico do produto." },
              { "@language": "ro", "@value": "Un pas specific în procesul de fabricație al produsului." },
              { "@language": "sk", "@value": "Konkrétny krok vo výrobnom procese výrobku." },
