{
    "@context": {
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "schema": "https://schema.org/",
        "gs1": "https://ref.gs1.org/voc/",
        "dppk": "https://dpp-keystone.org/spec/{{VERSION}}/terms#",
        "dcterms": "http://purl.org/dc/terms/",
        "@base": "https://dpp-keystone.org/spec/{{VERSION}}/terms"
    },
    "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/sectors/Textile",
    "@type": "owl:Ontology",
    "dcterms:title": [
      { "@language": "en", "@value": "DPP Sector Ontology - Textile ESPR Compliant" },
      { "@language": "bg", "@value": "Онтология на сектора на DPP - Съвместим с ESPR за текстил" },
      { "@language": "cs", "@value": "Ontologie odvětví DPP - V souladu s ESPR pro textil" },
      { "@language": "da", "@value": "DPP-sektorontologi - I overensstemmelse med ESPR for tekstiler" },
      { "@language": "de", "@value": "DPP-Sektor-Ontologie - ESPR-konform für Textilien" },
      { "@language": "el", "@value": "Οντολογία Τομέα DPP - Συμβατή με ESPR για κλωστοϋφαντουργικά προϊόντα" },
      { "@language": "es", "@value": "Ontología del Sector DPP - Cumple con ESPR para textiles" },
      { "@language": "et", "@value": "DPP sektori ontoloogia - Tekstiilide ESPR-iga ühilduv" },
      { "@language": "fi", "@value": "DPP-sektoriontologia - Yhteensopiva tekstiilien ESPR:n kanssa" },
      { "@language": "fr", "@value": "Ontologie sectorielle DPP - Conforme à l'ESPR pour les textiles" },
      { "@language": "ga", "@value": "Ointeolaíocht Earnála DPP - Comhlíontach le ESPR do Theicstílí" },
      { "@language": "hr", "@value": "Ontologija sektora DPP - U skladu s ESPR-om za tekstil" },
      { "@language": "hu", "@value": "DPP ágazati ontológia - ESPR-kompatibilis textíliákhoz" },
      { "@language": "it", "@value": "Ontologia del settore DPP - Conforme all'ESPR per i tessili" },
      { "@language": "lt", "@value": "DPP sektoriaus ontologija - Suderinama su ESPR tekstilės gaminiams" },
      { "@language": "lv", "@value": "DPP nozares ontoloģija - Atbilst ESPR prasībām tekstilizstrādājumiem" },
      { "@language": "mt", "@value": "Ontoloġija tas-Settur DPP - Konformi mal-ESPR għat-Tessuti" },
      { "@language": "nl", "@value": "DPP Sectorontologie - Voldoet aan ESPR voor textiel" },
      { "@language": "pl", "@value": "Ontologia sektora DPP - Zgodna z ESPR dla tekstyliów" },
      { "@language": "pt", "@value": "Ontologia do Setor DPP - Em conformidade com o ESPR para têxteis" },
      { "@language": "ro", "@value": "Ontologia sectorului DPP - Conform cu ESPR pentru textile" },
      { "@language": "sk", "@value": "Ontológia sektora DPP - V súlade s ESPR pre textil" },
      { "@language": "sl", "@value": "Sektorska ontologija DPP - V skladu z ESPR za tekstil" },
      { "@language": "sv", "@value": "DPP-sektorontologi - Överensstämmer med ESPR för textilier" }
    ],
    "dcterms:description": [
      { "@language": "en", "@value": "Defines sector-specific concepts compliant with the upcoming ESPR Delegated Act for Textiles." },
      { "@language": "bg", "@value": "Определя специфични за сектора концепции, съвместими с предстоящия Делегиран акт на ESPR за текстила." },
      { "@language": "cs", "@value": "Definuje koncepty specifické pro dané odvětví v souladu s nadcházejícím aktem v přenesené pravomoci ESPR pro textil." },
      { "@language": "da", "@value": "Definerer sektorspecifikke koncepter i overensstemmelse med den kommende delegerede retsakt fra ESPR for tekstiler." },
      { "@language": "de", "@value": "Definiert sektorspezifische Konzepte, die dem kommenden delegierten Rechtsakt des ESPR für Textilien entsprechen." },
      { "@language": "el", "@value": "Καθορίζει έννοιες ειδικές για τον τομέα που συμμορφώνονται με την επερχόμενη κατ' εξουσιοδότηση πράξη ESPR για τα κλωστοϋφαντουργικά προϊόντα." },
      { "@language": "es", "@value": "Define conceptos específicos del sector que cumplen con el próximo Acto Delegado del ESPR para textiles." },
      { "@language": "et", "@value": "Määratleb sektoripõhised kontseptsioonid, mis on kooskõlas eelseisva tekstiiltoodete ESPR delegeeritud õigusaktiga." },
      { "@language": "fi", "@value": "Määrittää alakohtaisia käsitteitä, jotka ovat yhteensopivia tulevan tekstiilejä koskevan ESPR:n delegoidun säädöksen kanssa." },
      { "@language": "fr", "@value": "Définit des concepts spécifiques au secteur conformes au prochain acte délégué de l'ESPR pour les textiles." },
      { "@language": "ga", "@value": "Sainmhínítear coincheapa a bhaineann go sonrach leis an earnáil agus atá i gcomhréir le Gníomh Tarmligthe ESPR do Theicstílí atá le teacht." },
      { "@language": "hr", "@value": "Definira koncepte specifične za sektor u skladu s nadolazećim delegiranim aktom ESPR-a za tekstil." },
      { "@language": "hu", "@value": "Meghatározza az ágazatspecifikus fogalmakat, amelyek megfelelnek a textilekre vonatkozó közelgő ESPR felhatalmazáson alapuló jogi aktusnak." },
      { "@language": "it", "@value": "Definisce concetti specifici del settore conformi al prossimo atto delegato dell'ESPR per i tessili." },
      { "@language": "lt", "@value": "Apibrėžia konkrečiam sektoriui skirtas sąvokas, atitinkančias būsimą ESPR deleguotąjį aktą dėl tekstilės gaminių." },
      { "@language": "lv", "@value": "Nosaka nozarei specifiskus jēdzienus, kas atbilst gaidāmajam ESPR deleģētajam aktam par tekstilizstrādājumiem." },
      { "@language": "mt", "@value": "Jiddefinixxi kunċetti speċifiċi għas-settur li huma konformi mal-Att Delegat li jmiss tal-ESPR għat-Tessuti." },
      { "@language": "nl", "@value": "Definieert sectorspecifieke concepten die voldoen aan de komende gedelegeerde handeling van de ESPR voor textiel." },
      { "@language": "pl", "@value": "Definiuje pojęcia specyficzne dla sektora, zgodne z nadchodzącym aktem delegowanym ESPR dotyczącym tekstyliów." },
      { "@language": "pt", "@value": "Define conceitos específicos do setor em conformidade com o próximo Ato Delegado do ESPR para os têxteis." },
      { "@language": "ro", "@value": "Definește concepte specifice sectorului, conforme cu viitorul act delegat al ESPR pentru textile." },
      { "@language": "sk", "@value": "Definuje koncepty špecifické pre dané odvetvie v súlade s pripravovaným delegovaným aktom ESPR pre textil." },
      { "@language": "sl", "@value": "Določa koncepte, specifične za posamezne sektorje, ki so v skladu s prihajajočim delegiranim aktom ESPR za tekstil." },
      { "@language": "sv", "@value": "Definierar branschspecifika koncept som överensstämmer med den kommande delegerade akten från ESPR för textilier." }
    ],
    "owl:versionInfo": "Draft",
    "owl:imports": [
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Compliance.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/sectors/EUApparelSizeSystem.jsonld" }
    ],
    "@graph": [
        {
            "@id": "dppk:TextileProduct",
            "@type": "rdfs:Class",
            "rdfs:label": [
              { "@language": "en", "@value": "Textile Product" },
              { "@language": "bg", "@value": "Текстилен продукт" },
              { "@language": "cs", "@value": "Textilní výrobek" },
              { "@language": "da", "@value": "Tekstilprodukt" },
              { "@language": "de", "@value": "Textilerzeugnis" },
              { "@language": "el", "@value": "Κλωστοϋφαντουργικό προϊόν" },
              { "@language": "es", "@value": "Producto textil" },
              { "@language": "et", "@value": "Tekstiiltoode" },
              { "@language": "fi", "@value": "Tekstiilituote" },
              { "@language": "fr", "@value": "Produit textile" },
              { "@language": "ga", "@value": "Táirge teicstíle" },
              { "@language": "hr", "@value": "Tekstilni proizvod" },
              { "@language": "hu", "@value": "Textiltermék" },
              { "@language": "it", "@value": "Prodotto tessile" },
              { "@language": "lt", "@value": "Tekstilės gaminys" },
              { "@language": "lv", "@value": "Tekstilizstrādājums" },
              { "@language": "mt", "@value": "Prodott tat-tessuti" },
              { "@language": "nl", "@value": "Textielproduct" },
              { "@language": "pl", "@value": "Produkt włókienniczy" },
              { "@language": "pt", "@value": "Produto têxtil" },
              { "@language": "ro", "@value": "Produs textil" },
              { "@language": "sk", "@value": "Textilný výrobok" },
              { "@language": "sl", "@value": "Tekstilni izdelek" },
              { "@language": "sv", "@value": "Textilprodukt" }
            ],
            "rdfs:comment": [
              { "@language": "en", "@value": "Any raw, semi-worked, or worked product which is exclusively composed of textile fibres, regardless of the mixing or assembly process employed." },
              { "@language": "bg", "@value": "Всеки суров, полуобработен или обработен продукт, който е съставен изключително от текстилни влакна, независимо от използвания процес на смесване или сглобяване." },
              { "@language": "cs", "@value": "Jakýkoli surový, polozpracovaný nebo zpracovaný výrobek, který je výlučně složen z textilních vláken, bez ohledu na použitý proces mísení nebo montáže." },
              { "@language": "da", "@value": "Ethvert råt, halvforarbejdet eller forarbejdet produkt, der udelukkende består af tekstilfibre, uanset hvilken blandings- eller samleproces der anvendes." },
              { "@language": "de", "@value": "Jedes rohe, halbbearbeitete oder bearbeitete Erzeugnis, das ausschließlich aus Textilfasern besteht, unabhängig vom angewandten Misch- oder Montageverfahren." },
              { "@language": "el", "@value": "Κάθε ακατέργαστο, ημικατεργασμένο ή κατεργασμένο προϊόν το οποίο αποτελείται αποκλειστικά από υφαντικές ίνες, ανεξάρτητα από τη διαδικασία ανάμειξης ή συναρμολόγησης που χρησιμοποιείται." },
              { "@language": "es", "@value": "Todo producto en bruto, semielaborado o elaborado que esté compuesto exclusivamente por fibras textiles, independientemente del proceso de mezcla o ensamblaje empleado." },
              { "@language": "et", "@value": "Mis tahes toor-, pooltoode või töödeldud toode, mis koosneb eranditult tekstiilkiududest, sõltumata kasutatud segamis- või kokkupanemisprotsessist." },
              { "@language": "fi", "@value": "Kaikki raa'at, puolivalmisteet tai valmisteet, jotka koostuvat yksinomaan tekstiilikuiduista, riippumatta käytetystä sekoitus- tai kokoonpanoprosessista." },
              { "@language": "fr", "@value": "Tout produit brut, semi-ouvré ou ouvré qui est exclusivement composé de fibres textiles, quel que soit le processus de mélange ou d'assemblage employé." },
              { "@language": "ga", "@value": "Aon táirge amh, leath-oibrithe nó oibrithe atá comhdhéanta go heisiach de shnáithíní teicstíle, is cuma cén próiseas measctha nó cóimeála a úsáidtear." },
              { "@language": "hr", "@value": "Bilo koji sirovi, poluobrađeni ili obrađeni proizvod koji se isključivo sastoji od tekstilnih vlakana, bez obzira na upotrijebljeni proces miješanja ili sastavljanja." },
              { "@language": "hu", "@value": "Bármely nyers, félkész vagy késztermék, amely kizárólag textilszálakból áll, függetlenül az alkalmazott keverési vagy összeszerelési eljárástól." },
              { "@language": "it", "@value": "Qualsiasi prodotto grezzo, semilavorato o lavorato che è composto esclusivamente da fibre tessili, indipendentemente dal processo di miscelazione o assemblaggio impiegato." },
              { "@language": "lt", "@value": "Bet koks žalias, pusgaminis ar apdorotas gaminys, kuris yra išimtinai sudarytas iš tekstilės pluoštų, neatsižvelgiant į naudojamą maišymo ar surinkimo procesą." },
              { "@language": "lv", "@value": "Jebkurš neapstrādāts, daļēji apstrādāts vai apstrādāts izstrādājums, kas sastāv tikai no tekstilšķiedrām neatkarīgi no izmantotā sajaukšanas vai montāžas procesa." },
              { "@language": "mt", "@value": "Kwalunkwe prodott mhux maħdum, nofsu maħdum, jew maħdum li huwa kompost esklussivament minn fibri tat-tessuti, irrispettivament mill-proċess ta' taħlit jew assemblaġġ impjegat." },
              { "@language": "nl", "@value": "Elk rauw, halfbewerkt of bewerkt product dat uitsluitend bestaat uit textielvezels, ongeacht het gebruikte meng- of assemblageproces." },
              { "@language": "pl", "@value": "Każdy surowy, półprodukt lub gotowy produkt, który składa się wyłącznie z włókien tekstylnych, niezależnie od zastosowanego procesu mieszania lub montażu." },
              { "@language": "pt", "@value": "Qualquer produto em bruto, semitrabalhado ou trabalhado que seja exclusivamente composto por fibras têxteis, independentemente do processo de mistura ou montagem utilizado." },
              { "@language": "ro", "@value": "Orice produs brut, semiprelucrat sau prelucrat care este compus exclusiv din fibre textile, indiferent de procesul de amestecare sau asamblare utilizat." },
              { "@language": "sk", "@value": "Akýkoľvek surový, polotovar alebo hotový výrobok, ktorý je výlučne zložený z textilných vlákien, bez ohľadu na použitý proces miešania alebo montáže." },
              { "@language": "sl", "@value": "Kateri koli surov, polizdelan ali izdelan izdelek, ki je izključno sestavljen iz tekstilnih vlaken, ne glede na uporabljeni postopek mešanja ali sestavljanja." },
              { "@language": "sv", "@value": "Varje rå, halvbearbetad eller bearbetad produkt som uteslutande består av textilfibrer, oavsett vilken blandnings- eller monteringsprocess som används." }
            ],
