                { "@language": "da", "@value": "Jern- og stålprodukt" },
                { "@language": "de", "@value": "Eisen- und Stahlprodukt" },
                { "@language": "el", "@value": "Προϊόν σιδήρου και χάλυβα" },
                { "@language": "es", "@value": "Producto de hierro y acero" },
                { "@language": "et", "@value": "Raua- ja terasetoode" },
                { "@language": "fi", "@value": "Rauta- ja terästuote" },
                { "@language": "fr", "@value": "Produit en fer et en acier" },
                { "@language": "hr", "@value": "Proizvod od željeza i čelika" },
                { "@language": "hu", "@value": "Vas- és acéltermék" },
                { "@language": "it", "@value": "Prodotto in ferro e acciaio" },
                { "@language": "lt", "@value": "Geležies ir plieno produktas" },
                { "@language": "lv", "@value": "Dzelzs un tērauda izstrādājums" },
                { "@language": "mt", "@value": "Prodott tal-Ħadid u l-Azzar" },
                { "@language": "nl", "@value": "IJzer- en staalproduct" },
                { "@language": "pl", "@value": "Produkt z żelaza i stali" },
                { "@language": "pt", "@value": "Produto de ferro e aço" },
                { "@language": "ro", "@value": "Produs din fier și oțel" },
                { "@language": "sk", "@value": "Výrobok zo železa a ocele" },
                { "@language": "sl", "@value": "Izdelek iz železa in jekla" },
                { "@language": "sv", "@value": "Järn- och stålprodukt" },
                { "@language": "ga", "@value": "Táirge Iarainn agus Cruach" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "Data model for the Iron and Steel Passport according to EU ESPR." },
                { "@language": "bg", "@value": "Модел на данни за паспорта за желязо и стомана съгласно ESPR на ЕС." },
                { "@language": "cs", "@value": "Datový model pro pas železa a oceli podle nařízení EU ESPR." },
                { "@language": "da", "@value": "Datamodel for jern- og stålpasset i henhold til EU ESPR." },
                { "@language": "de", "@value": "Datenmodell für den Eisen- und Stahlpass gemäß EU-ESPR." },
                { "@language": "el", "@value": "Μοντέλο δεδομένων για το διαβατήριο σιδήρου και χάλυβα σύμφωνα με το ESPR της ΕΕ." },
                { "@language": "es", "@value": "Modelo de datos para el pasaporte de hierro y acero de acuerdo con el ESPR de la UE." },
                { "@language": "et", "@value": "Raua- ja terasepassi andmemudel vastavalt ELi ESPR-ile." },
                { "@language": "fi", "@value": "EU:n ESPR-asetuksen mukainen rauta- ja teräspassin tietomalli." },
                { "@language": "fr", "@value": "Modèle de données pour le passeport pour le fer et l'acier selon l'ESPR de l'UE." },
                { "@language": "hr", "@value": "Model podataka za putovnicu za željezo i čelik u skladu s EU ESPR-om." },
                { "@language": "hu", "@value": "Az EU ESPR szerinti vas- és acélútlevél adatmodellje." },
                { "@language": "it", "@value": "Modello di dati per il passaporto per ferro e acciaio secondo l'ESPR dell'UE." },
                { "@language": "lt", "@value": "Geležies ir plieno paso duomenų modelis pagal ES ESPR." },
                { "@language": "lv", "@value": "Dzelzs un tērauda pases datu modelis saskaņā ar ES ESPR." },
                { "@language": "mt", "@value": "Mudell ta' data għall-Passaport tal-Ħadid u l-Azzar skont l-ESPR tal-UE." },
                { "@language": "nl", "@value": "Datamodel voor het ijzer- en staalpaspoort volgens EU ESPR." },
                { "@language": "pl", "@value": "Model danych dla paszportu dla żelaza i stali zgodnie z unijnym rozporządzeniem ESPR." },
                { "@language": "pt", "@value": "Modelo de dados para o passaporte de ferro e aço de acordo com o ESPR da UE." },
                { "@language": "ro", "@value": "Model de date pentru pașaportul pentru fier și oțel conform ESPR al UE." },
                { "@language": "sk", "@value": "Dátový model pre pas pre železo a oceľ podľa nariadenia EÚ ESPR." },
                { "@language": "sl", "@value": "Podatkovni model za potni list za železo in jeklo v skladu z uredbo EU ESPR." },
                { "@language": "sv", "@value": "Datamodell för järn- och stålpasset enligt EU:s ESPR." },
                { "@language": "ga", "@value": "Samhail sonraí don Phas Iarainn agus Cruach de réir ESPR an AE." }
            ],
            "rdfs:term_status": "unstable"
        },
        {
            "@id": "dppk:heatNumber",
            "@type": "owl:DatatypeProperty",
            "rdfs:label": [
                { "@language": "en", "@value": "Heat Number" },
                { "@language": "bg", "@value": "Номер на топене" },
                { "@language": "cs", "@value": "Číslo tavby" },
                { "@language": "da", "@value": "Heat-nummer" },
                { "@language": "de", "@value": "Chargennummer" },
                { "@language": "el", "@value": "Αριθμός χύτευσης" },
                { "@language": "es", "@value": "Número de colada" },
                { "@language": "et", "@value": "Sulatusnumber" },
                { "@language": "fi", "@value": "Sulatusnumero" },
                { "@language": "fr", "@value": "Numéro de coulée" },
                { "@language": "hr", "@value": "Broj taline" },
                { "@language": "hu", "@value": "Adagszám" },
                { "@language": "it", "@value": "Numero di colata" },
                { "@language": "lt", "@value": "Lydymo numeris" },
                { "@language": "lv", "@value": "Kausējuma numurs" },
                { "@language": "mt", "@value": "Numru tal-Funderija" },
                { "@language": "nl", "@value": "Chargenummer" },
                { "@language": "pl", "@value": "Numer wytopu" },
                { "@language": "pt", "@value": "Número da corrida" },
                { "@language": "ro", "@value": "Numărul șarjei" },
                { "@language": "sk", "@value": "Číslo tavby" },
                { "@language": "sl", "@value": "Številka taline" },
                { "@language": "sv", "@value": "Charge-nummer" },
                { "@language": "ga", "@value": "Uimhir Leáite" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The heat number for iron and steel to serve as a lot-level identifier." },
                { "@language": "bg", "@value": "Номерът на топене на желязото и стоманата, който служи като идентификатор на партида." },
                { "@language": "cs", "@value": "Číslo tavby pro železo a ocel sloužící jako identifikátor na úrovni šarže." },
                { "@language": "da", "@value": "Heat-nummeret for jern og stål, der fungerer som en lot-identifikator." },
                { "@language": "de", "@value": "Die Chargennummer für Eisen und Stahl, die als Identifikator auf Los-Ebene dient." },
                { "@language": "el", "@value": "Ο αριθμός χύτευσης για σίδηρο και χάλυβα που χρησιμεύει ως αναγνωριστικό επιπέδου παρτίδας." },
                { "@language": "es", "@value": "El número de colada para el hierro y el acero que sirve como identificador a nivel de lote." },
                { "@language": "et", "@value": "Raua ja terase sulatusnumber, mis toimib partii taseme identifikaatorina." },
                { "@language": "fi", "@value": "Raudan ja teräksen sulatusnumero, joka toimii erätason tunnisteena." },
                { "@language": "fr", "@value": "Le numéro de coulée pour le fer et l'acier servant d'identifiant au niveau du lot." },
                { "@language": "hr", "@value": "Broj taline za željezo i čelik koji služi kao identifikator na razini serije." },
                { "@language": "hu", "@value": "A vas és acél adagszáma, amely tételszintű azonosítóként szolgál." },
                { "@language": "it", "@value": "Il numero di colata per ferro e acciaio che funge da identificatore a livello di lotto." },
                { "@language": "lt", "@value": "Geležies ir plieno lydymo numeris, naudojamas kaip partijos lygio identifikatorius." },
                { "@language": "lv", "@value": "Dzelzs un tērauda kausējuma numurs, kas kalpo kā partijas līmeņa identifikators." },
                { "@language": "mt", "@value": "In-numru tal-funderija għall-ħadid u l-azzar biex iservi bħala identifikatur fil-livell tal-lott." },
                { "@language": "nl", "@value": "Het chargenummer voor ijzer en staal dat dient als identificatie op partijniveau." },
                { "@language": "pl", "@value": "Numer wytopu żelaza i stali służący jako identyfikator na poziomie partii." },
                { "@language": "pt", "@value": "O número da corrida para ferro e aço para servir como um identificador ao nível do lote." },
                { "@language": "ro", "@value": "Numărul șarjei pentru fier și oțel care servește drept identificator la nivel de lot." },
                { "@language": "sk", "@value": "Číslo tavby pre železo a oceľ slúžiace ako identifikátor na úrovni šarže." },
                { "@language": "sl", "@value": "Številka taline za železo in jeklo, ki služi kot identifikator na ravni serije." },
                { "@language": "sv", "@value": "Charge-numret för järn och stål som fungerar som en lot-identifierare." },
                { "@language": "ga", "@value": "An uimhir leáite d'iarann agus cruach chun feidhmiú mar aitheantóir ag leibhéal an bhais." }
            ],
            "dppk:governedBy": "EN 10168",
            "rdfs:domain": { "@id": "dppk:IronSteelProduct" },
            "rdfs:range": "xsd:string",
            "dppk:visibility": { "@id": "dppk:Public" },
            "owl:equivalentProperty": [
                { "@id": "gs1:batchLot" },
                { "@id": "schema:sku" }
            ],
            "rdfs:term_status": "unstable"
        },
