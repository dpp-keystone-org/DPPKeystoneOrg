{
    "@context": {
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "dppk": "https://dpp-keystone.org/spec/{{VERSION}}/terms#",
        "dcterms": "http://purl.org/dc/terms/",
        "schema": "http://schema.org/"
    },
    "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/sectors/IronSteel",
    "@type": "owl:Ontology",
    "dcterms:title": "DPP Iron & Steel Sector Ontology",
    "dcterms:description": "Defines the specific data model for the Iron and Steel Passport, covering ESPR and MTC attributes.",
    "rdfs:label": [
        { "@language": "en", "@value": "DPP Iron & Steel Sector Ontology" },
        { "@language": "bg", "@value": "Онтология на сектора на желязото и стоманата на ЦПП" },
        { "@language": "cs", "@value": "Ontologie odvětví železa a oceli DPP" },
        { "@language": "da", "@value": "DPP Jern- og stålsektorontologi" },
        { "@language": "de", "@value": "DPP Eisen- und Stahlsektor-Ontologie" },
        { "@language": "el", "@value": "Οντολογία τομέα σιδήρου και χάλυβα DPP" },
        { "@language": "es", "@value": "Ontología del sector del hierro y el acero del DPP" },
        { "@language": "et", "@value": "DPP raua- ja terasesektori ontoloogia" },
        { "@language": "fi", "@value": "DPP:n rauta- ja teräsalan ontologia" },
        { "@language": "fr", "@value": "Ontologie du secteur du fer et de l'acier du DPP" },
        { "@language": "hr", "@value": "Ontologija sektora željeza i čelika DPP-a" },
        { "@language": "hu", "@value": "DPP vas- és acélágazati ontológia" },
        { "@language": "it", "@value": "Ontologia del settore siderurgico del DPP" },
        { "@language": "lt", "@value": "DPP geležies ir plieno sektoriaus ontologija" },
        { "@language": "lv", "@value": "DPP dzelzs un tērauda nozares ontoloģija" },
        { "@language": "mt", "@value": "Ontoloġija tas-Settur tal-Ħadid u l-Azzar tad-DPP" },
        { "@language": "nl", "@value": "DPP IJzer- en staalsectorontologie" },
        { "@language": "pl", "@value": "Ontologia sektora żelaza i stali DPP" },
        { "@language": "pt", "@value": "Ontologia do Setor do Ferro e do Aço do DPP" },
        { "@language": "ro", "@value": "Ontologia sectorului siderurgic al DPP" },
        { "@language": "sk", "@value": "Ontológia odvetvia železa a ocele DPP" },
        { "@language": "sl", "@value": "Ontologija sektorja železa in jekla DPP" },
        { "@language": "sv", "@value": "DPP järn- och stålsektorontologi" },
        { "@language": "ga", "@value": "Ointeolaíocht Earnáil Iarainn agus Cruach DPP" }
    ],
    "rdfs:comment": [
        { "@language": "en", "@value": "Defines the specific data model for the Iron and Steel Passport, covering ESPR and Mill Test Certificate (MTC) attributes." },
        { "@language": "bg", "@value": "Определя специфичния модел на данни за паспорта за желязо и стомана, обхващащ атрибутите на ESPR и сертификата за изпитване на прокатното производство (MTC)." },
        { "@language": "cs", "@value": "Definuje specifický datový model pro pas železa a oceli, pokrývající atributy ESPR a certifikátu zkoušky válcovny (MTC)." },
        { "@language": "da", "@value": "Definerer den specifikke datamodel for jern- og stålpasset, der dækker attributter for ESPR og valseværkscertifikat (MTC)." },
        { "@language": "de", "@value": "Definiert das spezifische Datenmodell für den Eisen- und Stahlpass, das die Attribute von ESPR und des Werkszeugnisses (MTC) abdeckt." },
        { "@language": "el", "@value": "Καθορίζει το συγκεκριμένο μοντέλο δεδομένων για το Διαβατήριο Σιδήρου και Χάλυβα, καλύπτοντας τα χαρακτηριστικά ESPR και Πιστοποιητικού Δοκιμής Μύλου (MTC)." },
        { "@language": "es", "@value": "Define el modelo de datos específico para el Pasaporte de Hierro y Acero, cubriendo los atributos de ESPR y del Certificado de Prueba de Molino (MTC)." },
        { "@language": "et", "@value": "Määratleb raua- ja terasepassi spetsiifilise andmemudeli, hõlmates ESPR-i ja valtsimistehase katsetunnistuse (MTC) atribuute." },
        { "@language": "fi", "@value": "Määrittää rauta- ja teräspassin tietomallin, joka kattaa ESPR:n ja tehdas- tai ainestodistuksen (MTC) ominaisuudet." },
        { "@language": "fr", "@value": "Définit le modèle de données spécifique pour le passeport pour le fer et l'acier, couvrant les attributs ESPR et le certificat de contrôle d'usine (MTC)." },
        { "@language": "hr", "@value": "Definira specifični model podataka za putovnicu za željezo i čelik, pokrivajući atribute ESPR-a i certifikata o ispitivanju u valjaonici (MTC)." },
        { "@language": "hu", "@value": "Meghatározza a vas- és acélútlevél specifikus adatmodelljét, kiterjedve az ESPR és a műbizonylat (MTC) attribútumaira." },
        { "@language": "it", "@value": "Definisce il modello di dati specifico per il passaporto per ferro e acciaio, coprendo gli attributi ESPR e del certificato di prova del laminatoio (MTC)." },
        { "@language": "lt", "@value": "Apibrėžia specifinį geležies ir plieno paso duomenų modelį, apimantį ESPR ir gamyklos bandymų sertifikato (MTC) atributus." },
        { "@language": "lv", "@value": "Nosaka specifisko datu modeli dzelzs un tērauda pasei, ietverot ESPR un rūpnīcas pārbaudes sertifikāta (MTC) atribūtus." },
        { "@language": "mt", "@value": "Jiddefinixxi l-mudell ta' data speċifiku għall-Passaport tal-Ħadid u l-Azzar, li jkopri l-attributi tal-ESPR u taċ-Ċertifikat tat-Test tal-Mitħna (MTC)." },
        { "@language": "nl", "@value": "Bepaalt het specifieke datamodel voor het ijzer- en staalpaspoort, waarbij ESPR- en walserijtestcertificaat (MTC)-attributen worden gedekt." },
        { "@language": "pl", "@value": "Określa specyficzny model danych dla paszportu dla żelaza i stali, obejmujący atrybuty ESPR i świadectwa odbioru (MTC)." },
        { "@language": "pt", "@value": "Define o modelo de dados específico para o Passaporte de Ferro e Aço, cobrindo os atributos do ESPR e do Certificado de Teste de Fábrica (MTC)." },
        { "@language": "ro", "@value": "Definește modelul specific de date pentru Pașaportul pentru fier și oțel, acoperind atributele ESPR și ale certificatului de testare a fabricii (MTC)." },
        { "@language": "sk", "@value": "Definuje špecifický dátový model pre pas pre železo a oceľ, ktorý pokrýva atribúty ESPR a osvedčenia o skúške z valcovne (MTC)." },
        { "@language": "sl", "@value": "Določa specifičen podatkovni model za potni list za železo in jeklo, ki zajema atribute ESPR in potrdila o tovarniškem preskusu (MTC)." },
        { "@language": "sv", "@value": "Definierar den specifika datamodellen för järn- och stålpasset, som täcker attribut för ESPR och verktygsintyg (MTC)." },
        { "@language": "ga", "@value": "Sainmhíníonn sé an tsamhail sonraí sainiúil don Phas Iarainn agus Cruach, a chlúdaíonn tréithe ESPR agus Teastais Tástála Muilinn (MTC)." }
    ],
    "owl:imports": [
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Product.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/EPD.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/DoPC.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Visibility.jsonld" },
        { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/MTC.jsonld" }
    ],
    "@graph": [
        {
            "@id": "dppk:IronSteelProduct",
            "@type": "rdfs:Class",
