                { "@language": "sv", "@value": "Smält- och hällningsland" },
                { "@language": "ga", "@value": "Tír Leáite agus Doirte" }
            ],
            "rdfs:comment": [
                { "@language": "en", "@value": "The country where the steel was originally melted and poured." },
                { "@language": "bg", "@value": "Държавата, в която стоманата е била първоначално разтопена и излята." },
                { "@language": "cs", "@value": "Země, kde byla ocel původně roztavena a odlita." },
                { "@language": "da", "@value": "Det land, hvor stålet oprindeligt blev smeltet og hældt." },
                { "@language": "de", "@value": "Das Land, in dem der Stahl ursprünglich geschmolzen und gegossen wurde." },
                { "@language": "el", "@value": "Η χώρα όπου ο χάλυβας λιώθηκε και χύθηκε αρχικά." },
                { "@language": "es", "@value": "El país donde el acero se fundió y vertió originalmente." },
                { "@language": "et", "@value": "Riik, kus teras algselt sulatati ja valati." },
                { "@language": "fi", "@value": "Maa, jossa teräs alun perin sulatettiin ja valettiin." },
                { "@language": "fr", "@value": "Le pays où l'acier a été originellement fondu et coulé." },
                { "@language": "hr", "@value": "Zemlja u kojoj je čelik izvorno otopljen i uliven." },
                { "@language": "hu", "@value": "Az az ország, ahol az acélt eredetileg megolvasztották és öntötték." },
                { "@language": "it", "@value": "Il paese in cui l'acciaio è stato originariamente fuso e colato." },
                { "@language": "lt", "@value": "Šalis, kurioje plienas buvo iš pradžių išlydytas ir išpilstytas." },
                { "@language": "lv", "@value": "Valsts, kurā tērauds sākotnēji tika izkausēts un izliets." },
                { "@language": "mt", "@value": "Il-pajjiż fejn l-azzar kien oriġinarjament imdewweb u mferra." },
                { "@language": "nl", "@value": "Het land waar het staal oorspronkelijk is gesmolten en gegoten." },
                { "@language": "pl", "@value": "Kraj, w którym stal została pierwotnie stopiona i odlana." },
                { "@language": "pt", "@value": "O país onde o aço foi originalmente fundido e vazado." },
                { "@language": "ro", "@value": "Țara în care oțelul a fost topit și turnat inițial." },
                { "@language": "sk", "@value": "Krajina, kde bola oceľ pôvodne roztavená a odliata." },
                { "@language": "sl", "@value": "Država, v kateri je bilo jeklo prvotno stopljeno in vlito." },
                { "@language": "sv", "@value": "Det land där stålet ursprungligen smältes och hälldes." },
                { "@language": "ga", "@value": "An tír inar leádh agus inar doirteadh an chruach ar dtús." }
            ],
