{
  "@context": {
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "gs1": "https://ref.gs1.org/voc/",
    "dppk": "https://dpp-keystone.org/spec/{{VERSION}}/terms#",
    "dcterms": "http://purl.org/dc/terms/",
    "unece": "https://vocabulary.uncefact.org/",
    "@base": "https://dpp-keystone.org/spec/{{VERSION}}/terms"
  },
  "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/sectors/Electronics",
  "@type": "owl:Ontology",
  "dcterms:title": "DPP Sector Ontology - Electronics and Electrical Equipment Definitions ({{VERSION}})",
  "dcterms:description": "Defines concepts for Electronics and Electrical Equipment (EEE), aligning with regulations such as RoHS, WEEE, and Eco-Design requirements.",
  "owl:versionInfo": "1.0.0",
  // Import Core ontologies.
  "owl:imports": [
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Product.jsonld" },
    { "@id": "https://dpp-keystone.org/spec/ontology/{{VERSION}}/core/Compliance.jsonld" }
  ],

  "@graph": [
    // ==================================================================
    // Classes
    // ==================================================================

    {
      "@id": "dppk:ElectronicDevice",
      "@type": "rdfs:Class",
      "rdfs:label": [
        { "@language": "en", "@value": "Electronic Device (EEE)" },
        { "@language": "bg", "@value": "Електронно устройство (ЕЕО)" },
        { "@language": "cs", "@value": "Elektronické zařízení (EEZ)" },
        { "@language": "da", "@value": "Elektronisk enhed (EEE)" },
        { "@language": "de", "@value": "Elektronisches Gerät (Elektro- und Elektronikgeräte)" },
        { "@language": "el", "@value": "Ηλεκτρονική συσκευή (ΗΗΕ)" },
        { "@language": "es", "@value": "Dispositivo electrónico (AEE)" },
        { "@language": "et", "@value": "Elektroonikaseade (EEE)" },
        { "@language": "fi", "@value": "Elektroninen laite (Sähkö- ja elektroniikkalaitteet)" },
        { "@language": "fr", "@value": "Appareil électronique (EEE)" },
        { "@language": "ga", "@value": "Feiste Leictreonach (EEE)" },
        { "@language": "hr", "@value": "Elektronički uređaj (EEA)" },
        { "@language": "hu", "@value": "Elektronikus eszköz (EEE)" },
        { "@language": "it", "@value": "Dispositivo elettronico (AEE)" },
        { "@language": "lt", "@value": "Elektroninis prietaisas (EEĮ)" },
        { "@language": "lv", "@value": "Elektroniska ierīce (EEI)" },
        { "@language": "mt", "@value": "Apparat Elettroniku (EEE)" },
        { "@language": "nl", "@value": "Elektronisch apparaat (EEA)" },
        { "@language": "pl", "@value": "Urządzenie elektroniczne (SEE)" },
        { "@language": "pt", "@value": "Dispositivo eletrónico (EEE)" },
        { "@language": "ro", "@value": "Dispozitiv electronic (EEE)" },
        { "@language": "sk", "@value": "Elektronické zariadenie (EEZ)" },
        { "@language": "sl", "@value": "Elektronska naprava (EEO)" },
        { "@language": "sv", "@value": "Elektronisk enhet (EEE)" }
      ],
      "rdfs:comment": [
        { "@language": "en", "@value": "Equipment which is dependent on electric currents or electromagnetic fields in order to work properly." },
        { "@language": "bg", "@value": "Оборудване, което зависи от електрически токове или електромагнитни полета, за да работи правилно." },
        { "@language": "cs", "@value": "Zařízení, které ke správnému fungování závisí na elektrickém proudu nebo elektromagnetickém poli." },
        { "@language": "da", "@value": "Udstyr, der er afhængigt af elektrisk strøm eller elektromagnetiske felter for at fungere korrekt." },
        { "@language": "de", "@value": "Geräte, die zu ihrem ordnungsgemäßen Betrieb von elektrischen Strömen oder elektromagnetischen Feldern abhängig sind." },
        { "@language": "el", "@value": "Εξοπλισμός που εξαρτάται από ηλεκτρικά ρεύματα ή ηλεκτρομαγνητικά πεδία για να λειτουργήσει σωστά." },
        { "@language": "es", "@value": "Aparatos que necesitan corriente eléctrica o campos electromagnéticos para funcionar correctamente." },
        { "@language": "et", "@value": "Seadmed, mis vajavad nõuetekohaseks töötamiseks elektrivoolu või elektromagnetvälju." },
        { "@language": "fi", "@value": "Laitteet, jotka tarvitsevat toimiakseen sähkövirtaa tai sähkömagneettisia kenttiä." },
        { "@language": "fr", "@value": "Équipements fonctionnant grâce à des courants électriques ou des champs électromagnétiques." },
        { "@language": "ga", "@value": "Trealamh a bhraitheann ar shruthanna leictreacha nó ar réimsí leictreamaighnéadacha chun oibriú i gceart." },
        { "@language": "hr", "@value": "Oprema koja za pravilan rad ovisi o električnoj struji ili elektromagnetskim poljima." },
        { "@language": "hu", "@value": "Olyan berendezés, amelynek megfelelő működése elektromos áramtól vagy elektromágneses mezőktől függ." },
        { "@language": "it", "@value": "Apparecchiature che dipendono da correnti elettriche o campi elettromagnetici per funzionare correttamente." },
        { "@language": "lt", "@value": "Įranga, kuriai tinkamai veikti reikalingos elektros srovės arba elektromagnetiniai laukai." },
        { "@language": "lv", "@value": "Iekārtas, kuru pareizai darbībai ir nepieciešama elektriskā strāva vai elektromagnētiskie lauki." },
        { "@language": "mt", "@value": "Tagħmir li jiddependi fuq kurrenti elettriċi jew kampi eletromanjetiċi biex jaħdem kif suppost." },
        { "@language": "nl", "@value": "Apparatuur die afhankelijk is van elektrische stromen of elektromagnetische velden om goed te kunnen werken." },
        { "@language": "pl", "@value": "Sprzęt, którego prawidłowe działanie jest uzależnione od dopływu prądu elektrycznego lub obecności pól elektromagnetycznych." },
        { "@language": "pt", "@value": "Equipamento cujo bom funcionamento depende de correntes elétricas ou campos eletromagnéticos." },
        { "@language": "ro", "@value": "Echipamente a căror bună funcționare depinde de curenți electrici sau de câmpuri electromagnetice." },
        { "@language": "sk", "@value": "Zariadenie, ktoré na svoju správnu činnosť potrebuje elektrický prúd alebo elektromagnetické polia." },
        { "@language": "sl", "@value": "Oprema, katere pravilno delovanje je odvisno od električnega toka ali elektromagnetnih polj." },
        { "@language": "sv", "@value": "Utrustning som är beroende av elektriska strömmar eller elektromagnetiska fält för att fungera korrekt." }
      ],
      "dcterms:source": {
        "@id": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32012L0019",
        "rdfs:label": [
          { "@language": "en", "@value": "Directive 2012/19/EU (WEEE Directive)" },
          { "@language": "bg", "@value": "Директива 2012/19/ЕС (Директива за ОЕЕО)" },
          { "@language": "cs", "@value": "Směrnice 2012/19/EU (Směrnice OEEZ)" },
          { "@language": "da", "@value": "Direktiv 2012/19/EU (WEEE-direktivet)" },
          { "@language": "de", "@value": "Richtlinie 2012/19/EU (WEEE-Richtlinie)" },
          { "@language": "el", "@value": "Οδηγία 2012/19/ΕΕ (Οδηγία ΑΗΗΕ)" },
          { "@language": "es", "@value": "Directiva 2012/19/UE (Directiva RAEE)" },
          { "@language": "et", "@value": "Direktiiv 2012/19/EL (elektroonikaromude direktiiv)" },
          { "@language": "fi", "@value": "Direktiivi 2012/19/EU (WEEE-direktiivi)" },
          { "@language": "fr", "@value": "Directive 2012/19/UE (Directive DEEE)" },
          { "@language": "ga", "@value": "Treoir 2012/19/AE (Treoir WEEE)" },
          { "@language": "hr", "@value": "Direktiva 2012/19/EU (Direktiva o OEEO)" },
          { "@language": "hu", "@value": "2012/19/EU irányelv (WEEE irányelv)" },
          { "@language": "it", "@value": "Direttiva 2012/19/UE (Direttiva RAEE)" },
          { "@language": "lt", "@value": "Direktyva 2012/19/ES (EEĮA direktyva)" },
          { "@language": "lv", "@value": "Direktīva 2012/19/ES (EEIA direktīva)" },
          { "@language": "mt", "@value": "Direttiva 2012/19/UE (Direttiva WEEE)" },
          { "@language": "nl", "@value": "Richtlijn 2012/19/EU (AEEA-richtlijn)" },
          { "@language": "pl", "@value": "Dyrektywa 2012/19/UE (Dyrektywa WEEE)" },
          { "@language": "pt", "@value": "Diretiva 2012/19/UE (Diretiva REEE)" },
          { "@language": "ro", "@value": "Directiva 2012/19/UE (Directiva DEEE)" },
          { "@language": "sk", "@value": "Smernica 2012/19/EÚ (Smernica o OEEZ)" },
          { "@language": "sl", "@value": "Direktiva 2012/19/EU (Direktiva OEEO)" },
          { "@language": "sv", "@value": "Direktiv 2012/19/EU (WEEE-direktivet)" }
        ]
      },
      "rdfs:subClassOf": { "@id": "dppk:Product" }
    },
    {
        "@id": "dppk:PowerTool",
        "@type": "rdfs:Class",
        "rdfs:label": [
          { "@language": "en", "@value": "Power Tool" },
          { "@language": "bg", "@value": "Електрически инструмент" },
          { "@language": "cs", "@value": "Elektrické nářadí" },
          { "@language": "da", "@value": "Elværktøj" },
          { "@language": "de", "@value": "Elektrowerkzeug" },
          { "@language": "el", "@value": "Ηλεκτρικό εργαλείο" },
          { "@language": "es", "@value": "Herramienta eléctrica" },
          { "@language": "et", "@value": "Elektritööriist" },
          { "@language": "fi", "@value": "Sähkötyökalu" },
          { "@language": "fr", "@value": "Outil électrique" },
          { "@language": "ga", "@value": "Uirlis chumhachta" },
          { "@language": "hr", "@value": "Električni alat" },
          { "@language": "hu", "@value": "Elektromos szerszám" },
          { "@language": "it", "@value": "Elettroutensile" },
          { "@language": "lt", "@value": "Elektrinis įrankis" },
          { "@language": "lv", "@value": "Elektroinstruments" },
          { "@language": "mt", "@value": "Għodda tal-Elettriku" },
          { "@language": "nl", "@value": "Elektrisch gereedschap" },
          { "@language": "pl", "@value": "Elektronarzędzie" },
          { "@language": "pt", "@value": "Ferramenta elétrica" },
          { "@language": "ro", "@value": "Sculă electrică" },
          { "@language": "sk", "@value": "Elektrické náradie" },
          { "@language": "sl", "@value": "Električno orodje" },
          { "@language": "sv", "@value": "Elverktyg" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "A tool that is actuated by an additional power source and mechanism other than the solely manual labor used with hand tools." },
          { "@language": "bg", "@value": "Инструмент, който се задвижва от допълнителен източник на енергия и механизъм, различен от ръчния труд." },
          { "@language": "cs", "@value": "Nářadí poháněné dodatečným zdrojem energie a mechanismem jiným než výhradně manuální prací." },
          { "@language": "da", "@value": "Et værktøj, der aktiveres af en ekstra strømkilde og mekanisme ud over udelukkende manuelt arbejde." },
          { "@language": "de", "@value": "Ein Werkzeug, das durch eine zusätzliche Energiequelle und einen Mechanismus angetrieben wird, der über die manuelle Arbeit hinausgeht." },
          { "@language": "el", "@value": "Εργαλείο που ενεργοποιείται από πρόσθετη πηγή ενέργειας και μηχανισμό εκτός από τη χειρωνακτική εργασία." },
          { "@language": "es", "@value": "Herramienta accionada por una fuente de energía adicional y un mecanismo distinto del trabajo manual." },
          { "@language": "et", "@value": "Tööriist, mida käivitab lisaenergiaallikas ja mehhanism, mis erineb ainult käsitööriistade puhul kasutatavast käsitsitööst." },
          { "@language": "fi", "@value": "Työkalu, jota käyttää ylimääräinen voimanlähde ja mekanismi, joka poikkeaa käsityökaluista." },
          { "@language": "fr", "@value": "Outil actionné par une source d'énergie supplémentaire et un mécanisme autre que le seul travail manuel." },
          { "@language": "ga", "@value": "Uirlis a ghníomhaítear trí fhoinse cumhachta agus sásra breise nach saothar láimhe amháin é." },
          { "@language": "hr", "@value": "Alat koji se pokreće dodatnim izvorom energije i mehanizmom drugačijim od ručnog rada." },
          { "@language": "hu", "@value": "Olyan szerszám, amelyet a kéziszerszámoknál használt manuális munkán kívül egy további áramforrás és mechanizmus működtet." },
          { "@language": "it", "@value": "Un utensile azionato da una fonte di energia e un meccanismo aggiuntivi rispetto al solo lavoro manuale." },
          { "@language": "lt", "@value": "Įrankis, kurį varo papildomas energijos šaltinis ir mechanizmas, o ne tik rankų darbas." },
          { "@language": "lv", "@value": "Instruments, ko darbina papildu enerģijas avots un mehānisms, izņemot manuālu darbu." },
          { "@language": "mt", "@value": "Għodda li titħaddem minn sors ta' enerġija addizzjonali u mekkaniżmu minbarra x-xogħol manwali." },
          { "@language": "nl", "@value": "Een stuk gereedschap dat wordt aangedreven door een extra energiebron en mechanisme, in plaats van uitsluitend handarbeid." },
          { "@language": "pl", "@value": "Narzędzie napędzane dodatkowym źródłem energii i mechanizmem innym niż wyłącznie praca ręczna." },
          { "@language": "pt", "@value": "Uma ferramenta acionada por uma fonte de energia e mecanismo adicionais, além do trabalho manual." },
          { "@language": "ro", "@value": "O unealtă acționată de o sursă suplimentară de energie și de un mecanism diferit de munca manuală." },
          { "@language": "sk", "@value": "Nástroj, ktorý je poháňaný prídavným zdrojom energie a mechanizmom iným ako manuálnou prácou." },
          { "@language": "sl", "@value": "Orodje, ki ga poganja dodaten vir energije in mehanizem, razen izključno ročnega dela." },
          { "@language": "sv", "@value": "Ett verktyg som drivs av en extra kraftkälla och mekanism förutom enbart manuellt arbete." }
        ],
        "rdfs:subClassOf": { "@id": "dppk:ElectronicDevice" }
    },

    // ==================================================================
    // Properties (Power and Energy)
    // ==================================================================

    // --- Voltage ---
    {
        "@id": "dppk:voltage",
        "@type": "owl:ObjectProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Voltage" },
          { "@language": "bg", "@value": "Напрежение" },
          { "@language": "cs", "@value": "Napětí" },
          { "@language": "da", "@value": "Spænding" },
          { "@language": "de", "@value": "Spannung" },
          { "@language": "el", "@value": "Τάση" },
          { "@language": "es", "@value": "Tensión" },
          { "@language": "et", "@value": "Pinge" },
          { "@language": "fi", "@value": "Jännite" },
          { "@language": "fr", "@value": "Tension" },
          { "@language": "ga", "@value": "Voltas" },
          { "@language": "hr", "@value": "Napon" },
          { "@language": "hu", "@value": "Feszültség" },
          { "@language": "it", "@value": "Tensione" },
          { "@language": "lt", "@value": "Įtampa" },
          { "@language": "lv", "@value": "Spriegums" },
          { "@language": "mt", "@value": "Vultaġġ" },
          { "@language": "nl", "@value": "Spanning" },
          { "@language": "pl", "@value": "Napięcie" },
          { "@language": "pt", "@value": "Tensão" },
          { "@language": "ro", "@value": "Tensiune" },
          { "@language": "sk", "@value": "Napätie" },
          { "@language": "sl", "@value": "Napetost" },
          { "@language": "sv", "@value": "Spänning" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "The electric potential difference, typically measured in Volts (V)." },
          { "@language": "bg", "@value": "Електрическата потенциална разлика, обикновено измервана във волтове (V)." },
          { "@language": "cs", "@value": "Elektrický potenciální rozdíl, obvykle měřený ve voltech (V)." },
          { "@language": "da", "@value": "Den elektriske potentialforskel, typisk målt i volt (V)." },
          { "@language": "de", "@value": "Die elektrische Potentialdifferenz, typischerweise gemessen in Volt (V)." },
          { "@language": "el", "@value": "Η διαφορά ηλεκτρικού δυναμικού, που μετράται συνήθως σε Volts (V)." },
          { "@language": "es", "@value": "La diferencia de potencial eléctrico, que normalmente se mide en voltios (V)." },
          { "@language": "et", "@value": "Elektriline potentsiaalide erinevus, mida tavaliselt mõõdetakse voltides (V)." },
          { "@language": "fi", "@value": "Sähköinen potentiaaliero, mitataan yleensä voltteina (V)." },
          { "@language": "fr", "@value": "La différence de potentiel électrique, généralement mesurée en volts (V)." },
          { "@language": "ga", "@value": "An difríocht poitéinsil leictrigh, a thomhaistear i Volta (V) de ghnáth." },
          { "@language": "hr", "@value": "Razlika električnog potencijala, koja se obično mjeri u voltima (V)." },
          { "@language": "hu", "@value": "Az elektromos potenciálkülönbség, amelyet jellemzően voltban (V) mérnek." },
          { "@language": "it", "@value": "La differenza di potenziale elettrico, tipicamente misurata in Volt (V)." },
          { "@language": "lt", "@value": "Elektrinio potencialo skirtumas, paprastai matuojamas voltais (V)." },
          { "@language": "lv", "@value": "Elektriskā potenciāla starpība, ko parasti mēra voltos (V)." },
          { "@language": "mt", "@value": "Id-differenza tal-potenzjal elettriku, tipikament imkejla f'Volts (V)." },
          { "@language": "nl", "@value": "Het elektrische potentiaalverschil, meestal gemeten in volt (V)." },
          { "@language": "pl", "@value": "Różnica potencjałów elektrycznych, zazwyczaj mierzona w woltach (V)." },
          { "@language": "pt", "@value": "A diferença de potencial elétrico, tipicamente medida em volts (V)." },
          { "@language": "ro", "@value": "Diferența de potențial electric, măsurată de obicei în volți (V)." },
          { "@language": "sk", "@value": "Rozdiel elektrického potenciálu, zvyčajne meraný vo voltoch (V)." },
          { "@language": "sl", "@value": "Razlika električnega potenciala, običajno merjena v voltih (V)." },
          { "@language": "sv", "@value": "Den elektriska potentialskillnaden, mäts vanligtvis i volt (V)." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "dppk:QuantitativeValue" }
    },

    // --- Rated Power (Wattage) ---
    {
        "@id": "dppk:ratedPower",
        "@type": "owl:ObjectProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Rated Power (Wattage)" },
          { "@language": "bg", "@value": "Номинална мощност (във ватове)" },
          { "@language": "cs", "@value": "Jmenovitý výkon (ve wattech)" },
          { "@language": "da", "@value": "Nominel effekt (watt)" },
          { "@language": "de", "@value": "Nennleistung (Wattzahl)" },
          { "@language": "el", "@value": "Ονομαστική ισχύς (Ισχύς σε Watt)" },
          { "@language": "es", "@value": "Potencia nominal (vatios)" },
          { "@language": "et", "@value": "Nimivõimsus (vattides)" },
          { "@language": "fi", "@value": "Nimellisteho (wateissa)" },
          { "@language": "fr", "@value": "Puissance nominale (puissance en watts)" },
          { "@language": "ga", "@value": "Cumhacht Rátáilte (Vataíocht)" },
          { "@language": "hr", "@value": "Nazivna snaga (snaga u vatima)" },
          { "@language": "hu", "@value": "Névleges teljesítmény (watt)" },
          { "@language": "it", "@value": "Potenza nominale (wattaggio)" },
          { "@language": "lt", "@value": "Vardinė galia (vatais)" },
          { "@language": "lv", "@value": "Nominālā jauda (vatos)" },
          { "@language": "mt", "@value": "Qawwa Nominali (Wattage)" },
          { "@language": "nl", "@value": "Nominaal vermogen (wattage)" },
          { "@language": "pl", "@value": "Moc znamionowa (w watach)" },
          { "@language": "pt", "@value": "Potência nominal (potência em watts)" },
          { "@language": "ro", "@value": "Putere nominală (în wați)" },
          { "@language": "sk", "@value": "Menovitý výkon (vo wattoch)" },
          { "@language": "sl", "@value": "Nazivna moč (moč v vatih)" },
          { "@language": "sv", "@value": "Märkeffekt (watt)" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "The power consumption of the device under normal operating conditions, typically measured in Watts (W)." },
          { "@language": "bg", "@value": "Консумацията на енергия на устройството при нормални условия на работа, обикновено измервана във ватове (W)." },
          { "@language": "cs", "@value": "Spotřeba energie zařízení za normálních provozních podmínek, obvykle měřená ve wattech (W)." },
          { "@language": "da", "@value": "Enhedens strømforbrug under normale driftsbetingelser, typisk målt i watt (W)." },
          { "@language": "de", "@value": "Der Stromverbrauch des Geräts unter normalen Betriebsbedingungen, typischerweise gemessen in Watt (W)." },
          { "@language": "el", "@value": "Η κατανάλωση ενέργειας της συσκευής υπό κανονικές συνθήκες λειτουργίας, που μετράται συνήθως σε Watt (W)." },
          { "@language": "es", "@value": "El consumo de energía del dispositivo en condiciones normales de funcionamiento, normalmente medido en vatios (W)." },
          { "@language": "et", "@value": "Seadme energiatarve tavapärastes töötingimustes, mida tavaliselt mõõdetakse vattides (W)." },
          { "@language": "fi", "@value": "Laitteen virrankulutus normaaleissa käyttöolosuhteissa, mitataan yleensä watteina (W)." },
          { "@language": "fr", "@value": "La consommation d'énergie de l'appareil dans des conditions de fonctionnement normales, généralement mesurée en watts (W)." },
          { "@language": "ga", "@value": "Tomhaltas cumhachta na feiste faoi ghnáthchoinníollacha oibriúcháin, a thomhaistear i Vataí (W) de ghnáth." },
          { "@language": "hr", "@value": "Potrošnja energije uređaja u normalnim radnim uvjetima, koja se obično mjeri u vatima (W)." },
          { "@language": "hu", "@value": "A készülék energiafogyasztása normál üzemi körülmények között, jellemzően wattban (W) mérve." },
          { "@language": "it", "@value": "Il consumo energetico del dispositivo in condizioni operative normali, tipicamente misurato in Watt (W)." },
          { "@language": "lt", "@value": "Prietaiso energijos suvartojimas normaliomis veikimo sąlygomis, paprastai matuojamas vatais (W)." },
          { "@language": "lv", "@value": "Ierīces enerģijas patēriņš normālos darbības apstākļos, ko parasti mēra vatos (W)." },
          { "@language": "mt", "@value": "Il-konsum tal-enerġija tal-apparat taħt kundizzjonijiet ta' tħaddim normali, tipikament imkejjel f'Watts (W)." },
          { "@language": "nl", "@value": "Het stroomverbruik van het apparaat onder normale bedrijfsomstandigheden, meestal gemeten in watt (W)." },
          { "@language": "pl", "@value": "Pobór mocy przez urządzenie w normalnych warunkach pracy, zazwyczaj mierzony w watach (W)." },
          { "@language": "pt", "@value": "O consumo de energia do dispositivo em condições normais de funcionamento, tipicamente medido em watts (W)." },
          { "@language": "ro", "@value": "Consumul de energie al dispozitivului în condiții normale de funcționare, măsurat de obicei în wați (W)." },
          { "@language": "sk", "@value": "Spotreba energie zariadenia za normálnych prevádzkových podmienok, zvyčajne meraná vo wattoch (W)." },
          { "@language": "sl", "@value": "Poraba energije naprave v normalnih pogojih delovanja, običajno merjena v vatih (W)." },
          { "@language": "sv", "@value": "Enhetens strömförbrukning under normala driftsförhållanden, mäts vanligtvis i watt (W)." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "dppk:QuantitativeValue" }
    },
    
    // --- Energy Efficiency Class ---
    {
        "@id": "dppk:energyEfficiencyClass",
        "@type": "owl:DatatypeProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Energy Efficiency Class" },
          { "@language": "bg", "@value": "Клас на енергийна ефективност" },
          { "@language": "cs", "@value": "Třída energetické účinnosti" },
          { "@language": "da", "@value": "Energieffektivitetsklasse" },
          { "@language": "de", "@value": "Energieeffizienzklasse" },
          { "@language": "el", "@value": "Τάξη ενεργειακής απόδοσης" },
          { "@language": "es", "@value": "Clase de eficiencia energética" },
          { "@language": "et", "@value": "Energiatõhususe klass" },
          { "@language": "fi", "@value": "Energiatehokkuusluokka" },
          { "@language": "fr", "@value": "Classe d'efficacité énergétique" },
          { "@language": "ga", "@value": "Aicme Éifeachtúlachta Fuinnimh" },
          { "@language": "hr", "@value": "Razred energetske učinkovitosti" },
          { "@language": "hu", "@value": "Energiahatékonysági osztály" },
          { "@language": "it", "@value": "Classe di efficienza energetica" },
          { "@language": "lt", "@value": "Energijos vartojimo efektyvumo klasė" },
          { "@language": "lv", "@value": "Energoefektivitātes klase" },
          { "@language": "mt", "@value": "Klassi tal-Effiċjenza Enerġetika" },
          { "@language": "nl", "@value": "Energie-efficiëntieklasse" },
          { "@language": "pl", "@value": "Klasa efektywności energetycznej" },
          { "@language": "pt", "@value": "Classe de eficiência energética" },
          { "@language": "ro", "@value": "Clasa de eficiență energetică" },
          { "@language": "sk", "@value": "Trieda energetickej účinnosti" },
          { "@language": "sl", "@value": "Razred energijske učinkovitosti" },
          { "@language": "sv", "@value": "Energieffektivitetsklass" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "The energy efficiency rating as defined by the EU Energy Labelling framework (e.g., A, B, C)." },
          { "@language": "bg", "@value": "Рейтингът на енергийна ефективност, както е определен от рамката на ЕС за енергийно етикетиране (напр. A, B, C)." },
          { "@language": "cs", "@value": "Hodnocení energetické účinnosti, jak je definováno v rámci EU pro označování energetickými štítky (např. A, B, C)." },
          { "@language": "da", "@value": "Energieffektivitetsvurderingen som defineret i EU's rammeregulering for energimærkning (f.eks. A, B, C)." },
          { "@language": "de", "@value": "Die Energieeffizienzklasse gemäß dem EU-Rahmen für die Energieverbrauchskennzeichnung (z. B. A, B, C)." },
          { "@language": "el", "@value": "Η βαθμολογία ενεργειακής απόδοσης όπως ορίζεται από το πλαίσιο της ΕΕ για την ενεργειακή επισήμανση (π.χ. A, B, C)." },
          { "@language": "es", "@value": "La calificación de eficiencia energética tal como la define el marco de etiquetado energético de la UE (por ejemplo, A, B, C)." },
          { "@language": "et", "@value": "Energiatõhususe hinnang, nagu see on määratletud ELi energiamärgistuse raamistikus (nt A, B, C)." },
          { "@language": "fi", "@value": "Energiatehokkuusluokitus EU:n energiamerkintäkehyksen mukaisesti (esim. A, B, C)." },
          { "@language": "fr", "@value": "La note d'efficacité énergétique telle que définie par le cadre d'étiquetage énergétique de l'UE (par exemple, A, B, C)." },
          { "@language": "ga", "@value": "An rátáil éifeachtúlachta fuinnimh mar a shainítear i gcreat Lipéadaithe Fuinnimh an AE (m.sh., A, B, C)." },
          { "@language": "hr", "@value": "Ocjena energetske učinkovitosti kako je definirana okvirom EU-a za označivanje energetske učinkovitosti (npr. A, B, C)." },
          { "@language": "hu", "@value": "Az EU energiacímkézési keretrendszere által meghatározott energiahatékonysági besorolás (pl. A, B, C)." },
          { "@language": "it", "@value": "La classificazione di efficienza energetica come definita dal quadro di etichettatura energetica dell'UE (ad es. A, B, C)." },
          { "@language": "lt", "@value": "Energijos vartojimo efektyvumo įvertinimas, kaip apibrėžta ES energijos vartojimo efektyvumo ženklinimo sistemoje (pvz., A, B, C)." },
          { "@language": "lv", "@value": "Energoefektivitātes novērtējums, kā noteikts ES energomarķējuma sistēmā (piem., A, B, C)." },
          { "@language": "mt", "@value": "Il-klassifikazzjoni tal-effiċjenza enerġetika kif iddefinita mill-qafas tal-ittikkettar tal-enerġija tal-UE (eż., A, B, C)." },
          { "@language": "nl", "@value": "De energie-efficiëntiebeoordeling zoals gedefinieerd in het EU-kader voor energie-etikettering (bijv. A, B, C)." },
          { "@language": "pl", "@value": "Ocena efektywności energetycznej określona w unijnych ramach etykietowania energetycznego (np. A, B, C)." },
          { "@language": "pt", "@value": "A classificação de eficiência energética, tal como definida pelo quadro de rotulagem energética da UE (por exemplo, A, B, C)." },
          { "@language": "ro", "@value": "Clasa de eficiență energetică definită de cadrul UE privind etichetarea energetică (de ex., A, B, C)." },
          { "@language": "sk", "@value": "Hodnotenie energetickej účinnosti podľa rámca EÚ pre energetické štítkovanie (napr. A, B, C)." },
          { "@language": "sl", "@value": "Ocena energijske učinkovitosti, kot je opredeljena v okviru EU za označevanje z energijskimi nalepkami (npr. A, B, C)." },
          { "@language": "sv", "@value": "Energieffektivitetsklassningen enligt EU:s ramverk för energimärkning (t.ex. A, B, C)." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "xsd:string" }
    },

    // ==================================================================
    // Properties (Durability and Repairability)
    // ==================================================================

    // --- IP Rating ---
    {
        "@id": "dppk:ipRating",
        "@type": "owl:DatatypeProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Ingress Protection (IP) Rating" },
          { "@language": "bg", "@value": "Степен на защита (IP)" },
          { "@language": "cs", "@value": "Stupeň krytí (IP)" },
          { "@language": "da", "@value": "Kapslingsklasse (IP)" },
          { "@language": "de", "@value": "IP-Schutzart" },
          { "@language": "el", "@value": "Βαθμός προστασίας IP" },
          { "@language": "es", "@value": "Grado de protección IP" },
          { "@language": "et", "@value": "Kaitseaste (IP)" },
          { "@language": "fi", "@value": "Kotelointiluokka (IP)" },
          { "@language": "fr", "@value": "Indice de protection (IP)" },
          { "@language": "ga", "@value": "Rátáil Chosanta Isteach (IP)" },
          { "@language": "hr", "@value": "Stupanj zaštite (IP)" },
          { "@language": "hu", "@value": "IP védettségi besorolás" },
          { "@language": "it", "@value": "Grado di protezione (IP)" },
          { "@language": "lt", "@value": "Apsaugos laipsnis (IP)" },
          { "@language": "lv", "@value": "Aizsardzības klase (IP)" },
          { "@language": "mt", "@value": "Klassifikazzjoni ta' Protezzjoni (IP)" },
          { "@language": "nl", "@value": "Beschermingsgraad (IP)" },
          { "@language": "pl", "@value": "Stopień ochrony (IP)" },
          { "@language": "pt", "@value": "Índice de proteção (IP)" },
          { "@language": "ro", "@value": "Grad de protecție (IP)" },
          { "@language": "sk", "@value": "Stupeň ochrany (IP)" },
          { "@language": "sl", "@value": "Stopnja zaščite (IP)" },
          { "@language": "sv", "@value": "Kapslingsklassning (IP)" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Defines levels of sealing effectiveness against intrusion from foreign bodies (tools, dirt) and moisture (e.g., IP54)." },
          { "@language": "bg", "@value": "Определя нивата на ефективност на уплътняване срещу проникване на чужди тела (инструменти, мръсотия) и влага (напр. IP54)." },
          { "@language": "cs", "@value": "Definuje úroveň účinnosti utěsnění proti vniknutí cizích těles (nástrojů, nečistot) a vlhkosti (např. IP54)." },
          { "@language": "da", "@value": "Definerer niveauer af forseglingseffektivitet mod indtrængen fra fremmedlegemer (værktøj, snavs) og fugt (f.eks. IP54)." },
          { "@language": "de", "@value": "Definiert den Grad der Abdichtungswirksamkeit gegen das Eindringen von Fremdkörpern (Werkzeugen, Schmutz) und Feuchtigkeit (z. B. IP54)." },
          { "@language": "el", "@value": "Ορίζει τα επίπεδα αποτελεσματικότητας στεγανοποίησης έναντι της διείσδυσης από ξένα σώματα (εργαλεία, βρωμιά) και υγρασία (π.χ. IP54)." },
          { "@language": "es", "@value": "Define los niveles de eficacia del sellado contra la intrusión de cuerpos extraños (herramientas, suciedad) y la humedad (por ejemplo, IP54)." },
          { "@language": "et", "@value": "Määrab tihenduse tõhususe tasemed võõrkehade (tööriistad, mustus) ja niiskuse sissetungimise vastu (nt IP54)." },
          { "@language": "fi", "@value": "Määrittelee tiivistyksen tehokkuuden vieraiden esineiden (työkalut, lika) ja kosteuden tunkeutumista vastaan (esim. IP54)." },
          { "@language": "fr", "@value": "Définit les niveaux d'efficacité de l'étanchéité contre l'intrusion de corps étrangers (outils, saleté) et de l'humidité (par exemple, IP54)." },
          { "@language": "ga", "@value": "Sainmhínítear leibhéil d'éifeachtacht séalaithe i gcoinne cur isteach ó chomhlachtaí eachtracha (uirlisí, salachar) agus taise (m.sh., IP54)." },
          { "@language": "hr", "@value": "Definira razine učinkovitosti brtvljenja protiv prodora stranih tijela (alati, prljavština) i vlage (npr. IP54)." },
          { "@language": "hu", "@value": "Meghatározza az idegen testek (szerszámok, szennyeződés) és a nedvesség behatolása elleni tömítési hatékonyság szintjeit (pl. IP54)." },
          { "@language": "it", "@value": "Definisce i livelli di efficacia della sigillatura contro l'intrusione di corpi estranei (strumenti, sporcizia) e umidità (ad es. IP54)." },
          { "@language": "lt", "@value": "Apibrėžia sandarinimo efektyvumo lygius, apsaugančius nuo svetimkūnių (įrankių, purvo) ir drėgmės įsibrovimo (pvz., IP54)." },
          { "@language": "lv", "@value": "Nosaka blīvējuma efektivitātes līmeņus pret svešķermeņu (instrumentu, netīrumu) un mitruma iekļūšanu (piem., IP54)." },
          { "@language": "mt", "@value": "Jiddefinixxi l-livelli ta' effettività tas-siġillar kontra l-intrużjoni minn korpi barranin (għodda, ħmieġ) u umdità (eż., IP54)." },
          { "@language": "nl", "@value": "Definieert niveaus van afdichtingseffectiviteit tegen binnendringen van vreemde voorwerpen (gereedschap, vuil) en vocht (bijv. IP54)." },
          { "@language": "pl", "@value": "Określa poziomy skuteczności uszczelnienia przed wnikaniem ciał obcych (narzędzi, brudu) i wilgoci (np. IP54)." },
          { "@language": "pt", "@value": "Define os níveis de eficácia da vedação contra a intrusão de corpos estranhos (ferramentas, sujidade) e humidade (por exemplo, IP54)." },
          { "@language": "ro", "@value": "Definește nivelurile de eficiență a etanșării împotriva intruziunii din partea corpurilor străine (instrumente, murdărie) și a umidității (de ex., IP54)." },
          { "@language": "sk", "@value": "Definuje úrovne účinnosti tesnenia proti vniknutiu cudzích telies (nástrojov, nečistôt) a vlhkosti (napr. IP54)." },
          { "@language": "sl", "@value": "Določa ravni učinkovitosti tesnjenja pred vdorom tujkov (orodja, umazanija) in vlage (npr. IP54)." },
          { "@language": "sv", "@value": "Definierar nivåer av tätningseffektivitet mot inträngning från främmande föremål (verktyg, smuts) och fukt (t.ex. IP54)." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "xsd:string" }
    },

    // --- Spare Parts Availability ---
    {
        "@id": "dppk:sparePartsAvailable",
        "@type": "owl:DatatypeProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Spare Parts Availability" },
          { "@language": "bg", "@value": "Наличие на резервни части" },
          { "@language": "cs", "@value": "Dostupnost náhradních dílů" },
          { "@language": "da", "@value": "Tilgængelighed af reservedele" },
          { "@language": "de", "@value": "Verfügbarkeit von Ersatzteilen" },
          { "@language": "el", "@value": "Διαθεσιμότητα ανταλλακτικών" },
          { "@language": "es", "@value": "Disponibilidad de piezas de repuesto" },
          { "@language": "et", "@value": "Varuosade kättesaadavus" },
          { "@language": "fi", "@value": "Varaosien saatavuus" },
          { "@language": "fr", "@value": "Disponibilité des pièces de rechange" },
          { "@language": "ga", "@value": "Infhaighteacht Páirteanna Spártha" },
          { "@language": "hr", "@value": "Dostupnost rezervnih dijelova" },
          { "@language": "hu", "@value": "Pótalkatrészek rendelkezésre állása" },
          { "@language": "it", "@value": "Disponibilità dei pezzi di ricambio" },
          { "@language": "lt", "@value": "Atsarginių dalių prieinamumas" },
          { "@language": "lv", "@value": "Rezerves daļu pieejamība" },
          { "@language": "mt", "@value": "Disponibbiltà ta' Spare Parts" },
          { "@language": "nl", "@value": "Beschikbaarheid van reserveonderdelen" },
          { "@language": "pl", "@value": "Dostępność części zamiennych" },
          { "@language": "pt", "@value": "Disponibilidade de peças sobresselentes" },
          { "@language": "ro", "@value": "Disponibilitatea pieselor de schimb" },
          { "@language": "sk", "@value": "Dostupnosť náhradných dielov" },
          { "@language": "sl", "@value": "Razpoložljivost rezervnih delov" },
          { "@language": "sv", "@value": "Tillgänglighet av reservdelar" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Indicates whether spare parts are available for the product." },
          { "@language": "bg", "@value": "Показва дали за продукта има налични резервни части." },
          { "@language": "cs", "@value": "Udává, zda jsou pro produkt k dispozici náhradní díly." },
          { "@language": "da", "@value": "Angiver, om der er reservedele tilgængelige for produktet." },
          { "@language": "de", "@value": "Gibt an, ob Ersatzteile für das Produkt verfügbar sind." },
          { "@language": "el", "@value": "Υποδεικνύει εάν υπάρχουν διαθέσιμα ανταλλακτικά για το προϊόν." },
          { "@language": "es", "@value": "Indica si hay piezas de repuesto disponibles para el producto." },
          { "@language": "et", "@value": "Näitab, kas tootele on saadaval varuosi." },
          { "@language": "fi", "@value": "Ilmoittaa, onko tuotteeseen saatavilla varaosia." },
          { "@language": "fr", "@value": "Indique si des pièces de rechange sont disponibles pour le produit." },
          { "@language": "ga", "@value": "Léiríonn sé seo an bhfuil páirteanna spártha ar fáil don táirge." },
          { "@language": "hr", "@value": "Označava jesu li za proizvod dostupni rezervni dijelovi." },
          { "@language": "hu", "@value": "Jelzi, hogy rendelkezésre állnak-e pótalkatrészek a termékhez." },
          { "@language": "it", "@value": "Indica se sono disponibili pezzi di ricambio per il prodotto." },
          { "@language": "lt", "@value": "Nurodo, ar produktui galima įsigyti atsarginių dalių." },
          { "@language": "lv", "@value": "Norāda, vai produktam ir pieejamas rezerves daļas." },
          { "@language": "mt", "@value": "Jindika jekk l-ispare parts humiex disponibbli għall-prodott." },
          { "@language": "nl", "@value": "Geeft aan of er reserveonderdelen voor het product beschikbaar zijn." },
          { "@language": "pl", "@value": "Wskazuje, czy dla produktu dostępne są części zamienne." },
          { "@language": "pt", "@value": "Indica se existem peças sobresselentes disponíveis para o produto." },
          { "@language": "ro", "@value": "Indică dacă sunt disponibile piese de schimb pentru produs." },
          { "@language": "sk", "@value": "Udáva, či sú pre produkt dostupné náhradné diely." },
          { "@language": "sl", "@value": "Označuje, ali so za izdelek na voljo rezervni deli." },
          { "@language": "sv", "@value": "Indikerar om reservdelar finns tillgängliga för produkten." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "xsd:boolean" }
    },

    // --- Service Manual Availability ---
    {
        "@id": "dppk:serviceManualAvailable",
        "@type": "owl:DatatypeProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Service Manual Availability" },
          { "@language": "bg", "@value": "Наличие на ръководство за сервиз" },
          { "@language": "cs", "@value": "Dostupnost servisního manuálu" },
          { "@language": "da", "@value": "Tilgængelighed af servicemanual" },
          { "@language": "de", "@value": "Verfügbarkeit des Servicehandbuchs" },
          { "@language": "el", "@value": "Διαθεσιμότητα εγχειριδίου σέρβις" },
          { "@language": "es", "@value": "Disponibilidad del manual de servicio" },
          { "@language": "et", "@value": "Hooldusjuhendi kättesaadavus" },
          { "@language": "fi", "@value": "Huoltokäsikirjan saatavuus" },
          { "@language": "fr", "@value": "Disponibilité du manuel d'entretien" },
          { "@language": "ga", "@value": "Infhaighteacht Lámhleabhar Seirbhíse" },
          { "@language": "hr", "@value": "Dostupnost servisnog priručnika" },
          { "@language": "hu", "@value": "Szervizkönyv rendelkezésre állása" },
          { "@language": "it", "@value": "Disponibilità del manuale di servizio" },
          { "@language": "lt", "@value": "Techninės priežiūros vadovo prieinamumas" },
          { "@language": "lv", "@value": "Apkopes rokasgrāmatas pieejamība" },
          { "@language": "mt", "@value": "Disponibbiltà tal-Manwal tas-Servizz" },
          { "@language": "nl", "@value": "Beschikbaarheid van de servicehandleiding" },
          { "@language": "pl", "@value": "Dostępność instrukcji serwisowej" },
          { "@language": "pt", "@value": "Disponibilidade do manual de serviço" },
          { "@language": "ro", "@value": "Disponibilitatea manualului de service" },
          { "@language": "sk", "@value": "Dostupnosť servisnej príručky" },
          { "@language": "sl", "@value": "Razpoložljivost servisnega priročnika" },
          { "@language": "sv", "@value": "Tillgänglighet av servicemanual" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Indicates whether a service or repair manual is available." },
          { "@language": "bg", "@value": "Показва дали е налично ръководство за сервиз или ремонт." },
          { "@language": "cs", "@value": "Udává, zda je k dispozici servisní nebo opravárenský manuál." },
          { "@language": "da", "@value": "Angiver, om en service- eller reparationsmanual er tilgængelig." },
          { "@language": "de", "@value": "Gibt an, ob ein Service- oder Reparaturhandbuch verfügbar ist." },
          { "@language": "el", "@value": "Υποδεικνύει εάν είναι διαθέσιμο ένα εγχειρίδιο σέρβις ή επισκευής." },
          { "@language": "es", "@value": "Indica si hay disponible un manual de servicio o reparación." },
          { "@language": "et", "@value": "Näitab, kas hooldus- või remondijuhend on saadaval." },
          { "@language": "fi", "@value": "Ilmoittaa, onko huolto- tai korjauskäsikirja saatavilla." },
          { "@language": "fr", "@value": "Indique si un manuel d'entretien ou de réparation est disponible." },
          { "@language": "ga", "@value": "Léiríonn sé seo an bhfuil lámhleabhar seirbhíse nó deisiúcháin ar fáil." },
          { "@language": "hr", "@value": "Označava je li dostupan servisni priručnik ili priručnik za popravak." },
          { "@language": "hu", "@value": "Jelzi, hogy rendelkezésre áll-e szerviz- vagy javítási kézikönyv." },
          { "@language": "it", "@value": "Indica se è disponibile un manuale di servizio o di riparazione." },
          { "@language": "lt", "@value": "Nurodo, ar galima gauti techninės priežiūros ar remonto vadovą." },
          { "@language": "lv", "@value": "Norāda, vai ir pieejama apkopes vai remonta rokasgrāmata." },
          { "@language": "mt", "@value": "Jindika jekk manwal ta' servizz jew tiswija huwiex disponibbli." },
          { "@language": "nl", "@value": "Geeft aan of er een service- of reparatiehandleiding beschikbaar is." },
          { "@language": "pl", "@value": "Wskazuje, czy dostępna jest instrukcja serwisowa lub naprawcza." },
          { "@language": "pt", "@value": "Indica se está disponível um manual de serviço ou reparação." },
          { "@language": "ro", "@value": "Indică dacă este disponibil un manual de service sau de reparații." },
          { "@language": "sk", "@value": "Udáva, či je dostupná servisná príručka alebo príručka na opravu." },
          { "@language": "sl", "@value": "Označuje, ali je na voljo servisni priročnik ali priročnik za popravilo." },
          { "@language": "sv", "@value": "Indikerar om en service- eller reparationsmanual är tillgänglig." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "xsd:boolean" }
    },

