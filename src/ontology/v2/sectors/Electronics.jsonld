          { "@language": "sl", "@value": "Navodila za razstavljanje" },
          { "@language": "sv", "@value": "Demonteringsinstruktioner" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "Instructions for safely disassembling the product for repair or recycling." },
          { "@language": "bg", "@value": "Инструкции за безопасно разглобяване на продукта с цел ремонт или рециклиране." },
          { "@language": "cs", "@value": "Pokyny pro bezpečnou demontáž výrobku za účelem opravy nebo recyklace." },
          { "@language": "da", "@value": "Instruktioner til sikker demontering af produktet til reparation eller genanvendelse." },
          { "@language": "de", "@value": "Anleitungen zur sicheren Demontage des Produkts für Reparatur oder Recycling." },
          { "@language": "el", "@value": "Οδηγίες για την ασφαλή αποσυναρμολόγηση του προϊόντος για επισκευή ή ανακύκλωση." },
          { "@language": "es", "@value": "Instrucciones para desmontar el producto de forma segura para su reparación o reciclaje." },
          { "@language": "et", "@value": "Juhised toote ohutuks lahtivõtmiseks parandamise või ringlussevõtu eesmärgil." },
          { "@language": "fi", "@value": "Ohjeet tuotteen turvalliseen purkamiseen korjausta tai kierrätystä varten." },
          { "@language": "fr", "@value": "Instructions pour démonter le produit en toute sécurité à des fins de réparation ou de recyclage." },
          { "@language": "ga", "@value": "Treoracha chun an táirge a dhíchóimeáil go sábháilte le haghaidh deisiúcháin nó athchúrsála." },
          { "@language": "hr", "@value": "Upute za sigurno rastavljanje proizvoda za popravak ili recikliranje." },
          { "@language": "hu", "@value": "Utasítások a termék javítás vagy újrafeldolgozás céljából történő biztonságos szétszereléséhez." },
          { "@language": "it", "@value": "Istruzioni per smontare in sicurezza il prodotto per la riparazione o il riciclaggio." },
          { "@language": "lt", "@value": "Saugaus gaminio išardymo taisymo ar perdirbimo tikslais instrukcijos." },
          { "@language": "lv", "@value": "Norādījumi par produkta drošu demontāžu remontam vai pārstrādei." },
          { "@language": "mt", "@value": "Istruzzjonijiet għaż-żarmar sikur tal-prodott għat-tiswija jew ir-riċiklaġġ." },
          { "@language": "nl", "@value": "Instructies voor het veilig demonteren van het product voor reparatie of recycling." },
          { "@language": "pl", "@value": "Instrukcje bezpiecznego demontażu produktu w celu naprawy lub recyklingu." },
          { "@language": "pt", "@value": "Instruções para desmontar o produto com segurança para reparação ou reciclagem." },
          { "@language": "ro", "@value": "Instrucțiuni pentru dezasamblarea în siguranță a produsului în vederea reparării sau reciclării." },
          { "@language": "sk", "@value": "Pokyny na bezpečné rozobratie výrobku za účelom opravy alebo recyklácie." },
          { "@language": "sl", "@value": "Navodila za varno razstavljanje izdelka za popravilo ali recikliranje." },
          { "@language": "sv", "@value": "Instruktioner för säker demontering av produkten för reparation eller återvinning." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "rdf:langString" }
    },



    // ==================================================================
    // Properties (Specialized Subclass Example: Power Tools)
    // ==================================================================

    {
        "@id": "dppk:torque",
        "@type": "owl:ObjectProperty",
        "rdfs:label": [
          { "@language": "en", "@value": "Torque" },
          { "@language": "bg", "@value": "Въртящ момент" },
          { "@language": "cs", "@value": "Točivý moment" },
          { "@language": "da", "@value": "Drejningsmoment" },
          { "@language": "de", "@value": "Drehmoment" },
          { "@language": "el", "@value": "Ροπή" },
          { "@language": "es", "@value": "Par de apriete" },
          { "@language": "et", "@value": "Pöördemoment" },
          { "@language": "fi", "@value": "Vääntömomentti" },
          { "@language": "fr", "@value": "Couple" },
          { "@language": "ga", "@value": "Casmhóimint" },
          { "@language": "hr", "@value": "Zakretni moment" },
          { "@language": "hu", "@value": "Nyomaték" },
          { "@language": "it", "@value": "Coppia" },
          { "@language": "lt", "@value": "Sukimo momentas" },
          { "@language": "lv", "@value": "Griezes moments" },
          { "@language": "mt", "@value": "Torque" },
          { "@language": "nl", "@value": "Koppel" },
          { "@language": "pl", "@value": "Moment obrotowy" },
          { "@language": "pt", "@value": "Binário" },
          { "@language": "ro", "@value": "Cuplu" },
          { "@language": "sk", "@value": "Krútiaci moment" },
          { "@language": "sl", "@value": "Navor" },
          { "@language": "sv", "@value": "Vridmoment" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "The rotational force generated by the tool, typically measured in Newton-meters (Nm)." },
          { "@language": "bg", "@value": "Ротационната сила, генерирана от инструмента, обикновено измервана в нютон-метри (Nm)." },
          { "@language": "cs", "@value": "Rotační síla generovaná nástrojem, obvykle měřená v newtonmetrech (Nm)." },
          { "@language": "da", "@value": "Rotationskraften genereret af værktøjet, typisk målt i newtonmeter (Nm)." },
          { "@language": "de", "@value": "Die vom Werkzeug erzeugte Rotationskraft, typischerweise gemessen in Newtonmetern (Nm)." },
          { "@language": "el", "@value": "Η περιστροφική δύναμη που δημιουργείται από το εργαλείο, συνήθως μετράται σε Νιούτον-μέτρα (Nm)." },
          { "@language": "es", "@value": "La fuerza de rotación generada por la herramienta, que normalmente se mide en Newton-metros (Nm)." },
          { "@language": "et", "@value": "Tööriista tekitatav pöörlemisjõud, mida tavaliselt mõõdetakse njuutonmeetrites (Nm)." },
          { "@language": "fi", "@value": "Työkalun tuottama pyörimisvoima, mitataan yleensä newtonmetreinä (Nm)." },
          { "@language": "fr", "@value": "La force de rotation générée par l'outil, généralement mesurée en newtons-mètres (Nm)." },
          { "@language": "ga", "@value": "An fórsa rothlach a ghineann an uirlis, a thomhaistear i Newton-mhéadair (Nm) de ghnáth." },
          { "@language": "hr", "@value": "Rotacijska sila koju stvara alat, obično se mjeri u njutnmetrima (Nm)." },
          { "@language": "hu", "@value": "A szerszám által generált forgóerő, amelyet jellemzően newtonméterben (Nm) mérnek." },
          { "@language": "it", "@value": "La forza rotazionale generata dall'utensile, tipicamente misurata in Newton-metri (Nm)." },
          { "@language": "lt", "@value": "Įrankio sukuriama sukimosi jėga, paprastai matuojama niutonmetrais (Nm)." },
          { "@language": "lv", "@value": "Instrumenta radītais rotācijas spēks, ko parasti mēra ņūtonmetros (Nm)." },
          { "@language": "mt", "@value": "Il-forza rotazzjonali ġġenerata mill-għodda, tipikament imkejla f'Newton-metri (Nm)." },
          { "@language": "nl", "@value": "De rotatiekracht die door het gereedschap wordt gegenereerd, meestal gemeten in Newtonmeter (Nm)." },
          { "@language": "pl", "@value": "Siła obrotowa generowana przez narzędzie, zazwyczaj mierzona w niutonometrach (Nm)." },
