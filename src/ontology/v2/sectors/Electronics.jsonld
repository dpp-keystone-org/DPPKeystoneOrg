          { "@language": "es", "@value": "Categoría RAEE" },
          { "@language": "et", "@value": "Elektroonikaromude kategooria" },
          { "@language": "fi", "@value": "WEEE-luokka" },
          { "@language": "fr", "@value": "Catégorie DEEE" },
          { "@language": "ga", "@value": "Catagóir WEEE" },
          { "@language": "hr", "@value": "Kategorija OEEO" },
          { "@language": "hu", "@value": "WEEE kategória" },
          { "@language": "it", "@value": "Categoria RAEE" },
          { "@language": "lt", "@value": "EEĮA kategorija" },
          { "@language": "lv", "@value": "EEIA kategorija" },
          { "@language": "mt", "@value": "Kategorija WEEE" },
          { "@language": "nl", "@value": "AEEA-categorie" },
          { "@language": "pl", "@value": "Kategoria WEEE" },
          { "@language": "pt", "@value": "Categoria REEE" },
          { "@language": "ro", "@value": "Categoria DEEE" },
          { "@language": "sk", "@value": "Kategória OEEZ" },
          { "@language": "sl", "@value": "Kategorija OEEO" },
          { "@language": "sv", "@value": "WEEE-kategori" }
        ],
        "rdfs:comment": [
          { "@language": "en", "@value": "The category under the Waste Electrical and Electronic Equipment (WEEE) Directive." },
          { "@language": "bg", "@value": "Категорията съгласно Директивата за отпадъците от електрическо и електронно оборудване (ОЕЕО)." },
          { "@language": "cs", "@value": "Kategorie podle směrnice o odpadních elektrických a elektronických zařízeních (OEEZ)." },
          { "@language": "da", "@value": "Kategorien under direktivet om affald af elektrisk og elektronisk udstyr (WEEE)." },
          { "@language": "de", "@value": "Die Kategorie gemäß der Richtlinie über Elektro- und Elektronik-Altgeräte (WEEE)." },
          { "@language": "el", "@value": "Η κατηγορία βάσει της οδηγίας για τα απόβλητα ηλεκτρικού και ηλεκτρονικού εξοπλισμού (ΑΗΗΕ)." },
          { "@language": "es", "@value": "La categoría en el marco de la Directiva sobre residuos de aparatos eléctricos y electrónicos (RAEE)." },
          { "@language": "et", "@value": "Elektri- ja elektroonikaseadmete jäätmete (WEEE) direktiivi kohane kategooria." },
          { "@language": "fi", "@value": "Sähkö- ja elektroniikkalaiteromua (WEEE) koskevan direktiivin mukainen luokka." },
          { "@language": "fr", "@value": "La catégorie au titre de la directive relative aux déchets d'équipements électriques et électroniques (DEEE)." },
          { "@language": "ga", "@value": "An chatagóir faoin Treoir maidir le Dramhthrealamh Leictreach agus Leictreonach (WEEE)." },
          { "@language": "hr", "@value": "Kategorija prema Direktivi o otpadnoj električnoj i elektroničkoj opremi (OEEO)." },
          { "@language": "hu", "@value": "Az elektromos és elektronikus berendezések hulladékairól szóló (WEEE) irányelv szerinti kategória." },
          { "@language": "it", "@value": "La categoria ai sensi della direttiva sui rifiuti di apparecchiature elettriche ed elettroniche (RAEE)." },
          { "@language": "lt", "@value": "Kategorija pagal Elektros ir elektroninės įrangos atliekų (EEĮA) direktyvą." },
          { "@language": "lv", "@value": "Kategorija saskaņā ar Elektrisko un elektronisko iekārtu atkritumu (EEIA) direktīvu." },
          { "@language": "mt", "@value": "Il-kategorija taħt id-Direttiva dwar l-Iskart ta' Tagħmir Elettriku u Elettroniku (WEEE)." },
          { "@language": "nl", "@value": "De categorie onder de richtlijn betreffende afgedankte elektrische en elektronische apparatuur (AEEA)." },
          { "@language": "pl", "@value": "Kategoria zgodnie z dyrektywą w sprawie zużytego sprzętu elektrycznego i elektronicznego (WEEE)." },
          { "@language": "pt", "@value": "A categoria ao abrigo da Diretiva relativa aos resíduos de equipamentos elétricos e eletrónicos (REEE)." },
          { "@language": "ro", "@value": "Categoria în conformitate cu Directiva privind deșeurile de echipamente electrice și electronice (DEEE)." },
          { "@language": "sk", "@value": "Kategória podľa smernice o odpade z elektrických a elektronických zariadení (OEEZ)." },
          { "@language": "sl", "@value": "Kategorija v skladu z Direktivo o odpadni električni in elektronski opremi (OEEO)." },
          { "@language": "sv", "@value": "Kategorin under direktivet om avfall från elektrisk och elektronisk utrustning (WEEE)." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "xsd:string" }
    },

