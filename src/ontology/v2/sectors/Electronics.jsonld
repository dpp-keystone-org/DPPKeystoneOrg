        "rdfs:comment": [
          { "@language": "en", "@value": "Information on the duration and type of software/firmware updates provided by the manufacturer." },
          { "@language": "bg", "@value": "Информация за продължителността и вида на софтуерните/фърмуерните актуализации, предоставени от производителя." },
          { "@language": "cs", "@value": "Informace o době trvání a typu aktualizací softwaru/firmwaru poskytovaných výrobcem." },
          { "@language": "da", "@value": "Oplysninger om varigheden og typen af software-/firmwareopdateringer leveret af producenten." },
          { "@language": "de", "@value": "Informationen zu Dauer und Art der vom Hersteller bereitgestellten Software-/Firmware-Updates." },
          { "@language": "el", "@value": "Πληροφορίες σχετικά με τη διάρκεια και τον τύπο των ενημερώσεων λογισμικού/υλικολογισμικού που παρέχονται από τον κατασκευαστή." },
          { "@language": "es", "@value": "Información sobre la duración y el tipo de las actualizaciones de software/firmware proporcionadas por el fabricante." },
          { "@language": "et", "@value": "Teave tootja pakutavate tarkvara-/püsivara värskenduste kestuse ja tüübi kohta." },
          { "@language": "fi", "@value": "Tietoja valmistajan tarjoamien ohjelmisto-/laiteohjelmistopäivitysten kestosta ja tyypistä." },
          { "@language": "fr", "@value": "Informations sur la durée et le type des mises à jour logicielles/du micrologiciel fournies par le fabricant." },
          { "@language": "ga", "@value": "Faisnéis faoi ré agus faoi chineál na nuashonruithe bogearraí/dochtearraí a sholáthraíonn an monaróir." },
          { "@language": "hr", "@value": "Informacije o trajanju i vrsti ažuriranja softvera/firmvera koje pruža proizvođač." },
          { "@language": "hu", "@value": "A gyártó által biztosított szoftver-/firmware-frissítések időtartamára és típusára vonatkozó információk." },
          { "@language": "it", "@value": "Informazioni sulla durata e sul tipo di aggiornamenti software/firmware forniti dal produttore." },
          { "@language": "lt", "@value": "Informacija apie gamintojo teikiamų programinės / programinės aparatinės įrangos atnaujinimų trukmę ir tipą." },
          { "@language": "lv", "@value": "Informācija par ražotāja nodrošināto programmatūras/aparātprogrammatūras atjauninājumu ilgumu un veidu." },
          { "@language": "mt", "@value": "Informazzjoni dwar it-tul ta' żmien u t-tip ta' aġġornamenti ta' softwer/firmware pprovduti mill-manifattur." },
          { "@language": "nl", "@value": "Informatie over de duur en het type software-/firmware-updates dat door de fabrikant wordt geleverd." },
          { "@language": "pl", "@value": "Informacje o czasie trwania i rodzaju aktualizacji oprogramowania/oprogramowania układowego udostępnianych przez producenta." },
          { "@language": "pt", "@value": "Informações sobre a duração e o tipo de atualizações de software/firmware fornecidas pelo fabricante." },
          { "@language": "ro", "@value": "Informații privind durata și tipul actualizărilor de software/firmware furnizate de producător." },
          { "@language": "sk", "@value": "Informácie o trvaní a type aktualizácií softvéru/firmvéru poskytovaných výrobcom." },
          { "@language": "sl", "@value": "Informacije o trajanju in vrsti posodobitev programske/strojne opreme, ki jih zagotavlja proizvajalec." },
          { "@language": "sv", "@value": "Information om varaktighet och typ av mjukvaru-/firmwareuppdateringar som tillhandahålls av tillverkaren." }
        ],
        "rdfs:domain": { "@id": "dppk:ElectronicDevice" },
        "rdfs:range": { "@id": "rdf:langString" }
    },

