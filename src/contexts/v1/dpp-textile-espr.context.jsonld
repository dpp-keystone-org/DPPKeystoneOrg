{
    "@context": [
        "https://dpp-keystone.org/spec/contexts/v1/dpp-core.context.jsonld",
        {
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "pefcrCategory": {
                "@id": "dppk:pefcrCategory",
                "@type": "@vocab"
            },
            "T-shirts": "dppk:PefcrTShirts",
            "Shirts and blouses": "dppk:PefcrShirtsAndBlouses",
            "Sweaters and midlayers": "dppk:PefcrSweatersAndMidlayers",
            "Jackets and coats": "dppk:PefcrJacketsAndCoats",
            "Pants and shorts": "dppk:PefcrPantsAndShorts",
            "Dresses, skirts and jumpsuits": "dppk:PefcrDressesSkirtsAndJumpsuits",
            "Leggings, stockings, tights and socks": "dppk:PefcrLeggingsStockingsTightsAndSocks",
            "Underwear": "dppk:PefcrUnderwear",
            "Swimwear": "dppk:PefcrSwimwear",
            "Apparel Accessories": "dppk:PefcrApparelAccessories",
            "Open-toed shoes": "dppk:PefcrOpenToedShoes",
            "Closed-toed shoes": "dppk:PefcrClosedToedShoes",
            "Boots": "dppk:PefcrBoots",
            "substancesOfConcern": {
                "@id": "dppk:substancesOfConcern",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "fibreComposition": {
                "@id": "dppk:fibreComposition",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "organicMaterialComposition": {
                "@id": "dppk:organicMaterialComposition",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "recycledMaterialComposition": {
                "@id": "dppk:recycledMaterialComposition",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "textileCertifications": {
                "@id": "dppk:textileCertifications",
                "@container": "@set",
                "@context": {
                    "name": "dppk:certificationName",
                    "identifier": "dppk:certificationId",
                    "url": {
                        "@id": "dppk:certificationUrl",
                        "@type": "xsd:anyURI"
                    },
                    "certificationBodyName": "dppk:certificationBodyName",
                    "certificationBodyId": "dppk:certificationBodyId",
                    "certificationStartDate": {
                        "@id": "dppk:certificationStartDate",
                        "@type": "xsd:date"
                    },
                    "certificationEndDate": {
                        "@id": "dppk:certificationEndDate",
                        "@type": "xsd:date"
                    },
                    "certificationBodyRole": "dppk:certificationBodyRole",
                    "document": "dppk:documents"
                }
            },
            "safeUseInstructions": {
                "@id": "dppk:safeUseInstructions",
                "@container": "@set",
                "@context": {
                    "resourceTitle": "dppk:resourceTitle",
                    "contentType": "dppk:contentType",
                    "language": "dppk:language",
                    "url": {
                        "@id": "dppk:url",
                        "@type": "xsd:anyURI"
                    }
                }
            },
            "endOfLifeInstructions": {
                "@id": "dppk:endOfLifeInstructions",
                "@container": "@set",
                "@context": {
                    "resourceTitle": "dppk:resourceTitle",
                    "contentType": "dppk:contentType",
                    "language": "dppk:language",
                    "url": {
                        "@id": "dppk:url",
                        "@type": "xsd:anyURI"
                    }
                }
            },
            "repairInstructions": {
                "@id": "dppk:repairInstructions",
                "@container": "@set",
                "@context": {
                    "resourceTitle": "dppk:resourceTitle",
                    "contentType": "dppk:contentType",
                    "language": "dppk:language",
                    "url": {
                        "@id": "dppk:url",
                        "@type": "xsd:anyURI"
                    }
                }
            },
            "warrantyDuration": {
                "@id": "dppk:warrantyDuration",
                "@type": "xsd:string"
            },
            "repairServices": {
                "@id": "dppk:repairServices",
                "@container": "@set"
            },
            "carbonFootprint": {
                "@id": "dppk:carbonFootprint",
                "@type": "xsd:double"
            },
            "carbonFootprintBenchmarkPercentage": {
                "@id": "dppk:carbonFootprintBenchmarkPercentage",
                "@type": "xsd:double"
            },
            "robustnessScore": {
                "@id": "dppk:robustnessScore",
                "@type": "xsd:double"
            },
            "recyclabilityScore": {
                "@id": "dppk:recyclabilityScore",
                "@type": "xsd:double"
            },
            "spirality": {
                "@id": "dppk:spirality",
                "@type": "xsd:double"
            },
            "dimensionalChange": {
                "@id": "dppk:dimensionalChange",
                "@type": "xsd:double"
            },
            "visualInspection": {
                "@id": "dppk:visualInspection",
                "@type": "xsd:string"
            },
            "apparelSize": {
                "@id": "dppk:apparelSize",
                "@type": "xsd:string"
            },
            "animalOriginNonTextile": {
                "@id": "dppk:animalOriginNonTextile",
                "@type": "xsd:boolean"
            },
            "brand": {
                "@id": "dppk:brand",
                "@type": "xsd:string"
            },
            "color": {
                "@id": "dppk:color",
                "@type": "xsd:string"
            }
        }
    ]
}
