{
    "@context": [
        "https://dpp-keystone.org/spec/contexts/v1/dpp-core.context.jsonld",
        {
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "substancesOfConcern": {
                "@id": "dppk:substancesOfConcern",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "fibreComposition": {
                "@id": "dppk:fibreComposition",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "organicMaterialComposition": {
                "@id": "dppk:organicMaterialComposition",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "recycledMaterialComposition": {
                "@id": "dppk:recycledMaterialComposition",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            },
            "textileCertifications": {
                "@id": "dppk:textileCertifications",
                "@container": "@set",
                "@context": {
                    "name": "dppk:certificationName",
                    "identifier": "dppk:certificationId",
                    "url": {
                        "@id": "dppk:certificationUrl",
                        "@type": "xsd:anyURI"
                    },
                    "certificationBodyName": "dppk:certificationBodyName",
                    "certificationBodyId": "dppk:certificationBodyId",
                    "certificationStartDate": {
                        "@id": "dppk:certificationStartDate",
                        "@type": "xsd:date"
                    },
                    "certificationEndDate": {
                        "@id": "dppk:certificationEndDate",
                        "@type": "xsd:date"
                    },
                    "certificationBodyRole": "dppk:certificationBodyRole",
                    "document": "dppk:documents"
                }
            }
        }
    ]
}
