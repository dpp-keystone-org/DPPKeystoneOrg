{
    "@context": [
        "https://dpp-keystone.org/spec/contexts/v1/dpp-core.context.jsonld",
        "https://dpp-keystone.org/spec/contexts/v1/dpp-epd.context.jsonld",
        "https://dpp-keystone.org/spec/contexts/v1/dpp-dopc.context.jsonld",
        {
            "dppk": "https://dpp-keystone.org/spec/v1/terms#",
            "dcterms": "http://purl.org/dc/terms/",
            "schema": "https://schema.org/",
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "IronSteelProduct": "dppk:IronSteelProduct",
            "heatNumber": "dppk:heatNumber",
            "productNumber": "dppk:productNumber",
            "castNumber": "dppk:castNumber",
            "lotNumber": "dppk:lotNumber",
            "manufacturingDate": {
                "@id": "dppk:manufacturingDate",
                "@type": "xsd:date"
            },
            "manufacturerInfo": { "@id": "dppk:manufacturerInfo" },
            "purchaserOrder": "dppk:purchaserOrder",
            "steelGradeClassification": "dppk:steelGradeClassification",
            "steelDesignation": "dppk:steelDesignation",
            "technologyRoute": "dppk:technologyRoute",
            "meltAndPourCountry": "dppk:meltAndPourCountry",
            "countryOfOrigin": "dppk:countryOfOrigin",
            "safeUseInstructions": "dppk:safeUseInstructions",
            "endOfLifeInstructions": "dppk:endOfLifeInstructions",
            "recycledContentPercentage": {
                "@id": "dppk:recycledContentPercentage",
                "@type": "xsd:double"
            },
            "preConsumerRecycledContent": {
                "@id": "dppk:preConsumerRecycledContent",
                "@type": "xsd:double"
            },
            "postConsumerRecycledContent": {
                "@id": "dppk:postConsumerRecycledContent",
                "@type": "xsd:double"
            },
            "recycledContentConformity": {
                "@id": "dppk:recycledContentConformity",
                "@type": "@id"
            },
            "cbamReportId": "dppk:cbamReportId",
            "reachDocumentation": "dppk:reachDocumentation",
            "substancesOfConcern": {
                "@id": "dppk:substancesOfConcern",
                "@container": "@set",
                "@context": {
                    "casNumber": "dppk:casNumber",
                    "ecNumber": "dppk:ecNumber",
                    "iupacName": "dppk:iupacName",
                    "locationInProduct": "dppk:locationInProduct"
                }
            },
            "nominalSize": {
                "@id": "dppk:nominalSize",
                "@type": "xsd:double"
            },
            "weightTolerance": {
                "@id": "dppk:weightTolerance",
                "@type": "xsd:double"
            },
            "yieldStrength": {
                "@id": "dppk:yieldStrength",
                "@type": "xsd:double"
            },
            "yieldStrengthRatio": {
                "@id": "dppk:yieldStrengthRatio",
                "@type": "xsd:double"
            },
            "elongation": {
                "@id": "dppk:elongation",
                "@type": "xsd:double"
            },
            "relativeRibArea": {
                "@id": "dppk:relativeRibArea",
                "@type": "xsd:double"
            },
            "carbonContent": {
                "@id": "dppk:carbonContent",
                "@type": "xsd:double"
            },
            "phosphorusContent": {
                "@id": "dppk:phosphorusContent",
                "@type": "xsd:double"
            },
            "sulfurContent": {
                "@id": "dppk:sulfurContent",
                "@type": "xsd:double"
            },
            "copperContent": {
                "@id": "dppk:copperContent",
                "@type": "xsd:double"
            },
            "nitrogenContent": {
                "@id": "dppk:nitrogenContent",
                "@type": "xsd:double"
            },
            "carbonEquivalent": {
                "@id": "dppk:carbonEquivalent",
                "@type": "xsd:double"
            },
            "steelProcess": "dppk:steelProcess",
            "finishing": "dppk:finishing",
            "radiometricControl": {
                "@id": "dppk:radiometricControl",
                "@type": "xsd:double"
            }
        }
    ],
    "@id": "https://dpp-keystone.org/spec/contexts/v1/dpp-iron-steel"
}