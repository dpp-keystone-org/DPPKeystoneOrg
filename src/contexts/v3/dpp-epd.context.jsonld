{
      "@context": {
        "dppk": "https://dpp-keystone.org/spec/{{VERSION}}/terms#",
        "dppk-epd": "https://dpp-keystone.org/spec/{{VERSION}}/terms/epd#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        // Term for EPD Data Block which holds an array of EPD Indicators
        "epd": { "@id": "dppk:epd" },

        "biogCProduct": "dppk-epd:biogCProduct",
        "biogCPackaging": "dppk-epd:biogCPackaging",

        // EPD Indicators
        "gwp": "dppk-epd:gwp",
        "gwpF": "dppk-epd:gwpF",
        "gwpB": "dppk-epd:gwpB",
        "gwpLuluc": "dppk-epd:gwpLuluc",
        "gwpGhg": "dppk-epd:gwpGhg",
        "odp": "dppk-epd:odp",
        "ap": "dppk-epd:ap",
        "epF": "dppk-epd:epF",
        "epM": "dppk-epd:epM",
        "epT": "dppk-epd:epT",
        "pocp": "dppk-epd:pocp",
        "adpe": "dppk-epd:adpe",
        "adpf": "dppk-epd:adpf",
        "wdp": "dppk-epd:wdp",
        "pm": "dppk-epd:pm",
        "irp": "dppk-epd:irp",
        "etpFw": "dppk-epd:etpFw",
        "htpC": "dppk-epd:htpC",
        "htpNc": "dppk-epd:htpNc",
        "sqp": "dppk-epd:sqp",
        "pere": "dppk-epd:pere",
        "perm": "dppk-epd:perm",
        "pert": "dppk-epd:pert",
        "penre": "dppk-epd:penre",
        "penrm": "dppk-epd:penrm",
        "penrt": "dppk-epd:penrt",
        "sm": "dppk-epd:sm",
        "rsf": "dppk-epd:rsf",
        "nrsf": "dppk-epd:nrsf",
        "fw": "dppk-epd:fw",
        "hwd": "dppk-epd:hwd",
        "nhwd": "dppk-epd:nhwd",
        "rwd": "dppk-epd:rwd",
        "cru": "dppk-epd:cru",
        "mfr": "dppk-epd:mfr",
        "mer": "dppk-epd:mer",
        "ee": "dppk-epd:ee",

        // EPD Life Cycle Stages with Type Coercion
        "a1": { "@id": "dppk-epd:a1", "@type": "xsd:double" },
        "A1": { "@id": "dppk-epd:a1", "@type": "xsd:double" },
        "a2": { "@id": "dppk-epd:a2", "@type": "xsd:double" },
        "A2": { "@id": "dppk-epd:a2", "@type": "xsd:double" },
        "a3": { "@id": "dppk-epd:a3", "@type": "xsd:double" },
        "A3": { "@id": "dppk-epd:a3", "@type": "xsd:double" },
        "a4": { "@id": "dppk-epd:a4", "@type": "xsd:double" },
        "A4": { "@id": "dppk-epd:a4", "@type": "xsd:double" },
        "a5": { "@id": "dppk-epd:a5", "@type": "xsd:double" },
        "A5": { "@id": "dppk-epd:a5", "@type": "xsd:double" },
        "b1": { "@id": "dppk-epd:b1", "@type": "xsd:double" },
        "B1": { "@id": "dppk-epd:b1", "@type": "xsd:double" },
        "b2": { "@id": "dppk-epd:b2", "@type": "xsd:double" },
        "B2": { "@id": "dppk-epd:b2", "@type": "xsd:double" },
        "b3": { "@id": "dppk-epd:b3", "@type": "xsd:double" },
        "B3": { "@id": "dppk-epd:b3", "@type": "xsd:double" },
        "b4": { "@id": "dppk-epd:b4", "@type": "xsd:double" },
        "B4": { "@id": "dppk-epd:b4", "@type": "xsd:double" },
        "b5": { "@id": "dppk-epd:b5", "@type": "xsd:double" },
        "B5": { "@id": "dppk-epd:b5", "@type": "xsd:double" },
        "b6": { "@id": "dppk-epd:b6", "@type": "xsd:double" },
        "B6": { "@id": "dppk-epd:b6", "@type": "xsd:double" },
        "b7": { "@id": "dppk-epd:b7", "@type": "xsd:double" },
        "B7": { "@id": "dppk-epd:b7", "@type": "xsd:double" },
        "c1": { "@id": "dppk-epd:c1", "@type": "xsd:double" },
        "C1": { "@id": "dppk-epd:c1", "@type": "xsd:double" },
        "c2": { "@id": "dppk-epd:c2", "@type": "xsd:double" },
        "C2": { "@id": "dppk-epd:c2", "@type": "xsd:double" },
        "c3": { "@id": "dppk-epd:c3", "@type": "xsd:double" },
        "C3": { "@id": "dppk-epd:c3", "@type": "xsd:double" },
        "c4": { "@id": "dppk-epd:c4", "@type": "xsd:double" },
        "C4": { "@id": "dppk-epd:c4", "@type": "xsd:double" },
        "d": { "@id": "dppk-epd:d", "@type": "xsd:double" },
        "D": { "@id": "dppk-epd:d", "@type": "xsd:double" },
        "total": { "@id": "dppk-epd:total", "@type": "xsd:double" },
        "Total": { "@id": "dppk-epd:total", "@type": "xsd:double" }
    }
}
