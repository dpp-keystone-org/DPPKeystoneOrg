{
    "@context": [
        "https://dpp-keystone.org/spec/contexts/{{VERSION}}/dpp-core.context.jsonld",
        "https://dpp-keystone.org/spec/contexts/{{VERSION}}/dpp-epd.context.jsonld",
        "https://dpp-keystone.org/spec/contexts/{{VERSION}}/dpp-dopc.context.jsonld",
        "https://dpp-keystone.org/spec/contexts/{{VERSION}}/dpp-mtc.context.jsonld",
        {
            "dppk": "https://dpp-keystone.org/spec/{{VERSION}}/terms#",
            "dcterms": "http://purl.org/dc/terms/",
            "schema": "https://schema.org/",
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "IronSteelProduct": "dppk:IronSteelProduct",
            "heatNumber": "dppk:heatNumber",
            "productNumber": "dppk:productNumber",
            "castNumber": "dppk:castNumber",
            "lotNumber": "dppk:lotNumber",
            "manufacturingDate": {
                "@id": "dppk:manufacturingDate",
                "@type": "xsd:date"
            },
            "purchaserOrder": "dppk:purchaserOrder",
            "steelGradeClassification": "dppk:steelGradeClassification",
            "steelDesignation": "dppk:steelDesignation",
            "technologyRoute": "dppk:technologyRoute",
            "meltAndPourCountry": "dppk:meltAndPourCountry",
            "countryOfOrigin": "dppk:countryOfOrigin",
            "importerInfo": "dppk:importer",
            "safeUseInstructions": "dppk:safeUseInstructions",
            "endOfLifeInstructions": "dppk:endOfLifeInstructions",
            "recycledContentPercentage": {
                "@id": "dppk:recycledContentPercentage",
                "@type": "xsd:double"
            },
            "preConsumerRecycledContent": {
                "@id": "dppk:preConsumerRecycledContent",
                "@type": "xsd:double"
            },
            "postConsumerRecycledContent": {
                "@id": "dppk:postConsumerRecycledContent",
                "@type": "xsd:double"
            },
            "recycledContentConformity": {
                "@id": "dppk:recycledContentConformity",
                "@type": "@id"
            },
            "cbamReportId": "dppk:cbamReportId",
            "reachDocumentation": "dppk:reachDocumentation",
            "substancesOfConcern": {
                "@id": "dppk:substancesOfConcern",
                "@container": "@set",
                "@context": {
                    "name": "dppk:componentName",
                    "percentage": "dppk:componentPercentage",
                    "uniqueProductIdentifier": "dppk:componentIdentifier",
                    "casNumber": "dppk:componentCasNumber",
                    "ecNumber": "dppk:componentEcNumber",
                    "iupacName": "dppk:componentIupacName",
                    "locationInProduct": "dppk:componentLocationInProduct"
                }
            }
        }
    ],
    "@id": "https://dpp-keystone.org/spec/contexts/{{VERSION}}/dpp-iron-steel"
}