{
    "@context": {
        "dppk": "https://dpp-keystone.org/spec/{{VERSION}}/terms#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "mtc": {
            "@id": "dppk:mtc",
            "@context": {
                "sourceDocument": {
                    "@id": "dppk:sourceDocument",
                    "@type": "@id"
                },
                "nominalSize": {
                    "@id": "dppk:mtcNominalSize",
                    "@type": "xsd:double"
                },
                "weightTolerance": {
                    "@id": "dppk:mtcWeightTolerance",
                    "@type": "xsd:double"
                },
                "yieldStrength": {
                    "@id": "dppk:mtcYieldStrength",
                    "@type": "xsd:double"
                },
                "yieldStrengthRatio": {
                    "@id": "dppk:mtcYieldStrengthRatio",
                    "@type": "xsd:double"
                },
                "elongation": {
                    "@id": "dppk:mtcElongation",
                    "@type": "xsd:double"
                },
                "relativeRibArea": {
                    "@id": "dppk:mtcRelativeRibArea",
                    "@type": "xsd:double"
                },
                "carbonContent": {
                    "@id": "dppk:mtcCarbonContent",
                    "@type": "xsd:double"
                },
                "phosphorusContent": {
                    "@id": "dppk:mtcPhosphorusContent",
                    "@type": "xsd:double"
                },
                "sulfurContent": {
                    "@id": "dppk:mtcSulfurContent",
                    "@type": "xsd:double"
                },
                "copperContent": {
                    "@id": "dppk:mtcCopperContent",
                    "@type": "xsd:double"
                },
                "nitrogenContent": {
                    "@id": "dppk:mtcNitrogenContent",
                    "@type": "xsd:double"
                },
                "carbonEquivalent": {
                    "@id": "dppk:mtcCarbonEquivalent",
                    "@type": "xsd:double"
                },
                "steelProcess": "dppk:mtcSteelProcess",
                "finishing": "dppk:mtcFinishing",
                "radiometricControl": {
                    "@id": "dppk:mtcRadiometricControl",
                    "@type": "xsd:double"
                }
            }
        }
    },
    "@id": "https://dpp-keystone.org/spec/contexts/{{VERSION}}/dpp-mtc"
}