// This is a source file. Do not edit the file in the `dist` directory.
// This example represents a Digital Product Passport for a pack of socks.
// It includes the mandatory core header fields and a payload with textile-specific data points,
// adhering strictly to the vocabulary defined in the dpp-textile.context.jsonld.
{
  "@context": "https://dpp-keystone.org/spec/contexts/v1/dpp-textile.context.jsonld",
  "@type": "dppk:DigitalProductPassport",
  // --- Normative DPP Header ---
  "digitalProductPassportId": "urn:uuid:123e4567-e89b-12d3-a456-426614174000",
  // Note: This example uses a direct HTML link for demonstrative purposes. 
  // A real uniqueProductIdentifier must be a resolver URI that uses HTTP 
  // content negotiation to return either this JSON payload or an HTML page 
  // depending on the client's Accept headers.
  "uniqueProductIdentifier": "https://dpp-keystone.org/spec/examples/html/sock-dpp-v1.html",
  "granularity": "Model",
  "dppSchemaVersion": "ENXXX:v1.0",
  "dppStatus": "Active",
  "lastUpdate": "2024-05-22T11:30:00Z",
  "economicOperatorId": "urn:gln:1122334455667",
  "contentSpecificationIds": [
    "draft_textile_specification_id"
  ],
  // --- Core Product Information ---
  "productName": "Everyday Comfort Crew Socks (3-Pack)",
  "image": [
    {
      "resourceTitle": "Product Image",
      "url": "/spec/examples/images/sock.png",
      "contentType": "image/png"
    }
  ],
  // --- Documents (Aligned with Core Ontology) ---
  "documents": [
    {
      "contentType": "RelatedResource",
      "resourceTitle": "IBU EPD Listing",
      "url": "https://ibu-epd.com/veroeffentlichte-epds/"
    }
  ],
  // --- Textile-Specific Payload ---
  // This section uses terms defined in the dpp-textile.context.jsonld.
  "fibreComposition": [
    {
      "fibreType": "Cotton",
      "fibrePercentage": 85.0
    },
    {
      "fibreType": "Polyamide",
      "fibrePercentage": 13.0
    },
    {
      "fibreType": "Elastane",
      "fibrePercentage": 2.0
    }
  ],
  "color": "Black",
  "apparelSize": "EU 42-45",
  "apparelSizeSystem": "EU",
  "careInstructions": [
    "GINETEX:30C",
    "GINETEX:DoNotBleach",
    "GINETEX:TumbleDryLow"
  ],
  "recycledContentPercentage": 20.0,
  // This boolean is required by the textile SHACL shape.
  "animalOriginNonTextile": false,
  "productionSteps": [
    {
      "step": "Spinning",
      "countryCode": "TUR"
    },
    {
      "step": "Knitting",
      "countryCode": "PRT"
    }
  ],
  "abrasionResistance": {
    "cycles": 20000,
    "testMethod": "ISO 12947-2"
  },
  "dimensionalStability": {
    "warpChange": -2.0,
    "weftChange": -1.5,
    "testMethod": "ISO 5077"
  },
  "colorfastnessToWashing": {
    "grade": 4.5,
    "testMethod": "ISO 105-C06"
  },
  "microplasticRelease": {
    "value": 150.0,
    "testMethod": "ISO 4484-1"
  }
}