      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A structured value representing a measurement, including the numeric value and the unit of measure."
        },
        {
          "@language": "bg",
          "@value": "Структурирана стойност, представляваща измерване, включително цифровата стойност и мерната единица."
        },
        {
          "@language": "cs",
          "@value": "Strukturovaná hodnota představující měření, včetně číselné hodnoty a měrné jednotky."
        },
        {
          "@language": "da",
          "@value": "En struktureret værdi, der repræsenterer en måling, herunder den numeriske værdi og måleenheden."
        },
        {
          "@language": "de",
          "@value": "Ein strukturierter Wert, der eine Messung darstellt, einschließlich des numerischen Werts und der Maßeinheit."
        },
        {
          "@language": "el",
          "@value": "Μια δομημένη τιμή που αντιπροσωπεύει μια μέτρηση, συμπεριλαμβανομένης της αριθμητικής τιμής και της μονάδας μέτρησης."
        },
        {
          "@language": "es",
          "@value": "Un valor estructurado que representa una medición, incluido el valor numérico y la unidad de medida."
        },
        {
          "@language": "et",
          "@value": "Struktureeritud väärtus, mis esindab mõõtmist, sealhulgas arvväärtust ja mõõtühikut."
        },
        {
          "@language": "fi",
          "@value": "Rakenteinen arvo, joka edustaa mittausta, mukaan lukien numeroarvo ja mittayksikkö."
        },
        {
          "@language": "fr",
          "@value": "Une valeur structurée représentant une mesure, y compris la valeur numérique et l'unité de mesure."
        },
        {
          "@language": "ga",
          "@value": "Luach struchtúrtha a léiríonn tomhas, lena n-áirítear an luach uimhriúil agus an t-aonad tomhais."
        },
        {
          "@language": "hr",
          "@value": "Strukturirana vrijednost koja predstavlja mjerenje, uključujući numeričku vrijednost i mjernu jedinicu."
        },
        {
          "@language": "hu",
          "@value": "Strukturált érték, amely egy mérést képvisel, beleértve a számértéket és a mértékegységet."
        },
        {
          "@language": "it",
          "@value": "Un valore strutturato che rappresenta una misurazione, incluso il valore numerico e l'unità di misura."
        },
        {
          "@language": "lt",
          "@value": "Struktūrizuota vertė, atspindinti matavimą, įskaitant skaitmeninę vertę ir matavimo vienetą."
        },
        {
          "@language": "lv",
          "@value": "Strukturēta vērtība, kas atspoguļo mērījumu, tostarp skaitlisko vērtību un mērvienību."
        },
        {
          "@language": "mt",
          "@value": "Valur strutturat li jirrappreżenta kejl, inkluż il-valur numeriku u l-unità tal-kejl."
        },
        {
          "@language": "nl",
          "@value": "Een gestructureerde waarde die een meting vertegenwoordigt, inclusief de numerieke waarde en de meeteenheid."
        },
        {
          "@language": "pl",
          "@value": "Strukturalna wartość reprezentująca pomiar, w tym wartość liczbową i jednostkę miary."
        },
        {
          "@language": "pt",
          "@value": "Um valor estruturado que representa uma medição, incluindo o valor numérico e a unidade de medida."
        },
        {
          "@language": "ro",
          "@value": "O valoare structurată care reprezintă o măsurătoare, inclusiv valoarea numerică și unitatea de măsură."
        },
        {
          "@language": "sk",
          "@value": "Štruktúrovaná hodnota predstavujúca meranie vrátane číselnej hodnoty a mernej jednotky."
        },
        {
          "@language": "sl",
