      "dppk:unit": "%",
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "The percentage of the material that is derived from recycled sources."
        },
        {
          "@language": "bg",
          "@value": "Процентът на материала, който е получен от рециклирани източници."
        },
        {
          "@language": "cs",
          "@value": "Procento materiálu, které pochází z recyklovaných zdrojů."
        },
        {
          "@language": "da",
          "@value": "Procentdelen af det materiale, der stammer fra genanvendte kilder."
        },
        {
          "@language": "de",
          "@value": "Der Prozentsatz des Materials, der aus recycelten Quellen stammt."
        },
        {
          "@language": "el",
          "@value": "Το ποσοστό του υλικού που προέρχεται από ανακυκλωμένες πηγές."
        },
        {
          "@language": "es",
          "@value": "El porcentaje del material que se deriva de fuentes recicladas."
        },
        {
          "@language": "et",
          "@value": "Materjali protsent, mis on saadud ringlussevõetud allikatest."
