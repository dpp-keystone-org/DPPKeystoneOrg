      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A generic name or title for a resource (e.g., a document title). For the name of a product, prefer the more specific 'dppk:productName'."
        },
        {
          "@language": "bg",
          "@value": "Общо име или заглавие за ресурс (напр. заглавие на документ). За името на продукт предпочитайте по-конкретното 'dppk:productName'."
        },
        {
          "@language": "cs",
          "@value": "Obecný název nebo titul zdroje (např. název dokumentu). Pro název produktu upřednostněte specifičtější 'dppk:productName'."
        },
        {
          "@language": "da",
          "@value": "Et generisk navn eller titel på en ressource (f.eks. en dokumenttitel). For navnet på et produkt foretrækkes det mere specifikke 'dppk:productName'."
        },
        {
          "@language": "de",
          "@value": "Ein generischer Name oder Titel für eine Ressource (z. B. ein Dokumenttitel). Für den Namen eines Produkts ist das spezifischere 'dppk:productName' zu bevorzugen."
        },
        {
          "@language": "el",
          "@value": "Ένα γενικό όνομα ή τίτλος για έναν πόρο (π.χ. τίτλος εγγράφου). Για το όνομα ενός προϊόντος, προτιμήστε το πιο συγκεκριμένο 'dppk:productName'."
        },
        {
          "@language": "es",
          "@value": "Un nombre o título genérico para un recurso (por ejemplo, el título de un documento). Para el nombre de un producto, prefiera el más específico 'dppk:productName'."
        },
        {
          "@language": "et",
          "@value": "Üldine nimi või pealkiri ressursile (nt dokumendi pealkiri). Toote nime puhul eelistage täpsemat 'dppk:productName'."
        },
        {
          "@language": "fi",
          "@value": "Yleinen nimi tai otsikko resurssille (esim. asiakirjan otsikko). Tuotteen nimelle suositellaan tarkempaa 'dppk:productName'."
        },
        {
          "@language": "fr",
          "@value": "Un nom ou titre générique pour une ressource (par ex., le titre d'un document). Pour le nom d'un produit, préférez le plus spécifique 'dppk:productName'."
        },
        {
          "@language": "ga",
          "@value": "Ainm nó teideal cineálach d'acmhainn (m.sh., teideal doiciméid). D'ainm táirge, is fearr an 'dppk:productName' níos sonraí."
        },
        {
          "@language": "hr",
          "@value": "Generički naziv ili naslov za resurs (npr. naslov dokumenta). Za naziv proizvoda preferirajte specifičniji 'dppk:productName'."
        },
        {
          "@language": "hu",
          "@value": "Egy erőforrás általános neve vagy címe (pl. egy dokumentum címe). Egy termék nevéhez részesítse előnyben a specifikusabb 'dppk:productName' kifejezést."
        },
        {
          "@language": "it",
          "@value": "Un nome o titolo generico per una risorsa (ad es. il titolo di un documento). Per il nome di un prodotto, preferire il più specifico 'dppk:productName'."
        },
        {
          "@language": "lt",
          "@value": "Bendras ištekliaus pavadinimas ar antraštė (pvz., dokumento pavadinimas). Produkto pavadinimui teikite pirmenybę konkretesniam 'dppk:productName'."
        },
        {
          "@language": "lv",
          "@value": "Resursa vispārīgs nosaukums vai virsraksts (piem., dokumenta virsraksts). Produkta nosaukumam dodiet priekšroku konkrētākam 'dppk:productName'."
        },
        {
          "@language": "mt",
          "@value": "Isem jew titlu ġeneriku għal riżorsa (eż., titolu ta' dokument). Għall-isem ta' prodott, ippreferi l-aktar speċifiku 'dppk:productName'."
        },
        {
          "@language": "nl",
          "@value": "Een algemene naam of titel voor een resource (bijv. de titel van een document). Geef voor de naam van een product de voorkeur aan het specifiekere 'dppk:productName'."
        },
        {
          "@language": "pl",
          "@value": "Ogólna nazwa lub tytuł zasobu (np. tytuł dokumentu). W przypadku nazwy produktu preferuj bardziej szczegółowe 'dppk:productName'."
        },
        {
          "@language": "pt",
          "@value": "Um nome ou título genérico para um recurso (por exemplo, o título de um documento). Para o nome de um produto, prefira o mais específico 'dppk:productName'."
        },
        {
          "@language": "ro",
          "@value": "Un nume sau titlu generic pentru o resursă (de ex., titlul unui document). Pentru numele unui produs, preferați cel mai specific 'dppk:productName'."
        },
        {
          "@language": "sk",
          "@value": "Všeobecný názov alebo titul pre zdroj (napr. názov dokumentu). Pre názov produktu uprednostnite špecifickejšie 'dppk:productName'."
        },
        {
          "@language": "sl",
          "@value": "Splošno ime ali naslov za vir (npr. naslov dokumenta). Za ime izdelka raje uporabite bolj specifično 'dppk:productName'."
        },
        {
          "@language": "sv",
          "@value": "Ett allmänt namn eller titel på en resurs (t.ex. en dokumenttitel). För namnet på en produkt, föredra den mer specifika 'dppk:productName'."
        }
      ],
