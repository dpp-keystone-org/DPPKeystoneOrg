        {
          "@language": "fi",
          "@value": "Komponentin tai aineen tarkka fyysinen sijainti emokokoonpanon sisällä."
        },
        {
          "@language": "fr",
          "@value": "Emplacement physique spécifique du composant ou de la substance à l'intérieur de l'assemblage parent."
        },
        {
          "@language": "ga",
          "@value": "Suíomh fisiciúil sonrach na comhpháirte nó na substainte laistigh den phríomhthionól."
        },
        {
          "@language": "hr",
          "@value": "Specifična fizička lokacija komponente ili tvari unutar nadređenog sklopa."
        },
        {
          "@language": "hu",
          "@value": "Az alkatrész vagy anyag konkrét fizikai helye a szülőszerelvényen belül."
        },
        {
          "@language": "it",
          "@value": "Posizione fisica specifica del componente o della sostanza all'interno dell'assieme principale."
        },
        {
          "@language": "lt",
          "@value": "Konkreti fizinė komponento ar medžiagos vieta pagrindiniame surinkime."
        },
        {
          "@language": "lv",
          "@value": "Konkrēta komponenta vai vielas fiziskā atrašanās vieta vecākajā mezglā."
        },
        {
          "@language": "mt",
          "@value": "Post fiżiku speċifiku tal-komponent jew tas-sustanza ġewwa l-assemblaġġ ġenitur."
        },
        {
          "@language": "nl",
          "@value": "Specifieke fysieke locatie van de component of stof binnen de bovenliggende eenheid."
        },
        {
          "@language": "pl",
          "@value": "Konkretna fizyczna lokalizacja komponentu lub substancji w zespole nadrzędnym."
        },
        {
          "@language": "pt",
          "@value": "Localização física específica do componente ou substância dentro da montagem principal."
        },
        {
          "@language": "ro",
          "@value": "Locația fizică specifică a componentei sau substanței în interiorul ansamblului părinte."
