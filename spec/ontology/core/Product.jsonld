  "dcterms:description": [
    {
      "@language": "en",
      "@value": "Defines horizontal concepts related to the product description, Bill of Materials (BOM), materials, and quantitative measurements."
    },
    {
      "@language": "bg",
      "@value": "Определя хоризонтални концепции, свързани с описанието на продукта, Списъка на материалите (BOM), материалите и количествените измервания."
    },
    {
      "@language": "cs",
      "@value": "Definuje horizontální koncepty související s popisem produktu, kusovníkem (BOM), materiály a kvantitativními měřeními."
    },
    {
      "@language": "da",
      "@value": "Definerer horisontale koncepter relateret til produktbeskrivelsen, styklisten (BOM), materialer og kvantitative målinger."
    },
    {
      "@language": "de",
      "@value": "Definiert horizontale Konzepte in Bezug auf die Produktbeschreibung, Stückliste (BOM), Materialien und quantitative Messungen."
    },
    {
      "@language": "el",
      "@value": "Καθορίζει οριζόντιες έννοιες που σχετίζονται με την περιγραφή του προϊόντος, το Πιστοποιητικό υλικών (BOM), τα υλικά και τις ποσοτικές μετρήσεις."
    },
    {
      "@language": "es",
      "@value": "Define conceptos horizontales relacionados con la descripción del producto, la Lista de Materiales (BOM), materiales y mediciones cuantitativas."
    },
    {
      "@language": "et",
      "@value": "Määratleb horisontaalsed kontseptsioonid, mis on seotud tootekirjelduse, materjalide loetelu (BOM), materjalide ja kvantitatiivsete mõõtmistega."
    },
    {
      "@language": "fi",
      "@value": "Määrittää horisontaalisia käsitteitä, jotka liittyvät tuotekuvaukseen, osaluetteloon (BOM), materiaaleihin ja määrällisiin mittauksiin."
    },
    {
      "@language": "fr",
      "@value": "Définit des concepts horizontaux liés à la description du produit, à la nomenclature (BOM), aux matériaux et aux mesures quantitatives."
    },
    {
      "@language": "ga",
      "@value": "Sainmhíníonn sé coincheapa cothrománacha a bhaineann leis an gcur síos ar an táirge, Bille Ábhar (BOM), ábhair, agus tomhais chainníochtúla."
    },
    {
      "@language": "hr",
      "@value": "Definira horizontalne koncepte povezane s opisom proizvoda, sastavnicom (BOM), materijalima i kvantitativnim mjerenjima."
    },
    {
      "@language": "hu",
      "@value": "Meghatározza a termékleíráshoz, az anyagjegyzékhez (BOM), az anyagokhoz és a mennyiségi mérésekhez kapcsolódó horizontális fogalmakat."
    },
    {
      "@language": "it",
      "@value": "Definisce concetti orizzontali relativi alla descrizione del prodotto, alla distinta base (BOM), ai materiali e alle misurazioni quantitative."
    },
    {
      "@language": "lt",
      "@value": "Apibrėžia horizontalias koncepcijas, susijusias su produkto aprašymu, medžiagų žiniaraščiu (BOM), medžiagomis ir kiekybiniais matavimais."
    },
    {
      "@language": "lv",
      "@value": "Nosaka horizontālus jēdzienus, kas saistīti ar produkta aprakstu, materiālu sarakstu (BOM), materiāliem un kvantitatīviem mērījumiem."
    },
    {
      "@language": "mt",
      "@value": "Jiddefinixxi kunċetti orizzontali relatati mad-deskrizzjoni tal-prodott, il-Kont tal-Materjali (BOM), il-materjali, u l-kejl kwantitattiv."
    },
    {
      "@language": "nl",
      "@value": "Definieert horizontale concepten met betrekking tot de productbeschrijving, stuklijst (BOM), materialen en kwantitatieve metingen."
    },
    {
      "@language": "pl",
      "@value": "Określa poziome pojęcia związane z opisem produktu, zestawieniem materiałów (BOM), materiałami i pomiarami ilościowymi."
    },
    {
      "@language": "pt",
      "@value": "Define conceitos horizontais relacionados com a descrição do produto, Lista de Materiais (BOM), materiais e medições quantitativas."
    },
    {
      "@language": "ro",
      "@value": "Definește concepte orizontale referitoare la descrierea produsului, lista de materiale (BOM), materiale și măsurători cantitative."
    },
    {
      "@language": "sk",
      "@value": "Definuje horizontálne koncepty súvisiace s popisom produktu, kusovníkom (BOM), materiálmi a kvantitatívnymi meraniami."
    },
    {
      "@language": "sl",
      "@value": "Določa horizontalne koncepte, povezane z opisom izdelka, kosovnico (BOM), materiali in kvantitativnimi meritvami."
    },
    {
      "@language": "sv",
      "@value": "Definierar horisontella begrepp relaterade till produktbeskrivningen, stycklistan (BOM), material och kvantitativa mätningar."
    }
  ],
