      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "The weight of the product or material, excluding packaging. Recommended to use specific datatypes like dppk:KgWeightLiteral."
        },
        {
          "@language": "bg",
          "@value": "Теглото на продукта или материала, без опаковката. Препоръчително е да се използват специфични типове данни като dppk:KgWeightLiteral."
        },
        {
          "@language": "cs",
          "@value": "Hmotnost produktu nebo materiálu, bez obalu. Doporučuje se používat specifické datové typy jako dppk:KgWeightLiteral."
        },
        {
          "@language": "da",
          "@value": "Vægten af produktet eller materialet, eksklusiv emballage. Det anbefales at bruge specifikke datatyper som dppk:KgWeightLiteral."
        },
        {
          "@language": "de",
          "@value": "Das Gewicht des Produkts oder Materials, ohne Verpackung. Es wird empfohlen, spezifische Datentypen wie dppk:KgWeightLiteral zu verwenden."
        },
        {
          "@language": "el",
          "@value": "Το βάρος του προϊόντος ή του υλικού, χωρίς τη συσκευασία. Συνιστάται η χρήση συγκεκριμένων τύπων δεδομένων όπως dppk:KgWeightLiteral."
        },
        {
          "@language": "es",
          "@value": "El peso del producto o material, excluyendo el embalaje. Se recomienda utilizar tipos de datos específicos como dppk:KgWeightLiteral."
        },
        {
          "@language": "et",
          "@value": "Toote või materjali kaal, välja arvatud pakend. Soovitatav on kasutada spetsiifilisi andmetüüpe nagu dppk:KgWeightLiteral."
        },
        {
          "@language": "fi",
          "@value": "Tuotteen tai materiaalin paino ilman pakkausta. Suositellaan käyttämään tiettyjä tietotyyppejä, kuten dppk:KgWeightLiteral."
        },
        {
          "@language": "fr",
          "@value": "Le poids du produit ou du matériau, à l'exclusion de l'emballage. Il est recommandé d'utiliser des types de données spécifiques comme dppk:KgWeightLiteral."
        },
        {
          "@language": "ga",
          "@value": "Meáchan an táirge nó an ábhair, gan pacáistiú a áireamh. Moltar cineálacha sonraí sonracha a úsáid cosúil le dppk:KgWeightLiteral."
        },
        {
          "@language": "hr",
          "@value": "Težina proizvoda ili materijala, isključujući ambalažu. Preporučuje se korištenje specifičnih tipova podataka kao što je dppk:KgWeightLiteral."
        },
        {
          "@language": "hu",
          "@value": "A termék vagy anyag tömege, a csomagolást nem számítva. Ajánlott specifikus adattípusok, például a dppk:KgWeightLiteral használata."
        },
        {
          "@language": "it",
          "@value": "Il peso del prodotto o del materiale, escluso l'imballaggio. Si consiglia di utilizzare tipi di dati specifici come dppk:KgWeightLiteral."
        },
        {
          "@language": "lt",
          "@value": "Produkto ar medžiagos svoris be pakuotės. Rekomenduojama naudoti specifinius duomenų tipus, pvz., dppk:KgWeightLiteral."
        },
        {
          "@language": "lv",
          "@value": "Produkta vai materiāla svars, neskaitot iepakojumu. Ieteicams izmantot konkrētus datu tipus, piemēram, dppk:KgWeightLiteral."
        },
        {
          "@language": "mt",
          "@value": "Il-piż tal-prodott jew materjal, eskluż l-ippakkjar. Huwa rrakkomandat li jintużaw tipi ta' dejta speċifiċi bħal dppk:KgWeightLiteral."
        },
        {
          "@language": "nl",
          "@value": "Het gewicht van het product of materiaal, exclusief verpakking. Aanbevolen wordt om specifieke datatypes zoals dppk:KgWeightLiteral te gebruiken."
        },
        {
          "@language": "pl",
          "@value": "Waga produktu lub materiału, z wyłączeniem opakowania. Zaleca się stosowanie określonych typów danych, takich jak dppk:KgWeightLiteral."
        },
        {
          "@language": "pt",
          "@value": "O peso do produto ou material, excluindo a embalagem. Recomenda-se o uso de tipos de dados específicos, como dppk:KgWeightLiteral."
        },
        {
          "@language": "ro",
          "@value": "Greutatea produsului sau materialului, excluzând ambalajul. Se recomandă utilizarea tipurilor de date specifice, cum ar fi dppk:KgWeightLiteral."
        },
        {
          "@language": "sk",
          "@value": "Hmotnosť produktu alebo materiálu, bez obalu. Odporúča sa používať špecifické dátové typy ako dppk:KgWeightLiteral."
        },
        {
          "@language": "sl",
          "@value": "Teža izdelka ali materiala, brez embalaže. Priporoča se uporaba specifičnih podatkovnih tipov, kot je dppk:KgWeightLiteral."
        },
        {
          "@language": "sv",
          "@value": "Vikten på produkten eller materialet, exklusive förpackning. Det rekommenderas att använda specifika datatyper som dppk:KgWeightLiteral."
        }
      ],
