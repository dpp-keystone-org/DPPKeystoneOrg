        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A literal value representing a weight in kilograms. A reasoner can expand this into a full dppk:QuantitativeValue."
        },
        {
          "@language": "bg",
          "@value": "Буквална стойност, представляваща тегло в килограми. Система за логически извод може да го разшири до пълна dppk:QuantitativeValue."
        },
        {
          "@language": "cs",
          "@value": "Doslovná hodnota představující hmotnost v kilogramech. Odvozovací systém to může rozšířit na plnou hodnotu dppk:QuantitativeValue."
        },
        {
          "@language": "da",
          "@value": "En bogstavelig værdi, der repræsenterer en vægt i kilogram. En reasoner kan udvide dette til en fuld dppk:QuantitativeValue."
        },
        {
          "@language": "de",
          "@value": "Ein literaler Wert, der ein Gewicht in Kilogramm darstellt. Ein Reasoner kann dies in einen vollständigen dppk:QuantitativeValue erweitern."
        },
        {
          "@language": "el",
          "@value": "Μια κυριολεκτική τιμή που αντιπροσωπεύει ένα βάρος σε κιλά. Ένας μηχανισμός συλλογισμού μπορεί να το επεκτείνει σε πλήρες dppk:QuantitativeValue."
        },
        {
          "@language": "es",
          "@value": "Un valor literal que representa un peso en kilogramos. Un razonador puede expandir esto a un dppk:QuantitativeValue completo."
        },
        {
          "@language": "et",
          "@value": "Literaalne väärtus, mis esindab kaalu kilogrammides. Arutleja saab seda laiendada täielikuks dppk:QuantitativeValue-ks."
        },
        {
          "@language": "fi",
          "@value": "Literaaliarvo, joka edustaa painoa kilogrammoina. Päättelykone voi laajentaa tämän täydeksi dppk:QuantitativeValue:ksi."
        },
        {
          "@language": "fr",
          "@value": "Une valeur littérale représentant un poids en kilogrammes. Un raisonneur peut développer cela en un dppk:QuantitativeValue complet."
        },
        {
          "@language": "ga",
          "@value": "Luach litriúil a léiríonn meáchan i gcileagraim. Is féidir le réasúnaí é seo a leathnú go dppk:QuantitativeValue iomlán."
        },
        {
          "@language": "hr",
          "@value": "Doslovna vrijednost koja predstavlja težinu u kilogramima. Sustav za zaključivanje to može proširiti u potpuni dppk:QuantitativeValue."
        },
        {
          "@language": "hu",
          "@value": "Literális érték, amely egy súlyt kilogrammban képvisel. Egy következtető ezt teljes dppk:QuantitativeValue értékké tudja kiterjeszteni."
        },
        {
          "@language": "it",
          "@value": "Un valore letterale che rappresenta un peso in chilogrammi. Un ragionatore può espanderlo in un dppk:QuantitativeValue completo."
        },
        {
          "@language": "lt",
          "@value": "Tiesioginė vertė, atspindinti svorį kilogramais. Išvedimo sistema gali tai išplėsti į visą dppk:QuantitativeValue."
        },
        {
          "@language": "lv",
          "@value": "Burtiska vērtība, kas atspoguļo svaru kilogramos. Spriedējs to var paplašināt par pilnu dppk:QuantitativeValue."
        },
        {
          "@language": "mt",
          "@value": "Valur litterali li jirrappreżenta piż f'kilogrammi. Raġunatur jista' jespandi dan f'dppk:QuantitativeValue sħiħ."
        },
        {
          "@language": "nl",
          "@value": "Een letterlijke waarde die een gewicht in kilogram vertegenwoordigt. Een reasoner kan dit uitbreiden tot een volledige dppk:QuantitativeValue."
        },
        {
          "@language": "pl",
          "@value": "Wartość literałowa reprezentująca wagę w kilogramach. System wnioskujący może rozszerzyć to do pełnego dppk:QuantitativeValue."
        },
        {
          "@language": "pt",
          "@value": "Um valor literal que representa um peso em quilogramas. Um raciocinador pode expandir isso para um dppk:QuantitativeValue completo."
        },
        {
          "@language": "ro",
          "@value": "O valoare literală care reprezintă o greutate în kilograme. Un motor de inferență poate extinde acest lucru într-un dppk:QuantitativeValue complet."
        },
        {
          "@language": "sk",
          "@value": "Doslovná hodnota predstavujúca hmotnosť v kilogramoch. Odvodzovací systém to môže rozšíriť na plnú dppk:QuantitativeValue."
        },
        {
          "@language": "sl",
          "@value": "Dobesedna vrednost, ki predstavlja težo v kilogramih. Sklepalnik lahko to razširi v polno dppk:QuantitativeValue."
        },
        {
          "@language": "sv",
          "@value": "Ett bokstavligt värde som representerar en vikt i kilogram. En resonerare kan utöka detta till ett fullständigt dppk:QuantitativeValue."
        }
      ],
      "rdfs:subClassOf": {
        "@id": "xsd:double"
      },
      "dppk:unit": "kg"
    },
