        },
        {
          "@language": "pl",
          "@value": "Kraj pochodzenia"
        },
        {
          "@language": "pt",
          "@value": "País de origem"
        },
        {
          "@language": "ro",
          "@value": "Țara de origine"
        },
        {
          "@language": "sk",
          "@value": "Krajina pôvodu"
        },
