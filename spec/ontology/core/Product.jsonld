        {
          "@language": "hu",
          "@value": "Az újrahasznosított forrásokból származó anyag százalékos aránya."
        },
        {
          "@language": "it",
          "@value": "La percentuale del materiale derivata da fonti riciclate."
        },
        {
          "@language": "lt",
          "@value": "Medžiagos, gautos iš perdirbtų šaltinių, procentas."
