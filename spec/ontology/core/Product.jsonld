      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A general concept covering finished goods, components, or raw materials."
        },
        {
          "@language": "bg",
          "@value": "Обща концепция, обхващаща готови стоки, компоненти или суровини."
        },
        {
          "@language": "cs",
          "@value": "Obecný koncept zahrnující hotové výrobky, součástky nebo suroviny."
        },
        {
          "@language": "da",
          "@value": "Et generelt koncept, der dækker færdigvarer, komponenter eller råmaterialer."
        },
        {
          "@language": "de",
          "@value": "Ein allgemeines Konzept, das Fertigwaren, Komponenten oder Rohstoffe abdeckt."
        },
        {
          "@language": "el",
          "@value": "Μια γενική έννοια που καλύπτει τελικά προϊόντα, εξαρτήματα ή πρώτες ύλες."
        },
        {
          "@language": "es",
          "@value": "Un concepto general que cubre productos terminados, componentes o materias primas."
        },
        {
          "@language": "et",
          "@value": "Üldine kontseptsioon, mis hõlmab valmistooteid, komponente või tooraineid."
        },
        {
          "@language": "fi",
          "@value": "Yleinen käsite, joka kattaa valmiit tavarat, komponentit tai raaka-aineet."
        },
        {
          "@language": "fr",
          "@value": "Un concept général couvrant les produits finis, les composants ou les matières premières."
        },
        {
          "@language": "ga",
          "@value": "Coincheap ginearálta a chuimsíonn earraí críochnaithe, comhpháirteanna, nó amhábhair."
        },
        {
          "@language": "hr",
          "@value": "Opći koncept koji pokriva gotove proizvode, komponente ili sirovine."
        },
        {
          "@language": "hu",
          "@value": "Általános fogalom, amely magában foglalja a késztermékeket, alkatrészeket vagy nyersanyagokat."
        },
        {
          "@language": "it",
          "@value": "Un concetto generale che copre prodotti finiti, componenti o materie prime."
        },
        {
          "@language": "lt",
          "@value": "Bendra sąvoka, apimanti pagamintas prekes, komponentus ar žaliavas."
        },
        {
          "@language": "lv",
          "@value": "Vispārīgs jēdziens, kas aptver gatavās preces, komponentus vai izejvielas."
        },
        {
          "@language": "mt",
          "@value": "Kunċett ġenerali li jkopri oġġetti lesti, komponenti, jew materja prima."
        },
        {
          "@language": "nl",
          "@value": "Een algemeen concept dat eindproducten, componenten of grondstoffen omvat."
        },
        {
          "@language": "pl",
          "@value": "Ogólne pojęcie obejmujące wyroby gotowe, komponenty lub surowce."
        },
        {
          "@language": "pt",
          "@value": "Um conceito geral que abrange produtos acabados, componentes ou matérias-primas."
        },
        {
          "@language": "ro",
          "@value": "Un concept general care acoperă produsele finite, componentele sau materiile prime."
        },
        {
          "@language": "sk",
          "@value": "Všeobecný koncept zahŕňajúci hotové výrobky, súčiastky alebo suroviny."
        },
        {
          "@language": "sl",
          "@value": "Splošni koncept, ki zajema končne izdelke, komponente ali surovine."
        },
        {
          "@language": "sv",
          "@value": "Ett allmänt koncept som täcker färdiga varor, komponenter eller råmaterial."
        }
      ],
