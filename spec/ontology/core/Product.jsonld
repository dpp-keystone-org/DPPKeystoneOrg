      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "The size of the product (e.g., 'M', 'L', '42'). Applicable primarily to apparel and textiles."
        },
        {
          "@language": "bg",
          "@value": "Размерът на продукта (напр. 'M', 'L', '42'). Приложимо основно за облекло и текстил."
