          "@value": "Karakteristike proizvoda"
        },
        {
          "@language": "hu",
          "@value": "Termékjellemzők"
        },
        {
          "@language": "it",
          "@value": "Caratteristiche del prodotto"
        },
        {
          "@language": "lt",
          "@value": "Produkto charakteristikos"
        },
        {
          "@language": "lv",
          "@value": "Produkta raksturojums"
        },
        {
          "@language": "mt",
          "@value": "Karatteristiċi tal-Prodott"
        },
        {
          "@language": "nl",
          "@value": "Productkenmerken"
        },
        {
          "@language": "pl",
          "@value": "Charakterystyka produktu"
        },
        {
          "@language": "pt",
          "@value": "Características do produto"
        },
        {
          "@language": "ro",
          "@value": "Caracteristicile produsului"
        },
        {
          "@language": "sk",
          "@value": "Vlastnosti produktu"
        },
        {
          "@language": "sl",
          "@value": "Značilnosti izdelka"
        },
        {
          "@language": "sv",
          "@value": "Produktegenskaper"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Relates a product to its specific characteristics or performance properties."
        },
        {
          "@language": "bg",
          "@value": "Свързва продукт с неговите специфични характеристики или експлоатационни свойства."
        },
        {
          "@language": "cs",
          "@value": "Spojuje produkt s jeho specifickými vlastnostmi nebo výkonnostními parametry."
        },
        {
          "@language": "da",
          "@value": "Relaterer et produkt til dets specifikke egenskaber eller ydeevneegenskaber."
        },
        {
          "@language": "de",
          "@value": "Bezieht ein Produkt auf seine spezifischen Eigenschaften oder Leistungsmerkmale."
        },
        {
          "@language": "el",
          "@value": "Συσχετίζει ένα προϊόν με τα ειδικά χαρακτηριστικά ή τις ιδιότητες απόδοσής του."
        },
        {
          "@language": "es",
          "@value": "Relaciona un producto con sus características específicas o propiedades de rendimiento."
        },
        {
          "@language": "et",
          "@value": "Seob toote selle spetsiifiliste omaduste või toimivusnäitajatega."
        },
        {
          "@language": "fi",
          "@value": "Yhdistää tuotteen sen erityisominaisuuksiin tai suorituskykyominaisuuksiin."
        },
        {
          "@language": "fr",
          "@value": "Relie un produit à ses caractéristiques spécifiques ou à ses propriétés de performance."
        },
        {
          "@language": "ga",
          "@value": "Baineann sé táirge lena shaintréithe sonracha nó lena airíonna feidhmíochta."
        },
        {
          "@language": "hr",
          "@value": "Povezuje proizvod s njegovim specifičnim karakteristikama ili svojstvima izvedbe."
        },
        {
          "@language": "hu",
          "@value": "A terméket annak konkrét jellemzőivel vagy teljesítménytulajdonságaival kapcsolja össze."
        },
        {
          "@language": "it",
          "@value": "Mette in relazione un prodotto con le sue caratteristiche specifiche o proprietà di prestazione."
        },
        {
          "@language": "lt",
          "@value": "Susieja produktą su jo specifinėmis charakteristikomis ar našumo savybėmis."
        },
        {
          "@language": "lv",
          "@value": "Saista produktu ar tā īpašajām pazīmēm vai veiktspējas īpašībām."
        },
        {
          "@language": "mt",
          "@value": "Jirrelata prodott mal-karatteristiċi speċifiċi jew il-proprjetajiet ta' prestazzjoni tiegħu."
        },
        {
          "@language": "nl",
          "@value": "Verbindt een product met zijn specifieke kenmerken of prestatie-eigenschappen."
        },
        {
          "@language": "pl",
          "@value": "Powiązuje produkt z jego specyficznymi cechami lub właściwościami użytkowymi."
        },
        {
          "@language": "pt",
          "@value": "Relaciona um produto com suas características específicas ou propriedades de desempenho."
        },
        {
          "@language": "ro",
          "@value": "Relaționează un produs cu caracteristicile sale specifice sau cu proprietățile de performanță."
        },
        {
          "@language": "sk",
          "@value": "Spája produkt s jeho špecifickými vlastnosťami alebo výkonnostnými parametrami."
        },
        {
          "@language": "sl",
          "@value": "Povezuje izdelek z njegovimi specifičnimi značilnostmi ali lastnostmi delovanja."
        },
