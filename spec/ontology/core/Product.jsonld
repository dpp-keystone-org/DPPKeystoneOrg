      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A reference to the standard or methodology used to determine the characteristic's value."
        },
        {
          "@language": "bg",
          "@value": "Справка към стандарта или методологията, използвани за определяне стойността на характеристиката."
        },
        {
          "@language": "cs",
          "@value": "Odkaz na normu nebo metodiku použitou k určení hodnoty vlastnosti."
        },
        {
          "@language": "da",
          "@value": "En henvisning til den standard eller metode, der er brugt til at bestemme egenskabens værdi."
        },
        {
          "@language": "de",
          "@value": "Ein Verweis auf den Standard oder die Methodik, die zur Bestimmung des Merkmalswerts verwendet wurde."
        },
        {
          "@language": "el",
          "@value": "Αναφορά στο πρότυπο ή τη μεθοδολογία που χρησιμοποιήθηκε για τον καθορισμό της τιμής του χαρακτηριστικού."
        },
        {
          "@language": "es",
          "@value": "Una referencia a la norma o metodología utilizada para determinar el value de la característica."
        },
        {
          "@language": "et",
          "@value": "Viide standardile või metoodikale, mida kasutati omaduse väärtuse määramiseks."
        },
        {
          "@language": "fi",
          "@value": "Viittaus standardiin tai menetelmään, jota on käytetty ominaisuuden arvon määrittämisessä."
        },
        {
          "@language": "fr",
          "@value": "Une référence à la norme ou à la méthodologie utilisée pour déterminer la valeur de la caractéristique."
        },
        {
          "@language": "ga",
          "@value": "Tagairt don chaighdeán nó don mhodheolaíocht a úsáideadh chun luach na saintréithe a chinneadh."
        },
        {
          "@language": "hr",
          "@value": "Referenca na standard ili metodologiju koja se koristi za određivanje vrijednosti karakteristike."
        },
        {
          "@language": "hu",
          "@value": "Hivatkozás a jellemző értékének meghatározásához használt szabványra vagy módszertanra."
        },
        {
          "@language": "it",
          "@value": "Un riferimento alla norma o alla metodologia utilizzata per determinare il valore della caratteristica."
        },
        {
          "@language": "lt",
          "@value": "Nuoroda į standartą ar metodiką, naudotą nustatant charakteristikos vertę."
        },
        {
          "@language": "lv",
          "@value": "Atsauce uz standartu vai metodoloģiju, kas izmantota, lai noteiktu raksturlieluma vērtību."
        },
        {
          "@language": "mt",
          "@value": "Referenza għall-istandard jew il-metodoloġija użata biex jiġi ddeterminat il-valur tal-karatteristika."
        },
        {
          "@language": "nl",
          "@value": "Een verwijzing naar de standaard of methodologie die is gebruikt om de waarde van het kenmerk te bepalen."
        },
        {
          "@language": "pl",
          "@value": "Odniesienie do normy lub metodologii użytej do określenia wartości cechy."
        },
        {
          "@language": "pt",
          "@value": "Uma referência ao padrão ou metodologia usada para determinar o valor da característica."
        },
        {
          "@language": "ro",
          "@value": "O referință la standardul sau metodologia utilizată pentru a determina valoarea caracteristicii."
        },
        {
          "@language": "sk",
          "@value": "Odkaz na normu alebo metodiku použitú na určenie hodnoty vlastnosti."
        },
        {
          "@language": "sl",
          "@value": "Sklicevanje na standard ali metodologijo, uporabljeno za določanje vrednosti značilnosti."
        },
        {
          "@language": "sv",
          "@value": "En hänvisning till standarden eller metoden som använts för att fastställa egenskapens värde."
        }
      ],
