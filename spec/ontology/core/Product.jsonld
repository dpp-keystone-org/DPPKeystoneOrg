        {
          "@language": "fi",
          "@value": "Tämän komponentin prosentuaalinen osuus emokokoonpanossa (esim. painon mukaan)."
        },
        {
          "@language": "fr",
          "@value": "La contribution en pourcentage de ce composant à l'assemblage parent (par ex., en poids)."
        },
        {
          "@language": "ga",
          "@value": "Ranníocaíocht chéatadáin na comhpháirte seo leis an bpríomhthionól (m.sh., de réir meáchain)."
        },
        {
          "@language": "hr",
          "@value": "Postotni udio ove komponente u nadređenom sklopu (npr. po težini)."
        },
        {
          "@language": "hu",
          "@value": "Ennek az alkatrésznek a százalékos hozzájárulása a szülőszerelvényhez (pl. tömeg szerint)."
        },
        {
          "@language": "it",
          "@value": "Il contributo percentuale di questo componente all'assieme principale (ad es. in base al peso)."
        },
        {
          "@language": "lt",
          "@value": "Šio komponento procentinis indėlis į pagrindinį surinkimą (pvz., pagal svorį)."
        },
        {
          "@language": "lv",
          "@value": "Šī komponenta procentuālais ieguldījums vecākajā mezglā (piem., pēc svara)."
