        {
          "@language": "cs",
          "@value": "Specifické fyzické umístění komponenty nebo látky uvnitř nadřazené sestavy."
        },
        {
          "@language": "da",
          "@value": "Specifik fysisk placering af komponenten eller stoffet inde i den overordnede samling."
        },
        {
          "@language": "de",
          "@value": "Spezifischer physischer Ort der Komponente oder Substanz innerhalb der übergeordneten Baugruppe."
        },
        {
          "@language": "el",
          "@value": "Συγκεκριμένη φυσική θέση του εξαρτήματος ή της ουσίας μέσα στη γονική διάταξη."
        },
        {
          "@language": "es",
          "@value": "Ubicación física específica del componente o sustancia dentro del ensamblaje principal."
        },
        {
          "@language": "et",
          "@value": "Komponendi või aine spetsiifiline füüsiline asukoht emakoostus."
