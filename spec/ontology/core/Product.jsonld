    {
      "@id": "dppk:ProductCharacteristic",
      "@type": "rdfs:Class",
      "rdfs:label": [
        {
          "@language": "en",
          "@value": "Product Characteristic"
        },
        {
          "@language": "bg",
          "@value": "Характеристика на продукта"
        },
        {
          "@language": "cs",
          "@value": "Vlastnost produktu"
        },
        {
          "@language": "da",
          "@value": "Produktegenskab"
        },
        {
          "@language": "de",
          "@value": "Produkteigenschaft"
        },
        {
          "@language": "el",
          "@value": "Χαρακτηριστικό Προϊόντος"
        },
        {
          "@language": "es",
          "@value": "Característica del producto"
        },
        {
          "@language": "et",
          "@value": "Toote omadus"
        },
        {
          "@language": "fi",
          "@value": "Tuotteen ominaisuus"
        },
        {
          "@language": "fr",
          "@value": "Caractéristique du produit"
        },
        {
          "@language": "ga",
          "@value": "Saintréith an Táirge"
        },
        {
          "@language": "hr",
          "@value": "Značajka proizvoda"
        },
        {
          "@language": "hu",
          "@value": "Termékjellemző"
        },
        {
          "@language": "it",
          "@value": "Caratteristica del prodotto"
        },
        {
          "@language": "lt",
          "@value": "Produkto charakteristika"
        },
        {
          "@language": "lv",
          "@value": "Produkta raksturojums"
        },
        {
          "@language": "mt",
          "@value": "Karatteristika tal-Prodott"
        },
        {
          "@language": "nl",
          "@value": "Productkenmerk"
        },
        {
          "@language": "pl",
          "@value": "Cecha produktu"
        },
        {
          "@language": "pt",
          "@value": "Característica do produto"
        },
        {
          "@language": "ro",
          "@value": "Caracteristică a produsului"
        },
        {
          "@language": "sk",
          "@value": "Vlastnosť produktu"
        },
        {
          "@language": "sl",
          "@value": "Značilnost izdelka"
        },
        {
          "@language": "sv",
          "@value": "Produktegenskap"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A specific, measurable or declared property of a product, such as its technical performance against a standard test."
        },
        {
          "@language": "bg",
          "@value": "Специфично, измеримо или декларирано свойство на продукт, като например неговото техническо представяне спрямо стандартен тест."
        },
        {
          "@language": "cs",
          "@value": "Specifická, měřitelná nebo deklarovaná vlastnost produktu, jako je jeho technický výkon při standardním testu."
        },
        {
          "@language": "da",
          "@value": "En specifik, målbær eller deklareret egenskab ved et produkt, såsom dets tekniske ydeevne i forhold til en standardtest."
        },
        {
          "@language": "de",
          "@value": "Eine spezifische, messbare oder deklarierte Eigenschaft eines Produkts, wie etwa seine technische Leistung bei einem Standardtest."
        },
        {
          "@language": "el",
          "@value": "Μια συγκεκριμένη, μετρήσιμη ή δηλωμένη ιδιότητα ενός προϊόντος, όπως η τεχνική του απόδοση σε σχέση με μια τυπική δοκιμή."
        },
        {
          "@language": "es",
          "@value": "Una propiedad específica, medible o declarada de un producto, como su rendimiento técnico frente a una prueba estándar."
        },
        {
          "@language": "et",
          "@value": "Toote spetsiifiline, mõõdetav või deklareeritud omadus, näiteks selle tehniline jõudlus standardtesti suhtes."
        },
        {
          "@language": "fi",
          "@value": "Tuotteen erityinen, mitattavissa oleva tai ilmoitettu ominaisuus, kuten sen tekninen suorituskyky standarditestiä vastaan."
        },
        {
          "@language": "fr",
          "@value": "Une propriété spécifique, mesurable ou déclarée d'un produit, comme ses performances techniques par rapport à un test standard."
        },
        {
          "@language": "ga",
          "@value": "Sain-airí den táirge is féidir a thomhas nó atá dearbhaithe, mar shampla a fheidhmíocht theicniúil i gcoinne tástála caighdeánaigh."
        },
        {
          "@language": "hr",
          "@value": "Specifično, mjerljivo ili deklarirano svojstvo proizvoda, kao što je njegova tehnička izvedba u usporedbi sa standardnim testom."
        },
        {
          "@language": "hu",
          "@value": "A termék egyedi, mérhető vagy bejelentett tulajdonsága, mint például egy szabványos teszttel szembeni műszaki teljesítménye."
        },
        {
          "@language": "it",
          "@value": "Una proprietà specifica, misurabile o dichiarata di un prodotto, come le sue prestazioni tecniche rispetto a un test standard."
        },
        {
          "@language": "lt",
          "@value": "Konkreti, išmatuojama arba deklaruojama produkto savybė, pvz., jo techninis veikimas pagal standartinį bandymą."
        },
        {
          "@language": "lv",
          "@value": "Produkta specifiska, izmērāma vai deklarēta īpašība, piemēram, tā tehniskā veiktspēja attiecībā pret standarta testu."
        },
        {
          "@language": "mt",
          "@value": "Proprjetà speċifika, miżurabbli jew iddikjarata ta' prodott, bħall-prestazzjoni teknika tiegħu kontra test standard."
        },
        {
          "@language": "nl",
          "@value": "Een specifieke, meetbare of gedeclareerde eigenschap van een product, zoals de technische prestaties bij een standaardtest."
        },
        {
          "@language": "pl",
          "@value": "Określona, wymierna lub deklarowana właściwość produktu, np. jego parametry techniczne w standardowym teście."
        },
        {
          "@language": "pt",
          "@value": "Uma propriedade específica, mensurável ou declarada de um produto, como o seu desempenho técnico em relação a um teste padrão."
        },
        {
          "@language": "ro",
          "@value": "O proprietate specifică, măsurabilă sau declarată a unui produs, cum ar fi performanța sa tehnică în comparație cu un test standard."
        },
        {
          "@language": "sk",
          "@value": "Špecifická, merateľná alebo deklarovaná vlastnosť produktu, ako napríklad jeho technický výkon pri štandardnom teste."
        },
        {
          "@language": "sl",
