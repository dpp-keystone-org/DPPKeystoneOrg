    {
      "@id": "dppk:productCharacteristics",
      "@type": "owl:ObjectProperty",
      "rdfs:label": [
        {
          "@language": "en",
          "@value": "Product Characteristics"
        },
        {
          "@language": "bg",
          "@value": "Характеристики на продукта"
        },
        {
          "@language": "cs",
          "@value": "Vlastnosti produktu"
        },
        {
          "@language": "da",
          "@value": "Produktegenskaber"
        },
        {
          "@language": "de",
          "@value": "Produkteigenschaften"
        },
        {
          "@language": "el",
          "@value": "Χαρακτηριστικά Προϊόντος"
        },
        {
          "@language": "es",
          "@value": "Características del producto"
        },
        {
          "@language": "et",
          "@value": "Toote omadused"
        },
        {
          "@language": "fi",
          "@value": "Tuotteen ominaisuudet"
        },
        {
          "@language": "fr",
