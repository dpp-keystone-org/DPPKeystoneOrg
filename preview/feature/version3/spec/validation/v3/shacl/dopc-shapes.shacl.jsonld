{
  "@context": {
    "sh": "http://www.w3.org/ns/shacl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dppk": "https://dpp-keystone.org/spec/v3/terms#",
    "dppk-dopc": "https://dpp-keystone.org/spec/v3/terms/dopc#",
    "dppkval": "https://dpp-keystone.org/spec/validation/v3/shacl/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "@vocab": "http://www.w3.org/ns/shacl#",
    "node": {
      "@type": "@id"
    },
    "path": {
      "@type": "@id"
    },
    "targetClass": {
      "@type": "@id"
    },
    "class": {
      "@type": "@id"
    },
    "datatype": {
      "@type": "@id"
    }
  },
  "@id": "dppkval:DoPCShapes",
  "@type": "ShapesGraph",
  "@graph": [
    {
      "@id": "dppkval:DoPCShape",
      "@type": "NodeShape",
      "targetClass": "dppk-dopc:DoPCBlock",
      "property": [
        {
          "path": "dppk-dopc:declarationCode",
          "minCount": 1,
          "datatype": "xsd:string",
          "message": "DoPC must have a declaration code."
        },
        {
          "path": "dppk-dopc:dateOfIssue",
          "minCount": 1,
          "datatype": "xsd:date",
          "message": "DoPC must have a date of issue."
        },
        {
          "path": "dppk-dopc:tensileStrengthAdhesion",
          "datatype": "xsd:string",
          "minCount": 0
        },
        {
          "path": "dppk-dopc:declaredUnit",
          "datatype": "xsd:double",
          "minCount": 0
        }
      ]
    }
  ]
}
