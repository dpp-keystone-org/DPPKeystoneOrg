  "dcterms:description": [
    {
      "@language": "en",
      "@value": "The main entry point for the DPP Harmonizing Data Dictionary (Keystone). This file imports all core modules and sector-specific definitions for Version 1."
    },
    {
      "@language": "bg",
      "@value": "Основната входна точка за DPP Хармонизиращ речник на данните (Keystone). Този файл импортира всички основни модули и специфични за сектора дефиниции за Версия 1."
    },
    {
      "@language": "cs",
      "@value": "Hlavní vstupní bod pro DPP Harmonizační datový slovník (Keystone). Tento soubor importuje všechny základní moduly a definice specifické pro dané odvětví pro verzi 1."
    },
    {
      "@language": "da",
      "@value": "Hovedindgangspunktet for DPP Harmoniserende dataordbog (Keystone). Denne fil importerer alle kernemoduler og sektorspecifikke definitioner for version 1."
    },
    {
      "@language": "de",
      "@value": "Der Haupteinstiegspunkt für das DPP Harmonisierende Datenwörterbuch (Keystone). Diese Datei importiert alle Kernmodule und sektorspezifischen Definitionen für Version 1."
    },
    {
      "@language": "el",
      "@value": "Το κύριο σημείο εισόδου για το DPP Εναρμονιστικό Λεξικό Δεδομένων (Keystone). Αυτό το αρχείο εισάγει όλες τις βασικές ενότητες και τους ειδικούς για τον τομέα ορισμούς για την Έκδοση 1."
    },
    {
      "@language": "es",
      "@value": "El punto de entrada principal para el DPP Diccionario de datos armonizador (Keystone). Este archivo importa todos los módulos centrales y las definiciones específicas del sector para la Versión 1."
    },
    {
      "@language": "et",
      "@value": "Peamine sisenemispunkt DPP Ühtlustava andmesõnastiku (Keystone) jaoks. See fail impordib kõik põhimoodulid ja sektoripõhised määratlused versiooni 1 jaoks."
    },
    {
      "@language": "fi",
      "@value": "Pääasiallinen aloituspiste DPP Yhdenmukaistavalle tietosanakirjalle (Keystone). Tämä tiedosto tuo kaikki ydinmoduulit ja alakohtaiset määritelmät versiolle 1."
    },
    {
      "@language": "fr",
      "@value": "Le point d'entrée principal du DPP Dictionnaire de données harmonisateur (Keystone). Ce fichier importe tous les modules de base et les définitions spécifiques au secteur pour la version 1."
    },
    {
      "@language": "ga",
      "@value": "An príomhphointe iontrála do DPP Foclóir Sonraí Comhchuibhithe (Keystone). Iompórtálann an comhad seo na croímhodúil agus na sainmhínithe earnáil-shonracha d'Leagan 1."
    },
    {
      "@language": "hr",
      "@value": "Glavna ulazna točka za DPP Harmonizirajući rječnik podataka (Keystone). Ova datoteka uvozi sve osnovne module i definicije specifične za sektor za verziju 1."
    },
    {
      "@language": "hu",
      "@value": "A fő belépési pont a DPP Harmonizáló adatszótárhoz (Keystone). Ez a fájl importálja az összes alapmodult és ágazatspecifikus definíciót az 1. verzióhoz."
    },
    {
      "@language": "it",
      "@value": "Il punto di ingresso principale per il DPP Dizionario dei dati armonizzante (Keystone). Questo file importa tutti i moduli principali e le definizioni specifiche del settore per la Versione 1."
    },
    {
      "@language": "lt",
      "@value": "Pagrindinis įėjimo taškas į DPP Harmonizuojantį duomenų žodyną (Keystone). Šis failas importuoja visus pagrindinius modulius ir konkretaus sektoriaus apibrėžimus 1 versijai."
    },
    {
      "@language": "lv",
      "@value": "Galvenais ieejas punkts DPP Harmonizējošajai datu vārdnīcai (Keystone). Šis fails importē visus pamatmoduļus un nozarei specifiskās definīcijas 1. versijai."
    },
    {
      "@language": "mt",
      "@value": "Il-punt tad-dħul ewlieni għad-DPP Dizzjunarju tad-dejta armonizzanti (Keystone). Dan il-fajl jimporta l-moduli ewlenin kollha u d-definizzjonijiet speċifiċi għas-settur għal Verżjoni 1."
    },
    {
      "@language": "nl",
      "@value": "Het belangrijkste toegangspunt voor het DPP Harmoniserend datawoordenboek (Keystone). Dit bestand importeert alle kernmodules en sectorspecifieke definities voor versie 1."
    },
    {
      "@language": "pl",
      "@value": "Główny punkt wejścia dla DPP Harmonizującego słownika danych (Keystone). Ten plik importuje wszystkie moduły podstawowe i definicje specyficzne dla sektora dla wersji 1."
    },
    {
      "@language": "pt",
      "@value": "O principal ponto de entrada para o DPP Dicionário de dados harmonizador (Keystone). Este arquivo importa todos os módulos principais e definições específicas do setor para a Versão 1."
    },
    {
      "@language": "ro",
      "@value": "Punctul principal de intrare pentru DPP Dicționarul de date armonizator (Keystone). Acest fișier importă toate modulele de bază și definițiile specifice sectorului pentru Versiunea 1."
    },
    {
      "@language": "sk",
      "@value": "Hlavný vstupný bod pre DPP Harmonizačný dátový slovník (Keystone). Tento súbor importuje všetky základné moduly a definície špecifické pre daný sektor pre verziu 1."
    },
    {
      "@language": "sl",
      "@value": "Glavna vstopna točka za DPP Harmonizacijski slovar podatkov (Keystone). Ta datoteka uvozi vse osnovne module in sektorsko specifične definicije za različico 1."
    },
    {
      "@language": "sv",
      "@value": "Huvudingångspunkten för DPP Harmoniserande dataordbok (Keystone). Denna fil importerar alla kärnmoduler och sektorspecifika definitioner för version 1."
    }
  ],
