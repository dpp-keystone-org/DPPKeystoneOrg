{
  "@context": {
    "dppk": "https://dpp-keystone.org/spec/v3/terms#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dopc": {
      "@id": "dppk-dopc:dopc",
      "@context": {
        "declarationCode": "dppk-dopc:declarationCode",
        "dateOfIssue": {
          "@id": "dppk-dopc:dateOfIssue",
          "@type": "xsd:date"
        },
        "tensileStrengthAdhesion": "dppk-dopc:tensileStrengthAdhesion",
        "modulusOfElasticityInCompression": {
          "@id": "dppk-dopc:modulusOfElasticityInCompression",
          "@context": {
            "method1": {
              "@id": "dppk-dopc:modulusMethod1",
              "@type": "xsd:double"
            }
          }
        },
        "capillaryAbsorption": {
          "@id": "dppk-dopc:capillaryAbsorption",
          "@type": "xsd:double"
        },
        "dangerousSubstances": "dppk-dopc:dangerousSubstances",
        "shrinkageAndExpansion": "dppk-dopc:shrinkageAndExpansion",
        "slipSkidResistance": {
          "@id": "dppk-dopc:slipSkidResistance",
          "@context": {
            "laboratory": {
              "@id": "dppk-dopc:slipSkidResistanceLab",
              "@type": "xsd:string"
            }
          }
        },
        "thermalExpansion": "dppk-dopc:thermalExpansion",
        "declaredUnit": {
          "@id": "dppk-dopc:declaredUnit",
          "@type": "xsd:string"
        },
        "functionalUnit": {
          "@id": "dppk-dopc:functionalUnit",
          "@type": "xsd:string"
        },
        "referenceServiceLife": {
          "@id": "dppk-dopc:referenceServiceLife",
          "@type": "xsd:integer"
        },
        "chlorideContent": {
          "@id": "dppk-dopc:chlorideContent",
          "@context": {
            "21DegC": {
              "@id": "dppk-dopc:chlorideContentAt21DegC",
              "@type": "xsd:double"
            }
          }
        },
        "bondStrength": {
          "@id": "dppk-dopc:bondStrength",
          "@context": {
            "28Days": {
              "@id": "dppk-dopc:bondStrengthAt28Days",
              "@type": "xsd:double"
            }
          }
        },
        "thermalCompatibility": {
          "@id": "dppk-dopc:thermalCompatibility",
          "@context": {
            "wetSurface": {
              "@id": "dppk-dopc:thermalCompatibilityWet",
              "@type": "xsd:double"
            }
          }
        },
        "resistanceToCarbonation": {
          "@id": "dppk-dopc:resistanceToCarbonation",
          "@context": {
            "21DegC": {
              "@id": "dppk-dopc:carbonationResistanceAt21DegC",
              "@type": "xsd:string"
            }
          }
        },
        "reactionToFire": {
          "@id": "dppk-dopc:reactionToFire",
          "@context": {
            "avcpSystem1": {
              "@id": "dppk-dopc:reactionToFireSystem1",
              "@type": "xsd:string"
            },
            "avcpSystem2": {
              "@id": "dppk-dopc:reactionToFireSystem2",
              "@type": "xsd:string"
            },
            "avcpSystem3": {
              "@id": "dppk-dopc:reactionToFireSystem3",
              "@type": "xsd:string"
            },
            "avcpSystem4": {
              "@id": "dppk-dopc:reactionToFireSystem4",
              "@type": "xsd:string"
            }
          }
        },
        "elasticRecovery": {
          "@id": "dppk-dopc:elasticRecovery",
          "@context": {
            "methodA": {
              "@id": "dppk-dopc:methodA",
              "@context": {
                "25Percent": {
                  "@id": "dppk-dopc:elasticRecoveryMethodA25",
                  "@type": "xsd:double"
                },
                "60Percent": {
                  "@id": "dppk-dopc:elasticRecoveryMethodA60",
                  "@type": "xsd:double"
                },
                "100Percent": {
                  "@id": "dppk-dopc:elasticRecoveryMethodA100",
                  "@type": "xsd:double"
                }
              }
            },
            "methodB": {
              "@id": "dppk-dopc:methodB",
              "@context": {
                "25Percent": {
                  "@id": "dppk-dopc:elasticRecoveryMethodB25",
                  "@type": "xsd:double"
                },
                "60Percent": {
                  "@id": "dppk-dopc:elasticRecoveryMethodB60",
                  "@type": "xsd:double"
                },
                "100Percent": {
                  "@id": "dppk-dopc:elasticRecoveryMethodB100",
                  "@type": "xsd:double"
                }
              }
            }
          }
        },
        "resistanceToFlow": {
          "@id": "dppk-dopc:resistanceToFlow",
          "@context": {
            "procedureA": {
              "@id": "dppk-dopc:procedureA",
              "@context": {
                "5DegC": {
                  "@id": "dppk-dopc:flowResistanceProcedureA5",
                  "@type": "xsd:double"
                },
                "50DegC": {
                  "@id": "dppk-dopc:flowResistanceProcedureA50",
                  "@type": "xsd:double"
                },
                "70DegC": {
                  "@id": "dppk-dopc:flowResistanceProcedureA70",
                  "@type": "xsd:double"
                }
              }
            },
            "procedureB": {
              "@id": "dppk-dopc:procedureB",
              "@context": {
                "5DegC": {
                  "@id": "dppk-dopc:flowResistanceProcedureB5",
                  "@type": "xsd:double"
                },
                "50DegC": {
                  "@id": "dppk-dopc:flowResistanceProcedureB50",
                  "@type": "xsd:double"
                },
                "70DegC": {
                  "@id": "dppk-dopc:flowResistanceProcedureB70",
                  "@type": "xsd:double"
                }
              }
            }
          }
        }
      }
    }
  }
}
