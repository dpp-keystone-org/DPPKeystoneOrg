        {
          "@language": "mt",
          "@value": "Jindika l-klassi ta' viżibbiltà espliċita ta' proprjetà partikolari."
        },
        {
          "@language": "nl",
          "@value": "Geeft de expliciete zichtbaarheidsklasse van een bepaalde eigenschap aan."
