      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Data access is heavily restricted explicitly to authoritative bodies."
        },
        {
          "@language": "bg",
          "@value": "Достъпът до данни е силно ограничен изрично до официални органи."
        },
        {
          "@language": "cs",
          "@value": "Přístup k datům je silně omezen výslovně na autoritativní orgány."
        },
        {
          "@language": "da",
          "@value": "Dataadgang er stærkt begrænset og udelukkende for autoritative organer."
        },
        {
          "@language": "de",
          "@value": "Der Datenzugriff ist ausdrücklich und stark auf befugte Behörden beschränkt."
        },
        {
          "@language": "el",
          "@value": "Η πρόσβαση στα δεδομένα περιορίζεται έντονα ρητά στους αρμόδιους φορείς."
        },
        {
          "@language": "es",
          "@value": "El acceso a los datos está fuertemente restringido explícitamente a organismos de autoridad."
        },
        {
          "@language": "et",
          "@value": "Andmetele juurdepääs on tugevalt piiratud ja lubatud ainult ametiasutustele."
        },
        {
          "@language": "fi",
          "@value": "Tiedonsaanti on voimakkaasti rajoitettu yksinomaan viranomaisille."
        },
        {
          "@language": "fr",
          "@value": "L'accès aux données est fortement restreint explicitement aux organes faisant autorité."
        },
        {
          "@language": "ga",
          "@value": "Tá rochtain ar shonraí teoranta go mór go sainráite d'eagraíochtaí údarásacha."
        },
        {
          "@language": "hr",
          "@value": "Pristup podacima je strogo ograničen izričito na nadležna tijela."
        },
        {
          "@language": "hu",
          "@value": "Az adathozzáférés erősen és kifejezetten a hatóságokra korlátozódik."
        },
        {
          "@language": "it",
          "@value": "L'accesso ai dati è fortemente limitato esplicitamente agli organi autoritativi."
        },
        {
          "@language": "lt",
          "@value": "Prieiga prie duomenų yra labai apribota tik kompetentingoms institucijoms."
        },
        {
          "@language": "lv",
          "@value": "Datu piekļuve ir stingri ierobežota tikai atbildīgajām iestādēm."
        },
        {
          "@language": "mt",
          "@value": "L-aċċess għad-data huwa ristrett b'mod qawwi u b'mod espliċitu għal korpi awtorevoli."
        },
        {
          "@language": "nl",
          "@value": "Toegang tot gegevens is sterk beperkt en expliciet voorbehouden aan bevoegde instanties."
        },
        {
          "@language": "pl",
          "@value": "Dostęp do danych jest mocno ograniczony i dotyczy wyraźnie uprawnionych organów."
        },
        {
          "@language": "pt",
          "@value": "O acesso aos dados é fortemente restrito explicitamente a órgãos de autoridade."
        },
        {
          "@language": "ro",
          "@value": "Accesul la date este puternic restricționat explicit la organismele autorizate."
        },
        {
          "@language": "sk",
          "@value": "Prístup k údajom je prísne obmedzený výlučne na autoritatívne orgány."
        },
        {
          "@language": "sl",
          "@value": "Dostop do podatkov je močno omejen in izrecno dovoljen zgolj pristojnim organom."
        },
        {
          "@language": "sv",
          "@value": "Dataåtkomsten är kraftigt begränsad och exklusiv för auktoritativa organ."
        }
      ]
