      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Data access is restricted or relies on proven legitimate interest."
        },
        {
          "@language": "bg",
          "@value": "Достъпът до данни е ограничен или разчита на доказан легитимен интерес."
        },
        {
          "@language": "cs",
          "@value": "Přístup k datům je omezen nebo závisí na prokázaném oprávněném zájmu."
        },
        {
          "@language": "da",
          "@value": "Dataadgang er begrænset eller afhænger af bevist legitim interesse."
        },
        {
          "@language": "de",
          "@value": "Der Datenzugriff ist beschränkt oder beruht auf einem nachgewiesenen berechtigten Interesse."
        },
        {
          "@language": "el",
          "@value": "Η πρόσβαση στα δεδομένα περιορίζεται ή βασίζεται σε αποδεδειγμένο έννομο συμφέρον."
        },
        {
          "@language": "es",
          "@value": "El acceso a los datos está restringido o se basa en un interés legítimo comprobado."
        },
        {
          "@language": "et",
          "@value": "Andmetele juurdepääs on piiratud või tugineb tõestatud õigustatud huvile."
        },
        {
          "@language": "fi",
          "@value": "Tiedonsaanti on rajoitettu tai perustuu todistettuun oikeutettuun etuun."
        },
        {
          "@language": "fr",
          "@value": "L'accès aux données est restreint ou repose sur un intérêt légitime avéré."
        },
        {
          "@language": "ga",
          "@value": "Tá srianta le rochtain ar shonraí nó braitheann sé ar leas dlisteanach cruthaithe."
        },
        {
          "@language": "hr",
          "@value": "Pristup podacima je ograničen ili se oslanja na dokazani legitimni interes."
        },
        {
          "@language": "hu",
          "@value": "Az adathozzáférés korlátozott, vagy bizonyított jogos érdeken alapul."
        },
        {
          "@language": "it",
          "@value": "L'accesso ai dati è limitato o si basa su un comprovato interesse legittimo."
        },
        {
          "@language": "lt",
          "@value": "Prieiga prie duomenų yra apribota arba remiasi įrodytu teisėtu interesu."
        },
        {
          "@language": "lv",
          "@value": "Datu piekļuve ir ierobežota vai pamatojas uz pierādītu leģitīmu interesi."
        },
        {
          "@language": "mt",
          "@value": "L-aċċess għad-data huwa ristrett jew jiddependi fuq interess leġittimu ppruvat."
        },
        {
          "@language": "nl",
          "@value": "De toegang tot gegevens is beperkt of is gebaseerd op een bewezen gerechtvaardigd belang."
        },
        {
          "@language": "pl",
          "@value": "Dostęp do danych jest ograniczony lub opiera się na udokumentowanym uzasadnionym interesie."
        },
        {
          "@language": "pt",
          "@value": "O acesso aos dados é restrito ou depende de um interesse legítimo comprovado."
        },
        {
          "@language": "ro",
          "@value": "Accesul la date este restricționat sau se bazează pe un interes legitim dovedit."
        },
        {
          "@language": "sk",
          "@value": "Prístup k údajom je obmedzený alebo závisí od preukázaného oprávneného záujmu."
        },
        {
          "@language": "sl",
          "@value": "Dostop do podatkov je omejen ali pa temelji na dokazanem zakonitem interesu."
        },
        {
          "@language": "sv",
          "@value": "Dataåtkomsten är begränsad eller baseras på bevisat berättigat intresse."
        }
      ]
    },
    {
      "@id": "dppk:LegitimateInterestOrAuthority",
      "@type": "dppk:VisibilityValue",
      "rdfs:label": [
        {
          "@language": "en",
          "@value": "Legitimate Interest / Authority Only"
        },
        {
          "@language": "bg",
          "@value": "Само легитимен интерес / орган"
        },
        {
          "@language": "cs",
          "@value": "Pouze oprávněný zájem / orgán"
        },
        {
          "@language": "da",
          "@value": "Kun legitim interesse / myndighed"
        },
        {
          "@language": "de",
          "@value": "Nur berechtigtes Interesse / Behörde"
        },
        {
          "@language": "el",
          "@value": "Μόνο Έννομο Συμφέρον / Αρχή"
        },
        {
          "@language": "es",
          "@value": "Solo interés legítimo / autoridad"
        },
        {
          "@language": "et",
          "@value": "Ainult õigustatud huvi / asutus"
        },
        {
          "@language": "fi",
          "@value": "Vain oikeutettu etu / viranomainen"
        },
        {
          "@language": "fr",
          "@value": "Intérêt légitime / Autorité uniquement"
        },
        {
          "@language": "ga",
          "@value": "Leas Dlisteanach / Údarás Amháin"
        },
        {
          "@language": "hr",
          "@value": "Samo legitimni interes / tijelo"
        },
        {
          "@language": "hu",
          "@value": "Csak jogos érdek / hatóság"
        },
        {
          "@language": "it",
          "@value": "Solo interesse legittimo / autorità"
        },
        {
          "@language": "lt",
          "@value": "Tik teisėtas interesas / institucija"
        },
        {
          "@language": "lv",
          "@value": "Tikai leģitīma interese / iestāde"
        },
        {
          "@language": "mt",
          "@value": "Interess Leġittimu / Awtorità Biss"
        },
        {
          "@language": "nl",
          "@value": "Alleen gerechtvaardigd belang / autoriteit"
        },
        {
          "@language": "pl",
          "@value": "Tylko uzasadniony interes / organ"
        },
        {
          "@language": "pt",
          "@value": "Apenas Interesse Legítimo / Autoridade"
        },
        {
          "@language": "ro",
          "@value": "Doar interes legitim / autoritate"
        },
        {
          "@language": "sk",
          "@value": "Len oprávnený záujem / orgán"
        },
        {
          "@language": "sl",
          "@value": "Samo zakonit interes / organ"
        },
        {
          "@language": "sv",
          "@value": "Endast berättigat intresse / myndighet"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Data access is tightly restricted to authorities or highly specialized legitimate interests."
        },
        {
          "@language": "bg",
          "@value": "Достъпът до данни е строго ограничен до органи или тясно специализирани легитимни интереси."
        },
        {
          "@language": "cs",
          "@value": "Přístup k datům je přísně omezen na orgány nebo vysoce specializované oprávněné zájmy."
        },
        {
          "@language": "da",
          "@value": "Dataadgang er stramt begrænset til myndigheder eller højt specialiserede legitime interesser."
        },
        {
          "@language": "de",
          "@value": "Der Datenzugriff ist streng auf Behörden oder hochspezialisierte berechtigte Interessen beschränkt."
        },
        {
          "@language": "el",
          "@value": "Η πρόσβαση στα δεδομένα περιορίζεται αυστηρά στις αρχές ή σε εξαιρετικά εξειδικευμένα έννομα συμφέροντα."
        },
        {
          "@language": "es",
          "@value": "El acceso a los datos está estrictamente restringido a autoridades o intereses legítimos altamente especializados."
        },
        {
          "@language": "et",
          "@value": "Andmetele juurdepääs on rangelt piiratud asutustele või väga spetsiifilistele õigustatud huvidele."
        },
        {
          "@language": "fi",
          "@value": "Tiedonsaanti on tiukasti rajoitettu viranomaisille tai erittäin erikoistuneille oikeutetuille eduille."
        },
        {
          "@language": "fr",
          "@value": "L'accès aux données est strictement limité aux autorités ou à des intérêts légitimes hautement spécialisés."
        },
        {
          "@language": "ga",
          "@value": "Tá srianta dochta ar rochtain ar shonraí d'údaráis nó leasanna dlisteanacha sár-shainfheidhmithe."
        },
        {
          "@language": "hr",
          "@value": "Pristup podacima strogo je ograničen na tijela ili visoko specijalizirane legitimne interese."
        },
        {
          "@language": "hu",
          "@value": "Az adathozzáférés szigorúan a hatóságokra vagy rendkívül speciális jogos érdekekre korlátozódik."
        },
        {
          "@language": "it",
          "@value": "L'accesso ai dati è strettamente limitato alle autorità o a interessi legittimi altamente specializzati."
        },
        {
          "@language": "lt",
          "@value": "Prieiga prie duomenų griežtai ribojama institucijoms arba labai specializuotiems teisėtiems interesams."
        },
        {
          "@language": "lv",
          "@value": "Datu piekļuve ir stingri ierobežota iestādēm vai ļoti specializētām leģitīmām interesēm."
        },
        {
          "@language": "mt",
          "@value": "L-aċċess għad-data huwa ristrett b'mod strett għal awtoritajiet jew interessi leġittimi speċjalizzati ħafna."
        },
        {
          "@language": "nl",
          "@value": "Toegang tot gegevens is strikt beperkt tot autoriteiten of zeer gespecialiseerde gerechtvaardigde belangen."
        },
        {
          "@language": "pl",
          "@value": "Dostęp do danych jest ściśle ograniczony do organów lub wysoce wyspecjalizowanych uzasadnionych interesów."
        },
        {
          "@language": "pt",
          "@value": "O acesso aos dados é estritamente restrito a autoridades ou interesses legítimos altamente especializados."
        },
        {
          "@language": "ro",
          "@value": "Accesul la date este strict restricționat la autorități sau la interese legitime extrem de specializate."
        },
        {
          "@language": "sk",
          "@value": "Prístup k údajom je prísne obmedzený na orgány alebo vysoko špecializované oprávnené záujmy."
        },
        {
          "@language": "sl",
          "@value": "Dostop do podatkov je strogo omejen na organe ali visoko specializirane zakonite interese."
        },
        {
          "@language": "sv",
          "@value": "Dataåtkomst är strikt begränsad till myndigheter eller mycket specialiserade berättigade intressen."
        }
      ]
    },
