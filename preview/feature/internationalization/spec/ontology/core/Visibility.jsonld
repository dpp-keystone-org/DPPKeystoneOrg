      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "An enumeration of the allowed visibility and access levels for specific DPP data."
        },
        {
          "@language": "bg",
          "@value": "Изброяване на разрешените нива на видимост и достъп за специфични DPP данни."
        },
        {
          "@language": "cs",
          "@value": "Výčet povolených úrovní viditelnosti a přístupu pro specifická data DPP."
        },
        {
          "@language": "da",
          "@value": "En opregning af de tilladte synligheds- og adgangsniveauer for specifikke DPP-data."
        },
        {
          "@language": "de",
          "@value": "Eine Aufzählung der zulässigen Sichtbarkeits- und Zugriffsebenen für spezifische DPP-Daten."
        },
        {
          "@language": "el",
          "@value": "Μια απαρίθμηση των επιτρεπόμενων επιπέδων ορατότητας και πρόσβασης για συγκεκριμένα δεδομένα DPP."
        },
        {
          "@language": "es",
          "@value": "Una enumeración de los niveles de visibilidad y acceso permitidos para datos específicos de DPP."
        },
        {
          "@language": "et",
          "@value": "Spetsiifiliste DPP-andmete lubatud nähtavuse ja juurdepääsutasemete loetelu."
        },
        {
          "@language": "fi",
          "@value": "Luettelo sallituista näkyvyys- ja käyttöoikeustasoista tietyille DPP-tiedoille."
        },
        {
          "@language": "fr",
          "@value": "Une énumération des niveaux de visibilité et d'accès autorisés pour des données DPP spécifiques."
        },
        {
          "@language": "ga",
          "@value": "Liosta de na leibhéil infheictheachta agus rochtana a cheadaítear do shonraí DPP sainiúla."
        },
        {
          "@language": "hr",
          "@value": "Popis dopuštenih razina vidljivosti i pristupa za specifične DPP podatke."
        },
        {
          "@language": "hu",
          "@value": "A specifikus DPP adatok megengedett láthatósági és hozzáférési szintjeinek felsorolása."
        },
        {
          "@language": "it",
          "@value": "Un'enumerazione dei livelli di visibilità e accesso consentiti per dati DPP specifici."
        },
        {
          "@language": "lt",
          "@value": "Leistinų konkrečių DPP duomenų matomumo ir prieigos lygių išvardijimas."
        },
        {
          "@language": "lv",
          "@value": "Atļauto redzamības un piekļuves līmeņu uzskaitījums konkrētiem DPP datiem."
        },
        {
          "@language": "mt",
          "@value": "Enumerazzjoni tal-livelli ta' viżibbiltà u aċċess permessi għal data speċifika tad-DPP."
        },
        {
          "@language": "nl",
          "@value": "Een opsomming van de toegestane zichtbaarheids- en toegangsniveaus voor specifieke DPP-gegevens."
        },
        {
          "@language": "pl",
          "@value": "Wyliczenie dozwolonych poziomów widoczności i dostępu dla określonych danych DPP."
        },
        {
          "@language": "pt",
          "@value": "Uma enumeração dos níveis de visibilidade e acesso permitidos para dados DPP específicos."
        },
        {
          "@language": "ro",
          "@value": "O enumerare a nivelurilor de vizibilitate și acces permise pentru datele DPP specifice."
        },
        {
          "@language": "sk",
          "@value": "Výpočet povolených úrovní viditeľnosti a prístupu pre špecifické údaje DPP."
        },
        {
          "@language": "sl",
          "@value": "Naštevanje dovoljenih ravni vidljivosti in dostopa za posebne podatke DPP."
        },
        {
          "@language": "sv",
          "@value": "En uppräkning av de tillåtna synlighets- och åtkomstnivåerna för specifika DPP-data."
        }
      ],
