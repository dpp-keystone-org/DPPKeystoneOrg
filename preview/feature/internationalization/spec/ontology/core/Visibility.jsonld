      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Data is publicly accessible without restriction."
        },
        {
          "@language": "bg",
          "@value": "Данните са публично достъпни без ограничения."
        },
        {
          "@language": "cs",
          "@value": "Data jsou veřejně přístupná bez omezení."
        },
        {
          "@language": "da",
          "@value": "Data er offentligt tilgængelige uden begrænsninger."
        },
        {
          "@language": "de",
          "@value": "Daten sind uneingeschränkt öffentlich zugänglich."
        },
        {
          "@language": "el",
          "@value": "Τα δεδομένα είναι δημόσια προσβάσιμα χωρίς περιορισμούς."
        },
        {
          "@language": "es",
          "@value": "Los datos son accesibles públicamente sin restricción."
        },
        {
          "@language": "et",
          "@value": "Andmed on avalikult ja piiranguteta kättesaadavad."
        },
        {
          "@language": "fi",
          "@value": "Tiedot ovat julkisesti saatavilla ilman rajoituksia."
        },
        {
          "@language": "fr",
          "@value": "Les données sont publiquement accessibles sans restriction."
        },
        {
          "@language": "ga",
          "@value": "Tá na sonraí inrochtana don phobal gan srian."
        },
        {
          "@language": "hr",
          "@value": "Podaci su javno dostupni bez ograničenja."
        },
        {
          "@language": "hu",
          "@value": "Az adatok korlátozás nélkül nyilvánosan hozzáférhetők."
        },
        {
          "@language": "it",
          "@value": "I dati sono accessibili pubblicamente senza restrizioni."
        },
        {
          "@language": "lt",
          "@value": "Duomenys yra viešai prieinami be apribojimų."
        },
        {
          "@language": "lv",
          "@value": "Dati ir publiski pieejami bez ierobežojumiem."
        },
        {
          "@language": "mt",
          "@value": "Id-data hija aċċessibbli pubblikament mingħajr restrizzjoni."
        },
        {
          "@language": "nl",
          "@value": "Gegevens zijn openbaar toegankelijk zonder beperking."
        },
        {
          "@language": "pl",
          "@value": "Dane są publicznie dostępne bez ograniczeń."
        },
        {
          "@language": "pt",
          "@value": "Os dados são publicamente acessíveis sem restrições."
        },
        {
          "@language": "ro",
          "@value": "Datele sunt accesibile public fără restricții."
        },
        {
          "@language": "sk",
          "@value": "Údaje sú verejne prístupné bez obmedzenia."
        },
        {
          "@language": "sl",
          "@value": "Podatki so javno dostopni brez omejitev."
        },
        {
          "@language": "sv",
          "@value": "Data är allmänt tillgänglig utan begränsning."
        }
      ]
    },
