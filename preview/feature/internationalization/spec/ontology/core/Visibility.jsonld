      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Indicates the explicit visibility class of a given property."
        },
        {
          "@language": "bg",
          "@value": "Показва изричния клас на видимост на дадено свойство."
        },
        {
          "@language": "cs",
          "@value": "Označuje explicitní třídu viditelnosti dané vlastnosti."
        },
        {
          "@language": "da",
          "@value": "Angiver den eksplicitte synlighedsklasse for en given egenskab."
        },
        {
          "@language": "de",
          "@value": "Gibt die explizite Sichtbarkeitsklasse einer bestimmten Eigenschaft an."
        },
        {
          "@language": "el",
          "@value": "Υποδεικνύει τη ρητή κλάση ορατότητας μιας δεδομένης ιδιότητας."
        },
        {
          "@language": "es",
          "@value": "Indica la clase de visibilidad explícita de una propiedad dada."
        },
        {
          "@language": "et",
          "@value": "Näitab antud omaduse selgesõnalist nähtavusklassi."
        },
        {
          "@language": "fi",
          "@value": "Ilmaisee tietyn ominaisuuden eksplisiittisen näkyvyysluokan."
        },
        {
          "@language": "fr",
          "@value": "Indique la classe de visibilité explicite d'une propriété donnée."
        },
        {
          "@language": "ga",
          "@value": "Léiríonn sé aicme infheictheachta fhollasach airíona ar leith."
        },
        {
          "@language": "hr",
          "@value": "Označava eksplicitnu klasu vidljivosti za zadano svojstvo."
        },
        {
          "@language": "hu",
          "@value": "Egy adott tulajdonság kifejezett láthatósági osztályát jelöli."
        },
        {
          "@language": "it",
          "@value": "Indica la classe di visibilità esplicita di una data proprietà."
        },
        {
          "@language": "lt",
          "@value": "Nurodo aiškią konkrečios savybės matomumo klasę."
        },
        {
          "@language": "lv",
          "@value": "Norāda konkrētas īpašības skaidru redzamības klasi."
