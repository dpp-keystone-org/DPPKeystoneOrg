      "rdfs:label": [
        {
          "@language": "en",
          "@value": "Nominal Size"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Nominal dimensional size of the steel product."
        }
      ],
      "dppk:governedBy": "EN 10168",
      "dppk:unit": "mm",
      "rdfs:domain": {
        "@id": "dppk:MaterialTestCertificate"
      },
      "rdfs:range": "xsd:double",
      "dppk:visibility": {
        "@id": "dppk:LegitimateInterest"
      },
      "rdfs:term_status": "unstable"
    },
    {
