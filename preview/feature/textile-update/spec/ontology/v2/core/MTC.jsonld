  "@id": "https://dpp-keystone.org/spec/ontology/v2/core/MTC",
  "@type": "owl:Ontology",
  "dcterms:title": "DPP Core Ontology - Material Test Certificate (MTC)",
  "dcterms:description": "Defines the base class and properties for a Material Test Certificate (e.g., EN 10204).",
  "rdfs:label": [
    {
      "@language": "en",
      "@value": "DPP Core Ontology - Material Test Certificate (MTC)"
    }
  ],
  "rdfs:comment": [
    {
      "@language": "en",
      "@value": "Defines the base class and properties for a Material Test Certificate (e.g., EN 10204)."
    }
  ],
  "owl:imports": {
    "@id": "https://dpp-keystone.org/spec/ontology/v2/core/Product.jsonld"
  },
  "@graph": [
    {
      "@id": "dppk:MaterialTestCertificate",
      "@type": "rdfs:Class",
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A certificate detailing the results of tests performed on a material, such as those defined in EN 10204."
        }
      ],
      "owl:equivalentClass": {
        "@id": "schema:Certification"
      },
      "rdfs:label": [
        {
          "@language": "en",
          "@value": "Material Test Certificate (MTC)"
        }
      ]
    },
    {
      "@id": "dppk:mtc",
      "@type": "owl:ObjectProperty",
      "rdfs:label": {
        "@language": "en",
        "@value": "The Material Test Certificate."
      },
      "dppk:governedBy": "EN 10204",
      "rdfs:range": {
        "@id": "dppk:MaterialTestCertificate"
      },
      "rdfs:comment": {
        "@language": "en",
        "@value": "A link to the Material Test Certificate associated with this product."
      }
    },
    {
      "@id": "dppk:sourceDocument",
      "@type": "owl:ObjectProperty",
      "rdfs:label": [
        {
          "@language": "en",
          "@value": "Source Document"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A reference to the original digital document or file representing this certificate."
        }
      ],
      "rdfs:range": {
        "@id": "dppk:RelatedResource"
      }
    },
    {
      "@id": "dppk:mtcNominalSize",
