        "@value": "EU Declaration of Conformity"
      },
      "rdfs:comment": {
        "@language": "en",
        "@value": "A reference to the EU Declaration of Conformity for the product."
      },
      "dppk:visibility": {
        "@id": "dppk:AuthorityOnly"
      },
      "dppk:governedBy": "ESPR DA of textiles",
      "dcterms:source": {
