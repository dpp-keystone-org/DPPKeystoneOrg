{
  "@context": [
    "https://dpp-keystone.org/spec/contexts/v2/dpp-general-product.context.jsonld",
    "https://dpp-keystone.org/spec/contexts/v2/dpp-packaging.context.jsonld",
    {
      "dppk": "https://dpp-keystone.org/spec/v2/terms#",
      "xsd": "http://www.w3.org/2001/XMLSchema#",
      "gs1": "https://ref.gs1.org/voc/",
      "schema": "https://schema.org/",
      "unece": "https://vocabulary.uncefact.org/",
      "DigitalProductPassport": "dppk:DigitalProductPassport",
      "Organization": "dppk:Organization",
      "PostalAddress": "dppk:PostalAddress",
      "Product": "dppk:Product",
      "QuantitativeValue": "dppk:QuantitativeValue",
      "RelatedResource": "dppk:RelatedResource",
      "Certification": "dppk:Certification",
      "Component": "dppk:Component",
      "Packaging": "dppk:Packaging",
      "ProductionStep": "dppk:ProductionStep",
      "ProductCharacteristic": "dppk:ProductCharacteristic",
      "certificationBodyRole": {
        "@id": "dppk:certificationBodyRole",
        "@type": "@vocab"
      },
      "EconomicOperatorRole": {
        "@id": "dppk:EconomicOperatorRole"
      },
      "ManufacturerRole": {
        "@id": "dppk:ManufacturerRole"
      },
      "ImporterRole": {
        "@id": "dppk:ImporterRole"
      },
      "NotifiedBodyRole": {
        "@id": "dppk:NotifiedBodyRole"
      },
      "Item": {
        "@id": "dppk:Item"
      },
      "Batch": {
        "@id": "dppk:Batch"
      },
      "Model": {
        "@id": "dppk:Model"
      },
      "digitalProductPassportId": {
        "@id": "dppk:digitalProductPassportId",
        "@type": "@id"
      },
      "uniqueProductIdentifier": {
        "@id": "dppk:uniqueProductIdentifier",
        "@type": "@id"
      },
      "economicOperatorId": {
        "@id": "dppk:economicOperatorId",
        "@type": "@id"
      },
      "facilityId": {
        "@id": "dppk:facilityId",
        "@type": "@id"
      },
      "granularity": {
        "@id": "dppk:granularity",
        "@type": "@vocab"
      },
      "dppStatus": "dppk:dppStatus",
      "lastUpdate": {
        "@id": "dppk:lastUpdate",
        "@type": "xsd:dateTime"
      },
      "dppSchemaVersion": "dppk:dppSchemaVersion",
      "versionNumber": "dppk:versionNumber",
      "versionDate": {
        "@id": "dppk:versionDate",
        "@type": "xsd:date"
      },
      "contentSpecificationIds": {
        "@id": "dppk:contentSpecificationIds",
        "@container": "@set"
      },
      "hsCode": "dppk:hsCode",
      "economicOperator": {
        "@id": "dppk:economicOperator"
      },
      "manufacturer": {
        "@id": "dppk:manufacturer"
      },
      "importer": {
        "@id": "dppk:importer"
      },
      "repairService": {
        "@id": "dppk:repairService"
      },
      "manufacturingFacilityId": {
        "@id": "dppk:manufacturingFacility",
        "@type": "@id"
      },
      "organizationName": "dppk:organizationName",
      "tradingName": "dppk:tradingName",
      "gln": "dppk:gln",
      "leiCode": "dppk:leiCode",
      "eori": "dppk:eori",
      "additionalOrganizationId": "dppk:additionalOrganizationId",
      "additionalOrganizationIdType": "dppk:additionalOrganizationIdType",
      "address": "dppk:address",
      "streetAddress": "dppk:streetAddress",
      "postalCode": "dppk:postalCode",
      "addressLocality": "dppk:addressLocality",
      "addressCountry": "dppk:addressCountry",
      "email": "dppk:email",
      "telephone": "dppk:telephone",
      "operatorEmail": "dppk:operatorEmail",
      "operatorTelephone": "dppk:operatorTelephone",
      "website": {
        "@id": "dppk:website",
        "@type": "@id"
      },
      "components": {
        "@id": "dppk:components",
        "@container": "@set",
        "@context": {
          "name": "dppk:componentName",
          "percentage": "dppk:componentPercentage",
          "uniqueProductIdentifier": "dppk:componentIdentifier",
          "casNumber": "dppk:componentCasNumber",
          "ecNumber": "dppk:componentEcNumber",
          "iupacName": "dppk:componentIupacName",
          "locationInProduct": "dppk:componentLocationInProduct"
        }
      },
      "recycledContentPercentage": {
        "@id": "dppk:recycledContentPercentage",
        "@type": "xsd:double"
      },
      "productCharacteristics": {
        "@id": "dppk:productCharacteristics",
        "@container": "@set"
      },
      "characteristicName": "dppk:characteristicName",
      "characteristicValue": "dppk:characteristicValue",
      "testMethod": "dppk:testMethod",
      "KgWeightLiteral": "dppk:KgWeightLiteral",
      "MetersLengthLiteral": "dppk:MetersLengthLiteral",
      "value": {
        "@id": "dppk:value",
        "@type": "xsd:double"
      },
      "unitCode": "dppk:unitCode",
      "unitText": "dppk:unitText",
      "documents": {
        "@id": "dppk:documents",
        "@container": "@set"
      },
      "substancesOfConcern": {
        "@id": "dppk:substancesOfConcern",
        "@container": "@set"
      },
      "instructionsForUse": {
        "@id": "dppk:instructionsForUse",
        "@type": "@id"
      },
      "safetyDataSheet": {
        "@id": "dppk:safetyDataSheet",
        "@type": "@id"
      },
      "resourceTitle": "dppk:resourceTitle",
      "contentType": "dppk:contentType",
      "language": "dppk:language",
      "apparelSize": {
        "@id": "dppk:apparelSize",
        "@type": "xsd:string"
      },
      "apparelSizeSystem": {
        "@id": "dppk:apparelSizeSystem",
        "@type": "xsd:string"
      },
      "name": {
        "@id": "dppk:name",
        "@container": "@language"
      },
      "identifier": "dppk:identifier",
      "url": {
        "@id": "dppk:url",
        "@type": "xsd:anyURI"
      }
    }
  ]
}
