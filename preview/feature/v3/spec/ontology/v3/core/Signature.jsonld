        {
          "@language": "mt",
          "@value": "Post fejn saret il-firma."
        },
        {
          "@language": "nl",
          "@value": "Plaats waar de ondertekening plaatsvond."
        },
        {
          "@language": "pl",
          "@value": "Miejsce, w którym złożono podpis."
