  "dcterms:description": [
    {
      "@language": "en",
      "@value": "Defines the classes and properties required for representing legal and cryptographic signatures."
    },
    {
      "@language": "bg",
      "@value": "Дефинира класовете и свойствата, необходими за представяне на правни и криптографски подписи."
    },
    {
      "@language": "cs",
      "@value": "Definuje třídy a vlastnosti požadované pro reprezentaci právních a kryptografických podpisů."
    },
    {
      "@language": "da",
      "@value": "Definerer de klasser og egenskaber, der kræves for at repræsentere juridiske og kryptografiske signaturer."
    },
    {
      "@language": "de",
      "@value": "Definiert die Klassen und Eigenschaften, die zur Darstellung von rechtlichen und kryptografischen Signaturen erforderlich sind."
    },
    {
      "@language": "el",
      "@value": "Ορίζει τις κλάσεις και τις ιδιότητες που απαιτούνται για την αναπαράσταση νομικών και κρυπτογραφικών υπογραφών."
    },
    {
      "@language": "es",
      "@value": "Define las clases y propiedades necesarias para representar firmas legales y criptográficas."
    },
    {
      "@language": "et",
      "@value": "Määratleb klassid ja omadused, mis on vajalikud õiguslike ja krüptograafiliste allkirjade esitamiseks."
    },
    {
      "@language": "fi",
      "@value": "Määrittää luokat ja ominaisuudet, joita tarvitaan laillisten ja kryptografisten allekirjoitusten esittämiseen."
    },
    {
      "@language": "fr",
      "@value": "Définit les classes et les propriétés requises pour représenter les signatures légales et cryptographiques."
    },
    {
      "@language": "ga",
      "@value": "Sainmhíníonn sé na haicmí agus na hairíonna is gá chun sínithe dlíthiúla agus cripteagrafacha a léiriú."
    },
    {
      "@language": "hr",
      "@value": "Definira klase i svojstva potrebna za predstavljanje pravnih i kriptografskih potpisa."
    },
    {
      "@language": "hu",
      "@value": "Meghatározza a jogi és kriptográfiai aláírások ábrázolásához szükséges osztályokat és tulajdonságokat."
    },
    {
      "@language": "it",
      "@value": "Definisce le classi e le proprietà necessarie per rappresentare le firme legali e crittografiche."
    },
    {
      "@language": "lt",
      "@value": "Apibrėžia klases ir savybes, reikalingas teisiniams ir kriptografiniams parašams atvaizduoti."
    },
    {
      "@language": "lv",
      "@value": "Nosaka klases un rekvizītus, kas nepieciešami juridisko un kriptogrāfisko parakstu attēlošanai."
    },
    {
      "@language": "mt",
      "@value": "Jiddefinixxi l-klassijiet u l-proprjetajiet meħtieġa għar-rappreżentazzjoni tal-firem legali u kriptografiċi."
    },
    {
      "@language": "nl",
      "@value": "Definieert de klassen en eigenschappen die vereist zijn voor het weergeven van wettelijke en cryptografische handtekeningen."
    },
    {
      "@language": "pl",
      "@value": "Definiuje klasy i właściwości wymagane do reprezentowania podpisów prawnych i kryptograficznych."
    },
    {
      "@language": "pt",
      "@value": "Define as classes e propriedades necessárias para representar assinaturas legais e criptográficas."
    },
    {
      "@language": "ro",
      "@value": "Definește clasele și proprietățile necesare pentru reprezentarea semnăturilor legale și criptografice."
    },
    {
      "@language": "sk",
      "@value": "Definuje triedy a vlastnosti potrebné na reprezentáciu právnych a kryptografických podpisov."
    },
    {
      "@language": "sl",
      "@value": "Določa razrede in lastnosti, potrebne za predstavitev pravnih in kriptografskih podpisov."
    },
    {
      "@language": "sv",
      "@value": "Definierar de klasser och egenskaper som krävs för att representera juridiska och kryptografiska signaturer."
    }
  ],
  "owl:versionInfo": "v3",
