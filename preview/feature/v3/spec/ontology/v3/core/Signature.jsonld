      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Place in which the signature took place."
        },
        {
          "@language": "bg",
          "@value": "Място, на което е положен подписът."
        },
        {
          "@language": "cs",
          "@value": "Místo, kde k podpisu došlo."
        },
        {
          "@language": "da",
          "@value": "Stedet, hvor signaturen fandt sted."
        },
        {
          "@language": "de",
          "@value": "Ort, an dem die Unterzeichnung stattfand."
        },
        {
          "@language": "el",
          "@value": "Τόπος στον οποίο πραγματοποιήθηκε η υπογραφή."
        },
        {
          "@language": "es",
          "@value": "Lugar en el que tuvo lugar la firma."
        },
        {
          "@language": "et",
          "@value": "Koht, kus allkirjastamine toimus."
        },
        {
          "@language": "fi",
          "@value": "Paikka, jossa allekirjoitus tapahtui."
        },
        {
          "@language": "fr",
          "@value": "Lieu où la signature a eu lieu."
        },
