      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of energy equal to one million joules."
        },
        {
          "@language": "bg",
          "@value": "Единица за енергия, равна на един милион джаула."
        },
        {
          "@language": "cs",
          "@value": "Jednotka energie rovnající se jednomu milionu joulů."
        },
        {
          "@language": "da",
          "@value": "En energienhed svarende til en million joule."
        },
        {
          "@language": "de",
          "@value": "Eine Energieeinheit, die einer Million Joule entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα ενέργειας ίση με ένα εκατομμύριο τζάουλ."
        },
        {
          "@language": "es",
          "@value": "Una unidad de energía igual a un millón de julios."
        },
        {
          "@language": "et",
          "@value": "Energiaühik, mis võrdub ühe miljoni džauliga."
        },
        {
          "@language": "fi",
          "@value": "Energian yksikkö, joka vastaa miljoonaa joulea."
        },
        {
          "@language": "fr",
          "@value": "Une unité d'énergie égale à un million de joules."
        },
        {
          "@language": "ga",
          "@value": "Aonad fuinnimh atá cothrom le milliún giúl."
        },
        {
          "@language": "hr",
          "@value": "Jedinica energije jednaka milijun džula."
        },
        {
          "@language": "hu",
          "@value": "Energia mértékegysége, amely egymillió joule-nak felel meg."
        },
        {
          "@language": "it",
          "@value": "Un'unità di energia pari a un milione di joule."
        },
        {
          "@language": "lt",
          "@value": "Energijos vienetas, lygus vienam milijonui džaulių."
        },
        {
          "@language": "lv",
          "@value": "Enerģijas vienība, kas vienāda ar vienu miljonu džoulu."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' enerġija ugwali għal miljun joules."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid van energie gelijk aan één miljoen joule."
        },
        {
          "@language": "pl",
          "@value": "Jednostka energii równa jednemu milionowi dżuli."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de energia equivalente a um milhão de joules."
        },
        {
          "@language": "ro",
          "@value": "O unitate de energie egală cu un milion de jouli."
        },
        {
          "@language": "sk",
          "@value": "Jednotka energie rovnajúca sa jednému miliónu joulov."
        },
        {
          "@language": "sl",
          "@value": "Enota za energijo, ki je enaka enemu milijonu džulov."
        },
        {
          "@language": "sv",
          "@value": "En energienhet som motsvarar en miljon joule."
        }
      ]
    },
