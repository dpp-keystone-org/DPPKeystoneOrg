          "@language": "sl",
          "@value": "A/Ah"
        },
        {
          "@language": "sv",
          "@value": "A/Ah"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit measuring the ratio of current in amperes to electric charge in ampere-hours."
        },
        {
          "@language": "bg",
          "@value": "Единица за измерване на съотношението на тока в ампери към електрическия заряд в амперчасове."
        },
        {
          "@language": "cs",
          "@value": "Jednotka měřící poměr proudu v ampérech k elektrickému náboji v ampérhodinách."
        },
        {
          "@language": "da",
          "@value": "En enhed til måling af forholdet mellem strøm i ampere og elektrisk ladning i amperetimer."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des Verhältnisses von Stromstärke in Ampere zu elektrischer Ladung in Amperestunden."
        },
        {
          "@language": "el",
          "@value": "Μονάδα μέτρησης της αναλογίας του ρεύματος σε αμπέρ προς το ηλεκτρικό φορτίο σε αμπερώρια."
        },
        {
          "@language": "es",
          "@value": "Unidad que mide la relación entre la corriente en amperios y la carga eléctrica en amperios-hora."
        },
        {
          "@language": "et",
          "@value": "Ühik, mis mõõdab voolutugevuse (amprites) ja elektrilaengu (ampertundides) suhet."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, joka mittaa ampeerien ja ampeerituntien sähkövarauksen suhdetta."
        },
        {
          "@language": "fr",
          "@value": "Unité mesurant le rapport entre le courant en ampères et la charge électrique en ampères-heures."
        },
        {
          "@language": "ga",
          "@value": "Aonad a thomhaiseann an cóimheas idir an sruth in aimpéir agus an lucht leictreach in aimpéaruaireanta."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja mjeri omjer struje u amperima i električnog naboja u ampersatima."
        },
        {
          "@language": "hu",
          "@value": "Az áramerősség (amper) és az elektromos töltés (amperóra) arányát mérő mértékegység."
        },
        {
          "@language": "it",
          "@value": "Unità di misura del rapporto tra la corrente in ampere e la carica elettrica in amperora."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, matuojantis srovės amperais ir elektros krūvio ampervalandėmis santykį."
        },
        {
          "@language": "lv",
          "@value": "Vienība, kas mēra strāvas ampēros un elektriskā lādiņa ampērstundās attiecību."
        },
        {
          "@language": "mt",
          "@value": "Unità li tkejjel il-proporzjon tal-kurrent f'amperes għal ċarġ elettriku f'ampere-sigħat."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die de verhouding meet van stroom in ampères tot elektrische lading in ampère-uren."
        },
        {
          "@language": "pl",
          "@value": "Jednostka mierząca stosunek natężenia prądu w amperach do ładunku elektrycznego w amperogodzinach."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade que mede a relação entre a corrente em amperes e a carga elétrica em amperes-hora."
        },
        {
          "@language": "ro",
          "@value": "O unitate care măsoară raportul dintre curentul în amperi și sarcina electrică în amperi-oră."
        },
        {
          "@language": "sk",
          "@value": "Jednotka merajúca pomer prúdu v ampéroch k elektrickému náboju v ampérhodinách."
        },
        {
          "@language": "sl",
          "@value": "Enota, ki meri razmerje med tokom v amperih in električnim nabojem v amperskih urah."
        },
        {
          "@language": "sv",
          "@value": "En enhet som mäter förhållandet mellan ström i ampere och elektrisk laddning i amperetimmar."
        }
      ]
    },
