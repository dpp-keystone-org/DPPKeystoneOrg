      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of volume equal to the volume of a cube with edges one meter in length."
        },
        {
          "@language": "bg",
          "@value": "Единица за обем, равна на обема на куб с ръбове с дължина един метър."
        },
        {
          "@language": "cs",
          "@value": "Jednotka objemu rovná objemu krychle o hraně délky jednoho metru."
        },
        {
          "@language": "da",
          "@value": "En volumenenhed svarende til rumfanget af en terning med kanter på en meter."
        },
        {
          "@language": "de",
          "@value": "Eine Volumeneinheit, die dem Volumen eines Würfels mit einer Kantenlänge von einem Meter entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα όγκου ίση με τον όγκο ενός κύβου με ακμές μήκους ενός μέτρου."
        },
        {
          "@language": "es",
          "@value": "Unidad de volumen equivalente al volumen de un cubo con aristas de un metro de longitud."
        },
        {
          "@language": "et",
          "@value": "Ruumalaühik, mis võrdub kuubi ruumalaga, mille serva pikkus on üks meeter."
        },
        {
          "@language": "fi",
          "@value": "Tilavuusyksikkö, joka vastaa sellaisen kuution tilavuutta, jonka sivun pituus on yksi metri."
        },
        {
          "@language": "fr",
          "@value": "Unité de volume équivalente au volume d'un cube dont les arêtes mesurent un mètre de longueur."
        },
        {
          "@language": "ga",
          "@value": "Aonad toirte is comhionann le toirt ciúb a bhfuil imill mhéadar amháin ar fad aige."
        },
        {
          "@language": "hr",
          "@value": "Jedinica za volumen jednaka volumenu kocke s rubovima duljine jedan metar."
        },
        {
          "@language": "hu",
          "@value": "Térfogat-mértékegység, amely egyenlő egy egy méter élhosszúságú kocka térfogatával."
        },
        {
          "@language": "it",
          "@value": "Unità di volume pari al volume di un cubo con spigoli lunghi un metro."
        },
        {
          "@language": "lt",
          "@value": "Tūrio vienetas, lygus kubo, kurio kraštinės ilgis yra vienas metras, tūriui."
        },
        {
          "@language": "lv",
          "@value": "Tilpuma vienība, kas vienāda ar kuba tilpumu, kura malas garums ir viens metrs."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' volum ugwali għall-volum ta' kubu bi truf ta' metru twal."
        },
        {
          "@language": "nl",
          "@value": "Een volume-eenheid die gelijk is aan het volume van een kubus met ribben van een meter lengte."
        },
        {
          "@language": "pl",
          "@value": "Jednostka objętości równa objętości sześcianu o krawędzi długości jednego metra."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de volume igual ao volume de um cubo com arestas de um metro de comprimento."
        },
        {
          "@language": "ro",
          "@value": "O unitate de volum egală cu volumul unui cub cu muchiile de un metru lungime."
        },
        {
          "@language": "sk",
          "@value": "Jednotka objemu rovnajúca sa objemu kocky s dĺžkou hrany jeden meter."
        },
        {
          "@language": "sl",
          "@value": "Enota za prostornino, enaka prostornini kocke z robovi dolžine en meter."
        },
        {
          "@language": "sv",
          "@value": "En volymenhet som motsvarar volymen av en kub med kantlängden en meter."
        }
      ]
    },
