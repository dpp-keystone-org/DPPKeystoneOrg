        {
          "@language": "en",
          "@value": "A unit used to measure eutrophication potential, expressed in terms of the equivalent amount of phosphorus."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на потенциала за еутрофикация, изразена чрез еквивалентното количество фосфор."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření potenciálu eutrofizace, vyjádřená ekvivalentním množstvím fosforu."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle eutrofieringspotentiale, udtrykt i form af den tilsvarende mængde fosfor."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des Eutrophierungspotenzials, ausgedrückt als die äquivalente Menge an Phosphor."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα που χρησιμοποιείται για τη μέτρηση του δυναμικού ευτροφισμού, εκφρασμένη ως προς την ισοδύναμη ποσότητα φωσφόρου."
        },
        {
          "@language": "es",
          "@value": "Una unidad utilizada para medir el potencial de eutrofización, expresada en términos de la cantidad equivalente de fósforo."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse eutrofeerumise potentsiaali mõõtmiseks, väljendatuna fosfori ekvivalentses koguses."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään rehevöitymispotentiaalin mittaamiseen ilmaistuna fosforin vastaavana määränä."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer le potentiel d'eutrophisation, exprimée en fonction de la quantité équivalente de phosphore."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun acmhainn eotrófaithe a thomhas, arna shloinneadh i dtéarmaí na méide coibhéisí de fhosfar."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje potencijala eutrofikacije, izražena u ekvivalentnoj količini fosfora."
        },
        {
          "@language": "hu",
          "@value": "Az eutrofizációs potenciál mérésére szolgáló mértékegység, foszfor egyenértékben kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare il potenziale di eutrofizzazione, espressa in termini di quantità equivalente di fosforo."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas eutrofikacijos potencialui matuoti, išreikštas ekvivalentiniu fosforo kiekiu."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto eitrofikācijas potenciāla mērīšanai, izteikta kā fosfora ekvivalentais daudzums."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel il-potenzjal ta' ewtrofikazzjoni, espressa f'termini tal-ammont ekwivalenti ta' fosfru."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om het eutrofiëringsvermogen te meten, uitgedrukt in de equivalente hoeveelheid fosfor."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru potencjału eutrofizacji, wyrażona jako równoważna ilość fosforu."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o potencial de eutrofização, expressa em termos da quantidade equivalente de fósforo."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura potențialul de eutrofizare, exprimată sub forma cantității echivalente de fosfor."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie potenciálu eutrofizácie vyjadrená v ekvivalentnom množstve fosforu."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje potenciala evtrofikacije, izražena kot ekvivalentna količina fosforja."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta övergödningspotential, uttryckt i form av motsvarande mängd fosfor."
        }
      ]
