      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit measuring global warming potential intensity, expressed in terms of the equivalent mass of carbon dioxide per kilogram of material."
        },
        {
          "@language": "bg",
          "@value": "Единица за измерване на интензитета на потенциала за глобално затопляне, изразена чрез еквивалентната маса въглероден диоксид на килограм материал."
        },
        {
          "@language": "cs",
          "@value": "Jednotka měřící intenzitu potenciálu globálního oteplování, vyjádřená v ekvivalentní hmotnosti oxidu uhličitého na kilogram materiálu."
        },
        {
          "@language": "da",
          "@value": "En enhed til måling af intensiteten af det globale opvarmningspotentiale, udtrykt i den tilsvarende masse af kuldioxid pr. kilogram materiale."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung der Intensität des Treibhauspotenzials, ausgedrückt als die äquivalente Masse an Kohlendioxid pro Kilogramm Material."
        },
        {
          "@language": "el",
          "@value": "Μονάδα μέτρησης της έντασης του δυναμικού υπερθέρμανσης του πλανήτη, εκφρασμένη ως προς την ισοδύναμη μάζα διοξειδίου του άνθρακα ανά χιλιόγραμμο υλικού."
        },
        {
          "@language": "es",
          "@value": "Una unidad que mide la intensidad del potencial de calentamiento global, expresada en términos de la masa equivalente de dióxido de carbono por kilogramo de material."
        },
        {
          "@language": "et",
          "@value": "Ühik, mis mõõdab globaalse soojenemise potentsiaali intensiivsust, väljendatuna süsinikdioksiidi ekvivalentses massis materjali kilogrammi kohta."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, joka mittaa ilmaston lämpenemispotentiaalin voimakkuutta ilmaistuna hiilidioksidin vastaavana massana materiaalin kilogrammaa kohti."
        },
        {
          "@language": "fr",
          "@value": "Une unité mesurant l'intensité du potentiel de réchauffement de la planète, exprimée en fonction de la masse équivalente de dioxyde de carbone par kilogramme de matériau."
        },
        {
          "@language": "ga",
          "@value": "Aonad a thomhaiseann déine acmhainneacht téimh dhomhanda, arna shloinneadh i dtéarmaí na maise coibhéisí de dhé-ocsaíd charbóin in aghaidh an chileagraim d'ábhar."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja mjeri intenzitet potencijala globalnog zagrijavanja, izražena u ekvivalentnoj masi ugljikovog dioksida po kilogramu materijala."
        },
        {
          "@language": "hu",
          "@value": "A globális felmelegedési potenciál intenzitását mérő mértékegység, egyenértékű szén-dioxid-tömegben kifejezve anyag kilogrammonként."
        },
        {
          "@language": "it",
          "@value": "Un'unità che misura l'intensità del potenziale di riscaldamento globale, espressa in termini di massa equivalente di anidride carbonica per chilogrammo di materiale."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, matuojantis visuotinio atšilimo potencialo intensyvumą, išreikštas anglies dioksido ekvivalentu kilogramui medžiagos."
        },
        {
          "@language": "lv",
          "@value": "Vienība globālās sasilšanas potenciāla intensitātes mērīšanai, izteikta kā oglekļa dioksīda ekvivalentā masa uz kilogramu materiāla."
        },
        {
          "@language": "mt",
          "@value": "Unità li tkejjel l-intensità tal-potenzjal ta' tisħin globali, espressa f'termini tal-massa ekwivalenti ta' diossidu tal-karbonju għal kull kilogramm ta' materjal."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die de intensiteit van het aardopwarmingsvermogen meet, uitgedrukt in de equivalente massa kooldioxide per kilogram materiaal."
        },
        {
          "@language": "pl",
          "@value": "Jednostka miary intensywności współczynnika ocieplenia globalnego, wyrażona jako równoważna masa dwutlenku węgla na kilogram materiału."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade que mede a intensidade do potencial de aquecimento global, expressa em termos da massa equivalente de dióxido de carbono por quilograma de material."
        },
        {
          "@language": "ro",
          "@value": "O unitate care măsoară intensitatea potențialului de încălzire globală, exprimată sub forma masei echivalente de dioxid de carbon per kilogram de material."
        },
        {
          "@language": "sk",
          "@value": "Jednotka na meranie intenzity potenciálu globálneho otepľovania vyjadrená v ekvivalentnej hmotnosti oxidu uhličitého na kilogram materiálu."
        },
        {
          "@language": "sl",
          "@value": "Enota, ki meri intenzivnost potenciala globalnega segrevanja, izražena kot ekvivalentna masa ogljikovega dioksida na kilogram materiala."
        },
        {
          "@language": "sv",
          "@value": "En enhet som mäter intensiteten av den globala uppvärmningspotentialen, uttryckt i motsvarande massa koldioxid per kilogram material."
        }
      ]
    },
