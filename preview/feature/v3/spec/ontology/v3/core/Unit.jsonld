        },
        {
          "@language": "fr",
          "@value": "Pourcentage par mois"
        },
        {
          "@language": "ga",
          "@value": "Faoin gcéad in aghaidh na míosa"
        },
        {
          "@language": "hr",
          "@value": "Postotak mjesečno"
        },
        {
          "@language": "hu",
          "@value": "Százalék havonta"
        },
        {
          "@language": "it",
          "@value": "Percentuale al mese"
        },
        {
          "@language": "lt",
          "@value": "Procentas per mėnesį"
        },
        {
          "@language": "lv",
          "@value": "Procenti mēnesī"
        },
        {
          "@language": "mt",
          "@value": "Perċentwal fix-xahar"
        },
        {
          "@language": "nl",
          "@value": "Procent per maand"
        },
        {
          "@language": "pl",
          "@value": "Procent miesięcznie"
        },
        {
          "@language": "pt",
          "@value": "Percentagem por mês"
        },
        {
          "@language": "ro",
          "@value": "Procent pe lună"
        },
        {
          "@language": "sk",
          "@value": "Percento za mesiac"
        },
        {
          "@language": "sl",
          "@value": "Odstotek na mesec"
        },
        {
          "@language": "sv",
          "@value": "Procent per månad"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A rate expressed as a percentage over a period of one month."
        },
        {
          "@language": "bg",
          "@value": "Ставка, изразена като процент за период от един месец."
        },
        {
          "@language": "cs",
          "@value": "Sazba vyjádřená v procentech za období jednoho měsíce."
        },
        {
          "@language": "da",
          "@value": "En sats udtrykt i procent over en periode på en måned."
        },
        {
          "@language": "de",
          "@value": "Eine als Prozentsatz ausgedrückte Rate über einen Zeitraum von einem Monat."
        },
        {
          "@language": "el",
          "@value": "Ποσοστό που εκφράζεται ως ποσοστό σε περίοδο ενός μηνός."
        },
        {
          "@language": "es",
          "@value": "Una tasa expresada como porcentaje durante un período de un mes."
        },
        {
          "@language": "et",
          "@value": "Määr, mis on väljendatud protsendina ühe kuu pikkuse perioodi jooksul."
        },
        {
          "@language": "fi",
          "@value": "Prosentteina ilmaistu korko yhden kuukauden ajalta."
        },
        {
          "@language": "fr",
          "@value": "Un taux exprimé en pourcentage sur une période d'un mois."
        },
        {
          "@language": "ga",
          "@value": "Ráta a shloinntear mar chéatadán thar thréimhse míosa."
        },
        {
          "@language": "hr",
          "@value": "Stopa izražena u postocima tijekom razdoblja od mjesec dana."
        },
        {
          "@language": "hu",
          "@value": "Egy hónapos időszakra vonatkozó százalékos arány."
        },
        {
          "@language": "it",
          "@value": "Un tasso espresso in percentuale su un periodo di un mese."
        },
        {
          "@language": "lt",
          "@value": "Norma, išreikšta procentais per vieno mėnesio laikotarpį."
        },
        {
          "@language": "lv",
          "@value": "Likme, kas izteikta procentos par viena mēneša periodu."
        },
        {
          "@language": "mt",
          "@value": "Rata espressa f'perċentwali fuq perjodu ta' xahar."
        },
        {
          "@language": "nl",
          "@value": "Een tarief uitgedrukt in een percentage over een periode van een maand."
        },
        {
          "@language": "pl",
          "@value": "Stawka wyrażona w procentach w okresie jednego miesiąca."
        },
        {
          "@language": "pt",
          "@value": "Uma taxa expressa em percentagem durante um período de um mês."
        },
        {
          "@language": "ro",
          "@value": "O rată exprimată ca procent pe o perioadă de o lună."
        },
        {
          "@language": "sk",
          "@value": "Sadzba vyjadrená v percentách za obdobie jedného mesiaca."
        },
        {
          "@language": "sl",
          "@value": "Stopnja, izražena v odstotkih v obdobju enega meseca."
        },
        {
          "@language": "sv",
          "@value": "En ränta uttryckt i procent under en period av en månad."
        }
      ]
    },
    {
      "@id": "dppk-unit:AmperePerAmpereHour",
      "@type": "dppk:Unit",
