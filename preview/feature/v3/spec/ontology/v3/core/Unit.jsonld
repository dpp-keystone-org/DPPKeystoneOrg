      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of length equal to one thousandth of a meter."
        },
        {
          "@language": "bg",
          "@value": "Единица за дължина, равна на една хилядна от метъра."
        },
        {
          "@language": "cs",
          "@value": "Jednotka délky rovná jedné tisícině metru."
        },
        {
          "@language": "da",
          "@value": "En længdeenhed svarende til en tusindedel af en meter."
        },
        {
          "@language": "de",
          "@value": "Eine Längeneinheit, die einem Tausendstel eines Meters entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα μήκους ίση με ένα χιλιοστό του μέτρου."
        },
        {
          "@language": "es",
          "@value": "Unidad de longitud equivalente a una milésima de metro."
        },
        {
          "@language": "et",
          "@value": "Pikkusühik, mis võrdub ühe tuhandikuga meetrist."
        },
        {
          "@language": "fi",
          "@value": "Pituusyksikkö, joka vastaa metrin tuhannesosaa."
