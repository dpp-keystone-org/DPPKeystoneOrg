      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit used to measure photochemical ozone creation potential, expressed in terms of the equivalent amount of non-methane volatile organic compounds."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на потенциала за създаване на фотохимичен озон, изразена чрез еквивалентното количество неметанови летливи органични съединения."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření potenciálu tvorby fotochemického ozonu, vyjádřená ekvivalentním množstvím nemethanových těkavých organických sloučenin."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle det fotokemiske ozonskabelsespotentiale, udtrykt i form af den tilsvarende mængde ikke-methan flygtige organiske forbindelser."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des fotochemischen Ozonbildungspotenzials, ausgedrückt als die äquivalente Menge an flüchtigen organischen Verbindungen ohne Methan."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα που χρησιμοποιείται για τη μέτρηση του δυναμικού δημιουργίας φωτοχημικού όζοντος, εκφρασμένη ως προς την ισοδύναμη ποσότητα πτητικών οργανικών ενώσεων εκτός του μεθανίου."
        },
        {
          "@language": "es",
          "@value": "Una unidad utilizada para medir el potencial de creación de ozono fotochimico, expresada en términos de la cantidad equivalente de compuestos orgánicos volátiles no metánicos."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse fotokeemilise osooniloome potentsiaali mõõtmiseks, väljendatuna mittemetaansete lenduvate orgaaniliste ühendite ekvivalentses koguses."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään valokemiallisen otsoninmuodostuspotentiaalin mittaamiseen ilmaistuna muiden haihtuvien orgaanisten yhdisteiden kuin metaanin vastaavana määränä."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer le potentiel de création d'ozone photochimique, exprimée en fonction de la quantité équivalente de composés organiques volatils non méthaniques."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun acmhainn cruthaithe ózóin fhótacheimicigh a thomhas, arna shloinneadh i dtéarmaí na méide coibhéisí de chomhdhúile orgánacha so-ghalaithe seachas meatán."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje potencijala stvaranja fotokemijskog ozona, izražena u ekvivalentnoj količini nemetanskih hlapljivih organskih spojeva."
        },
        {
          "@language": "hu",
          "@value": "A fotokémiai ózonképződési potenciál mérésére szolgáló mértékegység, a nem metán illékony szerves vegyületek egyenértékében kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare il potenziale di creazione di ozono fotochimico, espressa in termini di quantità equivalente di composti organici volatili non metanici."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas fotocheminio ozono susidarymo potencialui matuoti, išreikštas ekvivalentiniu nemetaninių lakiųjų organinių junginių kiekiu."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto fotoķīmiskā ozona veidošanās potenciāla mērīšanai, izteikta kā nemetāna gaistošo organisko savienojumu ekvivalentais daudzums."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel il-potenzjal tal-ħolqien tal-ożonu fotokimiku, espressa f'termini tal-ammont ekwivalenti ta' komposti organiċi volatili mhux tal-metan."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om het fotochemische ozonvormend vermogen te meten, uitgedrukt in de equivalente hoeveelheid niet-methaan vluchtige organische stoffen."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru potencjału tworzenia ozonu fotochemicznego, wyrażona jako równoważna ilość niemetanowych lotnych związków organicznych."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o potencial de criação de ozono fotoquímico, expressa em termos da quantidade equivalente de compostos orgânicos voláteis não metânicos."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura potențialul de creare a ozonului fotochimic, exprimată sub forma cantității echivalente de compuși organici volatili nemetanici."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie potenciálu tvorby fotochemického ozónu vyjadrená v ekvivalentnom množstve nemetánových prchavých organických zlúčenín."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje potenciala nastajanja fotokemičnega ozona, izražena kot ekvivalentna količina nemetanskih hlapnih organskih spojin."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta potentialen för fotokemisk ozonbildning, uttryckt i form av motsvarande mängd flyktiga organiska föreningar (exklusive metan)."
        }
      ]
    },
