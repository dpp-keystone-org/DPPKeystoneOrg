      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit used to measure abiotic depletion potential for non-fossil resources, expressed in terms of the equivalent amount of antimony."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на потенциала за абиотично изчерпване на нефосилни ресурси, изразена чрез еквивалентното количество антимон."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření potenciálu abiotického úbytku nefosilních zdrojů, vyjádřená ekvivalentním množstvím antimonu."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle abiotisk udtømningspotentiale for ikke-fossile ressourcer, udtrykt i form af den tilsvarende mængde antimon."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des abiotischen Ressourcenabbaupotenzials für nicht-fossile Ressourcen, ausgedrückt als die äquivalente Menge an Antimon."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα που χρησιμοποιείται για τη μέτρηση του δυναμικού αβιοτικής εξάντλησης για μη ορυκτούς πόρους, εκφρασμένη ως προς την ισοδύναμη ποσότητα αντιμονίου."
        },
        {
          "@language": "es",
          "@value": "Una unidad utilizada para medir el potencial de agotamiento abiótico de recursos no fósiles, expresada en términos de la cantidad equivalente de antimonio."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse abiootilise kahanemise potentsiaali mõõtmiseks mittefossiilsete ressursside puhul, väljendatuna antimoni ekvivalentses koguses."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään ei-fossiilisten luonnonvarojen abioottisen ehtymispotentiaalin mittaamiseen ilmaistuna antimonin vastaavana määränä."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer le potentiel d'épuisement abiotique pour les ressources non fossiles, exprimée en fonction de la quantité équivalente d'antimoine."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun acmhainn ídithe aibéitigh d'acmhainní neamhiontaiseacha a thomhas, arna shloinneadh i dtéarmaí na méide coibhéisí d'antamón."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje potencijala abiotičkog iscrpljivanja za nefosilne resurse, izražena u ekvivalentnoj količini antimona."
        },
        {
          "@language": "hu",
          "@value": "A nem fosszilis erőforrások abiotikus kimerülési potenciáljának mérésére szolgáló mértékegység, antimon egyenértékben kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare il potenziale di esaurimento abiotico per le risorse non fossili, espressa in termini di quantità equivalente di antimonio."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas ne iškastinių išteklių abiotinio senėjimo potencialui matuoti, išreikštas ekvivalentiniu stibio kiekiu."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto abiotiskās noārdīšanās potenciāla mērīšanai nefosilajiem resursiem, izteikta kā antimona ekvivalentais daudzums."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel il-potenzjal tat-tnaqqis abijotiku għal riżorsi mhux fossili, espressa f'termini tal-ammont ekwivalenti ta' antimonju."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om het abiotische uitputtingsvermogen voor niet-fossiele hulpbronnen te meten, uitgedrukt in de equivalente hoeveelheid antimoon."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru potencjału wyczerpywania zasobów abiotycznych w przypadku zasobów niekopalnych, wyrażona jako równoważna ilość antymonu."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o potencial de empobrecimento abiótico para recursos não fósseis, expressa em termos da quantidade equivalente de antimónio."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura potențialul de epuizare abiotică pentru resursele nefosile, exprimată sub forma cantității echivalente de stibiu."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie potenciálu abiotického úbytku nefosílnych zdrojov vyjadrená v ekvivalentnom množstve antimónu."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje potenciala abiotičnega izčrpavanja za nefosilne vire, izražena kot ekvivalentna količina antimona."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta abiotisk utarmningspotential för icke-fossila resurser, uttryckt i form av motsvarande mängd antimon."
        }
      ]
    },
