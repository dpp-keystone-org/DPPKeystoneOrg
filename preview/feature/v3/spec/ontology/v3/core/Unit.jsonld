          "@value": "kg CO₂ eq"
        },
        {
          "@language": "pl",
          "@value": "kg CO₂ eq"
        },
        {
          "@language": "pt",
          "@value": "kg CO₂ eq"
        },
        {
          "@language": "ro",
          "@value": "kg CO₂ eq"
        },
        {
          "@language": "sk",
          "@value": "kg CO₂ eq"
        },
        {
          "@language": "sl",
          "@value": "kg CO₂ eq"
        },
        {
          "@language": "sv",
          "@value": "kg CO₂ eq"
        }
      ],
      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit used to measure the global warming potential of various greenhouse gases, expressed in terms of the equivalent amount of carbon dioxide."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на потенциала за глобално затопляне на различни парникови газове, изразена чрез еквивалентното количество въглероден диоксид."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření potenciálu globálního oteplování různých skleníkových plynů, vyjádřená ekvivalentním množstvím oxidu uhličitého."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle det globale opvarmningspotentiale for forskellige drivhusgasser, udtrykt i form af den tilsvarende mængde kuldioxid."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des Treibhauspotenzials verschiedener Treibhausgase, ausgedrückt als die äquivalente Menge an Kohlendioxid."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα που χρησιμοποιείται για τη μέτρηση του δυναμικού υπερθέρμανσης του πλανήτη διαφόρων αερίων θερμοκηπίου, εκφρασμένη ως προς την ισοδύναμη ποσότητα διοξειδίου του άνθρακα."
        },
        {
          "@language": "es",
          "@value": "Una unidad utilizada para medir el potencial de calentamiento global de varios gases de efecto invernadero, expresada en términos de la cantidad equivalente de dióxido de carbono."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse erinevate kasvuhoonegaaside globaalse soojenemise potentsiaali mõõtmiseks, väljendatuna süsinikdioksiidi ekvivalentses koguses."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään eri kasvihuonekaasujen lämmityspotentiaalin mittaamiseen ilmaistuna hiilidioksidin vastaavana määränä."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer le potentiel de réchauffement planétaire de divers gaz à effet de serre, exprimée en fonction de la quantité équivalente de dioxyde de carbone."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun acmhainn téimh dhomhanda gás ceaptha teasa éagsúla a thomhas, arna shloinneadh i dtéarmaí na méide coibhéisí de dhé-ocsaíd charbóin."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje potencijala globalnog zagrijavanja različitih stakleničkih plinova, izražena u ekvivalentnoj količini ugljikovog dioksida."
        },
        {
          "@language": "hu",
          "@value": "A különböző üvegházhatású gázok globális felmelegedési potenciáljának mérésére szolgáló mértékegység, szén-dioxid egyenértékben kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare il potenziale di riscaldamento globale di vari gas serra, espressa in termini di quantità equivalente di anidride carbonica."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas įvairių šiltnamio efektą sukeliančių dujų visuotinio atšilimo potencialui matuoti, išreikštas ekvivalentiniu anglies dioksido kiekiu."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto dažādu siltumnīcefekta gāzu globālās sasilšanas potenciāla mērīšanai, izteikta kā oglekļa dioksīda ekvivalentais daudzums."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel il-potenzjal tat-tisħin globali ta' diversi gassijiet serra, espressa f'termini tal-ammont ekwivalenti ta' dijossidu tal-karbonju."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om het aardopwarmingsvermogen van verschillende broeikasgassen te meten, uitgedrukt in de equivalente hoeveelheid koolstofdioxide."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru potencjału tworzenia efektu cieplarnianego różnych gazów cieplarnianych, wyrażona jako równoważna ilość dwutlenku węgla."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o potencial de aquecimento global de vários gases com efeito de estufa, expressa em termos da quantidade equivalente de dióxido de carbono."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura potențialul de încălzire globală a diferitelor gaze cu efect de seră, exprimată sub forma cantității echivalente de dioxid de carbon."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie potenciálu globálneho otepľovania rôznych skleníkových plynov vyjadrená v ekvivalentnom množstve oxidu uhličitého."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje potenciala globalnega segrevanja različnih toplogrednih plinov, izražena kot ekvivalentna količina ogljikovega dioksida."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta olika växthusgasers globala uppvärmningspotential, uttryckt i form av motsvarande mängd koldioxid."
        }
      ]
    },
    {
