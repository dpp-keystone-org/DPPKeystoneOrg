        {
          "@language": "mt",
          "@value": "Unità li tirrappreżenta klassifikazzjoni kategorika."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die een categorische classificatie of gradering vertegenwoordigt."
        },
        {
          "@language": "pl",
          "@value": "Jednostka reprezentująca klasyfikację kategoryczną lub ocenę."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade que representa uma classificação ou graduação categórica."
        },
        {
          "@language": "ro",
          "@value": "O unitate care reprezintă o clasificare sau o evaluare categorică."
        },
        {
          "@language": "sk",
          "@value": "Jednotka predstavujúca kategorickú klasifikáciu alebo hodnotenie."
        },
        {
          "@language": "sl",
          "@value": "Enota, ki predstavlja kategorično klasifikacijo ali razvrstitev."
