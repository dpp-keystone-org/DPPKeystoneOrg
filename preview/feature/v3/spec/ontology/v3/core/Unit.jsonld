        {
          "@language": "en",
          "@value": "A unit of specific surface area measuring square meters per gram."
        },
        {
          "@language": "bg",
          "@value": "Единица за специфична повърхност, измерваща квадратни метри на грам."
        },
        {
          "@language": "cs",
          "@value": "Jednotka měrného povrchu měřící metry čtvereční na gram."
        },
        {
          "@language": "da",
          "@value": "En enhed for specifikt overfladeareal, der måler kvadratmeter pr. gram."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit der spezifischen Oberfläche, die Quadratmeter pro Gramm misst."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα ειδικής επιφάνειας που μετρά τετραγωνικά μέτρα ανά γραμμάριο."
        },
        {
          "@language": "es",
          "@value": "Una unidad de superficie específica que mide metros cuadrados por gramo."
