      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of specific radioactivity measuring becquerels per gram of mass."
        },
        {
          "@language": "bg",
          "@value": "Единица за специфична радиоактивност, измерваща бекерели на грам маса."
        },
        {
          "@language": "cs",
          "@value": "Jednotka měrné radioaktivity udávající počet becquerelů na gram hmotnosti."
        },
        {
          "@language": "da",
          "@value": "En enhed for specifik radioaktivitet, der måler becquerel pr. gram masse."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit der spezifischen Radioaktivität, die Becquerel pro Gramm Masse misst."
        },
        {
          "@language": "el",
          "@value": "Μονάδα ειδικής ραδιενέργειας που μετρά μπεκερέλ ανά γραμμάριο μάζας."
        },
        {
          "@language": "es",
          "@value": "Unidad de radiactividad específica que mide becquerelios por gramo de masa."
        },
        {
          "@language": "et",
          "@value": "Eriradioaktiivsuse ühik, mis mõõdab bekkerelle grammi massi kohta."
        },
        {
          "@language": "fi",
          "@value": "Ominaisradioaktiivisuuden yksikkö, joka mittaa becquerelejä massagrammaa kohti."
        },
        {
          "@language": "fr",
          "@value": "Unité de radioactivité spécifique mesurant les becquerels par gramme de masse."
        },
        {
          "@language": "ga",
          "@value": "Aonad radaighníomhaíochta sainiúil a thomhaiseann beicireil in aghaidh an ghraim maise."
        },
        {
          "@language": "hr",
          "@value": "Jedinica specifične radioaktivnosti koja mjeri bekerel po gramu mase."
        },
        {
          "@language": "hu",
          "@value": "A fajlagos radioaktivitás mértékegysége, amely becquerel per gramm tömeget mér."
        },
        {
          "@language": "it",
          "@value": "Unità di radioattività specifica che misura i becquerel per grammo di massa."
        },
        {
          "@language": "lt",
          "@value": "Savitojo radioaktyvumo vienetas, matuojantis bekerelius vienam gramui masės."
        },
        {
          "@language": "lv",
          "@value": "Īpatnējās radioaktivitātes vienība, kas mēra bekerelus uz gramu masas."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' radjuattività speċifika li tkejjel becquerels kull gramma ta' massa."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid van specifieke radioactiviteit die becquerel per gram massa meet."
        },
        {
          "@language": "pl",
          "@value": "Jednostka radioaktywności właściwej mierząca bekerele na gram masy."
        },
        {
          "@language": "pt",
          "@value": "Unidade de radioatividade específica que mede becqueréis por grama de massa."
        },
        {
          "@language": "ro",
          "@value": "Unitate de radioactivitate specifică care măsoară becquereli pe gram de masă."
        },
        {
          "@language": "sk",
          "@value": "Jednotka mernej rádioaktivity udávajúca počet becquerelov na gram hmotnosti."
        },
        {
          "@language": "sl",
          "@value": "Enota specifične radioaktivnosti, ki meri bekerel na gram mase."
        },
        {
          "@language": "sv",
          "@value": "En enhet för specifik radioaktivitet som mäter becquerel per gram massa."
        }
      ]
    },
