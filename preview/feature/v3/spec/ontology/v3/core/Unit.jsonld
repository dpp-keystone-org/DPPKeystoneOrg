      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit used to measure ionizing radiation impact, expressed in kilobecquerels of Uranium-235 equivalent."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на въздействието на йонизиращото лъчение, изразена в килобекерели еквивалент на уран-235."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření dopadu ionizujícího záření, vyjádřená v kilobecquerelech ekvivalentu uranu-235."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle påvirkningen fra ioniserende stråling, udtrykt i kilobecquerel af uran-235-ækvivalent."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung der Auswirkung ionisierender Strahlung, ausgedrückt in Kilobecquerel Uran-235-Äquivalent."
        },
        {
          "@language": "el",
          "@value": "Μονάδα που χρησιμοποιείται για τη μέτρηση των επιπτώσεων της ιονίζουσας ακτινοβολίας, εκφρασμένη σε κιλομπεκερέλ ισοδύναμου ουρανίου-235."
        },
        {
          "@language": "es",
          "@value": "Una unidad utilizada para medir el impacto de la radiación ionizante, expresada en kilobecquerelios de equivalente de uranio-235."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse ioniseeriva kiirguse mõju mõõtmiseks, väljendatuna uraan-235 ekvivalendi kilobekrellides."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään ionisoivan säteilyn vaikutuksen mittaamiseen ilmaistuna uraani-235-vastaavina kilobecquereleinä."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer l'impact des rayonnements ionisants, exprimée en kilobecquerels d'équivalent uranium-235."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun tionchar radaíochta ianaithí a thomhas, arna shloinneadh i gkilobecquerels de choibhéis úráiniam-235."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje utjecaja ionizirajućeg zračenja, izražena u kilobekerelima ekvivalenta uranija-235."
        },
        {
          "@language": "hu",
          "@value": "Az ionizáló sugárzás hatásának mérésére szolgáló mértékegység, 235-ös urán egyenértékű kilobecquerelében kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare l'impatto delle radiazioni ionizzanti, espressa in kilobecquerel di equivalente di uranio-235."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas jonizuojančiosios spinduliuotės poveikiui matuoti, išreikštas urano-235 ekvivalento kilobekereliais."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto jonizējošā starojuma ietekmes mērīšanai, izteikta urāna-235 ekvivalenta kilobekerelos."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel l-impatt tar-radjazzjoni jonizzanti, espressa f'kilobecquerels ta' ekwivalenti għall-Uranju-235."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om de impact van ioniserende straling te meten, uitgedrukt in kilobecquerel uraan-235-equivalent."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru wpływu promieniowania jonizującego, wyrażona w kilobekerelach równoważnika uranu-235."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o impacto da radiação ionizante, expressa em quilobecqueréis de equivalente de urânio-235."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura impactul radiațiilor ionizante, exprimată în kilobecquereli de echivalent uraniu-235."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie vplyvu ionizujúceho žiarenia vyjadrená v kilobecquereloch ekvivalentu uránu-235."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje vpliva ionizirajočega sevanja, izražena v kilobekerelih ekvivalenta urana-235."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta påverkan av joniserande strålning, uttryckt i kilobecquerel uran-235-ekvivalenter."
        }
      ]
    },
