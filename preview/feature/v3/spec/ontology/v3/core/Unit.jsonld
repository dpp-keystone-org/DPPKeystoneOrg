        {
          "@language": "fr",
          "@value": "Une unité de potentiel électrique et de force électromotrice."
        },
        {
          "@language": "ga",
          "@value": "Aonad poitéinsil leictrigh agus fórsa leictreamhótaigh."
        },
        {
          "@language": "hr",
          "@value": "Jedinica električnog potencijala i elektromotorne sile."
        },
        {
          "@language": "hu",
          "@value": "Az elektromos potenciál és az elektromotoros erő mértékegysége."
        },
        {
          "@language": "it",
          "@value": "Un'unità di potenziale elettrico e forza elettromotrice."
        },
        {
          "@language": "lt",
          "@value": "Elektrinio potencialo ir elektromotorinės jėgos vienetas."
        },
        {
          "@language": "lv",
          "@value": "Elektriskā potenciāla un elektrodzinējspēka vienība."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' potenzjal elettriku u forza elettromotriċi."
