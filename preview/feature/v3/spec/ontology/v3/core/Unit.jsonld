      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "The base unit of length in the International System of Units."
        },
        {
          "@language": "bg",
          "@value": "Основната единица за дължина в Международната система единици."
        },
        {
          "@language": "cs",
          "@value": "Základní jednotka délky v Mezinárodní soustavě jednotek."
        },
        {
          "@language": "da",
          "@value": "Grundlæggende længdeenhed i det internationale enhedssystem."
        },
        {
          "@language": "de",
          "@value": "Die Basiseinheit der Länge im Internationalen Einheitensystem."
        },
        {
          "@language": "el",
          "@value": "Η βασική μονάδα μήκους στο Διεθνές Σύστημα Μονάδων."
        },
        {
          "@language": "es",
          "@value": "Unidad base de longitud en el Sistema Internacional de Unidades."
        },
        {
          "@language": "et",
          "@value": "Pikkuse põhiühik rahvusvahelises ühikute süsteemis."
        },
        {
          "@language": "fi",
          "@value": "Pituuden perusyksikkö kansainvälisessä yksikköjärjestelmässä."
        },
        {
          "@language": "fr",
          "@value": "L'unité de base de longueur dans le Système international d'unités."
        },
        {
          "@language": "ga",
          "@value": "Bun-aonad an fhaid sa Chóras Idirnáisiúnta Aonad."
        },
        {
          "@language": "hr",
          "@value": "Osnovna jedinica duljine u Međunarodnom sustavu mjernih jedinica."
        },
        {
          "@language": "hu",
          "@value": "A hosszúság alapegysége a Nemzetközi Mértékegységrendszerben."
        },
        {
          "@language": "it",
          "@value": "L'unità di base della lunghezza nel Sistema Internazionale di Unità di Misura."
        },
        {
          "@language": "lt",
          "@value": "Ilgio pagrindinis vienetas Tarptautinėje vienetų sistemoje."
        },
        {
          "@language": "lv",
          "@value": "Garuma pamatvienība Starptautiskajā mērvienību sistēmā."
        },
        {
          "@language": "mt",
          "@value": "L-unità bażi tat-tul fis-Sistema Internazzjonali tal-Unitajiet."
        },
        {
          "@language": "nl",
          "@value": "De basiseenheid van lengte in het Internationale Stelsel van Eenheden."
        },
        {
          "@language": "pl",
          "@value": "Podstawowa jednostka długości w układzie SI."
        },
        {
          "@language": "pt",
          "@value": "A unidade básica de comprimento no Sistema Internacional de Unidades."
        },
