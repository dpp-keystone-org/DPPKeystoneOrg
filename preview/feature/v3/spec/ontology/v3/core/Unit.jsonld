  "dcterms:description": [
    {
      "@language": "en",
      "@value": "Ontology defining units of measurement used across the DPP ecosystem."
    },
    {
      "@language": "bg",
      "@value": "Онтология, дефинираща мерните единици, използвани в екосистемата на DPP."
    },
    {
      "@language": "cs",
      "@value": "Ontologie definující měrné jednotky používané v ekosystému DPP."
    },
    {
      "@language": "da",
      "@value": "Ontologi, der definerer måleenheder, som anvendes i DPP-økosystemet."
    },
    {
      "@language": "de",
      "@value": "Ontologie, die Messeinheiten definiert, die im gesamten DPP-Ökosystem verwendet werden."
    },
    {
      "@language": "el",
      "@value": "Οντολογία που ορίζει μονάδες μέτρησης που χρησιμοποιούνται στο οικοσύστημα DPP."
    },
    {
      "@language": "es",
      "@value": "Ontología que define las unidades de medida utilizadas en el ecosistema DPP."
    },
    {
      "@language": "et",
      "@value": "Ontoloogia, mis määratleb DPP ökosüsteemis kasutatavaid mõõtühikuid."
    },
    {
      "@language": "fi",
      "@value": "Ontologia, joka määrittelee DPP-ekosysteemissä käytetyt mittayksiköt."
    },
    {
      "@language": "fr",
      "@value": "Ontologie définissant les unités de mesure utilisées dans l'écosystème DPP."
    },
    {
      "@language": "ga",
      "@value": "Ointeolaíocht a shainíonn aonaid tomhais a úsáidtear ar fud an éiceachórais DPP."
    },
    {
      "@language": "hr",
      "@value": "Ontologija koja definira mjerne jedinice koje se koriste u DPP ekosustavu."
    },
    {
      "@language": "hu",
      "@value": "Ontológia, amely meghatározza a DPP ökoszisztémában használt mértékegységeket."
    },
    {
      "@language": "it",
      "@value": "Ontologia che definisce le unità di misura utilizzate nell'ecosistema DPP."
    },
    {
      "@language": "lt",
      "@value": "Ontologija, apibrėžianti matavimo vienetus, naudojamus DPP ekosistemoje."
    },
    {
      "@language": "lv",
      "@value": "Ontoloģija, kas definē mērvienības, ko izmanto DPP ekosistēmā."
    },
    {
      "@language": "mt",
      "@value": "Ontoloġija li tiddefinixxi l-unitajiet ta' kejl użati fl-ekosistema tad-DPP."
    },
    {
      "@language": "nl",
      "@value": "Ontologie die meeteenheden definieert die binnen het DPP-ecosysteem worden gebruikt."
    },
    {
      "@language": "pl",
      "@value": "Ontologia definiująca jednostki miary używane w ekosystemie DPP."
    },
    {
      "@language": "pt",
      "@value": "Ontologia que define as unidades de medida utilizadas no ecossistema DPP."
    },
    {
      "@language": "ro",
      "@value": "Ontologie care definește unitățile de măsură utilizate în ecosistemul DPP."
    },
    {
      "@language": "sk",
      "@value": "Ontológia definujúca merné jednotky používané v ekosystéme DPP."
    },
    {
      "@language": "sl",
      "@value": "Ontologija, ki določa merske enote, uporabljene v ekosistemu DPP."
    },
    {
      "@language": "sv",
      "@value": "Ontologi som definierar måttenheter som används i DPP-ekosystemet."
    }
  ],
