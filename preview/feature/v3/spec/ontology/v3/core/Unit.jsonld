      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit used to measure the ozone depletion potential of various substances, expressed in terms of the equivalent amount of CFC-11."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на потенциала за изтъняване на озоновия слой на различни вещества, изразена чрез еквивалентното количество CFC-11."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření potenciálu poškozování ozonové vrstvy různých látek, vyjádřená ekvivalentním množstvím CFC-11."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle ozonnedbrydningspotentialet for forskellige stoffer, udtrykt i form af den tilsvarende mængde CFC-11."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des Ozonabbaupotenzials verschiedener Stoffe, ausgedrückt als die äquivalente Menge an FCKW-11."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα που χρησιμοποιείται για τη μέτρηση του δυναμικού καταστροφής του όζοντος διαφόρων ουσιών, εκφρασμένη ως προς την ισοδύναμη ποσότητα CFC-11."
        },
        {
          "@language": "es",
          "@value": "Una unidad utilizada para medir el potencial de agotamiento del ozono de varias sustancias, expresada en términos de la cantidad equivalente de CFC-11."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse erinevate ainete osoonikihti kahandava potentsiaali mõõtmiseks, väljendatuna CFC-11 ekvivalentses koguses."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään eri aineiden otsonikatoa aiheuttavan potentiaalin mittaamiseen ilmaistuna CFC-11:n vastaavana määränä."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer le potentiel d'appauvrissement de la couche d'ozone de diverses substances, exprimée en fonction de la quantité équivalente de CFC-11."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun acmhainn ídithe ózóin substaintí éagsúla a thomhas, arna shloinneadh i dtéarmaí na méide coibhéisí de CFC-11."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje potencijala oštećenja ozonskog omotača različitih tvari, izražena u ekvivalentnoj količini CFC-11."
        },
        {
          "@language": "hu",
          "@value": "A különböző anyagok ózonlebontó potenciáljának mérésére szolgáló mértékegység, CFC-11 egyenértékben kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare il potenziale di eliminazione dell'ozono di varie sostanze, espressa in termini di quantità equivalente di CFC-11."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas įvairių medžiagų ozono sluoksnio ardymo potencialui matuoti, išreikštas ekvivalentiniu CFC-11 kiekiu."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto dažādu vielu ozona slāņa noārdīšanas potenciāla mērīšanai, izteikta kā CFC-11 ekvivalentais daudzums."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel il-potenzjal tat-tnaqqis tal-ożonu ta' diversi sustanzi, espressa f'termini tal-ammont ekwivalenti ta' CFC-11."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om het ozonaantastend vermogen van verschillende stoffen te meten, uitgedrukt in de equivalente hoeveelheid MFK-11."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru potencjału niszczenia warstwy ozonowej różnych substancji, wyrażona jako równoważna ilość CFC-11."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o potencial de empobrecimento da camada de ozono de várias substâncias, expressa em termos da quantidade equivalente de CFC-11."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura potențialul de epuizare a stratului de ozon al diferitelor substanțe, exprimată sub forma cantității echivalente de CFC-11."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie potenciálu poškodzovania ozónovej vrstvy rôznych látok vyjadrená v ekvivalentnom množstve CFC-11."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje potenciala tanjšanja ozonskega plašča različnih snovi, izražena kot ekvivalentna količina CFC-11."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta olika ämnens ozonnedbrytande potential, uttryckt i form av motsvarande mängd CFC-11."
        }
      ]
    },
