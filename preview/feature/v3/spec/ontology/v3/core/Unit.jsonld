      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of energy equal to one kilowatt of power sustained for one hour."
        },
        {
          "@language": "bg",
          "@value": "Единица за енергия, равна на един киловат мощност, поддържана в продължение на един час."
        },
        {
          "@language": "cs",
          "@value": "Jednotka energie rovná výkonu jeden kilowatt po dobu jedné hodiny."
        },
        {
          "@language": "da",
          "@value": "En energienhed svarende til en kilowatt effekt opretholdt i en time."
        },
        {
          "@language": "de",
          "@value": "Eine Energieeinheit, die einer Leistung von einem Kilowatt über einen Zeitraum von einer Stunde entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα ενέργειας ίση με ισχύ ενός κιλοβάτ που διατηρείται για μία ώρα."
        },
        {
          "@language": "es",
          "@value": "Una unidad de energía equivalente a un kilovatio de potencia sostenida durante una hora."
        },
        {
          "@language": "et",
          "@value": "Energiaühik, mis võrdub ühe kilovatise võimsusega ühe tunni jooksul."
        },
        {
          "@language": "fi",
          "@value": "Energiayksikkö, joka vastaa yhden kilowatin tehoa yhden tunnin ajan."
        },
        {
          "@language": "fr",
          "@value": "Une unité d'énergie équivalant à un kilowatt de puissance maintenue pendant une heure."
        },
        {
          "@language": "ga",
          "@value": "Aonad fuinnimh is comhionann le cileavata cumhachta a chothaítear ar feadh uair an chloig."
        },
        {
          "@language": "hr",
          "@value": "Jedinica za energiju jednaka jednom kilovatu snage koja se održava jedan sat."
        },
        {
          "@language": "hu",
          "@value": "Egy kilowattórának megfelelő energia mértékegysége, ami egy kilowatt teljesítmény egy órán át tartó fenntartását jelenti."
        },
        {
          "@language": "it",
          "@value": "Un'unità di energia pari a un kilowatt di potenza mantenuta per un'ora."
        },
        {
          "@language": "lt",
          "@value": "Energijos vienetas, lygus vienam kilovatui galios, palaikomos vieną valandą."
        },
        {
          "@language": "lv",
          "@value": "Enerģijas vienība, kas vienāda ar vienu kilovatu jaudas vienā stundā."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' enerġija ugwali għal kilowatt wieħed ta' qawwa sostnuta għal siegħa."
        },
        {
          "@language": "nl",
          "@value": "Een energie-eenheid die gelijk is aan één kilowatt vermogen dat gedurende één uur wordt volgehouden."
        },
        {
          "@language": "pl",
          "@value": "Jednostka energii równa jednemu kilowatowi mocy utrzymywanej przez jedną godzinę."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de energia igual a um quilowatt de potência mantida durante uma hora."
        },
        {
          "@language": "ro",
          "@value": "O unitate de energie egală cu un kilowatt de putere susținută timp de o oră."
        },
        {
          "@language": "sk",
          "@value": "Jednotka energie zodpovedajúca jednému kilowattu výkonu udržiavanému po dobu jednej hodiny."
        },
        {
          "@language": "sl",
          "@value": "Enota za energijo, enaka enemu kilovatu moči, ki se ohranja eno uro."
        },
        {
          "@language": "sv",
          "@value": "En energienhet som motsvarar en kilowatt effekt som upprätthålls under en timme."
        }
      ]
    },
