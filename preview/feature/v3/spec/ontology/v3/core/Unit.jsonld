      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit measuring reciprocal temperature, defined as one divided by kelvin."
        },
        {
          "@language": "bg",
          "@value": "Единица за реципрочна температура, определена като едно, разделено на келвин."
        },
        {
          "@language": "cs",
          "@value": "Jednotka měřící reciprokou teplotu, definovaná jako jedna dělená kelvinem."
        },
        {
          "@language": "da",
          "@value": "En enhed til måling af reciprok temperatur, defineret som en divideret med kelvin."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung der reziproken Temperatur, definiert als eins geteilt durch Kelvin."
        },
        {
          "@language": "el",
          "@value": "Μονάδα μέτρησης της αντίστροφης θερμοκρασίας, οριζόμενη ως ένα διαιρούμενο με κέλβιν."
        },
        {
          "@language": "es",
          "@value": "Una unidad que mide la temperatura recíproca, definida como uno dividido por kelvin."
        },
        {
          "@language": "et",
          "@value": "Pöördtemperatuuri mõõtühik, mis on defineeritud kui üks jagatud kelviniga."
        },
        {
          "@language": "fi",
          "@value": "Käänteisen lämpötilan mittayksikkö, määriteltynä yksi jaettuna kelvinillä."
        },
        {
          "@language": "fr",
          "@value": "Une unité mesurant la température réciproque, définie comme un divisé par kelvin."
        },
        {
          "@language": "ga",
          "@value": "Aonad a thomhaiseann teocht inbhéartach, sainithe mar a haon roinnte ar cheilvin."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja mjeri recipročnu temperaturu, definirana kao jedan podijeljen s kelvinom."
        },
        {
          "@language": "hu",
          "@value": "A reciprok hőmérséklet mértékegysége, meghatározása szerint egy osztva kelvinnel."
        },
        {
          "@language": "it",
          "@value": "Un'unità che misura la temperatura reciproca, definita come uno diviso per kelvin."
        },
        {
          "@language": "lt",
          "@value": "Atvirkštinės temperatūros matavimo vienetas, apibrėžiamas kaip vienetas, padalytas iš kelvino."
        },
        {
          "@language": "lv",
          "@value": "Vienība, kas mēra apgriezto temperatūru, kas definēta kā viens, dalīts ar kelvinu."
        },
        {
          "@language": "mt",
          "@value": "Unità li tkejjel it-temperatura reċiproka, definita bħala waħda diviża b'kelvin."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die de reciproke temperatuur meet, gedefinieerd als één gedeeld door kelvin."
        },
        {
          "@language": "pl",
          "@value": "Jednostka miary temperatury odwrotnej, zdefiniowana jako jeden podzielony przez kelwin."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade que mede a temperatura recíproca, definida como um dividido por kelvin."
        },
        {
          "@language": "ro",
          "@value": "O unitate care măsoară temperatura reciprocă, definită ca unu împărțit la kelvin."
        },
        {
          "@language": "sk",
          "@value": "Jednotka merajúca prevrátenú teplotu, definovaná ako jeden delený kelvinom."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje obratne temperature, opredeljena kot ena deljeno s kelvinom."
        },
        {
          "@language": "sv",
          "@value": "En enhet som mäter reciprok temperatur, definierad som ett dividerat med kelvin."
        }
      ]
    },
