      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of pressure or stress equal to one billion pascals."
        },
        {
          "@language": "bg",
          "@value": "Единица за налягане или напрежение, равна на един милиард паскала."
        },
        {
          "@language": "cs",
          "@value": "Jednotka tlaku nebo napětí rovnající se jedné miliardě pascalů."
        },
        {
          "@language": "da",
          "@value": "En enhed for tryk eller spænding svarende til en milliard pascal."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit für Druck oder Spannung, die einer Milliarde Pascal entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα πίεσης ή τάσης ίση με ένα δισεκατομμύριο πασκάλ."
        },
        {
          "@language": "es",
          "@value": "Una unidad de presión o tensión igual a mil millones de pascales."
        },
        {
          "@language": "et",
          "@value": "Rõhu või pinge ühik, mis võrdub ühe miljardi paskaliga."
        },
        {
          "@language": "fi",
          "@value": "Paineen tai jännityksen yksikkö, joka on yhtä suuri kuin miljardi pascalia."
        },
        {
          "@language": "fr",
          "@value": "Une unité de pression ou de contrainte égale à un milliard de pascals."
        },
        {
          "@language": "ga",
          "@value": "Aonad brú nó struis atá cothrom le billiún pascal."
        },
        {
          "@language": "hr",
          "@value": "Jedinica tlaka ili naprezanja jednaka milijardi paskala."
        },
        {
          "@language": "hu",
          "@value": "Nyomás vagy mechanikai feszültség mértékegysége, amely egymilliárd pascalnak felel meg."
        },
        {
          "@language": "it",
          "@value": "Un'unità di pressione o sollecitazione pari a un miliardo di pascal."
        },
        {
          "@language": "lt",
          "@value": "Slėgio ar įtempio vienetas, lygus vienam milijardui paskalių."
        },
        {
          "@language": "lv",
          "@value": "Spiediena vai sprieguma vienība, kas vienāda ar vienu miljardu paskālu."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' pressjoni jew stress ugwali għal biljun pascal."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid van druk of spanning gelijk aan één miljard pascal."
        },
        {
          "@language": "pl",
          "@value": "Jednostka ciśnienia lub naprężenia równa jednemu miliardowi paskali."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de pressão ou tensão equivalente a mil milhões de pascais."
        },
        {
          "@language": "ro",
          "@value": "O unitate de presiune sau efort egală cu un miliard de pascali."
        },
        {
          "@language": "sk",
          "@value": "Jednotka tlaku alebo napätia rovnajúca sa jednej miliarde pascalov."
        },
        {
          "@language": "sl",
          "@value": "Enota za tlak ali napetost, enaka eni milijardi paskalov."
        },
        {
          "@language": "sv",
          "@value": "En enhet för tryck eller spänning som är lika med en miljard pascal."
        }
      ]
    },
