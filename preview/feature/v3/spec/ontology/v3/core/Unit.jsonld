      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of time equal to sixty seconds."
        },
        {
          "@language": "bg",
          "@value": "Единица за време, равна на шестдесет секунди."
        },
        {
          "@language": "cs",
          "@value": "Jednotka času rovnající se šedesáti sekundám."
        },
        {
          "@language": "da",
          "@value": "En tidsenhed svarende til tres sekunder."
        },
        {
          "@language": "de",
          "@value": "Eine Zeiteinheit, die sechzig Sekunden entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα χρόνου ίση με εξήντα δευτερόλεπτα."
        },
        {
          "@language": "es",
          "@value": "Una unidad de tiempo igual a sesenta segundos."
        },
        {
          "@language": "et",
          "@value": "Ajaühik, mis võrdub kuuekümne sekundiga."
        },
        {
          "@language": "fi",
          "@value": "Ajan yksikkö, joka on yhtä suuri kuin kuusikymmentä sekuntia."
        },
        {
          "@language": "fr",
          "@value": "Une unité de temps égale à soixante secondes."
        },
        {
          "@language": "ga",
          "@value": "Aonad ama atá cothrom le seasca soicind."
        },
        {
          "@language": "hr",
          "@value": "Jedinica vremena jednaka šezdeset sekundi."
        },
        {
          "@language": "hu",
          "@value": "Időmértékegység, amely hatvan másodpercnek felel meg."
        },
        {
          "@language": "it",
          "@value": "Un'unità di tempo pari a sessanta secondi."
        },
        {
          "@language": "lt",
          "@value": "Laiko vienetas, lygus šešiasdešimčiai sekundžių."
        },
        {
          "@language": "lv",
          "@value": "Laika vienība, kas vienāda ar sešdesmit sekundēm."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' ħin ugwali għal sittin sekonda."
        },
        {
          "@language": "nl",
          "@value": "Een tijdseenheid gelijk aan zestig seconden."
        },
        {
          "@language": "pl",
          "@value": "Jednostka czasu równa sześćdziesięciu sekundom."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de tempo equivalente a sessenta segundos."
        },
        {
          "@language": "ro",
          "@value": "O unitate de timp egală cu șaizeci de secunde."
        },
        {
          "@language": "sk",
          "@value": "Jednotka času rovnajúca sa šesťdesiatim sekundám."
        },
        {
          "@language": "sl",
          "@value": "Enota za čas, ki je enaka šestdesetim sekundam."
        },
        {
          "@language": "sv",
          "@value": "En tidsenhet som är lika med sextio sekunder."
        }
      ]
    },
