      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit used to measure acidification potential, expressed in terms of the equivalent number of moles of hydrogen ions."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на потенциала за подкиселяване, изразена чрез еквивалентния брой молове водородни йони."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření potenciálu acidifikace, vyjádřená ekvivalentním počtem molů vodíkových iontů."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle forsuringspotentiale, udtrykt i form af det tilsvarende antal mol brintioner."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des Versauerungspotenzials, ausgedrückt als die äquivalente Anzahl von Molen an Wasserstoffionen."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα που χρησιμοποιείται για τη μέτρηση του δυναμικού οξίνισης, εκφρασμένη ως προς τον ισοδύναμο αριθμό γραμμομορίων ιόντων υδρογόνου."
        },
        {
          "@language": "es",
          "@value": "Una unidad utilizada para medir el potencial de acidificación, expresada en términos del número equivalente de moles de iones de hidrógeno."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse hapestumise potentsiaali mõõtmiseks, väljendatuna vesinikuioonide moolide ekvivalentses arvus."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään happamoitumispotentiaalin mittaamiseen ilmaistuna vetyionien vastaavana moolimääränä."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer le potentiel d'acidification, exprimée en fonction du nombre équivalent de moles d'ions hydrogène."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun acmhainn aigéadaithe a thomhas, arna shloinneadh i dtéarmaí líon coibhéiseach mól de hiain hidrigine."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje potencijala zakiseljavanja, izražena u ekvivalentnom broju molova vodikovih iona."
        },
        {
          "@language": "hu",
          "@value": "A savasodási potenciál mérésére szolgáló mértékegység, a hidrogénionok móljainak egyenértékű számában kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare il potenziale di acidificazione, espressa in termini di numero equivalente di moli di ioni idrogeno."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas rūgštėjimo potencialui matuoti, išreikštas ekvivalentiniu vandenilio jonų molių skaičiumi."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto paskābināšanās potenciāla mērīšanai, izteikta kā ūdeņraža jonu molu ekvivalentais skaits."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel il-potenzjal tal-aċidifikazzjoni, espressa f'termini tan-numru ekwivalenti ta' moli ta' joni tal-idroġenu."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om het verzuringsvermogen te meten, uitgedrukt in het equivalente aantal mol waterstofionen."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru potencjału zakwaszenia, wyrażona w równoważnej liczbie moli jonów wodorowych."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o potencial de acidificação, expressa em termos do número equivalente de moles de iões de hidrogénio."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura potențialul de acidificare, exprimată în numărul echivalent de moli de ioni de hidrogen."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie potenciálu acidifikácie vyjadrená v ekvivalentnom počte mólov vodíkových iónov."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje potenciala zakisljevanja, izražena kot ekvivalentno število molov vodikovih ionov."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta försurningspotential, uttryckt i form av motsvarande antal mol vätejoner."
        }
      ]
    },
