      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of power equal to one joule per second."
        },
        {
          "@language": "bg",
          "@value": "Единица за мощност, равна на един джаул в секунда."
        },
        {
          "@language": "cs",
          "@value": "Jednotka výkonu rovnající se jednomu joulu za sekundu."
        },
        {
          "@language": "da",
          "@value": "En effektenhed svarende til en joule pr. sekund."
        },
        {
          "@language": "de",
          "@value": "Eine Leistungseinheit, die einem Joule pro Sekunde entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα ισχύος ίση με ένα τζάουλ ανά δευτερόλεπτο."
        },
        {
          "@language": "es",
          "@value": "Una unidad de potencia igual a un julio por segundo."
        },
        {
          "@language": "et",
          "@value": "Võimsuse ühik, mis võrdub ühe džauliga sekundis."
        },
        {
          "@language": "fi",
          "@value": "Tehon yksikkö, joka vastaa yhtä joulea sekunnissa."
        },
        {
          "@language": "fr",
          "@value": "Une unité de puissance égale à un joule par seconde."
        },
        {
          "@language": "ga",
          "@value": "Aonad cumhachta atá cothrom le giúl amháin in aghaidh an tsoicind."
        },
        {
          "@language": "hr",
          "@value": "Jedinica snage jednaka jednom džulu u sekundi."
        },
        {
          "@language": "hu",
          "@value": "A teljesítmény mértékegysége, amely másodpercenként egy joule-nak felel meg."
        },
        {
          "@language": "it",
          "@value": "Un'unità di potenza pari a un joule al secondo."
        },
        {
          "@language": "lt",
          "@value": "Galios vienetas, lygus vienam džauliui per sekundę."
        },
        {
          "@language": "lv",
          "@value": "Jaudas vienība, kas vienāda ar vienu džoulu sekundē."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' enerġija ugwali għal joule wieħed kull sekonda."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid van vermogen gelijk aan één joule per seconde."
        },
        {
          "@language": "pl",
          "@value": "Jednostka mocy równa jednemu dżulowi na sekundę."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de potência equivalente a um joule por segundo."
        },
        {
          "@language": "ro",
          "@value": "O unitate de putere egală cu un joul pe secundă."
        },
        {
          "@language": "sk",
          "@value": "Jednotka výkonu rovnajúca sa jednému joulu za sekundu."
        },
        {
          "@language": "sl",
          "@value": "Enota za moč, ki je enaka enemu džulu na sekundo."
        },
        {
          "@language": "sv",
          "@value": "En effektenhet som motsvarar en joule per sekund."
        }
      ]
    },
