      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit representing power per unit of energy capacity."
        },
        {
          "@language": "bg",
          "@value": "Единица, представляваща мощност на единица енергиен капацитет."
        },
        {
          "@language": "cs",
          "@value": "Jednotka představující výkon na jednotku energetické kapacity."
        },
        {
          "@language": "da",
          "@value": "En enhed, der repræsenterer effekt pr. enhed energikapacitet."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit, die die Leistung pro Einheit Energiekapazität darstellt."
        },
        {
          "@language": "el",
          "@value": "Μονάδα που αντιπροσωπεύει ισχύ ανά μονάδα ενεργειακής χωρητικότητας."
        },
        {
          "@language": "es",
          "@value": "Una unidad que representa la potencia por unidad de capacidad energética."
        },
        {
          "@language": "et",
          "@value": "Ühik, mis tähistab võimsust energiamahtuvuse ühiku kohta."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, joka edustaa tehoa energiakapasiteetin yksikköä kohti."
        },
        {
          "@language": "fr",
          "@value": "Une unité représentant la puissance par unité de capacité énergétique."
        },
        {
          "@language": "ga",
          "@value": "Aonad a léiríonn cumhacht in aghaidh an aonaid acmhainne fuinnimh."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja predstavlja snagu po jedinici energetskog kapaciteta."
        },
        {
          "@language": "hu",
          "@value": "Az egységnyi energiakapacitásra jutó teljesítményt kifejező mértékegység."
        },
        {
          "@language": "it",
          "@value": "Un'unità che rappresenta la potenza per unità di capacità energetica."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, atspindintis galią vienam energijos talpos vienetui."
        },
        {
          "@language": "lv",
          "@value": "Vienība, kas apzīmē jaudu uz enerģijas jaudas vienību."
        },
        {
          "@language": "mt",
          "@value": "Unità li tirrappreżenta l-qawwa għal kull unità ta' kapaċità tal-enerġija."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die het vermogen per eenheid energiecapaciteit vertegenwoordigt."
        },
        {
          "@language": "pl",
          "@value": "Jednostka reprezentująca moc na jednostkę pojemności energetycznej."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade que representa a potência por unidade de capacidade energética."
        },
        {
          "@language": "ro",
          "@value": "O unitate care reprezintă puterea pe unitate de capacitate energetică."
        },
        {
          "@language": "sk",
          "@value": "Jednotka predstavujúca výkon na jednotku energetickej kapacity."
        },
        {
          "@language": "sl",
          "@value": "Enota, ki predstavlja moč na enoto energetske zmogljivosti."
        },
        {
          "@language": "sv",
          "@value": "En enhet som representerar effekt per enhet energikapacitet."
        }
      ]
    },
