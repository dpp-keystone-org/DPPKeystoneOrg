      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Comparative Toxic Unit for ecosystems, expressing the estimated increase in potentially affected fraction of species."
        },
        {
          "@language": "bg",
          "@value": "Сравнителна токсична единица за екосистеми, изразяваща очакваното увеличение на потенциално засегнатата част от видовете."
        },
        {
          "@language": "cs",
          "@value": "Srovnávací toxická jednotka pro ekosystémy, vyjadřující odhadované zvýšení potenciálně zasaženého podílu druhů."
        },
        {
          "@language": "da",
          "@value": "Komparativ toksisk enhed for økosystemer, der udtrykker den estimerede stigning i den potentielt påvirkede fraktion af arter."
        },
        {
          "@language": "de",
          "@value": "Vergleichende toxische Einheit für Ökosysteme, die den geschätzten Anstieg des potenziell betroffenen Artenanteils ausdrückt."
        },
        {
          "@language": "el",
          "@value": "Συγκριτική τοξική μονάδα για οικοσυστήματα, που εκφράζει την εκτιμώμενη αύξηση του δυνητικά επηρεαζόμενου κλάσματος των ειδών."
        },
        {
          "@language": "es",
          "@value": "Unidad tóxica comparativa para ecosistemas, que expresa el aumento estimado en la fracción de especies potencialmente afectadas."
        },
        {
          "@language": "et",
          "@value": "Ökosüsteemide võrdlev toksilisuse ühik, mis väljendab potentsiaalselt mõjutatud liikide osa hinnangulist suurenemist."
        },
        {
          "@language": "fi",
          "@value": "Ekosysteemien vertaileva myrkyllisyysyksikkö, joka ilmaisee mahdollisesti altistuneen lajiosuuden arvioidun kasvun."
        },
        {
          "@language": "fr",
          "@value": "Unité toxique comparative pour les écosystèmes, exprimant l'augmentation estimée de la fraction d'espèces potentiellement affectées."
        },
        {
          "@language": "ga",
          "@value": "Aonad Tocsaineach Comparáideach d'éiceachórais, a chuireann in iúl an méadú measta ar an gcodán speiceas a d'fhéadfadh a bheith buailte."
        },
        {
          "@language": "hr",
          "@value": "Usporedna toksična jedinica za ekosustave, izražava procijenjeno povećanje potencijalno pogođenog dijela vrsta."
        },
        {
          "@language": "hu",
          "@value": "Ökoszisztémákra vonatkozó összehasonlító toxikus egység, amely a potenciálisan érintett fajok arányának becsült növekedését fejezi ki."
        },
        {
          "@language": "it",
          "@value": "Unità tossica comparativa per gli ecosistemi, che esprime l'aumento stimato della frazione di specie potenzialmente colpite."
        },
        {
          "@language": "lt",
          "@value": "Lyginamasis toksinis vienetas ekosistemoms, išreiškiantis apskaičiuotą potencialiai paveiktos rūšių dalies padidėjimą."
        },
        {
          "@language": "lv",
          "@value": "Salīdzinošā toksiskā vienība ekosistēmām, kas izsaka aplēsto potenciāli ietekmētās sugu daļas pieaugumu."
        },
        {
          "@language": "mt",
          "@value": "Unità Tossika Komparattiva għall-ekosistemi, li tesprimi ż-żieda stmata fil-frazzjoni potenzjalment affettwata ta' speċi."
        },
        {
          "@language": "nl",
          "@value": "Vergelijkende toxische eenheid voor ecosystemen, die de geschatte toename van de potentieel aangetaste fractie van soorten uitdrukt."
        },
        {
          "@language": "pl",
          "@value": "Porównawcza jednostka toksyczności dla ekosystemów, wyrażająca szacowany wzrost potencjalnie dotkniętego odsetka gatunków."
        },
        {
          "@language": "pt",
          "@value": "Unidade tóxica comparativa para ecossistemas, expressando o aumento estimado da fração de espécies potencialmente afetadas."
        },
        {
          "@language": "ro",
          "@value": "Unitate toxică comparativă pentru ecosisteme, exprimând creșterea estimată a fracției de specii potențial afectate."
        },
        {
          "@language": "sk",
          "@value": "Porovnávacia toxická jednotka pre ekosystémy, vyjadrujúca odhadované zvýšenie potenciálne zasiahnutej časti druhov."
        },
        {
          "@language": "sl",
          "@value": "Primerjalna toksična enota za ekosisteme, ki izraža ocenjeno povečanje potencialno prizadetega deleža vrst."
        },
        {
          "@language": "sv",
          "@value": "Jämförande toxisk enhet för ekosystem, som uttrycker den uppskattade ökningen av potentiellt drabbade andel arter."
        }
      ]
    },
