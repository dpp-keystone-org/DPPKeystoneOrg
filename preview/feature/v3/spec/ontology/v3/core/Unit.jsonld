      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "Comparative Toxic Unit for humans, expressing the estimated increase in morbidity in the total human population."
        },
        {
          "@language": "bg",
          "@value": "Сравнителна токсична единица за хората, изразяваща очакваното увеличение на заболеваемостта в общото население."
        },
        {
          "@language": "cs",
          "@value": "Srovnávací toxická jednotka pro lidskou toxicitu, vyjadřující odhadované zvýšení nemocnosti v celé lidské populaci."
        },
        {
          "@language": "da",
          "@value": "Komparativ toksisk enhed for mennesker, der udtrykker den estimerede stigning i sygelighed i den samlede humane befolkning."
        },
        {
          "@language": "de",
          "@value": "Vergleichende toxische Einheit für den Menschen, die den geschätzten Anstieg der Morbidität in der gesamten menschlichen Bevölkerung ausdrückt."
        },
        {
          "@language": "el",
          "@value": "Συγκριτική τοξική μονάδα για ανθρώπους, που εκφράζει την εκτιμώμενη αύξηση της νοσηρότητας στο σύνολο του ανθρώπινου πληθυσμού."
        },
        {
          "@language": "es",
          "@value": "Unidad tóxica comparativa para la toxicidad humana, que expresa el aumento estimado de la morbilidad en la población humana total."
        },
        {
          "@language": "et",
          "@value": "Võrdlev toksilisuse ühik inimestele, mis väljendab hinnangulist haigestumuse kasvu kogu inimpopulatsioonis."
        },
        {
          "@language": "fi",
          "@value": "Vertaileva myrkyllisyysyksikkö ihmisille, joka ilmaisee arvioidun sairastuvuuden kasvun koko ihmisväestössä."
        },
        {
          "@language": "fr",
          "@value": "Unité toxique comparative pour la toxicité humaine, exprimant l'augmentation estimée de la morbidité dans la population humaine totale."
        },
        {
          "@language": "ga",
          "@value": "Aonad Tocsaineach Comparáideach do dhaoine, a chuireann in iúl an méadú measta ar ghalracht sa daonra daonna iomlán."
        },
        {
          "@language": "hr",
          "@value": "Usporedna toksična jedinica za ljudsku toksičnost, izražava procijenjeno povećanje morbiditeta u ukupnoj ljudskoj populaciji."
        },
        {
          "@language": "hu",
          "@value": "Emberi toxicitásra vonatkozó összehasonlító toxikus egység, amely a morbiditás becsült növekedését fejezi ki a teljes emberi populációban."
        },
        {
          "@language": "it",
          "@value": "Unità tossica comparativa per la tossicità umana, che esprime l'aumento stimato della morbilità nell'intera popolazione umana."
        },
        {
          "@language": "lt",
          "@value": "Lyginamasis toksinis vienetas žmonėms, išreiškiantis apskaičiuotą sergamumo padidėjimą visoje žmonių populiacijoje."
        },
        {
          "@language": "lv",
          "@value": "Salīdzinošā toksiskā vienība cilvēkiem, kas izsaka aplēsto saslimstības pieaugumu visā cilvēku populācijā."
        },
        {
          "@language": "mt",
          "@value": "Unità Tossika Komparattiva għat-tossiċità umana, li tesprimi ż-żieda stmata fil-morbidità fil-popolazzjoni umana totali."
        },
        {
          "@language": "nl",
          "@value": "Vergelijkende toxische eenheid voor menselijke toxiciteit, die de geschatte toename van morbiditeit in de totale menselijke bevolking uitdrukt."
        },
        {
          "@language": "pl",
          "@value": "Porównawcza jednostka toksyczności dla ludzi, wyrażająca szacowany wzrost zachorowalności w całej populacji ludzkiej."
        },
        {
          "@language": "pt",
          "@value": "Unidade tóxica comparativa para a toxicidade humana, que expressa o aumento estimado da morbidade na população humana total."
        },
        {
          "@language": "ro",
          "@value": "Unitate toxică comparativă pentru toxicitatea umană, exprimând creșterea estimată a morbidității în populația umană totală."
        },
        {
          "@language": "sk",
          "@value": "Porovnávacia toxická jednotka pre ľudskú toxicitu, vyjadrujúca odhadované zvýšenie chorobnosti v celej ľudskej populácii."
        },
        {
          "@language": "sl",
          "@value": "Primerjalna toksična enota za toksičnost za ljudi, ki izraža ocenjeno povečanje obolevnosti v celotni človeški populaciji."
        },
        {
          "@language": "sv",
          "@value": "Jämförande toxisk enhet för mänsklig toxicitet, som uttrycker den uppskattade ökningen av sjuklighet i hela den mänskliga befolkningen."
        }
      ]
    },
