      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit used to measure water absorption coefficient, expressed in kilograms per square meter per square root of hour."
        },
        {
          "@language": "bg",
          "@value": "Единица, използвана за измерване на коефициента на водопоглъщане, изразена в килограми на квадратен метър на корен квадратен от час."
        },
        {
          "@language": "cs",
          "@value": "Jednotka používaná k měření součinitele absorpce vody, vyjádřená v kilogramech na metr čtvereční za druhou odmocninu hodiny."
        },
        {
          "@language": "da",
          "@value": "En enhed brugt til at måle vandabsorptionskoefficienten, udtrykt i kilogram pr. kvadratmeter pr. kvadratrod af en time."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit zur Messung des Wasseraufnahmekoeffizienten, ausgedrückt in Kilogramm pro Quadratmeter und Quadratwurzel der Stunde."
        },
        {
          "@language": "el",
          "@value": "Μονάδα που χρησιμοποιείται για τη μέτρηση του συντελεστή απορρόφησης νερού, εκφρασμένη σε χιλιόγραμμα ανά τετραγωνικό μέτρο ανά τετραγωνική ρίζα ώρας."
        },
        {
          "@language": "es",
          "@value": "Unidad utilizada para medir el coeficiente de absorción de agua, expresada en kilogramos por metro cuadrado por raíz cuadrada de hora."
        },
        {
          "@language": "et",
          "@value": "Ühik, mida kasutatakse veeimavusteguri mõõtmiseks, väljendatuna kilogrammides ruutmeetri ja tunni ruutjuure kohta."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, jota käytetään vedenimeytymiskertoimen mittaamiseen ilmaistuna kilogrammoina neliömetriä ja tunnin neliöjuurta kohti."
        },
        {
          "@language": "fr",
          "@value": "Une unité utilisée pour mesurer le coefficient d'absorption d'eau, exprimée en kilogrammes par mètre carré par racine carrée d'heure."
        },
        {
          "@language": "ga",
          "@value": "Aonad a úsáidtear chun an chomhéifeacht ionsúite uisce a thomhas, arna shloinneadh i gcileagraim in aghaidh an mhéadair chearnaigh in aghaidh an fhréamh chearnaigh uaire."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja se koristi za mjerenje koeficijenta upijanja vode, izražena u kilogramima po kvadratnom metru po kvadratnom korijenu sata."
        },
        {
          "@language": "hu",
          "@value": "A vízfelvételi együttható mérésére szolgáló mértékegység, kilogramm per négyzetméter per óra négyzetgyökében kifejezve."
        },
        {
          "@language": "it",
          "@value": "Un'unità utilizzata per misurare il coefficiente di assorbimento dell'acqua, espressa in chilogrammi per metro quadrato per radice quadrata di ora."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, naudojamas vandens įgerties koeficientui matuoti, išreikštas kilogramais kvadratiniam metrui, tenkančiais kvadratinei valandos šakniai."
        },
        {
          "@language": "lv",
          "@value": "Vienība, ko izmanto ūdens absorbcijas koeficienta mērīšanai, izteikta kilogramos uz kvadrātmetru stundas kvadrātsaknē."
        },
        {
          "@language": "mt",
          "@value": "Unità użata biex jitkejjel il-koeffiċjent tal-assorbiment tal-ilma, espressa f'kilogrammi għal kull metru kwadru għal kull għerq kwadru ta' siegħa."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid die wordt gebruikt om de waterabsorptiecoëfficiënt te meten, uitgedrukt in kilogram per vierkante meter per vierkantswortel van een uur."
        },
        {
          "@language": "pl",
          "@value": "Jednostka używana do pomiaru współczynnika wchłaniania wody, wyrażona w kilogramach na metr kwadratowy na pierwiastek kwadratowy z godziny."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade utilizada para medir o coeficiente de absorção de água, expressa em quilogramas por metro quadrado por raiz quadrada de hora."
        },
        {
          "@language": "ro",
          "@value": "O unitate utilizată pentru a măsura coeficientul de absorbție a apei, exprimată în kilograme pe metru pătrat pe rădăcina pătrată a orei."
        },
        {
          "@language": "sk",
          "@value": "Jednotka používaná na meranie súčiniteľa absorpcie vody vyjadrená v kilogramoch na štvorcový meter za druhú odmocninu hodiny."
        },
        {
          "@language": "sl",
          "@value": "Enota za merjenje koeficienta absorpcije vode, izražena v kilogramih na kvadratni meter na kvadratni koren ure."
        },
        {
          "@language": "sv",
          "@value": "En enhet som används för att mäta vattenabsorptionskoefficienten, uttryckt i kilogram per kvadratmeter per kvadratrot ur en timme."
        }
      ]
    },
