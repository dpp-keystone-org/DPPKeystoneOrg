      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A dimensionless quantity or a quantity for which the unit of measurement is not applicable."
        },
        {
          "@language": "bg",
          "@value": "Безразмерна величина или величина, за която мерната единица е неприложима."
        },
        {
          "@language": "cs",
          "@value": "Bezrozměrná veličina nebo veličina, pro kterou není měrná jednotka použitelná."
        },
        {
          "@language": "da",
          "@value": "En dimensionsløs størrelse eller en størrelse, for hvilken måleenheden ikke er relevant."
        },
        {
          "@language": "de",
          "@value": "Eine dimensionslose Größe oder eine Größe, für die die Maßeinheit nicht anwendbar ist."
        },
        {
          "@language": "el",
          "@value": "Μια αδιάστατη ποσότητα ή μια ποσότητα για την οποία η μονάδα μέτρησης δεν έχει εφαρμογή."
        },
        {
          "@language": "es",
          "@value": "Magnitud adimensional o magnitud para la que no se aplica la unidad de medida."
        },
        {
          "@language": "et",
          "@value": "Dimensioonita suurus või suurus, mille puhul mõõtühik ei ole asjakohane."
        },
        {
          "@language": "fi",
          "@value": "Dimensioton suure tai suure, johon mittayksikköä ei voida soveltaa."
        },
        {
          "@language": "fr",
          "@value": "Grandeur sans dimension ou grandeur pour laquelle l'unité de mesure n'est pas applicable."
        },
        {
          "@language": "ga",
          "@value": "Cainníocht gan toise nó cainníocht nach mbaineann aonad tomhais léi."
        },
        {
          "@language": "hr",
          "@value": "Bezdimenzionalna veličina ili veličina za koju se mjerna jedinica ne primjenjuje."
        },
        {
          "@language": "hu",
          "@value": "Dimenzió nélküli mennyiség, vagy olyan mennyiség, amelyre a mértékegység nem alkalmazható."
        },
        {
          "@language": "it",
          "@value": "Una grandezza adimensionale o una grandezza per la quale l'unità di misura non è applicabile."
        },
        {
          "@language": "lt",
          "@value": "Bedimensinis dydis arba dydis, kuriam matavimo vienetas netaikomas."
        },
        {
          "@language": "lv",
          "@value": "Bezdimensiju lielums vai lielums, kuram mērvienība nav piemērojama."
        },
        {
          "@language": "mt",
          "@value": "Kwantità mingħajr dimensjoni jew kwantità li għaliha l-unità tal-kejl mhijiex applikabbli."
        },
        {
          "@language": "nl",
          "@value": "Een dimensieloze grootheid of een grootheid waarvoor de meeteenheid niet van toepassing is."
        },
        {
          "@language": "pl",
          "@value": "Wielkość bezwymiarowa lub wielkość, dla której jednostka miary nie ma zastosowania."
        },
        {
          "@language": "pt",
          "@value": "Uma grandeza adimensional ou uma grandeza para a qual a unidade de medida não é aplicável."
        },
        {
          "@language": "ro",
          "@value": "O mărime adimensională sau o mărime pentru care unitatea de măsură nu este aplicabilă."
        },
        {
          "@language": "sk",
          "@value": "Bezrozmerná veličina alebo veličina, pre ktorú nie je merná jednotka uplatniteľná."
        },
        {
          "@language": "sl",
          "@value": "Brezdimenzijska količina ali količina, za katero merska enota ni uporabna."
        },
        {
          "@language": "sv",
          "@value": "En dimensionslös storhet eller en storhet för vilken måttenheten inte är tillämplig."
        }
      ]
