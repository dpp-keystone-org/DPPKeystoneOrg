      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A ratio or value expressed as a fraction of one hundred."
        },
        {
          "@language": "bg",
          "@value": "Съотношение или стойност, изразена като дроб от сто."
        },
        {
          "@language": "cs",
          "@value": "Poměr nebo hodnota vyjádřená jako zlomek ze sta."
        },
        {
          "@language": "da",
          "@value": "Et forhold eller en værdi udtrykt som en brøkdel af hundrede."
        },
        {
          "@language": "de",
          "@value": "Ein Verhältnis oder Wert, ausgedrückt als Bruchteil von hundert."
        },
        {
          "@language": "el",
          "@value": "Αναλογία ή τιμή που εκφράζεται ως κλάσμα του εκατό."
        },
        {
          "@language": "es",
          "@value": "Una relación o valor expresado como una fracción de cien."
        },
        {
          "@language": "et",
          "@value": "Suhe või väärtus, mis on väljendatud murdosana sajast."
        },
        {
          "@language": "fi",
          "@value": "Suhde tai arvo, joka on ilmaistu sadasosan murto-osana."
        },
        {
          "@language": "fr",
          "@value": "Un rapport ou une valeur exprimée comme une fraction de cent."
        },
        {
          "@language": "ga",
          "@value": "Cóimheas nó luach a shloinntear mar chodán de chéad."
        },
        {
          "@language": "hr",
          "@value": "Omjer ili vrijednost izražena kao razlomak od sto."
        },
        {
          "@language": "hu",
          "@value": "Században kifejezett arány vagy érték."
        },
        {
          "@language": "it",
          "@value": "Un rapporto o un valore espresso come frazione di cento."
        },
        {
          "@language": "lt",
          "@value": "Santykis arba vertė, išreikšta šimtąja dalimi."
        },
        {
          "@language": "lv",
          "@value": "Attiecība vai vērtība, kas izteikta kā simtdaļa."
        },
        {
          "@language": "mt",
          "@value": "Proporzjon jew valur espress bħala frazzjoni ta 'mija."
        },
        {
          "@language": "nl",
          "@value": "Een verhouding of waarde uitgedrukt als een fractie van honderd."
        },
        {
          "@language": "pl",
          "@value": "Stosunek lub wartość wyrażona jako ułamek stu."
        },
        {
          "@language": "pt",
          "@value": "Uma proporção ou valor expresso como uma fração de cem."
        },
        {
          "@language": "ro",
          "@value": "Un raport sau o valoare exprimată ca fracție de o sută."
        },
        {
          "@language": "sk",
          "@value": "Pomer alebo hodnota vyjadrená ako zlomok zo sto."
        },
        {
          "@language": "sl",
          "@value": "Razmerje ali vrednost, izražena kot ulomek stotice."
        },
        {
          "@language": "sv",
          "@value": "Ett förhållande eller värde uttryckt som en bråkdel av hundra."
        }
      ]
    },
    {
      "@id": "dppk-unit:PercentPerMonth",
