      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of time equivalent to one year."
        },
        {
          "@language": "bg",
          "@value": "Единица за време, еквивалентна на една година."
        },
        {
          "@language": "cs",
          "@value": "Jednotka času ekvivalentní jednomu roku."
        },
        {
          "@language": "da",
          "@value": "En tidsenhed svarende til et år."
        },
        {
          "@language": "de",
          "@value": "Eine Zeiteinheit, die einem Jahr entspricht."
        },
        {
          "@language": "el",
          "@value": "Μονάδα χρόνου ισοδύναμη με ένα έτος."
        },
        {
          "@language": "es",
          "@value": "Una unidad de tiempo equivalente a un año."
        },
        {
          "@language": "et",
          "@value": "Ajaühik, mis on samaväärne ühe aastaga."
        },
        {
          "@language": "fi",
          "@value": "Ajan yksikkö, joka vastaa yhtä vuotta."
        },
        {
          "@language": "fr",
          "@value": "Une unité de temps équivalente à un an."
        },
        {
          "@language": "ga",
          "@value": "Aonad ama atá cothrom le bliain amháin."
        },
        {
          "@language": "hr",
          "@value": "Jedinica vremena ekvivalentna jednoj godini."
        },
        {
          "@language": "hu",
          "@value": "Egy évnek megfelelő időmértékegység."
        },
        {
          "@language": "it",
          "@value": "Un'unità di tempo equivalente a un anno."
        },
        {
          "@language": "lt",
          "@value": "Laiko vienetas, lygus vieniems metams."
        },
        {
          "@language": "lv",
          "@value": "Laika vienība, kas ekvivalenta vienam gadam."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' ħin ekwivalenti għal sena waħda."
        },
        {
          "@language": "nl",
          "@value": "Een tijdseenheid gelijk aan één jaar."
        },
        {
          "@language": "pl",
          "@value": "Jednostka czasu równa jednemu rokowi."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de tempo equivalente a um ano."
        },
        {
          "@language": "ro",
          "@value": "O unitate de timp echivalentă cu un an."
        },
        {
          "@language": "sk",
          "@value": "Jednotka času ekvivalentná jednému roku."
        },
        {
          "@language": "sl",
          "@value": "Enota za čas, ki ustreza enemu letu."
        },
        {
          "@language": "sv",
          "@value": "En tidsenhet motsvarande ett år."
        }
      ]
    },
