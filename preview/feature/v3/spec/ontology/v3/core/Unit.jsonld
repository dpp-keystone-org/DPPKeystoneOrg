      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "The base unit of mass in the International System of Units."
        },
        {
          "@language": "bg",
          "@value": "Основната единица за маса в Международната система от единици."
        },
        {
          "@language": "cs",
          "@value": "Základní jednotka hmotnosti v Mezinárodní soustavě jednotek."
        },
        {
          "@language": "da",
          "@value": "Basisenheden for masse i det internationale enhedssystem."
        },
        {
          "@language": "de",
          "@value": "Die Basiseinheit der Masse im Internationalen Einheitensystem."
        },
        {
          "@language": "el",
          "@value": "Η βασική μονάδα μάζας στο Διεθνές Σύστημα Μονάδων."
        },
        {
          "@language": "es",
          "@value": "La unidad básica de masa en el Sistema Internacional de Unidades."
        },
        {
          "@language": "et",
          "@value": "Massi põhiühik rahvusvahelises mõõtühikute süsteemis."
        },
        {
          "@language": "fi",
          "@value": "Massan perusyksikkö kansainvälisessä yksikköjärjestelmässä."
        },
        {
          "@language": "fr",
          "@value": "L'unité de base de masse dans le Système international d'unités."
        },
        {
          "@language": "ga",
          "@value": "An bunaonad maise sa Chóras Idirnáisiúnta Aonad."
        },
        {
          "@language": "hr",
          "@value": "Osnovna jedinica mase u Međunarodnom sustavu mjernih jedinica."
        },
        {
          "@language": "hu",
          "@value": "A tömeg alapegysége a Nemzetközi Mértékegységrendszerben."
        },
        {
          "@language": "it",
          "@value": "L'unità di base della massa nel Sistema Internazionale di Unità."
        },
        {
          "@language": "lt",
          "@value": "Masės pagrindinis vienetas Tarptautinėje vienetų sistemoje."
        },
        {
          "@language": "lv",
          "@value": "Misas pamatvienība Starptautiskajā mērvienību sistēmā."
        },
        {
          "@language": "mt",
          "@value": "L-unità bażika tal-massa fis-Sistema Internazzjonali tal-Unitajiet."
        },
        {
          "@language": "nl",
          "@value": "De basiseenheid van massa in het Internationale Systeem van Eenheden."
        },
        {
          "@language": "pl",
          "@value": "Podstawowa jednostka masy w Międzynarodowym Układzie Jednostek Miar."
        },
        {
          "@language": "pt",
          "@value": "A unidade básica de massa no Sistema Internacional de Unidades."
        },
        {
          "@language": "ro",
          "@value": "Unitatea de bază a masei în Sistemul Internațional de Unități."
        },
        {
          "@language": "sk",
          "@value": "Základná jednotka hmotnosti v Medzinárodnej sústave jednotiek."
        },
        {
          "@language": "sl",
          "@value": "Osnovna enota za maso v mednarodnem sistemu enot."
        },
        {
          "@language": "sv",
          "@value": "Basenheten för massa i det internationella måttenhetssystemet."
