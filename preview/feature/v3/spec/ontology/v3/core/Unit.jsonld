      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of electrical potential and electromotive force."
        },
        {
          "@language": "bg",
          "@value": "Единица за електрически потенциал и електродвижещо напрежение."
        },
        {
          "@language": "cs",
          "@value": "Jednotka elektrického potenciálu a elektromotorického napětí."
        },
        {
          "@language": "da",
          "@value": "En enhed for elektrisk potential og elektromotorisk kraft."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit für elektrisches Potenzial und elektromotorische Kraft."
        },
        {
          "@language": "el",
          "@value": "Μονάδα ηλεκτρικού δυναμικού και ηλεκτρεγερτικής δύναμης."
        },
        {
          "@language": "es",
          "@value": "Una unidad de potencial eléctrico y fuerza electromotriz."
        },
        {
          "@language": "et",
          "@value": "Elektrilise potentsiaali ja elektromotoorjõu ühik."
        },
        {
          "@language": "fi",
          "@value": "Sähköisen potentiaalin ja sähkömotorisen voiman yksikkö."
