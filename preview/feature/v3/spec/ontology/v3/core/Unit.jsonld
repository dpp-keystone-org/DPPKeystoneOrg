      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of measurement representing a score or points per kilogram of a substance."
        },
        {
          "@language": "bg",
          "@value": "Мерна единица, представляваща резултат или точки на килограм от дадено вещество."
        },
        {
          "@language": "cs",
          "@value": "Měrná jednotka představující skóre nebo body na kilogram látky."
        },
        {
          "@language": "da",
          "@value": "En måleenhed, der repræsenterer en score eller point pr. kilogram af et stof."
        },
        {
          "@language": "de",
          "@value": "Eine Maßeinheit, die eine Punktzahl oder Punkte pro Kilogramm eines Stoffes darstellt."
        },
        {
          "@language": "el",
          "@value": "Μονάδα μέτρησης που αντιπροσωπεύει βαθμολογία ή πόντους ανά χιλιόγραμμο ουσίας."
        },
        {
          "@language": "es",
          "@value": "Una unidad de medida que representa una puntuación o puntos por kilogramo de una sustancia."
        },
        {
          "@language": "et",
          "@value": "Mõõtühik, mis tähistab skoori või punkte aine kilogrammi kohta."
        },
        {
          "@language": "fi",
          "@value": "Mittayksikkö, joka edustaa pistemäärää tai pisteitä aineen kilogrammaa kohti."
        },
        {
          "@language": "fr",
          "@value": "Une unité de mesure représentant un score ou des points par kilogramme d'une substance."
        },
        {
          "@language": "ga",
          "@value": "Aonad tomhais a léiríonn scór nó pointí in aghaidh gach cileagraim de shubstaint."
        },
        {
          "@language": "hr",
          "@value": "Mjerna jedinica koja predstavlja rezultat ili bodove po kilogramu tvari."
        },
        {
          "@language": "hu",
          "@value": "Egy anyag kilogrammonkénti pontszámát vagy pontjait kifejező mértékegység."
        },
        {
          "@language": "it",
          "@value": "Un'unità di misura che rappresenta un punteggio o punti per chilogrammo di una sostanza."
        },
        {
          "@language": "lt",
          "@value": "Matavimo vienetas, atspindintis medžiagos kilogramo įvertinimą ar taškus."
        },
        {
          "@language": "lv",
          "@value": "Mērvienība, kas apzīmē rezultātu vai punktus par vielas kilogramu."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' kejl li tirrappreżenta punteġġ jew punti għal kull kilogramma ta' sustanza."
        },
        {
          "@language": "nl",
          "@value": "Een meeteenheid die een score of punten per kilogram van een stof vertegenwoordigt."
        },
        {
          "@language": "pl",
          "@value": "Jednostka miary reprezentująca wynik lub punkty na kilogram substancji."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de medida que representa uma pontuação ou pontos por quilograma de uma substância."
        },
        {
          "@language": "ro",
          "@value": "O unitate de măsură care reprezintă un scor sau puncte pe kilogram de substanță."
        },
        {
          "@language": "sk",
          "@value": "Merná jednotka predstavujúca skóre alebo body na kilogram látky."
        },
        {
          "@language": "sl",
          "@value": "Merska enota, ki predstavlja rezultat ali točke na kilogram snovi."
        },
        {
          "@language": "sv",
          "@value": "En måttenhet som representerar en poäng eller poäng per kilogram av ett ämne."
        }
      ]
    },
