        {
          "@language": "en",
          "@value": "A unit representing a categorical classification or grading."
        },
        {
          "@language": "bg",
          "@value": "Единица, представляваща категорийна класификация или степенуване."
        },
        {
          "@language": "cs",
          "@value": "Jednotka představující kategorickou klasifikaci nebo hodnocení."
        },
        {
          "@language": "da",
          "@value": "En enhed, der repræsenterer en kategorisk klassifikation eller graduering."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit, die eine kategoriale Klassifizierung oder Einstufung darstellt."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα που αντιπροσωπεύει μια κατηγορική ταξινόμηση ή βαθμολόγηση."
        },
        {
          "@language": "es",
          "@value": "Una unidad que representa una clasificación o gradación categórica."
        },
        {
          "@language": "et",
          "@value": "Ühik, mis esindab kategooriat või klassifikatsiooni."
        },
        {
          "@language": "fi",
          "@value": "Yksikkö, joka edustaa luokittelua tai arviointia."
        },
        {
          "@language": "fr",
          "@value": "Une unité représentant une classification ou une gradation catégorique."
        },
        {
          "@language": "ga",
          "@value": "Aonad a léiríonn aicmiú catagóireach nó grádú."
        },
        {
          "@language": "hr",
          "@value": "Jedinica koja predstavlja kategoričku klasifikaciju ili ocjenjivanje."
        },
        {
          "@language": "hu",
          "@value": "Kategorikus osztályozást vagy besorolást képviselő egység."
        },
        {
          "@language": "it",
          "@value": "Un'unità che rappresenta una classificazione o una gradazione categorica."
        },
        {
          "@language": "lt",
          "@value": "Vienetas, atstovaujantis kategoriniam klasifikavimui ar vertinimui."
