      "rdfs:comment": [
        {
          "@language": "en",
          "@value": "A unit of specific energy measuring joules per gram."
        },
        {
          "@language": "bg",
          "@value": "Единица за специфична енергия, измерваща джаули на грам."
        },
        {
          "@language": "cs",
          "@value": "Jednotka měrné energie měřící jouly na gram."
        },
        {
          "@language": "da",
          "@value": "En enhed for specifik energi, der måler joule pr. gram."
        },
        {
          "@language": "de",
          "@value": "Eine Einheit der spezifischen Energie, die Joule pro Gramm misst."
        },
        {
          "@language": "el",
          "@value": "Μια μονάδα ειδικής ενέργειας που μετρά τζάουλ ανά γραμμάριο."
        },
        {
          "@language": "es",
          "@value": "Una unidad de energía específica que mide julios por gramo."
        },
        {
          "@language": "et",
          "@value": "Erienergia ühik, mis mõõdab džaoule grammi kohta."
        },
        {
          "@language": "fi",
          "@value": "Ominaisenergian yksikkö, joka mittaa jouleja grammaa kohti."
        },
        {
          "@language": "fr",
          "@value": "Une unité d'énergie spécifique mesurant les joules par gramme."
        },
        {
          "@language": "ga",
          "@value": "Aonad fuinnimh shonraigh a thomhaiseann giúil in aghaidh an ghraim."
        },
        {
          "@language": "hr",
          "@value": "Jedinica specifične energije koja mjeri džule po gramu."
        },
        {
          "@language": "hu",
          "@value": "Fajlagos energia mértékegysége, amely joule per grammot mér."
        },
        {
          "@language": "it",
          "@value": "Un'unità di energia specifica che misura i joule per grammo."
        },
        {
          "@language": "lt",
          "@value": "Savitosios energijos vienetas, matuojantis džiaulius grame."
        },
        {
          "@language": "lv",
          "@value": "Īpatnējās enerģijas mērvienība, kas mēra džoulus uz gramu."
        },
        {
          "@language": "mt",
          "@value": "Unità ta' enerġija speċifika li tkejjel joules għal kull gramma."
        },
        {
          "@language": "nl",
          "@value": "Een eenheid van specifieke energie die joules per gram meet."
        },
        {
          "@language": "pl",
          "@value": "Jednostka energii właściwej mierzona w dżulach na gram."
        },
        {
          "@language": "pt",
          "@value": "Uma unidade de energia específica que mede joules por grama."
        },
        {
          "@language": "ro",
          "@value": "O unitate de energie specifică care măsoară jouli pe gram."
        },
        {
          "@language": "sk",
          "@value": "Jednotka mernej energie merajúca jouly na gram."
        },
        {
          "@language": "sl",
          "@value": "Enota specifične energije, ki meri džule na gram."
        },
        {
          "@language": "sv",
          "@value": "En enhet för specifik energi som mäter joule per gram."
        }
