        },
        {
          "@language": "bg",
          "@value": "Процент на месец"
        },
        {
          "@language": "cs",
          "@value": "Procento za měsíc"
        },
        {
          "@language": "da",
          "@value": "Procent pr. måned"
        },
        {
          "@language": "de",
          "@value": "Prozent pro Monat"
        },
        {
          "@language": "el",
