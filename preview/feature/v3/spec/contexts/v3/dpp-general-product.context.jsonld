{
  "@context": {
    "dppk": "https://dpp-keystone.org/spec/v3/terms#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "productName": {
      "@id": "dppk:productName",
      "@container": "@language"
    },
    "description": "dppk:description",
    "gtin": "dppk:gtin",
    "brand": "dppk:brand",
    "model": "dppk:model",
    "color": "dppk:color",
    "countryOfOrigin": "dppk:countryOfOrigin",
    "netWeight": {
      "@id": "dppk:netWeight",
      "@type": "KgWeightLiteral"
    },
    "grossWeight": "dppk:grossWeight",
    "length": {
      "@id": "dppk:length",
      "@type": "MetersLengthLiteral"
    },
    "width": {
      "@id": "dppk:width",
      "@type": "MetersLengthLiteral"
    },
    "height": {
      "@id": "dppk:height",
      "@type": "MetersLengthLiteral"
    },
    "depth": {
      "@id": "dppk:depth",
      "@type": "MetersLengthLiteral"
    },
    "image": {
      "@id": "dppk:image",
      "@container": "@set"
    },
    "additionalCertifications": {
      "@id": "dppk:additionalCertification",
      "@container": "@set",
      "@context": {
        "name": "dppk:certificationName",
        "identifier": "dppk:certificationId",
        "url": {
          "@id": "dppk:certificationUrl",
          "@type": "xsd:anyURI"
        },
        "certificationBodyName": "dppk:certificationBodyName",
        "certificationBodyId": "dppk:certificationBodyId",
        "certificationStartDate": {
          "@id": "dppk:certificationStartDate",
          "@type": "xsd:date"
        },
        "certificationEndDate": {
          "@id": "dppk:certificationEndDate",
          "@type": "xsd:date"
        },
        "certificationBodyRole": "dppk:certificationBodyRole",
        "document": "dppk:documents"
      }
    },
    "KgWeightLiteral": "dppk:KgWeightLiteral",
    "MetersLengthLiteral": "dppk:MetersLengthLiteral",
    "RelatedResource": "dppk:RelatedResource",
    "resourceTitle": "dppk:resourceTitle",
    "contentType": "dppk:contentType",
    "language": "dppk:language",
    "url": {
      "@id": "dppk:url",
      "@type": "xsd:anyURI"
    }
  }
}
